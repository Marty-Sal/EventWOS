# ─────────────────────────────────────────────────────────────────────────────
# EventWOS — Environment Variables Reference
# Copy this to .env for local docker-compose development.
# For Railway: set each key via `railway variables set KEY=value --service api`
# NEVER commit a filled-in .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Railway injects ${{Postgres.DATABASE_URL}} automatically.
# For local docker-compose, use the value below:
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=eventwos;Username=eventwos;Password=eventwos_secret

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway injects ${{Redis.REDIS_URL}} automatically.
ConnectionStrings__Redis=localhost:6379,abortConnect=false

# ── JWT (RSA256) ──────────────────────────────────────────────────────────────
# Generate with: ./scripts/generate-rsa-keys.sh
# Then paste the Base64 output here.
Jwt__Issuer=eventwos-api
Jwt__Audience=eventwos-client
Jwt__AccessTokenExpiryMinutes=60
Jwt__PrivateKey=REPLACE_WITH_BASE64_RSA_PRIVATE_KEY
Jwt__PublicKey=REPLACE_WITH_BASE64_RSA_PUBLIC_KEY

# ── OTP ───────────────────────────────────────────────────────────────────────
# Set to true in development to bypass real SMS — OTP will be logged to console.
Otp__IsDevelopmentMode=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Blazor app's public URL (Railway auto-injects via railway.toml).
AllowedOrigins__0=https://blazor.up.railway.app

# ── Blazor ────────────────────────────────────────────────────────────────────
# Set to the Railway API service public domain.
ApiBaseUrl=https://api.up.railway.app
