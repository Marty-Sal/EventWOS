{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=eventwos;Username=eventwos;Password=eventwos_secret;Include Error Detail=true",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer": "eventwos-api",
    "Audience": "eventwos-client",
    "PrivateKey": "REPLACE_WITH_BASE64_RSA_PRIVATE_KEY",
    "PublicKey": "REPLACE_WITH_BASE64_RSA_PUBLIC_KEY",
    "AccessTokenExpiryMinutes": 60
  },
  "Otp": {
    "IsDevelopmentMode": true
  },
  "AllowedOrigins": [
    "https://blazor-web-production.up.railway.app",
    "https://eventwos.yourdomain.com",
    "http://localhost:5173",
    "http://localhost:5000"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  }
}
