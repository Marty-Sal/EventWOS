@page "/crew"
@attribute [Authorize(Roles = "Admin,Manager,Vendor")]
@inject IVendorApiService VendorApi

<PageTitle>Crew — EventWOS</PageTitle>

<div class="space-y-5">
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Crew Members</h2>
            <p class="text-sm text-gray-500">Manage your workforce.</p>
        </div>
        <button @onclick="() => _showCreate = true"
                class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow">
            + Add Crew
        </button>
    </div>

    <div class="relative max-w-sm">
        <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
               placeholder="Search crew…"
               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
    </div>

    @if (_loading)
    {
        <div class="flex justify-center py-16">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_crew?.Items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <p class="text-4xl mb-3">👷</p>
            <p class="text-gray-500 text-sm">No crew members found.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var c in _crew!.Items)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
                    <div class="flex items-center gap-3">
                        <div class="w-11 h-11 rounded-xl bg-indigo-100 flex items-center justify-center font-bold text-indigo-700">
                            @(c.FullName.FirstOrDefault())
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-gray-800 truncate">@c.FullName</p>
                            <p class="text-xs text-gray-400 font-mono">@c.Mobile</p>
                        </div>
                        <span class="px-2 py-0.5 rounded-full text-xs font-medium @StatusColor(c.Status)">@c.Status</span>
                    </div>
                    <div class="mt-3 pt-3 border-t border-gray-50 grid grid-cols-3 gap-2 text-center">
                        <div>
                            <p class="text-xs text-gray-400">Vendor</p>
                            <p class="text-xs font-medium text-gray-700 truncate">@(c.VendorName ?? "—")</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400">Discipline</p>
                            <p class="text-sm font-bold @DisciplineColor(c.DisciplineScore)">@c.DisciplineScore.ToString("F0")</p>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400">Events</p>
                            <p class="text-sm font-bold text-gray-700">@c.EventsAttended</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_showCreate)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-gray-800">Add Crew Member</h3>
                <button @onclick="() => { _showCreate = false; _createError = null; }" class="text-gray-400 hover:text-gray-600">✕</button>
            </div>
            <div class="space-y-3">
                <input @bind="_newMobile" placeholder="Mobile (+91...)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_newName" placeholder="Full Name" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_newEmail" type="email" placeholder="Email (optional)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_referralCode" placeholder="Vendor Referral Code (optional)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 uppercase" />
            </div>
            @if (_createError is not null)
            {
                <p class="text-xs text-red-600 bg-red-50 rounded-lg px-3 py-2">⚠️ @_createError</p>
            }
            <div class="flex gap-3">
                <button @onclick="CreateCrew" disabled="@_creating"
                        class="flex-1 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 disabled:opacity-50 transition">
                    @(_creating ? "Creating…" : "Add Crew")
                </button>
                <button @onclick="() => { _showCreate = false; _createError = null; }"
                        class="px-5 py-2.5 rounded-xl border border-gray-200 text-sm hover:bg-gray-50 transition">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private PagedCrewResult? _crew;
    private bool _loading = true;
    private int  _page    = 1;
    private string? _search;
    private System.Timers.Timer? _debounce;
    private bool _showCreate;
    private bool _creating;
    private string? _createError;
    private string _newMobile   = string.Empty;
    private string _newName     = string.Empty;
    private string? _newEmail;
    private string? _referralCode;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _crew    = await VendorApi.GetCrewAsync(_page, _search);
        _loading = false;
    }

    private void OnSearchKeyUp(KeyboardEventArgs _)
    {
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(400);
        _debounce.Elapsed += async (_, _) => {
            _page = 1;
            await InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
            _debounce?.Dispose();
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task CreateCrew()
    {
        if (string.IsNullOrWhiteSpace(_newMobile) || string.IsNullOrWhiteSpace(_newName)) return;
        _creating = true; _createError = null;
        var (ok, err) = await VendorApi.CreateCrewAsync(_newMobile, _newName, _newEmail, _referralCode);
        if (ok) {
            _showCreate = false; _newMobile = _newName = string.Empty; _newEmail = _referralCode = null;
            await LoadAsync();
        } else { _createError = err; }
        _creating = false;
    }

    private static string StatusColor(string s) => s switch
    {
        "Active"    => "bg-green-50 text-green-700 border border-green-100",
        "Suspended" => "bg-amber-50 text-amber-700 border border-amber-100",
        _           => "bg-gray-100 text-gray-500"
    };

    private static string DisciplineColor(decimal score) => score >= 80
        ? "text-green-600" : score >= 50 ? "text-amber-500" : "text-red-500";
}
