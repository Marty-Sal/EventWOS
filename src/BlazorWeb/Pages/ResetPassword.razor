@page "/reset-password"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav

<PageTitle>Reset password — EventWOS</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-2xl p-8 space-y-4">
        <h1 class="text-xl font-bold text-gray-900 text-center">Reset password</h1>
        <p class="text-sm text-gray-500 text-center">Enter the 6-digit code we sent, plus your new password.</p>

        <Field Label="Mobile number" Required="true">
            <input @bind="_mobile" type="tel" class="@Css" placeholder="+91 98765 43210" />
        </Field>

        @if (OtpId is null)
        {
            <Field Label="OTP request ID" Required="true" Hint="From the previous step's link">
                <input @bind="_otpIdRaw" class="@Css" placeholder="GUID" />
            </Field>
        }

        <Field Label="OTP code" Required="true">
            <input @bind="_otp" type="tel" maxlength="6" class="@Css tracking-widest text-center" placeholder="••••••" />
        </Field>

        <Field Label="New password" Required="true" Hint="Min 8 chars · 1 letter · 1 number">
            <input @bind="_password" type="password" class="@Css" placeholder="••••••••" autocomplete="new-password" />
        </Field>

        @if (_error is not null)
        {
            <div class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-sm">@_error</div>
        }

        <button type="button" @onclick="SubmitAsync" disabled="@_loading"
                class="w-full py-2.5 rounded-xl bg-indigo-600 text-white font-medium shadow-md hover:bg-indigo-700 disabled:opacity-50">
            @(_loading ? "Updating…" : "Update password")
        </button>

        <p class="text-center text-xs text-gray-500">
            <a href="/login" class="text-indigo-600 hover:underline">Back to sign in</a>
        </p>
    </div>
</div>

@code {
    private const string Css = "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm";

    [SupplyParameterFromQuery(Name = "otpId")] public Guid? OtpId { get; set; }

    private string _mobile = "", _otp = "", _password = "", _otpIdRaw = "";
    private string? _error;
    private bool _loading;

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_mobile) || string.IsNullOrWhiteSpace(_otp) || string.IsNullOrWhiteSpace(_password))
        { _error = "Please fill in all fields."; return; }

        Guid otpId = OtpId ?? Guid.Empty;
        if (otpId == Guid.Empty && !Guid.TryParse(_otpIdRaw, out otpId))
        { _error = "Invalid OTP request ID."; return; }

        _loading = true;
        try
        {
            var req = new ResetPasswordRequest(otpId, _mobile.Trim(), _otp.Trim(), _password);
            var result = await AuthApi.ResetPasswordAsync(req);
            if (!result.Success)
            {
                _error = result.Errors?.FirstOrDefault() ?? result.Message ?? "Reset failed.";
                return;
            }
            Nav.NavigateTo("/login?reason=password-updated", forceLoad: true);
        }
        catch { _error = "Network error."; }
        finally { _loading = false; }
    }
}
