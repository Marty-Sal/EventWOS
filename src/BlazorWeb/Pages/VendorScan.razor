@*
    VendorScan — the vendor's side of the QR-verified check-in handshake.

    Turns on the phone's rear camera, decodes crew QRs on-frame, and posts
    each decoded code to /api/v1/attendance/checkin/verify. The server
    handles all validation (own-vendor / manager / admin, event state,
    already-checked-in, TTL, etc.) — this page just relays the code and
    renders the result.

    Access:  Vendor, Manager, Admin  (attendance:verify permission).
    Route:   /scan
*@
@page "/scan"
@attribute [Authorize(Roles = "Admin,Manager,Vendor")]
@inject ICheckInApiService CheckInApi
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Scan Check-In — EventWOS</PageTitle>

<div class="space-y-5 max-w-md mx-auto">
    <div>
        <h2 class="text-lg font-bold text-gray-800">Scan Check-In</h2>
        <p class="text-sm text-gray-500 mt-0.5">
            Point your camera at the crew's QR to check them in.
        </p>
    </div>

    @if (_permissionError is not null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100 text-red-800 text-sm">
            <p class="font-semibold mb-1">Camera unavailable</p>
            <p class="text-xs">@_permissionError</p>
            <p class="text-xs text-red-600 mt-2">
                You can still enter the fallback code manually below.
            </p>
        </div>
    }

    @* ── Camera viewport ─────────────────────────────────────────────── *@
    <div class="rounded-2xl overflow-hidden bg-black relative aspect-square shadow-lg">
        <div id="checkin-scanner-host" class="w-full h-full"></div>

        @if (!_scannerRunning && _permissionError is null)
        {
            <div class="absolute inset-0 flex items-center justify-center bg-gray-900/80 text-white">
                <button class="px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-sm font-semibold"
                        @onclick="StartScannerAsync"
                        disabled="@_starting">
                    @(_starting ? "Starting camera…" : "Start Scanner")
                </button>
            </div>
        }
    </div>

    @* ── Live status: last scan result ───────────────────────────────── *@
    @if (_lastResult is not null)
    {
        <div class="p-4 rounded-xl bg-emerald-50 border border-emerald-100">
            <div class="flex items-start gap-3">
                <span class="text-2xl">✅</span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-bold text-emerald-900">Checked in</p>
                    <p class="text-sm text-emerald-800">@_lastResult.CrewName</p>
                    <p class="text-xs text-emerald-700 mt-0.5">
                        @_lastResult.EventTitle
                        @if (!string.IsNullOrEmpty(_lastResult.ShiftScopeName))
                        {
                            <span> · @_lastResult.ShiftScopeName</span>
                        }
                    </p>
                    <p class="text-[11px] text-emerald-600 mt-1">
                        @_lastResult.CheckedInAt.ToLocalTime().ToString("HH:mm:ss")
                    </p>
                </div>
            </div>
        </div>
    }

    @if (_lastError is not null)
    {
        <div class="p-4 rounded-xl bg-red-50 border border-red-100">
            <p class="text-sm font-semibold text-red-900">Couldn't verify</p>
            <p class="text-xs text-red-700 mt-0.5">@_lastError</p>
        </div>
    }

    @* ── Fallback: manual code entry ─────────────────────────────────── *@
    <div class="p-4 rounded-xl bg-white border border-gray-200 shadow-sm space-y-3">
        <p class="text-xs font-semibold text-gray-700">Camera not working?</p>
        <p class="text-xs text-gray-500">
            Ask the crew to read the fallback code shown under their QR, then type it here.
        </p>
        <div class="flex gap-2">
            <input @bind="_manualCode" @bind:event="oninput"
                   maxlength="20"
                   placeholder="ABCD-EFGH-JKLM"
                   class="flex-1 px-3 py-2 rounded-lg border border-gray-200 text-sm font-mono uppercase tracking-widest focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <button class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 disabled:opacity-50"
                    @onclick="SubmitManualAsync"
                    disabled="@(_verifying || string.IsNullOrWhiteSpace(_manualCode))">
                @(_verifying ? "…" : "Verify")
            </button>
        </div>
    </div>
</div>

@code {
    private bool _starting;
    private bool _scannerRunning;
    private bool _verifying;
    private string? _permissionError;
    private string? _lastError;
    private CheckInVerifyResultDto? _lastResult;
    private string _manualCode = "";

    // .NET reference handed to JS so the scanner can call OnCodeScanned
    // back into this component with each decoded frame.
    private DotNetObjectReference<VendorScan>? _selfRef;

    // Deduplicates the classic html5-qrcode pattern where the same QR gets
    // decoded 3-5 times in quick succession before the caller stops scanning.
    private string? _lastCode;
    private DateTime _lastCodeAt = DateTime.MinValue;

    protected override void OnInitialized()
    {
        _selfRef = DotNetObjectReference.Create(this);
    }

    private async Task StartScannerAsync()
    {
        if (_starting || _scannerRunning) return;
        _starting = true;
        _permissionError = null;
        StateHasChanged();

        try
        {
            var result = await JS.InvokeAsync<ScannerStartResult>(
                "eventwosCheckin.startScanner", "checkin-scanner-host", _selfRef);

            if (!result.Ok)
            {
                _permissionError = string.IsNullOrEmpty(result.Error)
                    ? "Could not access the camera."
                    : $"Could not access the camera. {result.Error}";
            }
            else
            {
                _scannerRunning = true;
            }
        }
        catch (Exception ex)
        {
            _permissionError = $"Scanner failed to start: {ex.Message}";
        }
        finally
        {
            _starting = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Invoked from JS on every decoded frame. We debounce identical codes
    /// within a 3-second window so a single QR in the viewfinder doesn't
    /// spam the verify endpoint 5x. On success we briefly stop the scanner
    /// so the vendor can see the confirmation without a fresh scan
    /// clobbering the result — they tap Start Scanner to continue.
    /// </summary>
    [JSInvokable]
    public async Task OnCodeScanned(string code)
    {
        if (_verifying) return;

        var now = DateTime.UtcNow;
        if (code == _lastCode && (now - _lastCodeAt).TotalSeconds < 3) return;
        _lastCode   = code;
        _lastCodeAt = now;

        await VerifyAsync(code);
    }

    private async Task SubmitManualAsync()
    {
        if (_verifying || string.IsNullOrWhiteSpace(_manualCode)) return;
        // Strip dashes / spaces the vendor might have typed from the pretty
        // XXXX-XXXX-XXXX display.
        var normalised = new string(_manualCode.Where(char.IsLetterOrDigit).ToArray());
        await VerifyAsync(normalised);
    }

    private async Task VerifyAsync(string code)
    {
        _verifying = true;
        _lastError = null;
        StateHasChanged();

        var result = await CheckInApi.VerifyAsync(code, location: null);

        if (result.Success && result.Data is not null)
        {
            _lastResult = result.Data;
            _lastError  = null;
            _manualCode = "";
            // Pause the camera so the confirmation stays put. Vendor taps
            // Start Scanner to do the next crew.
            await StopScannerAsync();
        }
        else
        {
            _lastError  = result.Message ?? "The code could not be verified.";
        }

        _verifying = false;
        StateHasChanged();
    }

    private async Task StopScannerAsync()
    {
        if (!_scannerRunning) return;
        try { await JS.InvokeVoidAsync("eventwosCheckin.stopScanner"); } catch { }
        _scannerRunning = false;
    }

    public async ValueTask DisposeAsync()
    {
        await StopScannerAsync();
        _selfRef?.Dispose();
    }

    /// <summary>Shape returned by eventwosCheckin.startScanner.</summary>
    private sealed record ScannerStartResult(bool Ok, string? Error);
}
