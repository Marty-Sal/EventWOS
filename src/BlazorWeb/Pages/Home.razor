@page "/home"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization

<PageTitle>EveWos — Event Workforce Operating System</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 text-white overflow-x-hidden">

    @* ═══════════════════════════════════════ NAV ═══════════════════════════════════════ *@
    <header class="relative z-20">
        <div class="max-w-7xl mx-auto px-6 lg:px-10 h-20 flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center text-xl shadow-lg shadow-indigo-900/40">⚡</div>
                <div class="leading-tight">
                    <p class="text-lg font-bold tracking-tight">EveWos</p>
                    <p class="text-[10px] text-indigo-200/70 uppercase tracking-widest">Workforce OS</p>
                </div>
            </div>
            <nav class="hidden md:flex items-center gap-8 text-sm text-indigo-100/80">
                <a href="#features" class="hover:text-white transition">Features</a>
                <a href="#roles" class="hover:text-white transition">For Teams</a>
                <a href="#workflow" class="hover:text-white transition">Workflow</a>
            </nav>
            <button @onclick="GoLogin"
                    class="px-5 py-2.5 rounded-xl bg-white text-gray-900 text-sm font-semibold hover:bg-indigo-50 transition shadow-lg shadow-black/20">
                Login →
            </button>
        </div>
    </header>

    @* ═══════════════════════════════════════ HERO ═══════════════════════════════════════ *@
    <section class="relative">
        @* glow blobs *@
        <div class="absolute top-20 -left-20 w-96 h-96 bg-indigo-600/30 rounded-full blur-3xl"></div>
        <div class="absolute top-40 right-0 w-96 h-96 bg-fuchsia-600/20 rounded-full blur-3xl"></div>

        <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-28 text-center">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-xs text-indigo-200 backdrop-blur mb-8">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                Event Workforce Operating System
            </div>

            <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.05] max-w-4xl mx-auto">
                Run every event,
                <span class="bg-gradient-to-r from-indigo-300 via-fuchsia-300 to-indigo-300 bg-clip-text text-transparent">
                    every crew, every payment
                </span>
                — in one place.
            </h1>

            <p class="mt-7 text-lg md:text-xl text-indigo-100/70 max-w-2xl mx-auto leading-relaxed">
                EveWos is the operating system for event teams. Plan events, invite vendors, staff crew,
                track attendance, approve work and run payroll — without spreadsheets, group chats or chaos.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
                <button @onclick="GoLogin"
                        class="px-7 py-3.5 rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-500 transition shadow-xl shadow-indigo-900/50 flex items-center gap-2">
                    Get Started
                    <span>→</span>
                </button>
                <a href="#features"
                   class="px-7 py-3.5 rounded-xl bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 transition backdrop-blur">
                    See how it works
                </a>
            </div>

            @* trust strip *@
            <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/10 max-w-3xl mx-auto">
                <div class="bg-gray-900/40 backdrop-blur px-6 py-5">
                    <p class="text-2xl font-bold">4 Roles</p>
                    <p class="text-xs text-indigo-200/60 mt-1">Admin · Manager · Vendor · Crew</p>
                </div>
                <div class="bg-gray-900/40 backdrop-blur px-6 py-5">
                    <p class="text-2xl font-bold">3-Step</p>
                    <p class="text-xs text-indigo-200/60 mt-1">Vendor + Manager approval</p>
                </div>
                <div class="bg-gray-900/40 backdrop-blur px-6 py-5">
                    <p class="text-2xl font-bold">Real-time</p>
                    <p class="text-xs text-indigo-200/60 mt-1">Live updates via SignalR</p>
                </div>
                <div class="bg-gray-900/40 backdrop-blur px-6 py-5">
                    <p class="text-2xl font-bold">Secure</p>
                    <p class="text-xs text-indigo-200/60 mt-1">OTP login · audit logs</p>
                </div>
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════ FEATURES ═══════════════════════════════════════ *@
    <section id="features" class="relative py-24 bg-gray-50 text-gray-900">
        <div class="max-w-7xl mx-auto px-6 lg:px-10">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <p class="text-sm font-semibold text-indigo-600 uppercase tracking-widest">What's inside</p>
                <h2 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight text-gray-900">Everything an event team needs.</h2>
                <p class="mt-4 text-gray-500 text-lg">From the first invite to the final payout.</p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
                @foreach (var f in _features)
                {
                    <div class="group bg-white border border-gray-100 rounded-2xl p-7 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-100/50 transition-all">
                        <div class="w-12 h-12 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center text-2xl mb-5 group-hover:bg-indigo-600 group-hover:text-white transition">
                            @f.Icon
                        </div>
                        <h3 class="font-semibold text-gray-900 text-lg">@f.Title</h3>
                        <p class="text-sm text-gray-500 mt-2 leading-relaxed">@f.Desc</p>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════ WORKFLOW ═══════════════════════════════════════ *@
    <section id="workflow" class="relative py-24 bg-white text-gray-900">
        <div class="max-w-7xl mx-auto px-6 lg:px-10">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <p class="text-sm font-semibold text-indigo-600 uppercase tracking-widest">How it flows</p>
                <h2 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight">A clean, accountable workflow.</h2>
                <p class="mt-4 text-gray-500 text-lg">Every action approved. Every change logged.</p>
            </div>

            <div class="grid md:grid-cols-4 gap-5">
                @{ int n = 1; }
                @foreach (var step in _steps)
                {
                    <div class="relative bg-gradient-to-br from-gray-50 to-white border border-gray-100 rounded-2xl p-6">
                        <div class="absolute -top-3 -left-3 w-9 h-9 rounded-xl bg-indigo-600 text-white text-sm font-bold flex items-center justify-center shadow-lg">@(n++)</div>
                        <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wider mt-2">@step.Actor</p>
                        <h3 class="mt-2 font-semibold text-gray-900">@step.Title</h3>
                        <p class="text-sm text-gray-500 mt-2 leading-relaxed">@step.Desc</p>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════ ROLES ═══════════════════════════════════════ *@
    <section id="roles" class="relative py-24 bg-gray-50 text-gray-900">
        <div class="max-w-7xl mx-auto px-6 lg:px-10">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <p class="text-sm font-semibold text-indigo-600 uppercase tracking-widest">Built for everyone on the ground</p>
                <h2 class="mt-3 text-4xl md:text-5xl font-bold tracking-tight">One platform. Every role.</h2>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
                @foreach (var r in _roles)
                {
                    <div class="bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-xl hover:shadow-gray-200/50 transition">
                        <div class="text-3xl">@r.Emoji</div>
                        <h3 class="mt-4 font-bold text-gray-900 text-lg">@r.Name</h3>
                        <p class="text-xs text-indigo-600 font-semibold uppercase tracking-wider mt-0.5">@r.Tag</p>
                        <ul class="mt-4 space-y-2 text-sm text-gray-600">
                            @foreach (var b in r.Bullets)
                            {
                                <li class="flex gap-2">
                                    <span class="text-indigo-500 mt-0.5">✓</span>
                                    <span>@b</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════ CTA ═══════════════════════════════════════ *@
    <section class="relative py-28 bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 text-white overflow-hidden">
        <div class="absolute inset-0 opacity-30">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-indigo-600/40 rounded-full blur-3xl"></div>
        </div>
        <div class="relative max-w-3xl mx-auto px-6 text-center">
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight">Ready to run a calmer event?</h2>
            <p class="mt-5 text-lg text-indigo-100/70">Sign in to your EveWos workspace and pick up right where your team left off.</p>
            <div class="mt-9">
                <button @onclick="GoLogin"
                        class="px-8 py-4 rounded-xl bg-white text-gray-900 font-semibold hover:bg-indigo-50 transition shadow-2xl shadow-black/40 inline-flex items-center gap-2">
                    Login to EveWos
                    <span>→</span>
                </button>
            </div>
        </div>
    </section>

    @* ═══════════════════════════════════════ FOOTER ═══════════════════════════════════════ *@
    <footer class="bg-gray-950 text-indigo-100/60 border-t border-white/5">
        <div class="max-w-7xl mx-auto px-6 lg:px-10 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
            <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center text-sm">⚡</div>
                <span class="font-semibold text-white">EveWos</span>
                <span class="text-indigo-200/40">· Event Workforce Operating System</span>
            </div>
            <p>© @DateTime.UtcNow.Year EveWos. All rights reserved.</p>
        </div>
    </footer>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        // If the visitor is already signed in, send them straight to their dashboard.
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User?.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/dashboard", replace: true);
        }
    }

    private void GoLogin() => Nav.NavigateTo("/login");

    private sealed record Feature(string Icon, string Title, string Desc);
    private sealed record Step(string Actor, string Title, string Desc);
    private sealed record RoleCard(string Emoji, string Name, string Tag, string[] Bullets);

    private readonly Feature[] _features =
    {
        new("📅", "Events",      "Plan events end-to-end — venue, schedule, capacity and crew, all in one record."),
        new("👥", "Crew",        "Maintain a verified crew roster with skills, ratings and discipline scores."),
        new("🤝", "Vendors",     "Onboard vendors, assign them to events and let them staff their own teams."),
        new("✅", "Attendance",  "Crew check-in and check-out with audit trail — no more lost timesheets."),
        new("💸", "Payments",    "Approve crew payments, batch payroll and track every paid rupee."),
        new("🛡️", "Approvals",  "Two-step approval: vendor confirms, manager signs off — clean and accountable."),
    };

    private readonly Step[] _steps =
    {
        new("Manager",  "Create the event",       "Set venue, dates and crew capacity. Pick assignment mode: crew-only, vendor-only or vendor + crew."),
        new("Vendor",   "Staff the event",        "Invite crew from your roster. They accept on their phone — no app install needed."),
        new("Manager",  "Final approval",         "Manager reviews vendor-approved crew in the Approval Queue and gives the final yes."),
        new("Everyone", "Run it & get paid",      "Crew check in on-site. Vendor rates. Manager approves payment. Done."),
    };

    private readonly RoleCard[] _roles =
    {
        new("🛡️", "Admin",   "Full Control",      new[] { "Manage users & roles", "Configure permissions", "Full audit log access" }),
        new("📋", "Manager", "Plans & Approves",  new[] { "Create & publish events", "Approval queue & payments", "Permission-gated access" }),
        new("🤝", "Vendor",  "Brings the team",   new[] { "Build your crew roster", "Self-assign to events", "Track your payouts" }),
        new("🧑‍🔧", "Crew",  "On the ground",     new[] { "Accept invites", "Check in & out", "View earnings & ratings" }),
    };
}
