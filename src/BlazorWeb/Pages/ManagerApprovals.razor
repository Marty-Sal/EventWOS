@page "/manager-approvals"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject HttpClient Http
@inject EventWOS.BlazorWeb.Auth.AppAuthStateProvider Auth
@inject IAuthApiService AuthApi
@inject NavigationManager Nav
@inject NotificationHubService Hub
@implements IAsyncDisposable
@using System.Net.Http
@using System.Net.Http.Json

<PageTitle>Approvals · Events — EventWOS</PageTitle>

<div class="space-y-6">
    <ApprovalTabsHeader Active="events" EventsCount="@_pendingCount" />

    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Event assignments</h2>
            <p class="text-sm text-gray-500 mt-0.5">Crew forwarded by Vendors awaiting your final decision.</p>
        </div>
        @if (_pendingCount > 0)
        {
            <span class="px-3 py-1 rounded-full bg-red-100 text-red-700 text-sm font-bold border border-red-200">
                @_pendingCount pending
            </span>
        }
    </div>

    @if (_loading)
    {
        <div class="flex justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">@_error</div>
    }
    else if (!_items.Any())
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-5xl mb-4">✅</p>
            <p class="font-semibold text-gray-700 text-sm">All caught up!</p>
            <p class="text-xs text-gray-400 mt-1">No crew members waiting for your approval.</p>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @{
                // Phase D step 13: compute (Event + Crew) group metadata once.
                // groupKey → ordered list of AssignmentIds in this page so we
                // can render "Shift 1 of N" badges and tighter spacing for
                // siblings. Only operates on the current page; sort order
                // upstream (EventId → CrewId → ShiftStartAt) guarantees
                // siblings are adjacent.
                var groupRows = _items
                    .GroupBy(i => (i.EventId, CrewKey: i.CrewId == Guid.Empty ? (Guid?)null : i.CrewId))
                    .ToDictionary(g => g.Key, g => g.Select(x => x.AssignmentId).ToList());
                Guid lastEvt = Guid.Empty;
                Guid lastCrew = Guid.Empty;
            }
            @foreach (var item in _items)
            {
                var groupIds = groupRows[(item.EventId, item.CrewId == Guid.Empty ? (Guid?)null : item.CrewId)];
                var posInGroup = groupIds.IndexOf(item.AssignmentId) + 1;
                var totalInGroup = groupIds.Count;
                var isFirstOfGroup = posInGroup == 1;
                var isMidOfGroup = !isFirstOfGroup;
                var cardClasses = isMidOfGroup
                    ? "bg-white rounded-2xl border border-blue-100 border-t-2 border-t-indigo-300 shadow-sm p-5 -mt-2 ml-6"
                    : "bg-white rounded-2xl border border-blue-100 shadow-sm p-5";
                <div class="@cardClasses">
                    @if (totalInGroup > 1)
                    {
                        <div class="flex items-center gap-2 mb-2 -mt-1">
                            <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-indigo-100 text-indigo-700 border border-indigo-200">
                                Shift @posInGroup of @totalInGroup
                            </span>
                            <span class="text-[10px] text-gray-400">Same crew · same event</span>
                        </div>
                    }
                    <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-5">

                        @* Left: crew + event info *@
                        <div class="flex-1 space-y-3">
                            <div class="flex items-center gap-3 flex-wrap">
                                <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold text-sm shrink-0">
                                    @(string.IsNullOrEmpty(item.CrewName) ? '?' : item.CrewName[0])
                                </div>
                                <div>
                                    <p class="font-bold text-gray-800">@item.CrewName</p>
                                    <p class="text-xs text-gray-400">@item.CrewMobile</p>
                                </div>
                                <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-blue-50 text-blue-700 border border-blue-200">
                                    Pending Manager Approval
                                </span>
                            </div>

                            @* Crew stats *@
                            <div class="flex items-center gap-5 text-xs">
                                <div class="bg-gray-50 rounded-xl px-3 py-2 border border-gray-100">
                                    <p class="text-gray-400 mb-0.5">Discipline Score</p>
                                    <p class="font-bold text-lg @DisciplineColor(item.DisciplineScore)">@item.DisciplineScore.ToString("F0")</p>
                                    <p class="text-gray-400 text-[10px]">out of 100</p>
                                </div>
                                <div class="bg-gray-50 rounded-xl px-3 py-2 border border-gray-100">
                                    <p class="text-gray-400 mb-0.5">Events Completed</p>
                                    <p class="font-bold text-lg text-gray-700">@item.EventsAttended</p>
                                    <p class="text-gray-400 text-[10px]">total</p>
                                </div>
                                <div class="bg-gray-50 rounded-xl px-3 py-2 border border-gray-100">
                                    <p class="text-gray-400 mb-0.5">Via Vendor</p>
                                    <p class="font-semibold text-gray-700 text-sm">@item.VendorName</p>
                                    <p class="text-gray-400 text-[10px]">vendor approved @(item.VendorReviewedAt.HasValue ? item.VendorReviewedAt.Value.ToLocalTime().ToString("dd MMM") : "-")</p>
                                </div>
                            </div>

                            @* Event info *@
                            <div class="bg-indigo-50 rounded-xl p-3 border border-indigo-100 text-xs space-y-0.5">
                                <p class="font-semibold text-indigo-800">📅 @item.EventTitle</p>
                                <p class="text-indigo-600">📍 @item.EventVenue</p>
                                <p class="text-indigo-500">🗓 @item.EventStartAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</p>
                                @{ var shiftLbl = BuildShiftLabel(item); }
                                @if (shiftLbl is not null)
                                {
                                    <p class="text-indigo-700 font-semibold mt-1">🎯 @shiftLbl</p>
                                }
                            </div>
                        </div>

                        @* Right: action buttons *@
                        <div class="flex flex-col gap-2 shrink-0 min-w-[160px]">
                            <button @onclick="() => DoApprove(item.AssignmentId)"
                                    disabled="@(_busy == item.AssignmentId)"
                                    class="w-full px-4 py-2.5 rounded-xl bg-green-600 text-white text-sm font-semibold
                                           hover:bg-green-700 disabled:opacity-50 transition shadow-sm">
                                @(_busy == item.AssignmentId && _busyAction == "approve" ? "Approving…" : "✓ Approve")
                            </button>
                            <button @onclick="() => OpenReject(item)"
                                    disabled="@(_busy == item.AssignmentId)"
                                    class="w-full px-4 py-2.5 rounded-xl border border-red-200 text-red-600 text-sm font-semibold
                                           hover:bg-red-50 disabled:opacity-50 transition">
                                ✕ Reject
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Pagination *@
        @if (_totalPages > 1)
        {
            <div class="flex justify-center gap-3 pt-2">
                <button disabled="@(_page == 1)" @onclick="PrevPage"
                        class="px-4 py-2 rounded-xl border text-xs font-medium disabled:opacity-40 hover:border-indigo-400 transition">
                    ← Prev
                </button>
                <span class="px-4 py-2 text-xs text-gray-500">Page @_page of @_totalPages</span>
                <button disabled="@(_page == _totalPages)" @onclick="NextPage"
                        class="px-4 py-2 rounded-xl border text-xs font-medium disabled:opacity-40 hover:border-indigo-400 transition">
                    Next →
                </button>
            </div>
        }
    }

    @if (_toast is not null)
    {
        <div class="fixed bottom-6 right-6 z-50 px-5 py-3 rounded-2xl shadow-xl text-sm font-medium
                    @(_toastError ? "bg-red-600 text-white" : "bg-green-600 text-white")">
            @_toast
        </div>
    }
</div>

@* Reject Modal *@
@if (_rejectTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-4">
            <h3 class="font-bold text-gray-800 text-base">Reject Crew Application</h3>
            <div class="bg-gray-50 rounded-xl p-3 text-sm border border-gray-100 space-y-0.5">
                <p class="font-semibold text-gray-700">@_rejectTarget.CrewName</p>
                <p class="text-gray-500 text-xs">Event: @_rejectTarget.EventTitle</p>
                <p class="text-gray-500 text-xs">Vendor: @_rejectTarget.VendorName</p>
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1.5">
                    Rejection Reason <span class="text-red-500">*</span>
                    <span class="text-gray-400 font-normal">(mandatory — visible to Vendor and Crew)</span>
                </label>
                <textarea @bind="_rejectReason" rows="4"
                          class="w-full px-3 py-2 text-sm rounded-xl border @(_reasonError ? "border-red-400 bg-red-50" : "border-gray-200")
                                 focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"
                          placeholder="e.g. Insufficient attendance history, disciplinary record, event requirements not met…" />
                @if (_reasonError)
                {
                    <p class="text-xs text-red-500 mt-1">⚠ Rejection reason is mandatory before proceeding.</p>
                }
            </div>
            <div class="flex gap-3 pt-1">
                <button @onclick="CancelReject"
                        class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                    Cancel
                </button>
                <button @onclick="ConfirmReject" disabled="@_busy.HasValue"
                        class="flex-1 py-2.5 rounded-xl bg-red-600 text-white text-sm font-semibold
                               hover:bg-red-700 disabled:opacity-50 transition shadow-sm">
                    @(_busy.HasValue ? "Rejecting…" : "Confirm Rejection")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ManagerApprovalItemDto> _items = new();
    private bool    _loading = true;
    private string? _error;
    private int     _page = 1, _totalPages = 1, _pendingCount;
    private Guid?   _busy;
    private string? _busyAction;

    private ManagerApprovalItemDto? _rejectTarget;
    private string  _rejectReason = "";
    private bool    _reasonError;

    private string? _toast;
    private bool    _toastError;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        Hub.PendingManagerApprovalReceived += OnQueueChanged;
        try { await Hub.StartAsync(); } catch { }
        await Load();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.PendingManagerApprovalReceived -= OnQueueChanged;
        await ValueTask.CompletedTask;
    }

    private void OnQueueChanged(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await Load(); StateHasChanged(); });
    }

    private async Task Load()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            var resp = await GetWithAuthRetryAsync(
                $"api/v1/events/assignments/manager-queue?page={_page}&pageSize=20");

            if (resp is null)
            {
                _error = "Session expired. Redirecting to login…";
                await Auth.MarkLoggedOutAsync();
                Nav.NavigateTo("/login", forceLoad: true);
                return;
            }

            if (!resp.IsSuccessStatusCode)
            {
                _error = resp.StatusCode == System.Net.HttpStatusCode.Forbidden
                    ? "You do not have permission to view the approval queue. Ask an Admin to grant the \u0022crew:approve\u0022 permission."
                    : $"Could not load queue ({(int)resp.StatusCode} {resp.ReasonPhrase}).";
                _items = new();
                return;
            }

            var body = await resp.Content.ReadFromJsonAsync<ApiResult<PagedResult<ManagerApprovalItemDto>>>(JsonOpts);
            _items        = body?.Data?.Items?.ToList() ?? new();
            _pendingCount = body?.Data?.TotalCount ?? 0;
            _totalPages   = (int)Math.Ceiling((double)_pendingCount / 20);
            if (_totalPages < 1) _totalPages = 1;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    /// <summary>
    /// GET helper that transparently refreshes the access token on 401 and retries once.
    /// Returns null if both attempts fail with 401 (caller should force re-login).
    /// </summary>
    private async Task<HttpResponseMessage?> GetWithAuthRetryAsync(string url)
    {
        var resp = await Http.GetAsync(url);
        if (resp.StatusCode != System.Net.HttpStatusCode.Unauthorized) return resp;

        var refreshToken = await Auth.GetRefreshTokenAsync();
        if (string.IsNullOrEmpty(refreshToken)) return null;
        var refreshed = await AuthApi.RefreshTokenAsync(refreshToken);
        if (refreshed?.Success != true || refreshed.Data is null) return null;
        await Auth.UpdateAccessTokenAsync(refreshed.Data.AccessToken, refreshed.Data.RefreshToken);

        var retry = await Http.GetAsync(url);
        return retry.StatusCode == System.Net.HttpStatusCode.Unauthorized ? null : retry;
    }

    private async Task DoApprove(Guid id)
    {
        _busy = id; _busyAction = "approve"; StateHasChanged();
        var resp = await PatchWithAuthRetryAsync(
            $"api/v1/events/assignments/{id}/manager-approve", new { });
        if (resp is not null && resp.IsSuccessStatusCode)
        {
            ShowToast("Crew approved! Assignment is now fully confirmed. ✓", false);
            await Load();
        }
        else
        {
            var msg = resp is null
                ? "Session expired. Please log in again."
                : await resp.Content.ReadAsStringAsync();
            ShowToast("Error: " + msg, true);
        }
        _busy = null; _busyAction = null; StateHasChanged();
    }

    private async Task<HttpResponseMessage?> PatchWithAuthRetryAsync(string url, object body)
    {
        var resp = await Http.PatchAsJsonAsync(url, body);
        if (resp.StatusCode != System.Net.HttpStatusCode.Unauthorized) return resp;

        var refreshToken = await Auth.GetRefreshTokenAsync();
        if (string.IsNullOrEmpty(refreshToken)) return null;
        var refreshed = await AuthApi.RefreshTokenAsync(refreshToken);
        if (refreshed?.Success != true || refreshed.Data is null) return null;
        await Auth.UpdateAccessTokenAsync(refreshed.Data.AccessToken, refreshed.Data.RefreshToken);

        var retry = await Http.PatchAsJsonAsync(url, body);
        return retry.StatusCode == System.Net.HttpStatusCode.Unauthorized ? null : retry;
    }

    private void OpenReject(ManagerApprovalItemDto item)
    {
        _rejectTarget = item; _rejectReason = ""; _reasonError = false;
    }
    private void CancelReject() { _rejectTarget = null; _reasonError = false; }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason)) { _reasonError = true; return; }
        if (_rejectTarget is null) return;
        _busy = _rejectTarget.AssignmentId; _busyAction = "reject"; StateHasChanged();
        var resp = await PatchWithAuthRetryAsync(
            $"api/v1/events/assignments/{_rejectTarget.AssignmentId}/manager-reject",
            new { reason = _rejectReason });
        if (resp is not null && resp.IsSuccessStatusCode)
        {
            ShowToast("Crew rejected. Vendor and Crew will be notified.", false);
            _rejectTarget = null;
            await Load();
        }
        else
        {
            var msg = resp is null
                ? "Session expired. Please log in again."
                : await resp.Content.ReadAsStringAsync();
            ShowToast("Error: " + msg, true);
        }
        _busy = null; _busyAction = null; StateHasChanged();
    }

    private void ShowToast(string msg, bool isError)
    {
        _toast = msg; _toastError = isError; StateHasChanged();
        _ = Task.Delay(4000).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await Load(); } }

    private static string DisciplineColor(decimal score) =>
        score >= 80 ? "text-green-600" : score >= 50 ? "text-amber-600" : "text-red-600";

    /// <summary>Phase D step 12: shift chip text "Box Office · 18:00–23:00 · 5h".</summary>
    private static string? BuildShiftLabel(ManagerApprovalItemDto a)
    {
        if (string.IsNullOrWhiteSpace(a.ShiftScopeName) && a.ShiftStartAt is null) return null;
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(a.ShiftScopeName)) parts.Add(a.ShiftScopeName!);
        if (a.ShiftStartAt is { } st)
        {
            var ls = st.ToLocalTime();
            if (a.ShiftEndAt is { } et)
            {
                var le = et.ToLocalTime();
                parts.Add($"{ls:HH:mm}–{le:HH:mm}");
                var hrs = (le - ls).TotalHours;
                if (hrs > 0) parts.Add($"{hrs:0.#}h");
            }
            else parts.Add($"from {ls:HH:mm}");
        }
        return parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

    private sealed record ManagerApprovalItemDto(
        Guid AssignmentId, Guid EventId, string EventTitle, string EventVenue, DateTime EventStartAt,
        Guid CrewId, string CrewName, string CrewMobile,
        decimal DisciplineScore, int EventsAttended,
        Guid VendorId, string VendorName,
        DateTime CrewRespondedAt, DateTime? VendorReviewedAt, string Status,
        // Phase D step 12: per-shift approval context.
        Guid? ShiftId = null,
        string? ShiftScopeName = null,
        DateTime? ShiftStartAt = null,
        DateTime? ShiftEndAt = null);

    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
