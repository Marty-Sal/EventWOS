@page "/login"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject NavigationManager Nav

<PageTitle>Sign in — EventWOS</PageTitle>

@*
    Portal-picker landing. Replaces the old single-page OTP login.
    Pre-Phase-5 OTP login is still wired on the backend, but the visible
    sign-in UI now routes by audience:
       Admin / Manager  → /login/admin
       Vendor           → /login/vendor
       Crew             → /login/crew
    Each portal page renders the same PasswordLoginCard with a different
    theme + register link.
*@

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-2xl">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 text-3xl mb-4 shadow-lg text-white">⚡</div>
            <h1 class="text-3xl font-bold text-white">Welcome to EventWOS</h1>
            <p class="text-sm text-gray-400 mt-2">Sign in to the portal that matches your role.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="/login/admin"  class="group block bg-white rounded-2xl p-6 shadow-xl hover:shadow-2xl transition border-2 border-transparent hover:border-indigo-500">
                <div class="w-12 h-12 rounded-xl bg-indigo-100 text-indigo-700 flex items-center justify-center text-2xl mb-3">⚡</div>
                <div class="font-bold text-gray-900">Admin / Manager</div>
                <div class="text-xs text-gray-500 mt-1">Run the platform, approve registrations, manage events.</div>
            </a>
            <a href="/login/vendor" class="group block bg-white rounded-2xl p-6 shadow-xl hover:shadow-2xl transition border-2 border-transparent hover:border-emerald-500">
                <div class="w-12 h-12 rounded-xl bg-emerald-100 text-emerald-700 flex items-center justify-center text-2xl mb-3">🏢</div>
                <div class="font-bold text-gray-900">Vendor</div>
                <div class="text-xs text-gray-500 mt-1">Manage your crew, accept events, run payroll.</div>
                <div class="text-xs text-emerald-600 mt-3 font-medium group-hover:underline">New here? Sign up →</div>
            </a>
            <a href="/login/crew"   class="group block bg-white rounded-2xl p-6 shadow-xl hover:shadow-2xl transition border-2 border-transparent hover:border-orange-500">
                <div class="w-12 h-12 rounded-xl bg-orange-100 text-orange-700 flex items-center justify-center text-2xl mb-3">🧑‍🔧</div>
                <div class="font-bold text-gray-900">Crew</div>
                <div class="text-xs text-gray-500 mt-1">Pick up shifts, track attendance, see payouts.</div>
                <div class="text-xs text-orange-600 mt-3 font-medium group-hover:underline">New here? Sign up with vendor code →</div>
            </a>
        </div>

        <p class="text-center text-xs text-gray-500 mt-8">
            Need help? Email <a href="mailto:support@eventwos.app" class="text-indigo-400 hover:underline">support@eventwos.app</a>.
        </p>
    </div>
</div>
