@page "/login"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav
@inject TokenRefreshService RefreshSvc

<PageTitle>Sign In — EventWOS</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-sm">

        <!-- Card -->
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <!-- Logo -->
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-indigo-600 text-3xl mb-4 shadow-lg">
                    ⚡
                </div>
                <h1 class="text-2xl font-bold text-gray-900">EventWOS</h1>
                <p class="text-sm text-gray-500 mt-1">Workforce Operating System</p>
            </div>

            <!-- Step 1: Mobile -->
            @if (!_otpSent)
            {
                <div class="space-y-5">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Mobile Number</label>
                        <input @bind="_mobile" @bind:event="oninput"
                               @onkeydown="OnMobileKeyDown"
                               type="tel"
                               placeholder="+91 98765 43210"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                               disabled="@_loading" />
                    </div>

                    @if (_error is not null)
                    {
                        <div class="flex items-center gap-2 text-sm text-red-600 bg-red-50 border border-red-100 rounded-xl px-4 py-3">
                            <span>⚠️</span> @_error
                        </div>
                    }

                    <button @onclick="RequestOtpAsync"
                            disabled="@(_loading || string.IsNullOrWhiteSpace(_mobile))"
                            class="w-full py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-md hover:shadow-lg">
                        @if (_loading)
                        {
                            <span class="flex items-center justify-center gap-2">
                                <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                                </svg>
                                Sending OTP…
                            </span>
                        }
                        else { <span>Send OTP →</span> }
                    </button>
                </div>
            }
            else
            {
                <!-- Step 2: OTP -->
                <div class="space-y-5">
                    <div class="text-center text-sm text-gray-500 bg-gray-50 rounded-xl py-3 px-4">
                        OTP sent to <span class="font-semibold text-gray-700">@_mobile</span>
                        <button @onclick="() => { _otpSent = false; _otp = string.Empty; _error = null; _devOtp = null; }"
                                class="ml-2 text-indigo-600 hover:underline text-xs">Change</button>
                    </div>

                    @if (_devOtp is not null)
                    {
                        <div class="flex items-center justify-between text-sm bg-amber-50 border border-amber-200 rounded-xl px-4 py-3">
                            <span class="text-amber-700">🔐 <strong>Dev mode OTP:</strong></span>
                            <span class="font-mono text-lg font-bold tracking-widest text-amber-800">@_devOtp</span>
                        </div>
                    }

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1.5">Enter 6-digit OTP</label>
                        <input @bind="_otp" @bind:event="oninput"
                               @onkeydown="OnOtpKeyDown"
                               type="text"
                               inputmode="numeric"
                               maxlength="6"
                               placeholder="● ● ● ● ● ●"
                               class="w-full px-4 py-3 rounded-xl border border-gray-200 text-center text-2xl font-mono tracking-widest focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all"
                               disabled="@_loading" />
                    </div>

                    @if (_error is not null)
                    {
                        <div class="flex items-center gap-2 text-sm text-red-600 bg-red-50 border border-red-100 rounded-xl px-4 py-3">
                            <span>⚠️</span> @_error
                        </div>
                    }

                    <button @onclick="VerifyOtpAsync"
                            disabled="@(_loading || _otp.Length != 6)"
                            class="w-full py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold transition-all disabled:opacity-50 disabled:cursor-not-allowed shadow-md hover:shadow-lg">
                        @if (_loading)
                        {
                            <span class="flex items-center justify-center gap-2">
                                <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24" fill="none">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                                </svg>
                                Verifying…
                            </span>
                        }
                        else { <span>Verify &amp; Sign In ✓</span> }
                    </button>

                    <div class="text-center">
                        <button @onclick="RequestOtpAsync" disabled="@_loading"
                                class="text-sm text-indigo-600 hover:underline disabled:opacity-50">
                            Resend OTP
                        </button>
                    </div>
                </div>
            }
        </div>

        <p class="text-center text-xs text-gray-500 mt-6 opacity-60">
            EventWOS © @DateTime.UtcNow.Year — Workforce Management Platform
        </p>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private string _mobile = string.Empty;
    private string? _devOtp;   // Only set in dev/staging — shown as on-screen hint
    private string _otp = string.Empty;
    private Guid _otpRequestId;
    private bool _otpSent;
    private bool _loading;
    private string? _error;

    private async Task RequestOtpAsync()
    {
        _loading = true; _error = null;
        try
        {
            var result = await AuthApi.RequestOtpAsync(_mobile);
            if (result.Success && result.Data is not null)
            {
                _otpRequestId = result.Data.OtpRequestId;
                _devOtp = result.Data.DevOtp;
                if (_devOtp is not null)
                    _otp = _devOtp;   // auto-fill in dev mode
                _otpSent = true;
            }
            else
            {
                _error = result.Errors?.FirstOrDefault() ?? "Failed to send OTP.";
            }
        }
        catch { _error = "Network error. Please try again."; }
        finally { _loading = false; }
    }

    private async Task VerifyOtpAsync()
    {
        _loading = true; _error = null;
        try
        {
            var deviceId = Guid.NewGuid().ToString("N")[..16]; // Simple device ID
            var result = await AuthApi.VerifyOtpAsync(_mobile, _otp, _otpRequestId, deviceId);
            if (result.Success)
            {
                RefreshSvc.Start();
                // Force a full page reload so the auth state provider picks up
                // the newly stored tokens from localStorage on fresh initialisation
                var target = ReturnUrl is not null ? Uri.UnescapeDataString(ReturnUrl) : "/dashboard";
                Nav.NavigateTo(target, forceLoad: true);
            }
            else
            {
                _error = result.Errors?.FirstOrDefault() ?? "Invalid OTP.";
                _otp = string.Empty;
            }
        }
        catch { _error = "Network error. Please try again."; }
        finally { _loading = false; }
    }
    private async Task OnMobileKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RequestOtpAsync();
    }

    private async Task OnOtpKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await VerifyOtpAsync();
    }

}