@page "/admin/permissions"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject HttpClient Http

<PageTitle>Permissions — EventWOS</PageTitle>

@if (_accessDenied)
{
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
        <div class="text-5xl mb-4">🔒</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
        <p class="text-gray-500 text-sm">You need <strong>permissions:read</strong> permission.</p>
    </div>
    return;
}

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">Permissions</h2>
        <p class="text-sm text-gray-500 mt-0.5">All system permissions grouped by resource. Assign these to Managers via the Managers page.</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">@_error</div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
                <p class="text-sm font-semibold text-gray-700">@_allPermissions.Count total permissions across @_groups.Count resources</p>
                <input @bind="_search" @bind:event="oninput"
                       placeholder="Filter permissions..."
                       class="px-3 py-1.5 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-indigo-300 w-56" />
            </div>
        </div>

        @foreach (var group in FilteredGroups)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-5 py-3.5 bg-gray-50 border-b border-gray-100 flex items-center gap-3">
                    <span class="text-lg">@ResourceIcon(group.Resource)</span>
                    <h3 class="font-semibold text-gray-700 capitalize">@group.Resource</h3>
                    <span class="ml-auto px-2 py-0.5 rounded-full bg-white border border-gray-200 text-xs text-gray-500">
                        @group.Items.Count permissions
                    </span>
                </div>
                <div class="divide-y divide-gray-50">
                    @foreach (var perm in group.Items)
                    {
                        <div class="px-5 py-3.5 flex items-center justify-between hover:bg-gray-50 transition-colors">
                            <div class="flex items-center gap-3">
                                <span class="font-mono text-sm text-indigo-700 bg-indigo-50 px-2 py-0.5 rounded">@perm.Name</span>
                                <span class="text-xs text-gray-400">@perm.Description</span>
                            </div>
                            <div class="flex items-center gap-2 shrink-0 ml-4">
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500 border border-gray-200">
                                    @perm.Action
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (!FilteredGroups.Any())
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-10 text-center">
                <p class="text-gray-400 text-sm">No permissions match "@_search"</p>
            </div>
        }
    }
</div>

@code {
    private bool _loading     = true;
    private bool _accessDenied;
    private string? _error;
    private string  _search   = "";

    private List<PermissionDef> _allPermissions = new();
    private List<PermissionGroup> _groups = new();

    private IEnumerable<PermissionGroup> FilteredGroups =>
        string.IsNullOrWhiteSpace(_search)
            ? _groups
            : _groups
                .Select(g => new PermissionGroup(g.Resource, g.Items
                    .Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                             || (p.Description ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase))
                    .ToList()))
                .Where(g => g.Items.Count > 0)
                .ToList();

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var me = await Http.GetFromJsonAsync<ApiResult<UserProfileDto>>("api/v1/users/me", JsonOpts);
            _accessDenied = !(me?.Data?.Permissions.Contains("permissions:read") ?? false);
            if (_accessDenied) { _loading = false; StateHasChanged(); return; }

            var resp = await Http.GetFromJsonAsync<ApiResult<List<PermissionDef>>>(
                "api/v1/managers/permissions/all", JsonOpts);
            _allPermissions = resp?.Data ?? new();

            _groups = _allPermissions
                .GroupBy(p => p.Resource)
                .OrderBy(g => g.Key)
                .Select(g => new PermissionGroup(g.Key, g.OrderBy(p => p.Action).ToList()))
                .ToList();
        }
        catch (Exception ex)
        {
            _error = "Could not load permissions: " + ex.Message;
        }
        finally
        {
            _loading = false; StateHasChanged();
        }
    }

    private static string ResourceIcon(string resource) => resource switch
    {
        "users"       => "👥",
        "vendors"     => "🏢",
        "crew"        => "👷",
        "events"      => "📅",
        "attendance"  => "📍",
        "payments"    => "💰",
        "sessions"    => "🔌",
        "audit"       => "📋",
        "roles"       => "🛡️",
        "permissions" => "🔑",
        "reports"     => "📊",
        "profile"     => "👤",
        _             => "⚙️"
    };

    private sealed record PermissionGroup(string Resource, List<PermissionDef> Items);
    private sealed record PermissionDef(Guid Id, string Name, string Resource, string Action, string? Description);
    private sealed record UserProfileDto(Guid Id, string FullName, IReadOnlyList<string> Permissions);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
