@page "/register/crew"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav

<PageTitle>Crew sign-up — EventWOS</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-orange-950 to-gray-900 py-10 px-4">
    <div class="max-w-xl mx-auto">
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-orange-600 text-white text-2xl mb-3 shadow-lg">🧑‍🔧</div>
                <h1 class="text-2xl font-bold text-gray-900">Crew Sign-up</h1>
                <p class="text-sm text-gray-500 mt-1">Join EventWOS under your vendor and start picking up shifts.</p>
            </div>

            @if (_success is not null)
            {
                <div class="px-4 py-4 rounded-xl bg-orange-50 border border-orange-200 text-orange-800 text-sm space-y-2">
                    <div class="font-semibold flex items-center gap-2">✅ Registration submitted</div>
                    <div>@_success</div>
                    <a href="/login/crew?reason=registered" class="inline-block text-orange-700 underline mt-1">Back to sign in</a>
                </div>
            }
            else
            {
                <div class="space-y-4">
                    @if (Ref is not null)
                    {
                        <div class="px-3 py-2 rounded-lg bg-orange-50 border border-orange-200 text-orange-800 text-xs flex items-center gap-2">
                            🎟️ <span>You're signing up under vendor referral code <strong>@Ref</strong>.</span>
                        </div>
                    }

                    <Field Label="Your full name" Required="true">
                        <input @bind="_fullName" class="@Css" placeholder="Alex Roy" />
                    </Field>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <Field Label="Username" Required="true" Hint="3–50 chars · letters, numbers, . _ -">
                            <input @bind="_username" class="@Css" placeholder="alexroy" autocomplete="username" />
                        </Field>
                        <Field Label="Email" Required="true">
                            <input @bind="_email" type="email" class="@Css" placeholder="you@example.com" autocomplete="email" />
                        </Field>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <Field Label="Mobile" Required="true">
                            <input @bind="_mobile" type="tel" class="@Css" placeholder="+91 98765 43210" autocomplete="tel" />
                        </Field>
                        <Field Label="Password" Required="true" Hint="Min 8 chars · 1 letter · 1 number">
                            <input @bind="_password" type="password" class="@Css" placeholder="••••••••" autocomplete="new-password" />
                        </Field>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        <Field Label="City">
                            <input @bind="_city" class="@Css" placeholder="Mumbai" />
                        </Field>
                        <Field Label="Years of experience">
                            <input @bind="_years" type="number" min="0" max="60" class="@Css" placeholder="3" />
                        </Field>
                    </div>

                    <Field Label="Skills (comma-separated)" Hint="e.g. stage, lighting, sound, security">
                        <input @bind="_skills" class="@Css" placeholder="stage, lighting" />
                    </Field>

                    <Field Label="Vendor referral code" Required="true"
                           Hint="Ask your vendor for this code — it's how we link you to their roster.">
                        <input @bind="_ref" class="@Css uppercase" placeholder="ABC12345" disabled="@(_refLocked)" maxlength="20" />
                    </Field>

                    <Field Label="About you (optional)">
                        <textarea @bind="_bio" rows="3" class="@Css" placeholder="A short intro about your event experience."></textarea>
                    </Field>

                    @if (_error is not null)
                    {
                        <div class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-sm">@_error</div>
                    }

                    <button type="button" @onclick="SubmitAsync" disabled="@_loading"
                            class="w-full py-3 rounded-xl bg-orange-600 text-white font-medium shadow-md hover:bg-orange-700 disabled:opacity-50">
                        @(_loading ? "Submitting…" : "Submit registration")
                    </button>

                    <p class="text-center text-xs text-gray-500 pt-2">
                        Already have an account? <a href="/login/crew" class="text-orange-600 hover:underline">Sign in</a>
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private const string Css = "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500 text-sm";

    /// <summary>?ref=ABC123 — prefills + locks the referral code field.</summary>
    [SupplyParameterFromQuery(Name = "ref")] public string? Ref { get; set; }

    private string _username = "", _email = "", _mobile = "", _password = "", _fullName = "";
    private string? _city, _skills, _bio;
    private string? _ref;
    private int? _years;
    private bool _refLocked;
    private string? _error, _success;
    private bool _loading;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(Ref))
        {
            _ref = Ref.Trim().ToUpperInvariant();
            _refLocked = true;
        }
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_email)
            || string.IsNullOrWhiteSpace(_mobile) || string.IsNullOrWhiteSpace(_password)
            || string.IsNullOrWhiteSpace(_fullName))
        {
            _error = "Please fill in all required fields."; return;
        }
        if (string.IsNullOrWhiteSpace(_ref))
        {
            _error = "A vendor referral code is required. Don't have one? Ask the vendor who invited you.";
            return;
        }
        _loading = true;
        try
        {
            var req = new RegisterCrewRequest(
                _username.Trim(), _email.Trim(), _mobile.Trim(), _password, _fullName.Trim(),
                string.IsNullOrWhiteSpace(_ref) ? null : _ref!.Trim(),
                _city, _skills, _years, _bio);
            var result = await AuthApi.RegisterCrewAsync(req);
            if (!result.Success)
            {
                _error = result.Errors?.FirstOrDefault() ?? result.Message ?? "Registration failed.";
                return;
            }
            _success = result.Data?.Message ?? "We've received your registration.";
        }
        catch { _error = "Network error. Please try again."; }
        finally { _loading = false; }
    }
}
