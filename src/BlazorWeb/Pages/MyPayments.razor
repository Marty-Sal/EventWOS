@page "/my-payments"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NotificationHubService Hub
@implements IAsyncDisposable

<div class="min-h-screen bg-gray-50 p-6">

    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">My Payments</h1>
        <p class="text-sm text-gray-500 mt-1">Track payment status for your completed events.</p>
    </div>

    <!-- Summary cards -->
    @if (_summary is not null)
    {
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Total Agreed</p>
                <p class="text-2xl font-bold text-gray-900 mt-1">@string.Format("₹{0:N0}", _summary.TotalAgreed)</p>
            </div>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Total Paid</p>
                <p class="text-2xl font-bold text-green-600 mt-1">@string.Format("₹{0:N0}", _summary.TotalPaid)</p>
            </div>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
                <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Pending</p>
                <p class="text-2xl font-bold text-amber-500 mt-1">@string.Format("₹{0:N0}", _summary.TotalPending)</p>
            </div>
        </div>
    }

    <!-- Tabs -->
    <div class="flex gap-2 mb-5">
        @foreach (var tab in _tabs)
        {
            var isActive = tab == _activeTab;
            <button @onclick="() => SetTab(tab)"
                    class="@(isActive
                        ? "px-4 py-2 rounded-full text-sm font-medium bg-indigo-600 text-white shadow"
                        : "px-4 py-2 rounded-full text-sm font-medium bg-white border border-gray-200 text-gray-600 hover:border-indigo-300")">
                @tab
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="text-center py-20 text-gray-400 text-sm animate-pulse">Loading payments…</div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">⚠️ @_error</div>
    }
    else if (!_items.Any())
    {
        <div class="text-center py-20">
            <p class="text-5xl mb-3">💳</p>
            <p class="text-gray-500 font-medium">No payment records yet.</p>
            <p class="text-gray-400 text-sm mt-1">Payment records appear once a vendor creates them for your assignments.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var p in _items)
            {
                var stage         = StageOf(p);
                var showAmount    = stage is "Paid";
                var stageLabel    = StageLabel(stage);
                var stageChip     = StageChipClass(stage);
                var showPendingCta = stage is "VendorPaid" or "Paid";
                <div class="bg-white rounded-2xl shadow-sm border p-5 @StageBorder(stage)">
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-gray-900 truncate">@p.EventTitle</p>
                            @if (!string.IsNullOrEmpty(p.VendorName))
                            {
                                <p class="text-xs text-gray-400 mt-0.5">Via vendor: @p.VendorName</p>
                            }
                            else
                            {
                                <p class="text-xs text-gray-400 mt-0.5">Direct from organiser</p>
                            }
                        </div>
                        <span class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold @stageChip">
                            @stageLabel
                        </span>
                    </div>

                    @if (showAmount)
                    {
                        <div class="mt-3 grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm">
                            <div>
                                <p class="text-xs text-gray-400">Amount Paid</p>
                                <p class="font-semibold text-emerald-700">@string.Format("₹{0:N0}", p.PaidAmount ?? p.AgreedAmount)</p>
                            </div>
                            @if (!string.IsNullOrEmpty(p.Method))
                            {
                                <div>
                                    <p class="text-xs text-gray-400">Method</p>
                                    <p class="font-medium text-gray-700">@p.Method</p>
                                </div>
                            }
                            @if (p.PaidAt.HasValue)
                            {
                                <div>
                                    <p class="text-xs text-gray-400">Paid On</p>
                                    <p class="font-medium text-gray-700">@p.PaidAt.Value.ToLocalTime().ToString("dd MMM yyyy")</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="mt-3 text-xs text-gray-500">@StageHelp(stage)</p>
                    }

                    @if (!string.IsNullOrEmpty(p.Notes))
                    {
                        <p class="mt-3 text-xs text-gray-400 italic">@p.Notes</p>
                    }

                    @* ── Crew acknowledgment ──────────────────────────────── *@
                    @if (showPendingCta)
                    {
                        <div class="mt-4 pt-4 border-t border-gray-100">
                            @if (p.CrewAcknowledgment == "Received")
                            {
                                <p class="text-sm font-semibold text-emerald-700">✓ You marked this as received on @(p.AcknowledgedAt?.ToLocalTime().ToString("dd MMM yyyy"))</p>
                            }
                            else if (p.CrewAcknowledgment == "Pending")
                            {
                                <p class="text-sm font-semibold text-amber-700">⏳ You reported this as pending</p>
                                @if (!string.IsNullOrEmpty(p.AcknowledgmentNote))
                                {
                                    <p class="text-xs text-gray-500 mt-1 italic">"@p.AcknowledgmentNote"</p>
                                }
                                <button class="mt-2 px-3 py-1.5 text-xs rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-semibold"
                                        @onclick="() => AckReceived(p.Id)">Got it now — Mark Received</button>
                            }
                            else
                            {
                                <p class="text-xs text-gray-500 mb-2">Did you receive this payment?</p>
                                <div class="flex flex-wrap gap-2">
                                    <button class="px-3 py-1.5 text-xs rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white font-semibold"
                                            @onclick="() => AckReceived(p.Id)">✓ Yes, Received</button>
                                    <button class="px-3 py-1.5 text-xs rounded-lg border border-amber-300 text-amber-700 hover:bg-amber-50 font-semibold"
                                            @onclick="() => OpenPending(p)">⏳ Not yet — Report Pending</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @if (_totalPages > 1)
        {
            <div class="flex justify-center items-center gap-4 mt-6">
                <button @onclick="PrevPage" disabled="@(_page <= 1)"
                        class="px-4 py-2 text-sm rounded-xl border border-gray-200 disabled:opacity-40 hover:bg-gray-50">
                    Prev
                </button>
                <span class="text-sm text-gray-500">Page @_page of @_totalPages</span>
                <button @onclick="NextPage" disabled="@(_page >= _totalPages)"
                        class="px-4 py-2 text-sm rounded-xl border border-gray-200 disabled:opacity-40 hover:bg-gray-50">
                    Next
                </button>
            </div>
        }
    }

</div>



@* ── Report Pending modal ───────────────────────────────────────────────────── *@
@if (_pendingTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50" @onclick="() => _pendingTarget = null">
        <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md" @onclick:stopPropagation="true">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Report Payment as Pending</h3>
            <p class="text-xs text-gray-500 mb-4">@_pendingTarget.EventTitle · @_pendingTarget.VendorName</p>

            <label class="block text-xs font-semibold text-gray-600 mb-1">What's the issue? (optional)</label>
            <textarea class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm h-24 resize-none"
                      placeholder="e.g. Amount short, transfer not received yet"
                      @bind="_pendingNote"></textarea>

            @if (_ackError is not null)
            {
                <p class="text-xs text-red-500 mt-3">@_ackError</p>
            }

            <div class="flex justify-end gap-2 mt-5">
                <button class="px-4 py-2 rounded-lg text-sm bg-gray-100 hover:bg-gray-200 text-gray-700" @onclick="() => _pendingTarget = null">Cancel</button>
                <button class="px-4 py-2 rounded-lg text-sm bg-amber-600 hover:bg-amber-700 text-white font-semibold disabled:opacity-50"
                        disabled="@_ackSaving" @onclick="ConfirmPending">
                    @(_ackSaving ? "Saving…" : "Report Pending")
                </button>
            </div>
        </div>
    </div>
}

@code {


    // ── Acknowledgment state ─────────────────────────────────────────────────
    private PaymentDto? _pendingTarget;
    private string?     _pendingNote;
    private bool        _ackSaving;
    private string?     _ackError;

    private void OpenPending(PaymentDto p)
    {
        _pendingTarget = p;
        _pendingNote   = null;
        _ackError      = null;
    }

    private async Task ConfirmPending()
    {
        if (_pendingTarget is null) return;
        _ackSaving = true; _ackError = null;
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/v1/payments/{_pendingTarget.Id}/status",
                new { action = "ack-pending", reason = _pendingNote });
            if (!resp.IsSuccessStatusCode)
            {
                _ackError = "Failed to report pending. Try again.";
                return;
            }
            _pendingTarget = null;
            await Load();
        }
        catch (Exception ex) { _ackError = ex.Message; }
        finally { _ackSaving = false; }
    }

    private Task AckReceived(Guid paymentId) => Ack(paymentId, "ack-received");

    private async Task Ack(Guid paymentId, string action)
    {
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/v1/payments/{paymentId}/status",
                new { action });
            if (resp.IsSuccessStatusCode) await Load();
        }
        catch { /* swallow — UI will refresh on next hub event */ }
    }

    // Record types first — Blazor requires types to be declared before use in field declarations
    private sealed record PaymentDto(
        Guid Id, Guid EventId, string EventTitle, Guid AssignmentId,
        Guid CrewId, string CrewName, string CrewMobile,
        Guid? VendorId, string? VendorName,
        decimal AgreedAmount, decimal? PaidAmount,
        string Status, string? Method, string? TransactionRef, string? Notes,
        DateTime? PaidAt, Guid? PayrollBatchId,
        string CrewAcknowledgment, DateTime? AcknowledgedAt, string? AcknowledgmentNote,
        string? BatchStatus,
        DateTime CreatedAt);

    private sealed record LocalPagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record LocalApiResult<T>(bool Success, T? Data, string? Message);
    private sealed record PaymentSummary(decimal TotalAgreed, decimal TotalPaid, decimal TotalPending);

    // Fields
    private readonly string[] _tabs = { "All", "Pending", "Paid", "Processing" };
    private string _activeTab = "All";
    private List<PaymentDto> _items = new();
    private PaymentSummary?  _summary;
    private bool    _loading = true;
    private string? _error;
    private int     _page = 1, _totalPages = 1, _total;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        Hub.PaymentChangedReceived += OnPaymentMoved;
        try { await Hub.StartAsync(); } catch { }
        await Load();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.PaymentChangedReceived -= OnPaymentMoved;
        await ValueTask.CompletedTask;
    }

    private void OnPaymentMoved(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await Load(); StateHasChanged(); });
    }

    private async Task SetTab(string tab) { _activeTab = tab; _page = 1; await Load(); }

    private async Task Load()
    {
        _loading = true; _error = null;
        try
        {
            var statusParam = _activeTab == "All" ? "" : ("&status=" + _activeTab);
            var url = "api/v1/payments/my?page=" + _page + "&pageSize=20" + statusParam;

            var resp = await Http.GetFromJsonAsync<LocalApiResult<LocalPagedResult<PaymentDto>>>(url, JsonOpts);
            _items      = resp?.Data?.Items?.ToList() ?? new();
            _total      = resp?.Data?.TotalCount ?? 0;
            _totalPages = (int)Math.Ceiling(_total / 20.0);
            if (_totalPages < 1) _totalPages = 1;

            // Load summary once
            if (_summary is null)
            {
                var allResp = await Http.GetFromJsonAsync<LocalApiResult<LocalPagedResult<PaymentDto>>>(
                    "api/v1/payments/my?page=1&pageSize=500", JsonOpts);
                var all = allResp?.Data?.Items?.ToList() ?? new();
                _summary = new PaymentSummary(
                    all.Sum(p => p.AgreedAmount),
                    all.Where(p => p.Status == "Paid").Sum(p => p.PaidAmount ?? p.AgreedAmount),
                    all.Where(p => p.Status == "Pending").Sum(p => p.AgreedAmount));
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await Load(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await Load(); } }

    private static string StatusChip(string s) => s switch
    {
        "Paid"       => "bg-green-50 text-green-700 border border-green-200",
        "Pending"    => "bg-amber-50 text-amber-700 border border-amber-200",
        "Processing" => "bg-blue-50 text-blue-700 border border-blue-200",
        "Cancelled"  => "bg-red-50 text-red-600 border border-red-100",
        _            => "bg-gray-100 text-gray-500"
    };

    private static string StatusLabel(string s) => s switch
    {
        "Paid"       => "Paid",
        "Pending"    => "Pending",
        "Processing" => "Processing",
        "Cancelled"  => "Cancelled",
        _            => s
    };

    private static string BorderColor(string s) => s switch
    {
        "Paid"       => "border-green-100",
        "Pending"    => "border-amber-100",
        "Processing" => "border-blue-100",
        _            => "border-gray-100"
    };


    // ── Stage-aware UI helpers ─────────────────────────────────────────────────
    // Stage values:
    //   DraftingForVendor  — vendor row, batch is Draft/Submitted/Approved (manager hasn't paid vendor yet)
    //   VendorPaid         — vendor row, batch is Disbursed but crew row still Approved (vendor hasn't paid out)
    //   Drafting           — direct row, batch not Disbursed yet
    //   AwaitingPayout     — direct row, batch Disbursed but not yet Paid
    //   Paid               — payment row Status == Paid
    //   Pending            — payment row Status == Pending (no batch yet)
    //   Rejected / OnHold  — terminal/edge
    private static string StageOf(PaymentDto p)
    {
        if (p.Status == "Paid")     return "Paid";
        if (p.Status == "Rejected") return "Rejected";
        if (p.Status == "OnHold")   return "OnHold";
        if (p.Status == "Pending")  return "Pending";

        // Status == Approved → drill into batch state
        var batchDisbursed = p.BatchStatus == "Disbursed";
        if (p.VendorId is not null)
            return batchDisbursed ? "VendorPaid" : "DraftingForVendor";
        return batchDisbursed ? "AwaitingPayout" : "Drafting";
    }

    private static string StageLabel(string stage) => stage switch
    {
        "Paid"              => "Paid",
        "Pending"           => "Pending",
        "Rejected"          => "Rejected",
        "OnHold"            => "On Hold",
        "DraftingForVendor" => "Drafting payment to vendor",
        "VendorPaid"        => "Vendor paid — awaiting your payout",
        "Drafting"          => "Drafting",
        "AwaitingPayout"    => "Payout being processed",
        _                   => stage
    };

    private static string StageChipClass(string stage) => stage switch
    {
        "Paid"              => "bg-emerald-50 text-emerald-700 border border-emerald-200",
        "VendorPaid"        => "bg-blue-50 text-blue-700 border border-blue-200",
        "DraftingForVendor" => "bg-slate-50 text-slate-600 border border-slate-200",
        "Drafting"          => "bg-slate-50 text-slate-600 border border-slate-200",
        "AwaitingPayout"    => "bg-blue-50 text-blue-700 border border-blue-200",
        "Pending"           => "bg-amber-50 text-amber-700 border border-amber-200",
        "Rejected"          => "bg-red-50 text-red-600 border border-red-100",
        "OnHold"            => "bg-orange-50 text-orange-700 border border-orange-200",
        _                   => "bg-gray-100 text-gray-500"
    };

    private static string StageBorder(string stage) => stage switch
    {
        "Paid"              => "border-emerald-100",
        "VendorPaid"        => "border-blue-100",
        "AwaitingPayout"    => "border-blue-100",
        "DraftingForVendor" => "border-slate-100",
        "Drafting"          => "border-slate-100",
        _                   => "border-gray-100"
    };

    private static string StageHelp(string stage) => stage switch
    {
        "DraftingForVendor" => "Organiser is drafting payment to the vendor. Your individual amount will appear here once the vendor finalises it.",
        "VendorPaid"        => "Organiser has paid the vendor. Awaiting the vendor to pay you out.",
        "Drafting"          => "Organiser is drafting your payment.",
        "AwaitingPayout"    => "Your payment has been approved and is being processed.",
        "Pending"           => "Payment record was just created — pending approval.",
        "Rejected"          => "This payment was rejected. Contact the organiser if you have questions.",
        "OnHold"            => "This payment is on hold. Contact the organiser for details.",
        _                   => ""
    };
}
