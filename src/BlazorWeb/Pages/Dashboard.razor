@page "/dashboard"
@attribute [Authorize]
@inject IUserApiService      UserApi
@inject IAnalyticsApiService AnalyticsApi

<PageTitle>Dashboard — EventWOS</PageTitle>

<style>
    .stat-card { transition: box-shadow .15s; }
    .stat-card:hover { box-shadow: 0 4px 20px rgba(99,102,241,.12); }
    .prog-bar { height: 6px; border-radius: 9999px; transition: width .4s ease; }
</style>

<div class="space-y-6">

    @* ── Welcome banner ──────────────────────────────────────────────── *@
    <div class="bg-gradient-to-r from-indigo-600 to-purple-700 rounded-2xl p-6 text-white shadow-lg flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div>
            <h2 class="text-2xl font-bold">
                Welcome back, @(_profile?.FullName.Split(' ').FirstOrDefault() ?? "there") 👋
            </h2>
            <p class="text-indigo-200 mt-1 text-sm">
                <span class="font-semibold text-white">@_profile?.Role</span>
                · Last login: @(_profile?.LastLoginAt?.ToString("dd MMM yyyy, HH:mm") ?? "—")
            </p>
        </div>
        <div class="text-right hidden md:block">
            <p class="text-indigo-200 text-xs uppercase tracking-widest font-semibold">EventWOS</p>
            <p class="text-white text-sm font-medium">@DateTime.Now.ToString("dddd, dd MMM yyyy")</p>
        </div>
    </div>

    @* ── Admin / Manager full analytics ──────────────────────────────── *@
    <AuthorizeView Roles="Admin,Manager">
        <Authorized>
            @if (_loading)
            {
                <div class="flex items-center justify-center py-16">
                    <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-indigo-600"></div>
                </div>
            }
            else if (_stats is not null)
            {
                @* Top KPI row *@
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-xl bg-indigo-50 flex items-center justify-center text-2xl">📅</div>
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Total Events</p>
                                <p class="text-2xl font-bold text-gray-800">@_stats.TotalEvents</p>
                                <p class="text-xs text-gray-400 mt-0.5">@_stats.InProgressEvents live · @_stats.PublishedEvents upcoming</p>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-xl bg-sky-50 flex items-center justify-center text-2xl">👷</div>
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Total Crew</p>
                                <p class="text-2xl font-bold text-gray-800">@_stats.TotalCrew</p>
                                <p class="text-xs text-gray-400 mt-0.5">@_stats.TotalVendors vendors</p>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-xl bg-purple-50 flex items-center justify-center text-2xl">📋</div>
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Assignments</p>
                                <p class="text-2xl font-bold text-gray-800">@_stats.TotalAssignments</p>
                                <p class="text-xs text-gray-400 mt-0.5">@_stats.ConfirmedAssignments confirmed · @_stats.PendingAssignments pending</p>
                            </div>
                        </div>
                    </div>
                    <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                        <div class="flex items-center gap-3">
                            <div class="w-11 h-11 rounded-xl bg-green-50 flex items-center justify-center text-2xl">✅</div>
                            <div>
                                <p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Attendance Rate</p>
                                <p class="text-2xl font-bold text-gray-800">@_stats.AttendanceRate%</p>
                                <p class="text-xs text-gray-400 mt-0.5">@_stats.TotalCheckIns check-ins</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Status breakdowns *@
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    @* Event status *@
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                        <h3 class="text-sm font-semibold text-gray-700 mb-5">Event Status Breakdown</h3>
                        <div class="space-y-3">
                            @ProgressBar("Draft",       _stats.DraftEvents,      _stats.TotalEvents, "bg-gray-300")
                            @ProgressBar("Published",   _stats.PublishedEvents,  _stats.TotalEvents, "bg-blue-400")
                            @ProgressBar("In Progress", _stats.InProgressEvents, _stats.TotalEvents, "bg-amber-400")
                            @ProgressBar("Completed",   _stats.CompletedEvents,  _stats.TotalEvents, "bg-green-500")
                            @ProgressBar("Cancelled",   _stats.CancelledEvents,  _stats.TotalEvents, "bg-red-400")
                        </div>
                    </div>

                    @* Assignment status *@
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                        <h3 class="text-sm font-semibold text-gray-700 mb-5">Assignment Overview</h3>
                        <div class="space-y-3">
                            @ProgressBar("Pending (Invited)", _stats.PendingAssignments,   _stats.TotalAssignments, "bg-amber-400")
                            @ProgressBar("Confirmed",         _stats.ConfirmedAssignments, _stats.TotalAssignments, "bg-green-500")
                            @ProgressBar("Declined",          _stats.DeclinedAssignments,  _stats.TotalAssignments, "bg-red-400")
                        </div>
                        <div class="mt-6 pt-4 border-t border-gray-50 grid grid-cols-3 gap-4 text-center">
                            <div>
                                <p class="text-xl font-bold text-gray-800">@_stats.TotalVendors</p>
                                <p class="text-xs text-gray-400 mt-0.5">Vendors</p>
                            </div>
                            <div>
                                <p class="text-xl font-bold text-gray-800">@_stats.TotalCrew</p>
                                <p class="text-xs text-gray-400 mt-0.5">Crew</p>
                            </div>
                            <div>
                                <p class="text-xl font-bold text-gray-800">@_stats.TotalCheckIns</p>
                                <p class="text-xs text-gray-400 mt-0.5">Check-ins</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* Upcoming events + Top vendors *@
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    @* Upcoming events *@
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                        <h3 class="text-sm font-semibold text-gray-700 mb-4">📅 Upcoming Events</h3>
                        @if (!_stats.UpcomingEvents.Any())
                        {
                            <div class="text-center py-8">
                                <p class="text-3xl mb-2">🗓️</p>
                                <p class="text-gray-400 text-sm">No upcoming events</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-3">
                                @foreach (var e in _stats.UpcomingEvents)
                                {
                                    <div class="flex items-start gap-3 p-3 rounded-xl bg-gray-50 hover:bg-indigo-50 transition-colors cursor-default">
                                        <div class="w-10 h-10 rounded-xl bg-indigo-100 flex items-center justify-center text-lg flex-shrink-0">
                                            @StatusIcon(e.Status)
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-gray-800 truncate">@e.Title</p>
                                            <p class="text-xs text-gray-400">📍 @e.Venue</p>
                                            <p class="text-xs text-gray-400">🗓️ @e.StartAt.ToLocalTime().ToString("dd MMM, HH:mm")</p>
                                        </div>
                                        <div class="text-right flex-shrink-0">
                                            <p class="text-xs font-bold @(e.AssignedCrew >= e.MaxCrew ? "text-green-600" : "text-indigo-600")">
                                                @e.AssignedCrew / @e.MaxCrew
                                            </p>
                                            <p class="text-xs text-gray-400">crew</p>
                                            <span class="inline-block mt-1 px-1.5 py-0.5 rounded text-xs font-medium
                                                @(e.Status == "InProgress" ? "bg-amber-100 text-amber-700" : "bg-blue-100 text-blue-700")">
                                                @e.Status
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @* Top vendors *@
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                        <h3 class="text-sm font-semibold text-gray-700 mb-4">🏆 Top Vendors</h3>
                        @if (!_stats.TopVendors.Any())
                        {
                            <div class="text-center py-8">
                                <p class="text-3xl mb-2">🏢</p>
                                <p class="text-gray-400 text-sm">No vendor data yet</p>
                            </div>
                        }
                        else
                        {
                            <div class="space-y-3">
                                @foreach (var (v, i) in _stats.TopVendors.Select((v, i) => (v, i)))
                                {
                                    <div class="flex items-center gap-3">
                                        <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0
                                            @(i == 0 ? "bg-amber-100 text-amber-700" :
                                              i == 1 ? "bg-slate-100 text-slate-600"  :
                                              i == 2 ? "bg-orange-100 text-orange-700" : "bg-gray-50 text-gray-400")">
                                            @(i + 1)
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-gray-800 truncate">@v.VendorName</p>
                                            <p class="text-xs text-gray-400">@v.CrewCount crew · @v.AssignmentsCount assignments</p>
                                        </div>
                                        <span class="flex-shrink-0 text-xs font-bold px-2 py-1 rounded-full
                                            @(v.ConfirmationRate >= 75 ? "bg-green-100 text-green-700" :
                                              v.ConfirmationRate >= 50 ? "bg-amber-100 text-amber-700" :
                                              "bg-red-100 text-red-700")">
                                            @v.ConfirmationRate%
                                        </span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                @* ── Needs Staffing — vendor-only events awaiting crew ── *@
                @if (_stats.NeedsStaffing.Any())
                {
                    <div class="bg-white rounded-2xl border border-amber-200 shadow-sm p-6">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-sm font-semibold text-gray-700 flex items-center gap-2">
                                ⚠️ Needs Staffing
                                <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 text-xs font-bold">@_stats.NeedsStaffing.Count</span>
                            </h3>
                            <p class="text-xs text-gray-400">Vendor assigned, no crew yet</p>
                        </div>
                        <div class="space-y-2">
                            @foreach (var ns in _stats.NeedsStaffing)
                            {
                                <div class="flex items-center justify-between p-3 rounded-xl bg-amber-50/50 border border-amber-100 hover:bg-amber-50 transition-colors">
                                    <div class="min-w-0 flex-1">
                                        <p class="text-sm font-semibold text-gray-800 truncate">@ns.EventTitle</p>
                                        <p class="text-xs text-gray-500 mt-0.5">
                                            🗓 @ns.StartAt.ToLocalTime().ToString("dd MMM, HH:mm")
                                            · 📍 @ns.Venue
                                        </p>
                                        <p class="text-xs text-gray-500 mt-0.5">
                                            👤 Vendor: <span class="font-medium text-gray-700">@ns.VendorName</span>
                                        </p>
                                    </div>
                                    <div class="flex-shrink-0 text-right ml-3">
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold
                                            @(ns.AssignedSoFar == 0
                                                ? "bg-red-100 text-red-700"
                                                : ns.AssignedSoFar < ns.MaxCrew
                                                    ? "bg-amber-100 text-amber-700"
                                                    : "bg-green-100 text-green-700")">
                                            @ns.AssignedSoFar / @ns.MaxCrew
                                        </span>
                                        <p class="text-[10px] text-gray-400 mt-1">crew</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Recent activity feed *@
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-gray-700 mb-4">🕐 Recent Activity</h3>
                    @if (!_stats.RecentActivity.Any())
                    {
                        <p class="text-gray-400 text-sm text-center py-4">No activity recorded yet</p>
                    }
                    else
                    {
                        <div class="space-y-0">
                            @foreach (var act in _stats.RecentActivity)
                            {
                                <div class="flex items-center gap-3 py-2.5 border-b border-gray-50 last:border-0">
                                    <div class="w-8 h-8 rounded-full bg-indigo-50 flex items-center justify-center text-sm flex-shrink-0">
                                        @ActivityIcon(act.Action)
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="text-xs font-semibold text-gray-700">
                                            <span class="font-mono text-indigo-600">@act.Action.Replace("_"," ")</span>
                                            <span class="text-gray-400 font-normal"> · @act.Actor</span>
                                        </p>
                                        <p class="text-xs text-gray-400 truncate">@act.Target</p>
                                    </div>
                                    <p class="text-xs text-gray-400 whitespace-nowrap flex-shrink-0">
                                        @act.At.ToLocalTime().ToString("dd MMM HH:mm")
                                    </p>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </Authorized>
    </AuthorizeView>

    @* ── Crew / Vendor personal view ──────────────────────────────────── *@
    <AuthorizeView Roles="Crew,Vendor">
        <Authorized>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-indigo-50 flex items-center justify-center text-2xl">🛡️</div>
                    <div><p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Role</p><p class="text-lg font-bold text-gray-800">@(_profile?.Role ?? "—")</p></div>
                </div>
                <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-green-50 flex items-center justify-center text-2xl">✅</div>
                    <div><p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Status</p><p class="text-lg font-bold text-gray-800">@(_profile?.Status ?? "—")</p></div>
                </div>
                <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-amber-50 flex items-center justify-center text-2xl">🔑</div>
                    <div><p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Permissions</p><p class="text-lg font-bold text-gray-800">@(_profile?.Permissions.Count ?? 0)</p></div>
                </div>
                <div class="stat-card bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex items-center gap-4">
                    <div class="w-11 h-11 rounded-xl bg-sky-50 flex items-center justify-center text-2xl">📱</div>
                    <div><p class="text-xs text-gray-400 uppercase tracking-wider font-medium">Mobile</p><p class="text-lg font-bold text-gray-800">@(_profile?.Mobile ?? "—")</p></div>
                </div>
            </div>

            @if (_profile?.Permissions.Any() == true)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
                    <h3 class="text-sm font-semibold text-gray-700 mb-4">Your Permissions</h3>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var perm in _profile.Permissions.OrderBy(p => p))
                        {
                            <span class="px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-xs font-mono font-medium border border-indigo-100">@perm</span>
                        }
                    </div>
                </div>
            }
        </Authorized>
    </AuthorizeView>

</div>

@code {
    private UserProfileDto?    _profile;
    private DashboardStatsDto? _stats;
    private bool               _loading;

    protected override async Task OnInitializedAsync()
    {
        _profile = await UserApi.GetMeAsync();

        if (_profile?.Role is "Admin" or "Manager")
        {
            _loading = true;
            _stats   = await AnalyticsApi.GetDashboardStatsAsync();
            _loading = false;
        }
    }

    private RenderFragment ProgressBar(string label, int count, int total, string colorClass) =>
        @<div>
            <div class="flex justify-between mb-1">
                <span class="text-xs text-gray-600 font-medium">@label</span>
                <span class="text-xs text-gray-400 font-semibold">@count</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full" style="height:6px">
                <div class="prog-bar @colorClass rounded-full"
                     style="width: @(total > 0 ? Math.Round((double)count / total * 100, 1) : 0)%">
                </div>
            </div>
        </div>;

    private static string StatusIcon(string status) => status switch
    {
        "Published"  => "📢",
        "InProgress" => "🔴",
        "Completed"  => "✅",
        "Cancelled"  => "❌",
        _            => "📝"
    };

    private static string ActivityIcon(string action) => action switch
    {
        var a when a.Contains("Login")      => "🔑",
        var a when a.Contains("Otp")        => "📱",
        var a when a.Contains("User")       => "👤",
        var a when a.Contains("Session")    => "🔌",
        var a when a.Contains("Permission") => "🛡️",
        var a when a.Contains("Token")      => "🔄",
        _                                   => "📋"
    };
}
