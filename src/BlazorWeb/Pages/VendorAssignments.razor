@page "/vendor-assignments"
@attribute [Authorize(Roles = "Vendor")]
@inject HttpClient Http
@inject NotificationHubService Hub
@implements IAsyncDisposable

<PageTitle>Approvals · Events — EventWOS</PageTitle>

<div class="space-y-6">
    <ApprovalTabsHeader Active="events" EventsCount="@_awaitingCount" />

    <div>
        <h2 class="text-lg font-bold text-gray-800">Crew event responses</h2>
        <p class="text-sm text-gray-500 mt-0.5">Review crew responses and approve or reject before forwarding to Manager.</p>
    </div>

    @* Tab filter *@
    <div class="flex gap-2 flex-wrap">
        @foreach (var tab in _tabs)
        {
            <button @onclick="() => SetTab(tab)"
                    class="px-4 py-1.5 rounded-full text-xs font-semibold transition
                           @(_activeTab == tab ? "bg-indigo-600 text-white shadow" : "bg-white text-gray-500 border border-gray-200 hover:border-indigo-300")">
                @tab
                @if (tab == "Awaiting Review" && _awaitingCount > 0)
                {
                    <span class="ml-1.5 px-1.5 py-0.5 rounded-full bg-amber-400 text-white text-[10px] font-bold">@_awaitingCount</span>
                }
            </button>
        }
    </div>

    @* Phase D step 20: filter bar + view toggle. Mirrors the Events page
       pattern: search input + Event dropdown + Shift dropdown + Cards/List
       toggle. All three filters are populated from the current dataset so
       they always reflect what's on screen. Tab filter (above) and these
       filters stack — they intersect. *@
    <div class="flex flex-wrap gap-3 items-center bg-white rounded-2xl border border-gray-100 shadow-sm px-3 py-2.5">
        <div class="relative">
            <input @bind="_search" @bind:event="oninput"
                   placeholder="Search crew or event…"
                   class="w-64 pl-9 pr-4 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
        </div>
        <select @bind="_eventFilter"
                class="px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">All Events</option>
            @foreach (var opt in EventOptions)
            {
                <option value="@opt.Id">@opt.Title</option>
            }
        </select>
        <select @bind="_shiftFilter"
                class="px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">All Shifts</option>
            @foreach (var opt in ShiftOptions)
            {
                <option value="@opt.Id">@opt.Label</option>
            }
        </select>

        @if (HasActiveFilters)
        {
            <button @onclick="ClearFilters"
                    class="px-3 py-2 rounded-xl border border-gray-200 text-xs text-gray-600 hover:bg-gray-50 transition">
                Clear filters
            </button>
        }

        <div class="ml-auto inline-flex rounded-xl border border-gray-200 bg-white p-0.5">
            <button @onclick='() => _viewMode = "cards"'
                    class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "cards" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                🔲 Cards
            </button>
            <button @onclick='() => _viewMode = "list"'
                    class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "list" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                ☰ List
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="flex justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">@_error</div>
    }
    else if (!Filtered.Any())
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-4xl mb-3">@TabIcon</p>
            <p class="font-semibold text-gray-700 text-sm">No assignments in this category</p>
        </div>
    }
    else if (_viewMode == "cards")
    {
        <div class="space-y-3">
            @foreach (var a in Filtered)
            {
                <div class="bg-white rounded-2xl border @BorderColor(a.Status) shadow-sm p-5">
                    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                        <div class="flex-1 space-y-1.5">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="font-bold text-gray-800 text-sm">@a.CrewName</span>
                                <span class="text-xs text-gray-400">@a.CrewMobile</span>
                                @{
                                    var (lbl, badge, sub) = AssignmentStatusDisplay.For(a.Status, a.EventStatus, a.AttendanceNote);
                                }
                                <div class="flex flex-col gap-0.5">
                                    <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold @badge">@lbl</span>
                                    @if (!string.IsNullOrEmpty(sub))
                                    {
                                        <span class="text-[10px] text-gray-400 italic">@sub</span>
                                    }
                                </div>
                            </div>
                            <p class="text-xs text-gray-500">Event: <span class="font-medium text-gray-700">@a.EventTitle</span></p>
                            @{ var shiftLabel = BuildShiftLabel(a); }
                            @if (shiftLabel is not null)
                            {
                                <div class="flex items-center gap-1.5 text-[11px] text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-full px-2 py-0.5 w-fit mt-1">
                                    <span>🎯</span>
                                    <span class="font-semibold">@shiftLabel</span>
                                </div>
                            }
                            <div class="flex items-center gap-4 text-xs text-gray-400">
                                <span>🎯 Score: <span class="font-semibold @DisciplineColor(a.DisciplineScore)">@a.DisciplineScore.ToString("F0")</span></span>
                                <span>📅 Events attended: <span class="font-semibold text-gray-600">@a.EventsAttended</span></span>
                            </div>
                            @if (a.RejectionReason is not null)
                            {
                                <p class="text-xs text-red-500 mt-1">Rejected: @a.RejectionReason</p>
                            }
                        </div>

                        @* Actions — for VendorApproved (crew accepted) OR Invited (vendor can bypass) *@
                        @if (a.Status == "VendorApproved")
                        {
                            <div class="flex gap-2 shrink-0">
                                <button @onclick="() => OpenReject(a)"
                                        disabled="@(_busy == a.Id)"
                                        class="px-3 py-1.5 rounded-xl text-xs font-semibold border border-red-200 text-red-600
                                               hover:bg-red-50 disabled:opacity-50 transition">
                                    ✕ Reject
                                </button>
                                <button @onclick="() => DoApprove(a.Id)"
                                        disabled="@(_busy == a.Id)"
                                        class="px-4 py-1.5 rounded-xl text-xs font-semibold bg-indigo-600 text-white
                                               hover:bg-indigo-700 disabled:opacity-50 transition shadow">
                                    @(_busy == a.Id ? "…" : "✓ Send to Manager")
                                </button>
                            </div>
                        }
                        @if (a.Status == "Invited")
                        {
                            <div class="flex flex-col items-end gap-1.5 shrink-0">
                                <p class="text-[10px] text-gray-400 text-right">Crew hasn't responded yet</p>
                                <div class="flex gap-2">
                                    <button @onclick="() => OpenReject(a)"
                                            disabled="@(_busy == a.Id)"
                                            class="px-3 py-1.5 rounded-xl text-xs font-semibold border border-red-200 text-red-600
                                                   hover:bg-red-50 disabled:opacity-50 transition">
                                        ✕ Cancel
                                    </button>
                                    <button @onclick="() => DoDirectForward(a.Id)"
                                            disabled="@(_busy == a.Id)"
                                            class="px-4 py-1.5 rounded-xl text-xs font-semibold bg-amber-500 text-white
                                                   hover:bg-amber-600 disabled:opacity-50 transition shadow"
                                            title="Forward to Manager without waiting for crew to accept (offline confirmation)">
                                        @(_busy == a.Id ? "…" : "⚡ Force Forward")
                                    </button>
                                </div>
                            </div>
                        }
                        @* Star rating — only for Attended, not yet rated *@
                        @if (a.Status == "Attended" && !a.VendorRating.HasValue)
                        {
                            <div class="shrink-0 flex flex-col items-end gap-1">
                                <p class="text-xs text-gray-400">Rate crew performance</p>
                                <div class="flex gap-1">
                                    @for (int s = 1; s <= 5; s++)
                                    {
                                        var star = s; // capture loop variable
                                        <button @onclick="() => SubmitRating(a.Id, star)"
                                                class="text-xl leading-none @(_hoverStar >= star && _hoverTarget == a.Id ? "text-amber-400" : "text-gray-300")
                                                       hover:text-amber-400 transition-colors"
                                                @onmouseover="() => SetHover(a.Id, star)"
                                                @onmouseout="() => ClearHover()">
                                            ★
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        @if (a.Status == "Attended" && a.VendorRating.HasValue)
                        {
                            <div class="shrink-0 text-right">
                                <p class="text-xs text-gray-400">Your rating</p>
                                <p class="text-amber-500 font-bold">@string.Concat(Enumerable.Repeat("★", (int)a.VendorRating.Value))@string.Concat(Enumerable.Repeat("☆", 5 - (int)a.VendorRating.Value))</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        @* Phase D step 20: compact list view. Same filters / actions as the
           card view, just denser. Mirrors Events page list style: white card,
           thin border, table-like rows with hover. Action buttons are
           condensed to icon-style for tighter horizontal space. *@
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full text-xs">
                    <thead class="bg-gray-50 text-gray-500 uppercase tracking-wide">
                        <tr>
                            <th class="text-left px-4 py-2.5 font-semibold">Crew</th>
                            <th class="text-left px-4 py-2.5 font-semibold">Event</th>
                            <th class="text-left px-4 py-2.5 font-semibold">Shift</th>
                            <th class="text-left px-4 py-2.5 font-semibold">Score</th>
                            <th class="text-left px-4 py-2.5 font-semibold">Status</th>
                            <th class="text-right px-4 py-2.5 font-semibold">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        @foreach (var a in Filtered)
                        {
                            var (lbl, badge, _) = AssignmentStatusDisplay.For(a.Status, a.EventStatus, a.AttendanceNote);
                            var shiftLbl = BuildShiftLabel(a) ?? "—";
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-4 py-2.5">
                                    <div class="font-semibold text-gray-800">@a.CrewName</div>
                                    <div class="text-[11px] text-gray-400">@a.CrewMobile</div>
                                </td>
                                <td class="px-4 py-2.5 text-gray-700">@a.EventTitle</td>
                                <td class="px-4 py-2.5 text-gray-600">@shiftLbl</td>
                                <td class="px-4 py-2.5">
                                    <span class="font-semibold @DisciplineColor(a.DisciplineScore)">@a.DisciplineScore.ToString("F0")</span>
                                </td>
                                <td class="px-4 py-2.5">
                                    <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold @badge">@lbl</span>
                                </td>
                                <td class="px-4 py-2.5">
                                    <div class="flex gap-1.5 justify-end">
                                        @if (a.Status == "VendorApproved")
                                        {
                                            <button @onclick="() => OpenReject(a)" disabled="@(_busy == a.Id)"
                                                    class="px-2.5 py-1 rounded-lg text-[11px] font-semibold border border-red-200 text-red-600 hover:bg-red-50 disabled:opacity-50">
                                                ✕
                                            </button>
                                            <button @onclick="() => DoApprove(a.Id)" disabled="@(_busy == a.Id)"
                                                    class="px-2.5 py-1 rounded-lg text-[11px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50">
                                                ✓ Send
                                            </button>
                                        }
                                        else if (a.Status == "Invited")
                                        {
                                            <button @onclick="() => OpenReject(a)" disabled="@(_busy == a.Id)"
                                                    class="px-2.5 py-1 rounded-lg text-[11px] font-semibold border border-red-200 text-red-600 hover:bg-red-50 disabled:opacity-50">
                                                ✕ Cancel
                                            </button>
                                            <button @onclick="() => DoDirectForward(a.Id)" disabled="@(_busy == a.Id)"
                                                    class="px-2.5 py-1 rounded-lg text-[11px] font-semibold bg-amber-500 text-white hover:bg-amber-600 disabled:opacity-50"
                                                    title="Force forward to Manager without crew response">
                                                ⚡ Forward
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-[11px] text-gray-300">—</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (_toast is not null)
    {
        <div class="fixed bottom-6 right-6 z-50 px-5 py-3 rounded-2xl shadow-xl text-sm font-medium
                    @(_toastError ? "bg-red-600 text-white" : "bg-green-600 text-white")">
            @_toast
        </div>
    }
</div>

@* Reject modal *@
@if (_rejectTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 space-y-4">
            <h3 class="font-bold text-gray-800">Reject Crew Application</h3>
            <p class="text-sm text-gray-500">
                Rejecting <span class="font-semibold text-gray-700">@_rejectTarget.CrewName</span>
                for <span class="font-semibold text-gray-700">@_rejectTarget.EventTitle</span>.
            </p>
            <div>
                <label class="block text-xs font-semibold text-gray-600 mb-1">Rejection Reason <span class="text-red-500">*</span></label>
                <textarea @bind="_rejectReason" rows="3"
                          class="w-full px-3 py-2 text-sm rounded-xl border @(_reasonError ? "border-red-400" : "border-gray-200")
                                 focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"
                          placeholder="Describe why this crew member is not suitable…" />
                @if (_reasonError)
                {
                    <p class="text-xs text-red-500 mt-1">Rejection reason is mandatory.</p>
                }
            </div>
            <div class="flex gap-2 pt-1">
                <button @onclick="CancelReject"
                        class="flex-1 py-2 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                    Cancel
                </button>
                <button @onclick="ConfirmReject" disabled="@_busy.HasValue"
                        class="flex-1 py-2 rounded-xl bg-red-600 text-white text-sm font-semibold
                               hover:bg-red-700 disabled:opacity-50 transition">
                    @(_busy.HasValue ? "Rejecting…" : "Confirm Reject")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private readonly string[] _tabs = { "All", "Awaiting Review", "Forwarded", "Rejected", "Confirmed" };
    private string _activeTab = "All";

    // Phase D step 20: new filter / view state.
    private string  _search      = "";
    private string  _eventFilter = "";
    private string  _shiftFilter = "";
    private string  _viewMode    = "cards"; // "cards" | "list"

    private List<AssignmentDto> _all = new();
    private bool    _loading = true;
    private string? _error;
    private int     _awaitingCount;
    private Guid?   _busy;

    private AssignmentDto? _rejectTarget;
    private string  _rejectReason  = "";
    private bool    _reasonError;

    private string? _toast;
    private bool    _toastError;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    // Phase D step 20: filtered set used by both card and list views. The
    // tab buckets the rows by status; then search / event / shift filters
    // further narrow. Order: tab → search → event → shift. All filters
    // intersect (AND).
    private IEnumerable<AssignmentDto> Filtered
    {
        get
        {
            IEnumerable<AssignmentDto> src = _activeTab switch
            {
                "Awaiting Review" => _all.Where(a => a.Status is "Invited" or "VendorApproved"),
                "Forwarded"       => _all.Where(a => a.Status is "PendingManagerApproval" or "ManagerApproved"),
                "Rejected"        => _all.Where(a => a.Status is "RejectedByVendor" or "RejectedByManager" or "Declined"),
                "Confirmed"       => _all.Where(a => a.Status is "ManagerApproved" or "Confirmed" or "Attended"),
                _                 => _all
            };
            if (!string.IsNullOrWhiteSpace(_search))
            {
                var q = _search.Trim();
                src = src.Where(a =>
                    (a.CrewName    ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    (a.EventTitle  ?? "").Contains(q, StringComparison.OrdinalIgnoreCase) ||
                    (a.CrewMobile  ?? "").Contains(q, StringComparison.OrdinalIgnoreCase));
            }
            if (!string.IsNullOrWhiteSpace(_eventFilter) && Guid.TryParse(_eventFilter, out var evId))
                src = src.Where(a => a.EventId == evId);
            if (!string.IsNullOrWhiteSpace(_shiftFilter) && Guid.TryParse(_shiftFilter, out var shId))
                src = src.Where(a => a.ShiftId == shId);
            return src;
        }
    }

    // Event dropdown options — built from the rows currently loaded so it
    // always reflects what's visible. Distinct + alphabetised.
    private IEnumerable<(Guid Id, string Title)> EventOptions =>
        _all.Where(a => a.EventId != Guid.Empty)
            .GroupBy(a => a.EventId)
            .Select(g => (g.Key, g.First().EventTitle ?? "(untitled)"))
            .OrderBy(t => t.Item2);

    // Shift dropdown — same approach. Label is the "Scope · time" string.
    private IEnumerable<(Guid Id, string Label)> ShiftOptions =>
        _all.Where(a => a.ShiftId.HasValue)
            .GroupBy(a => a.ShiftId!.Value)
            .Select(g => (g.Key, BuildShiftLabel(g.First()) ?? "(unnamed shift)"))
            .OrderBy(t => t.Item2);

    private bool HasActiveFilters =>
        !string.IsNullOrWhiteSpace(_search) ||
        !string.IsNullOrWhiteSpace(_eventFilter) ||
        !string.IsNullOrWhiteSpace(_shiftFilter);

    private void ClearFilters()
    {
        _search = "";
        _eventFilter = "";
        _shiftFilter = "";
    }

    private string TabIcon => _activeTab switch
    {
        "Awaiting Review" => "⏳",
        "Forwarded"       => "📤",
        "Rejected"        => "❌",
        "Confirmed"       => "✅",
        _                 => "📋"
    };

    protected override async Task OnInitializedAsync()
    {
        // Live-refresh when any crew responds to one of this vendor's invites,
        // or when a manager finalises one of the vendor's referred crew.
        Hub.CrewAcceptedReceived     += OnAssignmentChanged;
        Hub.CrewDeclinedReceived     += OnAssignmentChanged;
        Hub.ManagerApprovedReceived  += OnAssignmentChanged;
        Hub.ManagerRejectedReceived  += OnAssignmentChanged;
        Hub.AssignmentInviteReceived += OnAssignmentChanged; // own invites just sent

        try { await Hub.StartAsync(); } catch { }
        await Load();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.CrewAcceptedReceived     -= OnAssignmentChanged;
        Hub.CrewDeclinedReceived     -= OnAssignmentChanged;
        Hub.ManagerApprovedReceived  -= OnAssignmentChanged;
        Hub.ManagerRejectedReceived  -= OnAssignmentChanged;
        Hub.AssignmentInviteReceived -= OnAssignmentChanged;
        await ValueTask.CompletedTask;
    }

    private void OnAssignmentChanged(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await Load(); StateHasChanged(); });
    }

    private async Task Load()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            var resp = await Http.GetFromJsonAsync<ApiResult<PagedResult<AssignmentDto>>>(
                "api/v1/events/vendor-assignments?mode=CrewAssignments&page=1&pageSize=500", JsonOpts);
            _all = resp?.Data?.Items?.ToList() ?? new();
            _awaitingCount = _all.Count(a => a.Status is "Invited" or "VendorApproved");
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    private void SetTab(string tab) { _activeTab = tab; }

    private async Task DoApprove(Guid id)
    {
        _busy = id; StateHasChanged();
        var resp = await Http.PatchAsJsonAsync($"api/v1/events/assignments/{id}/vendor-approve", new { });
        if (resp.IsSuccessStatusCode)
        {
            ShowToast("Crew forwarded to Manager queue ✓", false);
            await Load();
        }
        else ShowToast("Error: " + await resp.Content.ReadAsStringAsync(), true);
        _busy = null; StateHasChanged();
    }

    private void OpenReject(AssignmentDto a) { _rejectTarget = a; _rejectReason = ""; _reasonError = false; }
    private void CancelReject() { _rejectTarget = null; _reasonError = false; }

    private async Task DoDirectForward(Guid id)
    {
        _busy = id; StateHasChanged();
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/v1/events/assignments/{id}/vendor-direct-forward", new { });
            if (resp.IsSuccessStatusCode)
            {
                ShowToast("Forwarded to Manager approval queue!", false);
                await Load();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                ShowToast("Failed: " + body, true);
            }
        }
        catch (Exception ex) { ShowToast("Error: " + ex.Message, true); }
        finally { _busy = null; StateHasChanged(); }
    }

    private async Task ConfirmReject()
    {
        if (string.IsNullOrWhiteSpace(_rejectReason)) { _reasonError = true; return; }
        if (_rejectTarget is null) return;
        _busy = _rejectTarget.Id; StateHasChanged();
        var resp = await Http.PatchAsJsonAsync(
            $"api/v1/events/assignments/{_rejectTarget.Id}/vendor-reject",
            new { reason = _rejectReason });
        if (resp.IsSuccessStatusCode)
        {
            ShowToast("Crew rejected and notified.", false);
            _rejectTarget = null;
            await Load();
        }
        else ShowToast("Error: " + await resp.Content.ReadAsStringAsync(), true);
        _busy = null; StateHasChanged();
    }

    private void ShowToast(string msg, bool isError)
    {
        _toast = msg; _toastError = isError; StateHasChanged();
        _ = Task.Delay(3500).ContinueWith(_ => { _toast = null; InvokeAsync(StateHasChanged); });
    }

    private static string BorderColor(string status) => status switch
    {
        "Invited"                => "border-blue-100",
        "VendorApproved"         => "border-amber-200",
        "PendingManagerApproval" => "border-blue-200",
        "ManagerApproved"        => "border-green-200",
        "RejectedByVendor" or "RejectedByManager" => "border-red-200",
        _                        => "border-gray-100"
    };

    private static string StatusChip(string status) => status switch
    {
        "Invited"                => "bg-gray-50 text-gray-600 border border-gray-200",
        "VendorApproved"         => "bg-amber-50 text-amber-700 border border-amber-200",
        "PendingManagerApproval" => "bg-blue-50 text-blue-700 border border-blue-200",
        "ManagerApproved"        => "bg-green-50 text-green-700 border border-green-200",
        "RejectedByVendor" or "RejectedByManager" => "bg-red-50 text-red-700 border border-red-200",
        "Attended"               => "bg-indigo-50 text-indigo-700 border border-indigo-200",
        _                        => "bg-gray-50 text-gray-600 border border-gray-200"
    };

    private static string StatusLabel(string status) => status switch
    {
        "Invited"                => "Invited",
        "VendorApproved"         => "Awaiting Your Review",
        "PendingManagerApproval" => "Forwarded to Manager",
        "ManagerApproved"        => "Manager Approved ✓",
        "RejectedByVendor"       => "Rejected by You",
        "RejectedByManager"      => "Rejected by Manager",
        "Attended"               => "Attended",
        "Declined"               => "Declined by Crew",
        _                        => status
    };

    private static string DisciplineColor(decimal score) =>
        score >= 80 ? "text-green-600" : score >= 50 ? "text-amber-600" : "text-red-600";

    /// <summary>Phase D step 12: "Box Office · 18:00–23:00 · 5h" chip label.</summary>
    private static string? BuildShiftLabel(AssignmentDto a)
    {
        if (string.IsNullOrWhiteSpace(a.ShiftScopeName) && a.ShiftStartAt is null) return null;
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(a.ShiftScopeName)) parts.Add(a.ShiftScopeName!);
        if (a.ShiftStartAt is { } st)
        {
            var ls = st.ToLocalTime();
            if (a.ShiftEndAt is { } et)
            {
                var le = et.ToLocalTime();
                parts.Add($"{ls:HH:mm}–{le:HH:mm}");
                var hrs = (le - ls).TotalHours;
                if (hrs > 0) parts.Add($"{hrs:0.#}h");
            }
            else parts.Add($"from {ls:HH:mm}");
        }
        return parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

    private sealed record AssignmentDto(
        Guid Id, Guid EventId, string EventTitle, string EventStatus,
        Guid CrewId, string CrewName, string CrewMobile,
        decimal DisciplineScore, int EventsAttended,
        Guid VendorId, string VendorName,
        string Status, string? RejectionReason,
        DateTime? CrewRespondedAt, DateTime? VendorReviewedAt, DateTime? ManagerReviewedAt,
        DateTime? ConfirmedAt, DateTime? DeclinedAt, DateTime CreatedAt,
        decimal? VendorRating,
        string? AttendanceNote,
        // Phase D step 12: per-shift fields so vendor approval row shows scope + time.
        Guid? ShiftId = null,
        string? ShiftScopeName = null,
        DateTime? ShiftStartAt = null,
        DateTime? ShiftEndAt = null);

    // Star rating hover state
    private Guid _hoverTarget;
    private int  _hoverStar;
    private void SetHover(Guid id, int star) { _hoverTarget = id; _hoverStar = star; }
    private void ClearHover() { _hoverTarget = Guid.Empty; _hoverStar = 0; }

    private async Task SubmitRating(Guid assignmentId, int stars)
    {
        _busy = assignmentId; StateHasChanged();
        try
        {
            var resp = await Http.PostAsJsonAsync(
                $"api/v1/events/assignments/{assignmentId}/rate-crew",
                new { rating = (decimal)stars });

            if (resp.IsSuccessStatusCode)
            {
                ShowToast($"{stars}★ rating submitted!", false);
            }
            else
            {
                // Surface the actual server reason instead of a generic toast
                // so issues like 'Forbidden' or 'AlreadyRated' don't read as a
                // mystery failure. Falls back to the HTTP status if the body
                // isn't a structured ApiResponse.
                string reason;
                try
                {
                    var body = await resp.Content.ReadFromJsonAsync<ApiResult<object>>(JsonOpts);
                    reason = body?.Errors?.FirstOrDefault() ?? body?.Message ?? $"{(int)resp.StatusCode} {resp.StatusCode}";
                }
                catch
                {
                    reason = $"{(int)resp.StatusCode} {resp.StatusCode}";
                }
                ShowToast($"Couldn't submit rating: {reason}", true);
            }
        }
        catch (Exception ex)
        {
            ShowToast($"Couldn't submit rating: {ex.Message}", true);
        }
        finally
        {
            _busy = null;
            await Load();
        }
    }

    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message, List<string>? Errors);
}
