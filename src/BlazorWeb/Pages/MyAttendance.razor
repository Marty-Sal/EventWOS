@page "/my-attendance"
@attribute [Authorize(Roles = "Crew")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>My Attendance - EventWOS</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">My Attendance</h2>
        <p class="text-sm text-gray-500 mt-0.5">Check in and out of your confirmed events.</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">@_error</div>
    }
    else
    {
        @* Toast *@
        @if (_toast is not null)
        {
            <div class="fixed bottom-6 right-6 z-50 px-5 py-3 rounded-2xl shadow-xl text-sm font-medium text-white @(_toastError ? "bg-red-500" : "bg-green-600")">
                @_toast
            </div>
        }

        @* Active events for check-in *@
        @if (_activeAssignments.Count > 0)
        {
            <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 space-y-4">
                <h3 class="font-semibold text-amber-800 text-sm">Active Events — Check In / Out</h3>
                @foreach (var a in _activeAssignments)
                {
                    <div class="bg-white rounded-xl border border-amber-100 p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                        <div>
                            <p class="font-semibold text-gray-800">@a.EventTitle</p>
                            @* Phase D step 28: shift line. Renders only when the assignment has a
                               ShiftId — keeps legacy single-shift events clean. *@
                            @if (!string.IsNullOrEmpty(a.ShiftScopeName) || a.ShiftStartAt.HasValue)
                            {
                                <p class="text-xs font-medium text-indigo-600 mt-0.5">
                                    Shift:&nbsp;
                                    @if (!string.IsNullOrEmpty(a.ShiftScopeName)) { <span>@a.ShiftScopeName</span> }
                                    @if (a.ShiftStartAt.HasValue)
                                    {
                                        <span class="text-indigo-400 font-normal">
                                            · @a.ShiftStartAt.Value.ToLocalTime().ToString("dd MMM HH:mm")
                                            @if (a.ShiftEndAt.HasValue)
                                            {
                                                <span>– @a.ShiftEndAt.Value.ToLocalTime().ToString("HH:mm")</span>
                                            }
                                        </span>
                                    }
                                </p>
                            }
                            <p class="text-xs text-gray-400 mt-0.5">@a.Venue - @a.EventStartAt.ToLocalTime().ToString("dd MMM HH:mm")</p>
                        </div>
                        <div class="flex gap-2 shrink-0 items-center">
                            @{
                                var alreadyIn  = _checkedInAssignmentIds.Contains(a.Id) || a.Status == "Attended";
                                var alreadyOut = _checkedOutAssignmentIds.Contains(a.Id);
                            }
                            @if (!alreadyIn)
                            {
                                @* Check-In no longer POSTs directly — it opens the QR modal, which
                                   handles the whole handshake (mint code → vendor scans → server
                                   commits attendance → SignalR closes the modal). *@
                                <button @onclick="() => OpenQrAsync(a)"
                                        class="px-4 py-2 rounded-xl bg-green-600 text-white text-sm font-medium hover:bg-green-700 transition inline-flex items-center gap-1.5">
                                    <span>📱</span><span>Check In</span>
                                </button>
                            }
                            else if (!alreadyOut)
                            {
                                <span class="px-3 py-1.5 rounded-full bg-green-100 text-green-700 text-xs font-medium">✓ Checked in</span>
                                <button @onclick="() => RecordAttendance(a.Id, CheckOut)"
                                        disabled="@(_actionId == a.Id)"
                                        class="px-4 py-2 rounded-xl bg-gray-700 text-white text-sm font-medium hover:bg-gray-800 transition disabled:opacity-50">
                                    @if (_actionId == a.Id && _actionType == CheckOut)
                                    {
                                        <span>Checking out...</span>
                                    }
                                    else
                                    {
                                        <span>Check Out</span>
                                    }
                                </button>
                            }
                            else
                            {
                                <span class="px-3 py-1.5 rounded-full bg-gray-100 text-gray-600 text-xs font-medium">✓ Completed</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 text-center">
                <p class="text-3xl mb-3">📍</p>
                <p class="text-gray-600 font-medium text-sm">No active events right now</p>
                <p class="text-gray-400 text-xs mt-1">Check-in buttons appear when a confirmed event is InProgress.</p>
            </div>
        }

        @* Attendance History *@
        <div>
            <h3 class="text-sm font-semibold text-gray-700 mb-3">Attendance History</h3>
            @if (_history.Count == 0)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 text-center">
                    <p class="text-gray-400 text-sm">No attendance records yet.</p>
                </div>
            }
            else
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="overflow-x-auto -mx-1 sm:mx-0">
                    <table class="min-w-full text-sm">
                        <thead class="bg-gray-50 border-b border-gray-100">
                            <tr>
                                <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Event</th>
                                <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Shift</th>
                                <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                                <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Time</th>
                                <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Location</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            @foreach (var r in _history)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-5 py-3.5 font-medium text-gray-800">@r.EventTitle</td>
                                    <td class="px-5 py-3.5 text-xs text-gray-600">
                                        @if (!string.IsNullOrEmpty(r.ShiftScopeName))
                                        {
                                            <span class="font-medium text-indigo-700">@r.ShiftScopeName</span>
                                            @if (r.ShiftStartAt.HasValue)
                                            {
                                                <span class="text-gray-400"> · @r.ShiftStartAt.Value.ToLocalTime().ToString("dd MMM HH:mm")</span>
                                            }
                                        }
                                        else if (r.ShiftStartAt.HasValue)
                                        {
                                            <span class="text-gray-500">@r.ShiftStartAt.Value.ToLocalTime().ToString("dd MMM HH:mm")</span>
                                        }
                                        else { <span class="text-gray-300">—</span> }
                                    </td>
                                    <td class="px-5 py-3.5">
                                        @if (r.Action == "CheckIn")
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700 border border-green-100">Check In</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Check Out</span>
                                        }
                                    </td>
                                    <td class="px-5 py-3.5 text-gray-500 text-xs whitespace-nowrap">@r.RecordedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                                    <td class="px-5 py-3.5 text-xs"><LocationPin Address="@r.LocationAddress" Coords="@r.LocationCoords" /></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* QR-verified check-in modal — opened when crew clicks Check In. *@
<CheckInQrModal @ref="_qrModal"
                OnVerified="OnQrVerified"
                OnClosed="() => StateHasChanged()" />

@* Blocking modal shown when Check In/Out is attempted without a
   working browser location fix. Enforces the "no location, no
   attendance" policy — see EnsureLocationOrPrompt() below. *@
<LocationRequiredModal @ref="_locModal" />

@code {

    private const string CheckIn  = "checkin";
    private const string CheckOut = "checkout";

    private List<MyAssignmentWithEvent> _activeAssignments = new();
    private List<MyAttendanceRecord>    _history           = new();
    private bool   _loading   = true;
    private string? _error;
    private Guid?  _actionId;
    private string? _actionType;

    // QR-verified check-in — the modal handles the whole flow: minting
    // the code, showing the QR, waiting for the vendor's scan (via
    // SignalR), and firing OnQrVerified when the server commits. We keep
    // RecordAttendance for CheckOut only.
    private CheckInQrModal?         _qrModal;
    private LocationRequiredModal?  _locModal;

    // Uses the page-local MyAssignmentWithEvent record — that's what
    // the loop iterates over. Only Id + EventTitle are needed; the modal
    // handles everything else.
    private async Task OpenQrAsync(MyAssignmentWithEvent a)
    {
        if (_qrModal is null) return;

        // Enforce location BEFORE minting the QR. We now capture the
        // crew's coords on THEIR device and thread them all the way
        // down to the server so the eventual AttendanceRecord's
        // location_coords column reflects where the crew was —
        // not where the vendor's phone was pointed at scan time.
        //
        // Retry closure re-runs OpenQrAsync so "Try Again" resumes
        // the whole flow after the user fixes their settings.
        var gate = await EnsureLocationOrPromptAsync("check in", () => OpenQrAsync(a));
        if (gate.Coords is null) return;   // Gate failed → modal already up.

        await _qrModal.OpenAsync(a.Id, a.EventTitle, gate.Coords);
    }

    // ── Location gate ─────────────────────────────────────────────
    // Calls checkin.js requireLocation(). On success: returns true,
    // caller proceeds. On failure: pops LocationRequiredModal with
    // the appropriate copy for the reason, wires the modal's Retry
    // button to `retry` (which will re-run the whole gate + original
    // action), and returns false so the caller aborts NOW.
    //
    // actionLabel is inserted into the modal headline ("we need to
    // know where you check IN from" / "OUT from").
    // Result shape returned to callers. Coords is non-null iff Ok — the
    // "check-then-use" pattern avoids a second JS round-trip on the
    // happy path (the gate already resolved the fix; we just hand it
    // to the caller so RecordAttendance can POST it and OpenQrAsync
    // can pass it to the modal).
    private readonly record struct LocationGateOutcome(string? Coords);

    private async Task<LocationGateOutcome> EnsureLocationOrPromptAsync(
        string actionLabel,
        Func<Task> retryAction)
    {
        string reason;
        try
        {
            var res = await JS.InvokeAsync<LocationGateResult>(
                "eventwosCheckin.requireLocation");
            if (res is { Ok: true } && !string.IsNullOrWhiteSpace(res.Coords))
                return new LocationGateOutcome(res.Coords);
            reason = res?.Reason ?? "unavailable";
        }
        catch
        {
            reason = "unavailable";
        }

        // Show the modal with a Retry closure that re-runs the original
        // action — which itself calls back into this gate — so a
        // successful retry resumes the flow and a repeated failure
        // re-opens the modal with the current reason.
        if (_locModal is not null)
        {
            _locModal.Show(reason, actionLabel, async () =>
            {
                await retryAction();
                return true;
            });
        }
        return new LocationGateOutcome(null);
    }

    // Matches the shape returned by requireLocation() in checkin.js.
    // Kept simple so System.Text.Json deserialises without custom
    // converters. Property names lower-cased via JsonPropertyName
    // attributes so the JS { ok, reason, coords } payload maps
    // cleanly onto C# PascalCase properties.
    private sealed class LocationGateResult
    {
        [System.Text.Json.Serialization.JsonPropertyName("ok")]
        public bool Ok { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("reason")]
        public string? Reason { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("coords")]
        public string? Coords { get; set; }
    }

    private async Task OnQrVerified(EventWOS.BlazorWeb.Services.CheckInVerifyResultDto result)
    {
        // Vendor scanned successfully — the assignment is now Attended.
        // Refresh the list so the button state flips to Check Out.
        ShowToast("Checked in! Your vendor verified you.", false);
        await LoadAsync();
    }
    private HashSet<Guid> _checkedInAssignmentIds  = new();
    private HashSet<Guid> _checkedOutAssignmentIds = new();
    private string? _toast;
    private bool   _toastError;
    private System.Threading.CancellationTokenSource? _toastCts;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            // 1. My assignments
            var asgResp = await Http.GetFromJsonAsync<ApiResult<PagedResult<AssignmentDto>>>(
                "api/v1/events/my-assignments?page=1&pageSize=200", JsonOpts);
            var assignments = asgResp?.Data?.Items?.ToList() ?? new();

            // 2. My events (for event status + venue)
            var evResp = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventItemDto>>>(
                "api/v1/events/my-events?page=1&pageSize=200", JsonOpts);
            var evDict = (evResp?.Data?.Items ?? Enumerable.Empty<EventItemDto>())
                .ToDictionary(e => e.Id);

            // 3. Attendance history (fetched first so we know who's already checked in)
            var histResp = await Http.GetFromJsonAsync<ApiResult<PagedResult<AttendanceItemDto>>>(
                "api/v1/attendance/my?page=1&pageSize=50", JsonOpts);

            // Active = approved/confirmed on an InProgress event.
            // We include the full set of post-approval statuses that the
            // backend treats as eligible for attendance (see
            // EventAssignment.IsEligibleForAttendance + MarkAttended path).
            _activeAssignments = assignments
                .Where(a => a.Status is "Confirmed"
                                     or "Approved"            // legacy display label
                                     or "ManagerApproved"     // post-approval state
                                     or "Attended")
                .Where(a => evDict.TryGetValue(a.EventId, out var ev) && ev.Status == "InProgress")
                .Select(a => new MyAssignmentWithEvent(
                    a.Id, a.EventId, a.EventTitle, a.Status,
                    evDict.TryGetValue(a.EventId, out var ev2) ? ev2.Status : "Unknown",
                    evDict.TryGetValue(a.EventId, out var ev3) ? ev3.Venue : "-",
                    evDict.TryGetValue(a.EventId, out var ev4) ? ev4.StartAt : DateTime.MinValue,
                    a.ShiftScopeName, a.ShiftStartAt, a.ShiftEndAt))
                .ToList();

            // Determine which assignments have already been checked in
            // (so we can hide / disable the Check-In button accordingly).
            _checkedInAssignmentIds = new HashSet<Guid>(
                (histResp?.Data?.Items ?? Enumerable.Empty<AttendanceItemDto>())
                    .Where(r => r.Action.Equals("CheckIn", StringComparison.OrdinalIgnoreCase))
                    .Select(r => r.AssignmentId));

            _checkedOutAssignmentIds = new HashSet<Guid>(
                (histResp?.Data?.Items ?? Enumerable.Empty<AttendanceItemDto>())
                    .Where(r => r.Action.Equals("CheckOut", StringComparison.OrdinalIgnoreCase))
                    .Select(r => r.AssignmentId));

            _history = (histResp?.Data?.Items ?? Enumerable.Empty<AttendanceItemDto>())
                .Select(r => new MyAttendanceRecord(
                    r.EventTitle, r.Action, r.RecordedAt,
                    r.LocationAddress, r.LocationCoords,
                    r.ShiftScopeName, r.ShiftStartAt))
                .ToList();
        }
        catch (Exception ex)
        {
            _error = "Could not load attendance data: " + ex.Message;
        }
        finally
        {
            _loading = false; StateHasChanged();
        }
    }

    private async Task RecordAttendance(Guid assignmentId, string action)
    {
        // Strict location gate — same policy as Check-In. On failure
        // LocationRequiredModal takes over and the retry closure
        // resumes this method from the top.
        var actionLabel = action == CheckOut ? "check out" : "check in";
        var gate = await EnsureLocationOrPromptAsync(actionLabel,
            () => RecordAttendance(assignmentId, action));
        if (gate.Coords is null) return;

        _actionId = assignmentId; _actionType = action; StateHasChanged();
        try
        {
            // Use the coords the gate already captured. A fresh browser
            // GPS call here would just re-query for a fix at most a
            // few seconds old — same numbers, extra round-trip.
            string? location = gate.Coords;

            var resp = await Http.PostAsJsonAsync(
                $"api/v1/events/assignments/{assignmentId}/attendance",
                new { action, location });

            if (resp.IsSuccessStatusCode)
            {
                ShowToast(action == CheckIn ? "Checked in successfully!" : "Checked out!", false);
                await LoadAsync();
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                ShowToast("Error: " + (body.Length > 80 ? body[..80] : body), true);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error: " + ex.Message, true);
        }
        finally
        {
            _actionId = null; _actionType = null; StateHasChanged();
        }
    }

    private void ShowToast(string msg, bool isError)
    {
        _toastCts?.Cancel();
        _toast = msg; _toastError = isError; StateHasChanged();
        _toastCts = new System.Threading.CancellationTokenSource();
        var tok = _toastCts.Token;
        _ = Task.Delay(3500, tok).ContinueWith(_ =>
        {
            if (!tok.IsCancellationRequested)
            {
                _toast = null;
                InvokeAsync(StateHasChanged);
            }
        }, tok, System.Threading.Tasks.TaskContinuationOptions.OnlyOnRanToCompletion,
           System.Threading.Tasks.TaskScheduler.Default);
    }

    // Local models
    private sealed record MyAssignmentWithEvent(
        Guid Id, Guid EventId, string EventTitle, string Status,
        string EventStatus, string Venue, DateTime EventStartAt,
        string? ShiftScopeName, DateTime? ShiftStartAt, DateTime? ShiftEndAt);

    private sealed record MyAttendanceRecord(
        string EventTitle, string Action, DateTime RecordedAt,
        string? LocationAddress, string? LocationCoords,
        string? ShiftScopeName, DateTime? ShiftStartAt);

    private sealed record AssignmentDto(
        Guid Id, Guid EventId, string EventTitle,
        Guid CrewId, string CrewName, string CrewMobile,
        Guid VendorId, string VendorName,
        string Status, DateTime? ConfirmedAt, DateTime? DeclinedAt, DateTime CreatedAt,
        // Phase D step 28: shift fields. All nullable — legacy assignments
        // may have no ShiftId. JSON deserialiser tolerates missing keys.
        Guid? ShiftId = null,
        string? ShiftScopeName = null,
        DateTime? ShiftStartAt = null,
        DateTime? ShiftEndAt = null);

    private sealed record EventItemDto(
        Guid Id, string Title, string Venue,
        DateTime StartAt, DateTime EndAt, string Status,
        int MaxCrew, int AssignedCrew, DateTime CreatedAt);

    private sealed record AttendanceItemDto(
        Guid RecordId, Guid AssignmentId, Guid EventId, string EventTitle,
        Guid CrewId, string CrewName, string Action, DateTime RecordedAt,
        // Phase F: location split into address + coords.
        string? LocationAddress, string? LocationCoords,
        string? RecordedBy,
        // Phase D step 28: shift context.
        string? RecordedByName = null,
        string? ShiftScopeName = null,
        DateTime? ShiftStartAt = null,
        DateTime? ShiftEndAt = null);

    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
