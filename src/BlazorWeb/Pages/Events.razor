@page "/events"
@attribute [Authorize]
@inject IEventApiService EventApi
@inject IVendorApiService VendorApi
@inject AuthenticationStateProvider Auth

<PageTitle>Events — EventWOS</PageTitle>

<div class="space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Events</h2>
            <p class="text-sm text-gray-500">Manage workforce events end-to-end.</p>
        </div>
        @if (_isAdminOrManager)
        {
            <button @onclick="() => OpenCreateModal()"
                    class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow">
                + Create Event
            </button>
        }
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3 items-center">
        <div class="relative">
            <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
                   placeholder="Search events…"
                   class="w-64 pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
        </div>
        <select @bind="_statusFilter" @bind:event="onchange" @onchange="LoadEvents"
                class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
            <option value="">All Statuses</option>
            <option value="0">Draft</option>
            <option value="1">Published</option>
            <option value="2">In Progress</option>
            <option value="3">Completed</option>
            <option value="4">Cancelled</option>
        </select>
    </div>

    <!-- Loading -->
    @if (_loading)
    {
        <div class="flex justify-center py-16">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_events?.Items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <p class="text-4xl mb-3">📅</p>
            <p class="text-gray-500 text-sm">No events found. Create your first event!</p>
        </div>
    }
    else
    {
        <!-- Event Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
            @foreach (var ev in _events!.Items)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5 flex flex-col gap-3">
                    <!-- Status badge + Title -->
                    <div class="flex items-start justify-between gap-2">
                        <div>
                            <p class="font-semibold text-gray-800 text-sm leading-tight">@ev.Title</p>
                            <p class="text-xs text-gray-400 mt-0.5">📍 @ev.Venue</p>
                        </div>
                        <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(ev.Status)">
                            @ev.Status
                        </span>
                    </div>

                    <!-- Time -->
                    <div class="text-xs text-gray-500 space-y-0.5">
                        <p>🕐 @ev.StartAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                        <p>🔚 @ev.EndAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                    </div>

                    <!-- Crew pill -->
                    <div class="flex items-center gap-2 text-xs">
                        <span class="bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-full font-medium">
                            👥 @ev.AssignedCrew @(ev.MaxCrew > 0 ? $"/ {ev.MaxCrew}" : "") Crew
                        </span>
                    </div>

                    <!-- Actions -->
                    <div class="flex gap-2 pt-1 border-t border-gray-50">
                        <button @onclick="() => OpenDetailPanel(ev)"
                                class="flex-1 text-xs py-1.5 rounded-lg bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium transition">
                            View Details
                        </button>
                        @if (_isAdminOrManager)
                        {
                            <button @onclick="() => OpenEditModal(ev)"
                                    class="px-3 text-xs py-1.5 rounded-lg bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium transition">
                                Edit
                            </button>
                            @if (ev.Status == "Draft")
                            {
                                <button @onclick="() => ChangeStatus(ev.Id, \"publish\")"
                                        class="px-3 text-xs py-1.5 rounded-lg bg-green-50 hover:bg-green-100 text-green-700 font-medium transition">
                                    Publish
                                </button>
                            }
                            @if (ev.Status == "Published")
                            {
                                <button @onclick="() => ChangeStatus(ev.Id, \"start\")"
                                        class="px-3 text-xs py-1.5 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium transition">
                                    Start
                                </button>
                            }
                            @if (ev.Status == "InProgress")
                            {
                                <button @onclick="() => ChangeStatus(ev.Id, \"complete\")"
                                        class="px-3 text-xs py-1.5 rounded-lg bg-purple-50 hover:bg-purple-100 text-purple-700 font-medium transition">
                                    Complete
                                </button>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (_totalPages > 1)
        {
            <div class="flex justify-center gap-2 pt-2">
                <button @onclick="PrevPage" disabled="@(_page == 1)"
                        class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">← Prev</button>
                <span class="px-3 py-1.5 text-sm text-gray-500">Page @_page of @_totalPages</span>
                <button @onclick="NextPage" disabled="@(_page >= _totalPages)"
                        class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">Next →</button>
            </div>
        }
    }

    <!-- Error toast -->
    @if (_error is not null)
    {
        <div class="fixed bottom-5 right-5 bg-red-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
            ⚠️ @_error
            <button @onclick="() => _error = null" class="ml-3 font-bold">✕</button>
        </div>
    }
    @if (_success is not null)
    {
        <div class="fixed bottom-5 right-5 bg-green-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
            ✅ @_success
            <button @onclick="() => _success = null" class="ml-3 font-bold">✕</button>
        </div>
    }
</div>

<!-- ── Detail Side Panel ─────────────────────────────────────────────────────── -->
@if (_selectedEvent is not null)
{
    <div class="fixed inset-0 bg-black/40 z-40 flex justify-end" @onclick="CloseDetailPanel">
        <div class="bg-white w-full max-w-lg h-full overflow-y-auto shadow-2xl p-6 space-y-5 relative"
             @onclick:stopPropagation>
            <button @onclick="CloseDetailPanel"
                    class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl">✕</button>

            <div>
                <h3 class="text-lg font-bold text-gray-800">@_selectedEvent.Title</h3>
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(_selectedEvent.Status)">
                    @_selectedEvent.Status
                </span>
            </div>

            @if (_selectedEvent.Description is not null)
            {
                <p class="text-sm text-gray-600">@_selectedEvent.Description</p>
            }

            <div class="grid grid-cols-2 gap-3 text-sm">
                <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-xs text-gray-400 mb-1">Venue</p>
                    <p class="font-medium text-gray-700">@_selectedEvent.Venue</p>
                    @if (_selectedEvent.Address is not null)
                    {
                        <p class="text-xs text-gray-400">@_selectedEvent.Address</p>
                    }
                </div>
                <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-xs text-gray-400 mb-1">Schedule</p>
                    <p class="font-medium text-gray-700 text-xs">@_selectedEvent.StartAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                    <p class="text-xs text-gray-400">→ @_selectedEvent.EndAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                </div>
                <div class="bg-indigo-50 rounded-xl p-3">
                    <p class="text-xs text-indigo-400 mb-1">Crew Assigned</p>
                    <p class="font-bold text-indigo-700">@_selectedEvent.AssignedCrew @((_selectedEvent.MaxCrew > 0) ? $"/ {_selectedEvent.MaxCrew}" : "")</p>
                </div>
                <div class="bg-gray-50 rounded-xl p-3">
                    <p class="text-xs text-gray-400 mb-1">Created By</p>
                    <p class="font-medium text-gray-700 text-xs">@_selectedEvent.CreatedByName</p>
                </div>
            </div>

            <!-- Assignments section -->
            @if (_isAdminOrManager)
            {
                <div>
                    <div class="flex items-center justify-between mb-3">
                        <h4 class="font-semibold text-sm text-gray-700">Crew Assignments</h4>
                        <button @onclick="OpenAssignCrewModal"
                                class="text-xs px-3 py-1.5 rounded-lg bg-indigo-600 text-white hover:bg-indigo-700 transition">
                            + Assign Crew
                        </button>
                    </div>
                    @if (_loadingAssignments)
                    {
                        <p class="text-sm text-gray-400 py-4 text-center">Loading…</p>
                    }
                    else if (_assignments?.Items.Count == 0)
                    {
                        <p class="text-sm text-gray-400 py-4 text-center">No crew assigned yet.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var a in _assignments!.Items)
                            {
                                <div class="flex items-center justify-between bg-gray-50 rounded-xl px-3 py-2.5">
                                    <div>
                                        <p class="text-sm font-medium text-gray-700">@a.CrewName</p>
                                        <p class="text-xs text-gray-400">@a.CrewMobile · via @a.VendorName</p>
                                    </div>
                                    <span class="text-xs font-semibold px-2 py-0.5 rounded-full @GetAssignmentStatusClass(a.Status)">
                                        @a.Status
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Attendance Summary (for InProgress/Completed) -->
                @if (_selectedEvent.Status == "InProgress" || _selectedEvent.Status == "Completed")
                {
                    <div>
                        <h4 class="font-semibold text-sm text-gray-700 mb-3">Attendance Summary</h4>
                        @if (_attendance is not null)
                        {
                            <div class="grid grid-cols-4 gap-2 mb-3">
                                <div class="bg-blue-50 rounded-xl p-2 text-center">
                                    <p class="text-lg font-bold text-blue-700">@_attendance.TotalAssigned</p>
                                    <p class="text-xs text-blue-400">Assigned</p>
                                </div>
                                <div class="bg-green-50 rounded-xl p-2 text-center">
                                    <p class="text-lg font-bold text-green-700">@_attendance.TotalConfirmed</p>
                                    <p class="text-xs text-green-400">Confirmed</p>
                                </div>
                                <div class="bg-indigo-50 rounded-xl p-2 text-center">
                                    <p class="text-lg font-bold text-indigo-700">@_attendance.TotalAttended</p>
                                    <p class="text-xs text-indigo-400">Attended</p>
                                </div>
                                <div class="bg-red-50 rounded-xl p-2 text-center">
                                    <p class="text-lg font-bold text-red-700">@_attendance.TotalNoShow</p>
                                    <p class="text-xs text-red-400">No Show</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}

<!-- ── Create/Edit Modal ──────────────────────────────────────────────────────── -->
@if (_showEventModal)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6 space-y-4">
            <h3 class="text-base font-bold text-gray-800">@(_editingEvent is null ? "Create Event" : "Edit Event")</h3>

            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-xs text-gray-500 font-medium">Title *</label>
                    <input @bind="_form.Title" placeholder="Event title"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div class="col-span-2">
                    <label class="text-xs text-gray-500 font-medium">Description</label>
                    <textarea @bind="_form.Description" rows="2" placeholder="Optional description"
                              class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"></textarea>
                </div>
                <div>
                    <label class="text-xs text-gray-500 font-medium">Venue *</label>
                    <input @bind="_form.Venue" placeholder="Venue name"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="text-xs text-gray-500 font-medium">Max Crew (0 = unlimited)</label>
                    <input @bind="_form.MaxCrew" type="number" min="0"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="text-xs text-gray-500 font-medium">Address</label>
                    <input @bind="_form.Address" placeholder="Full address"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="text-xs text-gray-500 font-medium">Start Date/Time *</label>
                    <input @bind="_form.StartAtStr" type="datetime-local"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="text-xs text-gray-500 font-medium">End Date/Time *</label>
                    <input @bind="_form.EndAtStr" type="datetime-local"
                           class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
            </div>

            @if (_formError is not null)
            {
                <p class="text-red-500 text-xs">⚠️ @_formError</p>
            }

            <div class="flex justify-end gap-3 pt-2">
                <button @onclick="CloseEventModal"
                        class="px-4 py-2 text-sm rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50">
                    Cancel
                </button>
                <button @onclick="SubmitEventForm" disabled="@_saving"
                        class="px-4 py-2 text-sm rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50 font-semibold">
                    @(_saving ? "Saving…" : (_editingEvent is null ? "Create" : "Update"))
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Assign Crew Modal ──────────────────────────────────────────────────────── -->
@if (_showAssignModal)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 space-y-4">
            <h3 class="text-base font-bold text-gray-800">Assign Crew Member</h3>

            <div>
                <label class="text-xs text-gray-500 font-medium">Vendor</label>
                <select @bind="_assignVendorId"
                        class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">Select vendor…</option>
                    @foreach (var v in _vendors)
                    {
                        <option value="@v.Id">@v.FullName @(v.BusinessName != null ? $"({v.BusinessName})" : "")</option>
                    }
                </select>
            </div>

            <div>
                <label class="text-xs text-gray-500 font-medium">Crew Member</label>
                <select @bind="_assignCrewId"
                        class="mt-1 w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">Select crew member…</option>
                    @foreach (var c in _crewMembers)
                    {
                        <option value="@c.Id">@c.FullName (@c.Mobile)</option>
                    }
                </select>
            </div>

            @if (_assignError is not null)
            {
                <p class="text-red-500 text-xs">⚠️ @_assignError</p>
            }

            <div class="flex justify-end gap-3">
                <button @onclick="() => _showAssignModal = false"
                        class="px-4 py-2 text-sm rounded-xl border border-gray-200 text-gray-600 hover:bg-gray-50">
                    Cancel
                </button>
                <button @onclick="SubmitAssignment" disabled="@_saving"
                        class="px-4 py-2 text-sm rounded-xl bg-indigo-600 text-white hover:bg-indigo-700 disabled:opacity-50 font-semibold">
                    @(_saving ? "Assigning…" : "Assign")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private PagedEventResult?          _events;
    private EventDetailDto?            _selectedEvent;
    private PagedEventAssignmentResult? _assignments;
    private AttendanceSummaryDto?      _attendance;
    private IReadOnlyList<VendorListItemDto> _vendors = Array.Empty<VendorListItemDto>();
    private IReadOnlyList<CrewMemberDto>    _crewMembers = Array.Empty<CrewMemberDto>();

    private bool   _loading = true;
    private bool   _loadingAssignments;
    private bool   _saving;
    private bool   _isAdminOrManager;
    private string? _search;
    private string? _statusFilter;
    private string? _error;
    private string? _success;
    private int    _page = 1;
    private int    _totalPages = 1;

    // Modal state
    private bool            _showEventModal;
    private bool            _showAssignModal;
    private EventListItemDto? _editingEvent;
    private EventForm       _form = new();
    private string?         _formError;
    private string?         _assignError;
    private string          _assignVendorId = "";
    private string          _assignCrewId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        var role = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                ?? authState.User.FindFirst("role")?.Value ?? "";
        _isAdminOrManager = role is "Admin" or "Manager";

        await LoadEvents();
    }

    private async Task LoadEvents()
    {
        _loading = true;
        _events  = await EventApi.GetEventsAsync(_page, _search, _statusFilter);
        if (_events is not null)
            _totalPages = (int)Math.Ceiling((double)_events.TotalCount / 20);
        _loading = false;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadEvents(); }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadEvents(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadEvents(); } }

    private async Task OpenDetailPanel(EventListItemDto ev)
    {
        _selectedEvent = await EventApi.GetEventAsync(ev.Id);
        if (_selectedEvent is null) { _error = "Could not load event details."; return; }
        _loadingAssignments = true;
        _assignments = await EventApi.GetAssignmentsAsync(ev.Id);
        _loadingAssignments = false;
        if (_selectedEvent.Status is "InProgress" or "Completed")
            _attendance = await EventApi.GetAttendanceSummaryAsync(ev.Id);
    }

    private void CloseDetailPanel() { _selectedEvent = null; _assignments = null; _attendance = null; }

    private void OpenCreateModal()
    {
        _editingEvent = null;
        _form = new EventForm();
        _formError = null;
        _showEventModal = true;
    }

    private void OpenEditModal(EventListItemDto ev)
    {
        _editingEvent = ev;
        _form = new EventForm
        {
            Title      = ev.Title,
            Venue      = ev.Venue,
            StartAtStr = ev.StartAt.ToString("yyyy-MM-ddTHH:mm"),
            EndAtStr   = ev.EndAt.ToString("yyyy-MM-ddTHH:mm"),
        };
        _formError = null;
        _showEventModal = true;
    }

    private void CloseEventModal() { _showEventModal = false; _formError = null; }

    private async Task SubmitEventForm()
    {
        _formError = null;
        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Venue))
        { _formError = "Title and Venue are required."; return; }
        if (!DateTime.TryParse(_form.StartAtStr, out var start) || !DateTime.TryParse(_form.EndAtStr, out var end))
        { _formError = "Invalid date/time format."; return; }
        if (start >= end) { _formError = "Start must be before End."; return; }

        _saving = true;
        var req = new CreateEventRequest(_form.Title, _form.Description, _form.Venue, _form.Address,
                                          start.ToUniversalTime(), end.ToUniversalTime(), _form.MaxCrew);

        if (_editingEvent is null)
        {
            var (ok, err, _) = await EventApi.CreateEventAsync(req);
            if (!ok) { _formError = err; _saving = false; return; }
            _success = "Event created!";
        }
        else
        {
            var (ok, err) = await EventApi.UpdateEventAsync(_editingEvent.Id, req);
            if (!ok) { _formError = err; _saving = false; return; }
            _success = "Event updated!";
        }

        _saving = false;
        CloseEventModal();
        _page = 1;
        await LoadEvents();
        _ = Task.Delay(3000).ContinueWith(_ => { _success = null; InvokeAsync(StateHasChanged); });
    }

    private async Task ChangeStatus(Guid eventId, string action)
    {
        var (ok, err) = await EventApi.ChangeEventStatusAsync(eventId, action);
        if (!ok) { _error = err; return; }
        _success = $"Event {action}ed successfully!";
        await LoadEvents();
        if (_selectedEvent?.Id == eventId)
            _selectedEvent = await EventApi.GetEventAsync(eventId);
        _ = Task.Delay(3000).ContinueWith(_ => { _success = null; InvokeAsync(StateHasChanged); });
    }

    private async Task OpenAssignCrewModal()
    {
        _assignVendorId = "";
        _assignCrewId   = "";
        _assignError    = null;
        // Load vendors & crew for dropdowns
        var vendorResult = await VendorApi.GetVendorsAsync(1);
        _vendors = vendorResult?.Items ?? Array.Empty<VendorListItemDto>();
        var crewResult = await VendorApi.GetCrewAsync(1);
        _crewMembers = crewResult?.Items ?? Array.Empty<CrewMemberDto>();
        _showAssignModal = true;
    }

    private async Task SubmitAssignment()
    {
        _assignError = null;
        if (!Guid.TryParse(_assignVendorId, out var vendorId)) { _assignError = "Select a vendor."; return; }
        if (!Guid.TryParse(_assignCrewId,   out var crewId))   { _assignError = "Select a crew member."; return; }
        if (_selectedEvent is null) return;

        _saving = true;
        var (ok, err) = await EventApi.AssignCrewAsync(_selectedEvent.Id, crewId, vendorId);
        _saving = false;
        if (!ok) { _assignError = err; return; }

        _showAssignModal = false;
        _success = "Crew assigned!";
        _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
        _selectedEvent = await EventApi.GetEventAsync(_selectedEvent.Id);
        await LoadEvents();
        _ = Task.Delay(3000).ContinueWith(_ => { _success = null; InvokeAsync(StateHasChanged); });
    }

    private static string GetStatusClass(string status) => status switch
    {
        "Draft"      => "bg-gray-100 text-gray-600",
        "Published"  => "bg-blue-100 text-blue-700",
        "InProgress" => "bg-green-100 text-green-700",
        "Completed"  => "bg-purple-100 text-purple-700",
        "Cancelled"  => "bg-red-100 text-red-600",
        _            => "bg-gray-100 text-gray-600"
    };

    private static string GetAssignmentStatusClass(string status) => status switch
    {
        "Invited"   => "bg-yellow-100 text-yellow-700",
        "Confirmed" => "bg-green-100 text-green-700",
        "Declined"  => "bg-red-100 text-red-600",
        "Attended"  => "bg-indigo-100 text-indigo-700",
        "NoShow"    => "bg-orange-100 text-orange-600",
        _           => "bg-gray-100 text-gray-600"
    };

    private sealed class EventForm
    {
        public string  Title       { get; set; } = "";
        public string? Description { get; set; }
        public string  Venue       { get; set; } = "";
        public string? Address     { get; set; }
        public int     MaxCrew     { get; set; } = 0;
        public string  StartAtStr  { get; set; } = "";
        public string  EndAtStr    { get; set; } = "";
    }
}
