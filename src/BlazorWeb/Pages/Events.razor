    private async Task LoadEvents()
    {
        _loading = true;
        _events  = await EventApi.GetEventsAsync(_page, _search, _statusFilter);
        if (_events is not null)
            _totalPages = (int)Math.Ceiling((double)_events.TotalCount / 20);
        _loading = false;
    }

    private async Task OnStatusFilterChanged(string? value)
    {
        _statusFilter = value;
        _page = 1;
        await LoadEvents();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadEvents(); }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadEvents(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadEvents(); } }

    private async Task OpenDetailPanel(EventListItemDto ev)
    {
        _selectedEvent = await EventApi.GetEventAsync(ev.Id);
        if (_selectedEvent is null) { _error = "Could not load event details."; return; }
        _loadingAssignments = true;
        _assignments = await EventApi.GetAssignmentsAsync(ev.Id);
        _loadingAssignments = false;
        if (_selectedEvent.Status is "InProgress" or "Completed")
            _attendance = await EventApi.GetAttendanceSummaryAsync(ev.Id);

        // Phase C step 5: load shifts + allocations for this event so the
        // Vendor Quotas section can render. Errors are silent (UI shows
        // "no shifts" naturally) — section gates on _selectedEventShifts.
        _allocationsByShift.Clear();
        _allocSectionOpen = false;
        _allocError       = null;
        _selectedEventShifts = await EventApi.GetEventShiftsAsync(ev.Id);
        _assignShiftId       = "";   // reset the shift picker for the new event
        if (_selectedEventShifts is not null)
        {
            foreach (var sh in _selectedEventShifts)
            {
                var rows = await AllocApi.GetForShiftAsync(sh.Id);
                _allocationsByShift[sh.Id] = rows ?? Array.Empty<VendorAllocationDto>();
            }
        }

        // Auto-expand the first vendor group so the drawer doesn't open
        // looking empty when there are assignments. Subsequent groups stay
        // collapsed — keeps the panel tidy for events fanned across many
        // vendors.
        _expandedVendorGroups.Clear();
        if (_assignments is not null && _assignments.Items.Count > 0)
        {
            var first = GroupAssignmentsByVendor(_assignments.Items).FirstOrDefault();
            if (first is not null) _expandedVendorGroups.Add(first.Key);
        }
    }

    private void CloseDetailPanel()
    {
        _selectedEvent = null;
        _assignments = null;
        _attendance = null;
        _expandedVendorGroups.Clear();
        // Phase C step 5: tear down allocation drawer state too.
        _selectedEventShifts = null;
        _allocationsByShift.Clear();
        _allocSectionOpen = false;
        _allocError = null;
        _allocEditingId = null;
        CloseAllocCreate();
    }

