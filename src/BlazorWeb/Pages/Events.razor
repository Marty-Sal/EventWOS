                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-800">@a.EventTitle</p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    @if (_role == "Vendor")
                                    {
                                        <span>Crew: <span class="font-medium text-gray-700">@(a.CrewName ?? "(unassigned)")</span> @(string.IsNullOrEmpty(a.CrewMobile) ? "" : "· " + a.CrewMobile)</span>
                                    }
                                    else
                                    {
                                        <span>@(string.IsNullOrEmpty(a.VendorName) ? "(direct)" : "via " + a.VendorName)</span>
                                    }
                                </p>
                            </div>
                            <span class="shrink-0 text-xs font-semibold px-3 py-1.5 rounded-full @GetAssignmentStatusClass(a.Status)">
                                @a.Status
                            </span>
                        </div>

                        <div class="mt-3 flex flex-wrap gap-3 text-xs text-gray-500">
                            <span>📅 Assigned @a.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                            @if (a.ConfirmedAt.HasValue)
                            {
                                <span class="text-green-600">✓ Confirmed @a.ConfirmedAt.Value.ToLocalTime().ToString("MMM dd")</span>
                            }
                            @if (a.DeclinedAt.HasValue)
                            {
                                <span class="text-red-500">✗ Declined @a.DeclinedAt.Value.ToLocalTime().ToString("MMM dd")</span>
                            }
                        </div>

                        <!-- Crew: respond to pending assignment -->
                        @if (_role == "Crew" && a.Status == "Pending")
                        {
                            <div class="mt-4 flex gap-2">
                                <button @onclick='() => RespondToAssignment(a.Id, "confirm")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-green-600 text-white font-semibold hover:bg-green-700 transition">
                                    ✓ Accept
                                </button>
                                <button @onclick='() => RespondToAssignment(a.Id, "decline")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-red-50 text-red-600 font-semibold hover:bg-red-100 border border-red-200 transition">
                                    ✗ Decline
                                </button>
                            </div>
                        }

                        <!-- Crew: attendance check-in/out for confirmed + in-progress events -->
                        @if (_role == "Crew" && a.Status == "Confirmed")
                        {
                            <div class="mt-4 flex gap-2">
                                <button @onclick='() => RecordAttendance(a.Id, "checkin")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
                                    📍 Check In
                                </button>
                                <button @onclick='() => RecordAttendance(a.Id, "checkout")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition">
                                    🚪 Check Out
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_totalMyPages > 1)
            {
                <div class="flex justify-center gap-2 pt-2">
                    <button @onclick="PrevMyPage" disabled="@(_myPage == 1)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">← Prev</button>
                    <span class="px-3 py-1.5 text-sm text-gray-500">Page @_myPage of @_totalMyPages</span>
                    <button @onclick="NextMyPage" disabled="@(_myPage >= _totalMyPages)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">Next →</button>
                </div>
            }
        }

        @* Toasts *@
        @if (_error is not null)
        {
            <div class="fixed bottom-5 right-5 bg-red-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ⚠️ @_error <button @onclick="() => _error = null" class="ml-3 font-bold">✕</button>
            </div>
        }
        @if (_success is not null)
        {
            <div class="fixed bottom-5 right-5 bg-green-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ✅ @_success <button @onclick="() => _success = null" class="ml-3 font-bold">✕</button>
            </div>
        }
    </div>
}

@code {
    private bool _accessDenied;
    private bool _canWrite;
    private Guid _placeholderBusy = Guid.Empty;
    private Guid _overrideBusy    = Guid.Empty;   // admin "Mark Attended" button busy-state
    // ── State ──────────────────────────────────────────────────────────────────
    private string _role = "";
    private bool   _loading = true;
    private bool   _loadingAssignments;
    private bool   _saving;
    private string? _search;
    private string? _statusFilter;
    private string  _sortKey   = "upcoming";   // sort dropdown (client-side over current page)
    private string  _viewMode  = "cards";       // "cards" | "list"

    private IEnumerable<EventListItemDto> SortEvents(IEnumerable<EventListItemDto> items) => _sortKey switch
    {
        "past"         => items.OrderByDescending(e => e.StartAt),
        "created_desc" => items.OrderByDescending(e => e.CreatedAt),
        "created_asc"  => items.OrderBy(e => e.CreatedAt),
        "title"        => items.OrderBy(e => e.Title, StringComparer.OrdinalIgnoreCase),
        "capacity"     => items.OrderBy(e => e.MaxCrew),
        // "upcoming" — future events first (closest first), then past (most recent first)
        _              => items.OrderBy(e => e.StartAt < DateTime.UtcNow ? 1 : 0)
                                .ThenBy(e => e.StartAt < DateTime.UtcNow ? -e.StartAt.Ticks : e.StartAt.Ticks)
    };
    private string? _error;
    private string? _success;

    // Admin/Manager paging
    private int _page = 1;
    private int _totalPages = 1;
    private PagedEventResult? _events;

    // Detail panel
    private EventDetailDto?          _selectedEvent;
    private PagedEventAssignmentResult? _assignments;
    private AttendanceSummaryDto?    _attendance;
    // Assign crew — vendor picker
    private string                    _assignVendorSearch  = "";
    private bool                      _assignVendorDropOpen;
    private List<VendorListItemDto>   _assignVendorResults = new();
    private VendorListItemDto?        _assignSelectedVendor;

    // Assign crew — crew picker
    private string                    _assignCrewSearch    = "";
    private bool                      _assignCrewDropOpen;
    private List<CrewMemberDto>       _assignCrewResults   = new();
    private CrewMemberDto?            _assignSelectedCrew;

    private bool                      _assigning;
    private string?                   _assignError;
    private string                    _assignMode = "both"; // "crew" | "vendor" | "both" 

    // Modal
    private bool              _showEventModal;
    private EventListItemDto? _editingEvent;
    private EventForm         _form = new();
    private string?           _formError;

    // Crew/Vendor paging
    private int _myPage = 1;
    private int _totalMyPages = 1;
    private PagedEventAssignmentResult? _myAssignments;

    // ── Init ───────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        // ── Permission gate ──────────────────────────────────────────────────────
        _accessDenied = !await PermGuard.CanAsync("events:read");
        if (_accessDenied) { StateHasChanged(); return; }
        _canWrite = await PermGuard.CanAsync("events:write");

        var authState = await Auth.GetAuthenticationStateAsync();
        _role = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
             ?? authState.User.FindFirst("role")?.Value ?? "";

        if (_role is "Admin" or "Manager")
            await LoadEvents();
        else if (_role == "Vendor")
            await LoadVendorAssignments();
        else
            await LoadMyAssignments(); // Crew

        // Live refresh whenever any assignment in the system moves.
        Hub.AssignmentInviteReceived  += OnAssignmentMoved;
        Hub.CrewAcceptedReceived      += OnAssignmentMoved;
        Hub.CrewDeclinedReceived      += OnAssignmentMoved;
        Hub.VendorApprovedReceived    += OnAssignmentMoved;
        Hub.VendorRejectedReceived    += OnAssignmentMoved;
        Hub.ManagerApprovedReceived   += OnAssignmentMoved;
        Hub.ManagerRejectedReceived   += OnAssignmentMoved;
        try { await Hub.StartAsync(); } catch { }
    }

    public async ValueTask DisposeAsync()
    {
        Hub.AssignmentInviteReceived  -= OnAssignmentMoved;
        Hub.CrewAcceptedReceived      -= OnAssignmentMoved;
        Hub.CrewDeclinedReceived      -= OnAssignmentMoved;
        Hub.VendorApprovedReceived    -= OnAssignmentMoved;
        Hub.VendorRejectedReceived    -= OnAssignmentMoved;
        Hub.ManagerApprovedReceived   -= OnAssignmentMoved;
        Hub.ManagerRejectedReceived   -= OnAssignmentMoved;
        await ValueTask.CompletedTask;
    }

    private void OnAssignmentMoved(NotificationPayload payload)
    {
        _ = InvokeAsync(async () =>
        {
            if (_role is "Admin" or "Manager")      await LoadEvents();
            else if (_role == "Vendor")             await LoadVendorAssignments();
            else                                    await LoadMyAssignments();
            StateHasChanged();
        });
    }

    // ── Admin/Manager ──────────────────────────────────────────────────────────
    private async Task LoadEvents()
    {
        _loading = true;
        _events  = await EventApi.GetEventsAsync(_page, _search, _statusFilter);
        if (_events is not null)
            _totalPages = (int)Math.Ceiling((double)_events.TotalCount / 20);
        _loading = false;
    }

    private async Task OnStatusFilterChanged(string? value)
    {
        _statusFilter = value;
        _page = 1;
        await LoadEvents();
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadEvents(); }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadEvents(); } }
    private async Task NextPage() { if (_page < _totalPages) { _page++; await LoadEvents(); } }

    private async Task OpenDetailPanel(EventListItemDto ev)
    {
        _selectedEvent = await EventApi.GetEventAsync(ev.Id);
        if (_selectedEvent is null) { _error = "Could not load event details."; return; }
        _loadingAssignments = true;
        _assignments = await EventApi.GetAssignmentsAsync(ev.Id);
        _loadingAssignments = false;
        if (_selectedEvent.Status is "InProgress" or "Completed")
            _attendance = await EventApi.GetAttendanceSummaryAsync(ev.Id);
    }

    private void CloseDetailPanel() { _selectedEvent = null; _assignments = null; _attendance = null; }

    private void OpenCreateModal()
    {
        _editingEvent = null;
        _form = new EventForm { StartAt = DateTime.Now.AddDays(1), EndAt = DateTime.Now.AddDays(1).AddHours(4) };
        _formError = null;
        _showEventModal = true;
    }

    private void OpenEditModal(EventListItemDto ev)
    {
        _editingEvent = ev;
        _form = new EventForm
        {
            Title       = ev.Title,
            Venue       = ev.Venue,
            StartAt     = ev.StartAt.ToLocalTime(),
            EndAt       = ev.EndAt.ToLocalTime(),
            MaxCrew     = ev.MaxCrew,
        };
        _formError = null;
        _showEventModal = true;
    }

    private void CloseModal() => _showEventModal = false;

    private async Task SaveEvent()
    {
        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Venue))
        {
            _formError = "Title and Venue are required.";
            return;
        }
        _saving = true;
        _formError = null;
        var req = new CreateEventRequest(
            _form.Title, _form.Description, _form.Venue, _form.Address,
            _form.StartAt.ToUniversalTime(), _form.EndAt.ToUniversalTime(), _form.MaxCrew);

        if (_editingEvent is null)
        {
            var (ok, err, _) = await EventApi.CreateEventAsync(req);
            if (ok) { _success = "Event created!"; CloseModal(); await LoadEvents(); }
            else    { _formError = err; }
        }
        else
        {
            var (ok, err) = await EventApi.UpdateEventAsync(_editingEvent.Id, req);
            if (ok) { _success = "Event updated!"; CloseModal(); await LoadEvents(); }
            else    { _formError = err; }
        }
        _saving = false;
    }

    private async Task ChangeStatus(Guid id, string action)
    {
        var (ok, err) = await EventApi.ChangeEventStatusAsync(id, action);
        if (ok) { _success = "Status updated!"; await LoadEvents(); }
        else    { _error = err; }
    }

    // ── Vendor search for assign section ─────────────────────────────────────
    private async Task OnAssignVendorSearch(ChangeEventArgs e)
    {
        _assignVendorSearch = e.Value?.ToString() ?? "";
        if (_assignVendorSearch.Length < 1) { _assignVendorResults.Clear(); _assignVendorDropOpen = false; return; }
        var result = await VendorApi.GetVendorsAsync(search: _assignVendorSearch, page: 1);
        _assignVendorResults = result?.Items?.Take(8).ToList() ?? new();
        _assignVendorDropOpen = true;
    }

    private void SelectAssignVendor(VendorListItemDto v)
    {
        _assignSelectedVendor = v;
        _assignVendorDropOpen = false;
        _assignVendorSearch   = "";
        _assignVendorResults.Clear();
        // Reset crew when vendor changes
        _assignSelectedCrew  = null;
        _assignCrewResults.Clear();
    }

    private void ClearAssignVendor()
    {
        _assignSelectedVendor = null;
        _assignSelectedCrew   = null;
        _assignCrewResults.Clear();
    }

    // ── Crew search for assign section ───────────────────────────────────────
    private async Task OnAssignCrewSearch(ChangeEventArgs e)
    {
        _assignCrewSearch = e.Value?.ToString() ?? "";
        if (_assignCrewSearch.Length < 1) { _assignCrewResults.Clear(); _assignCrewDropOpen = false; return; }
        var vendorId = _assignSelectedVendor?.Id;
        var result   = await VendorApi.GetCrewAsync(search: _assignCrewSearch, vendorId: vendorId, page: 1);
        _assignCrewResults  = result?.Items?.Take(8).ToList() ?? new();
        _assignCrewDropOpen = true;
    }

    private void SelectAssignCrew(CrewMemberDto c)
    {
        _assignSelectedCrew = c;
        _assignCrewDropOpen = false;
        _assignCrewSearch   = "";
        _assignCrewResults.Clear();
    }

    private void ClearAssignCrew()
    {
        _assignSelectedCrew = null;
    }

    // ── Mode helpers ─────────────────────────────────────────────────────────
    private void SetAssignMode(string mode)
    {
        _assignMode  = mode;
        _assignError = null;
        // When switching modes, clear selections that don't apply
        if (mode == "crew")   { _assignSelectedVendor = null; _assignVendorSearch = ""; }
        if (mode == "vendor") { _assignSelectedCrew   = null; _assignCrewSearch   = ""; }
    }

    // Statuses that mean the row is still 'live' on the event — re-assigning would be a duplicate.
    private static readonly HashSet<string> ActiveAssignmentStatuses = new(StringComparer.OrdinalIgnoreCase)
    {
        "Invited", "VendorAccepted", "VendorApproved", "PendingManagerApproval",
        "ManagerApproved", "Confirmed", "Pending", "Attended"
    };

    private string? DuplicateAssignWarning()
    {
        if (_assignments?.Items is null || _assignments.Items.Count == 0) return null;
        var rows = _assignments.Items.Where(a => ActiveAssignmentStatuses.Contains(a.Status)).ToList();
        if (rows.Count == 0) return null;

        if (_assignMode == "crew" && _assignSelectedCrew is not null)
        {
            // Direct crew: same crew already assigned (with or without a vendor).
            var dup = rows.FirstOrDefault(a => a.CrewId == _assignSelectedCrew.Id);
            if (dup is not null)
                return $"{_assignSelectedCrew.FullName} is already on this event ({dup.Status}).";
        }
        else if (_assignMode == "vendor" && _assignSelectedVendor is not null)
        {
            // Vendor-only: this vendor already has a placeholder OR any active row on the event.
            var dup = rows.FirstOrDefault(a => a.VendorId == _assignSelectedVendor.Id);
            if (dup is not null)
                return $"{_assignSelectedVendor.FullName} is already invited to this event ({dup.Status}).";
        }
        else if (_assignMode == "both" && _assignSelectedCrew is not null && _assignSelectedVendor is not null)
        {
            var dup = rows.FirstOrDefault(a =>
                a.CrewId   == _assignSelectedCrew.Id &&
                a.VendorId == _assignSelectedVendor.Id);
            if (dup is not null)
                return $"{_assignSelectedCrew.FullName} is already assigned via {_assignSelectedVendor.FullName} ({dup.Status}).";

            // Same crew under a *different* vendor on the same event is also a duplicate.
            var dupCrew = rows.FirstOrDefault(a => a.CrewId == _assignSelectedCrew.Id);
            if (dupCrew is not null)
                return $"{_assignSelectedCrew.FullName} is already on this event via {dupCrew.VendorName ?? "another vendor"} ({dupCrew.Status}).";
        }
        return null;
    }

    private bool CanSubmitAssign()
    {
        var baseOk = _assignMode switch
        {
            "crew"   => _assignSelectedCrew   is not null,
            "vendor" => _assignSelectedVendor is not null,
            "both"   => _assignSelectedCrew is not null && _assignSelectedVendor is not null,
            _        => false
        };
        return baseOk && DuplicateAssignWarning() is null;
    }

    // ── Assign button handler ─────────────────────────────────────────────────
    private async Task AssignCrew()
    {
        _assignError = null;
        if (_selectedEvent is null) return;

        // Validate per mode
        if (_assignMode == "crew" && _assignSelectedCrew is null)
        {
            _assignError = "Please select a crew member.";
            return;
        }
        if (_assignMode == "vendor" && _assignSelectedVendor is null)
        {
            _assignError = "Please select a vendor.";
            return;
        }
        if (_assignMode == "both" && (_assignSelectedCrew is null || _assignSelectedVendor is null))
        {
            _assignError = "Please select both a vendor and a crew member.";
            return;
        }

        var dupNow = DuplicateAssignWarning();
        if (dupNow is not null)
        {
            _assignError = dupNow;
            return;
        }

        _assigning = true;
        var (ok, _, err) = await EventApi.AssignCrewAsync(
            _selectedEvent.Id,
            _assignSelectedCrew?.Id,
            _assignSelectedVendor?.Id);
        _assigning = false;

        if (ok)
        {
            var label = _assignMode switch
            {
                "crew"   => $"{_assignSelectedCrew!.FullName} assigned directly ✅",
                "vendor" => $"Vendor {_assignSelectedVendor!.FullName} assigned ✅",
                _        => $"{_assignSelectedCrew!.FullName} assigned via {_assignSelectedVendor!.FullName} ✅"
            };
            _success              = label;
            _assignSelectedVendor = null;
            _assignSelectedCrew   = null;
            _assignVendorSearch   = "";
            _assignCrewSearch     = "";
            _assignments          = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
        }
        else { _assignError = err; }
    }

    // ── Crew / Vendor ──────────────────────────────────────────────────────────
    private async Task LoadMyAssignments()
    {
        _loading = true;
        _myAssignments = await EventApi.GetMyAssignmentsAsync(_myPage);
        if (_myAssignments is not null)
            _totalMyPages = (int)Math.Ceiling((double)_myAssignments.TotalCount / 20);
        _loading = false;
    }

    private async Task LoadVendorAssignments()
    {
        _loading = true;
        _myAssignments = await EventApi.GetVendorAssignmentsAsync(_myPage);
        if (_myAssignments is not null)
            _totalMyPages = (int)Math.Ceiling((double)_myAssignments.TotalCount / 20);
        _loading = false;
    }

    private async Task PrevMyPage()
    {
        if (_myPage > 1) { _myPage--;
            if (_role == "Vendor") await LoadVendorAssignments();
            else await LoadMyAssignments();
        }
    }
    private async Task NextMyPage()
    {
        if (_myPage < _totalMyPages) { _myPage++;
            if (_role == "Vendor") await LoadVendorAssignments();
            else await LoadMyAssignments();
        }
    }

    private async Task RespondToAssignment(Guid assignmentId, string response)
    {
        var (ok, err) = await EventApi.RespondAssignmentAsync(assignmentId, response);
        if (ok) { _success = response == "confirm" ? "Assignment accepted!" : "Assignment declined."; await LoadMyAssignments(); }
        else    { _error = err ?? "Failed to respond."; }
    }

    private async Task RecordAttendance(Guid assignmentId, string action)
    {
        var (ok, err) = await EventApi.RecordAttendanceAsync(assignmentId, action);
        if (ok) { _success = action == "checkin" ? "Checked in! 📍" : "Checked out! 🚪"; await LoadMyAssignments(); }
        else    { _error = err ?? "Failed to record attendance."; }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    private static string GetStatusClass(string status) => status switch
    {
        "Draft"      => "bg-gray-100 text-gray-600",
        "Published"  => "bg-blue-100 text-blue-700",
        "InProgress" => "bg-yellow-100 text-yellow-700",
        "Completed"  => "bg-green-100 text-green-700",
        "Cancelled"  => "bg-red-100 text-red-700",
        _            => "bg-gray-100 text-gray-600"
    };

    private async Task RevokeVendorInvite(EventAssignmentDto a)
    {
        _placeholderBusy = a.Id; StateHasChanged();
        try
        {
            var resp = await Http.DeleteAsync($"api/v1/events/vendor-invitations/{a.Id}");
            if (resp.IsSuccessStatusCode)
            {
                _success = "Vendor invitation revoked.";
                if (_selectedEvent is not null) _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            }
            else
            {
                _error = "Couldn't revoke invitation: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    private async Task ReinviteVendor(EventAssignmentDto a)
    {
        _placeholderBusy = a.Id; StateHasChanged();
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/v1/events/vendor-invitations/{a.Id}/reinvite", new { });
            if (resp.IsSuccessStatusCode)
            {
                _success = "Vendor re-invited.";
                if (_selectedEvent is not null) _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            }
            else
            {
                _error = "Couldn't re-invite vendor: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    /// <summary>
    /// Admin-only post-event correction: flips a No-Show / hanging row to
    /// Attended via the API. The response carries no body, so the page
    /// optimistically updates the row and refreshes the drawer's
    /// assignments + the event's attendance summary so KPIs stay honest.
    /// </summary>
    private async Task AdminMarkAttended(EventAssignmentDto a)
    {
        if (_selectedEvent is null) return;
        _overrideBusy = a.Id; StateHasChanged();
        try
        {
            var (ok, err) = await EventApi.AdminMarkAttendedAsync(a.Id);
            if (!ok)
            {
                _error = "Couldn't mark attended: " + (err ?? "unknown error");
            }
            else
            {
                // Re-pull the assignment list + attendance summary so the
                // new label, audit note, badge, and KPI counts all render
                // from the source of truth instead of optimistic guesses.
                _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
                if (_selectedEvent.Status is "InProgress" or "Completed")
                    _attendance = await EventApi.GetAttendanceSummaryAsync(_selectedEvent.Id);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _overrideBusy = Guid.Empty; StateHasChanged(); }
    }

