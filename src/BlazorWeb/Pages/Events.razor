@page "/events"
@attribute [Authorize]
@inject IEventApiService EventApi
@inject IVendorApiService VendorApi
@inject IVendorAllocationApiService AllocApi
@inject HttpClient Http
@inject AuthenticationStateProvider Auth
@inject NotificationHubService Hub
@implements IAsyncDisposable


    @if (_accessDenied)
    {
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
            <p class="text-gray-500 text-sm">You don't have permission to view this page.<br/>Contact your Admin to request access.</p>
        </div>
        return;
    }

<PageTitle>Events — EventWOS</PageTitle>

@if (_role is "Admin" or "Manager")
{
    <!-- ══════════════════════════════════════════════════════════════════════
         ADMIN / MANAGER — Full Event Management Board
         ════════════════════════════════════════════════════════════════════ -->
    <div class="space-y-5">
        <!-- Header -->
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
                <h2 class="text-lg font-bold text-gray-800">Events</h2>
                <p class="text-sm text-gray-500">Manage workforce events end-to-end.</p>
            </div>
            @if (_canWrite)
            {
                <button @onclick="() => OpenCreateModal()"
                        class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow">
                    + Create Event
                </button>
            }
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 items-center">
            <div class="relative">
                <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
                       placeholder="Search events…"
                       class="w-64 pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
            </div>
            <select @bind:get="_statusFilter" @bind:set="OnStatusFilterChanged"
                    class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option value="">All Statuses</option>
                <option value="0">Draft</option>
                <option value="1">Published</option>
                <option value="2">In Progress</option>
                <option value="3">Completed</option>
                <option value="4">Cancelled</option>
            </select>

            <select @bind="_sortKey"
                    class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option value="upcoming">Upcoming first</option>
                <option value="past">Most recent first</option>
                <option value="created_desc">Recently created</option>
                <option value="created_asc">Oldest created</option>
                <option value="title">Title A→Z</option>
                <option value="capacity">Capacity (low→high)</option>
            </select>

            <div class="ml-auto inline-flex rounded-xl border border-gray-200 bg-white p-0.5">
                <button @onclick='() => _viewMode = "cards"'
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "cards" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                    🔲 Cards
                </button>
                <button @onclick='() => _viewMode = "list"'
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "list" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                    ☰ List
                </button>
            </div>
        </div>

        <!-- Loading -->
        @if (_loading)
        {
            <div class="flex justify-center py-16">
                <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
            </div>
        }
        else if (_events?.Items.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
                <p class="text-4xl mb-3">📅</p>
                <p class="text-gray-500 text-sm">No events found. Create your first event!</p>
            </div>
        }
        else
        {
            var _sortedEvents = SortEvents(_events!.Items);

            @if (_viewMode == "cards")
            {
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var ev in _sortedEvents)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5 flex flex-col gap-3">
                        <div class="flex items-start justify-between gap-2">
                            <div>
                                <p class="font-semibold text-gray-800 text-sm leading-tight">@ev.Title</p>
                                <p class="text-xs text-gray-400 mt-0.5">📍 @ev.Venue</p>
                            </div>
                            <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(ev.Status)">
                                @ev.Status
                            </span>
                        </div>
                        <div class="text-xs text-gray-500 space-y-0.5">
                            <p>🕐 @ev.StartAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                            <p>🔚 @ev.EndAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                        <div class="flex items-center gap-2 text-xs">
                            <span class="bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-full font-medium">
                                👥 @ev.AssignedCrew @(ev.MaxCrew > 0 ? $"/ {ev.MaxCrew}" : "") Crew
                            </span>
                        </div>
                        <div class="flex gap-2 pt-1 border-t border-gray-50">
                            <button @onclick="() => OpenDetailPanel(ev)"
                                    class="flex-1 text-xs py-1.5 rounded-lg bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium transition">
                                View Details
                            </button>
                            @if (ev.Status is not "Completed" and not "Cancelled")
                            {
                                <button @onclick="() => OpenEditModal(ev)"
                                        class="px-3 text-xs py-1.5 rounded-lg bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium transition">
                                    Edit
                                </button>
                            }
                            @if (ev.Status == "Draft")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "publish")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-green-50 hover:bg-green-100 text-green-700 font-medium transition">
                                    Publish
                                </button>
                            }
                            @if (ev.Status == "Published")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "start")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium transition">
                                    Start
                                </button>
                            }
                            @if (ev.Status == "InProgress")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "complete")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-purple-50 hover:bg-purple-100 text-purple-700 font-medium transition">
                                    Complete
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
            }
            else
            {
                <!-- List view -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="bg-gray-50 text-[11px] uppercase tracking-widest text-gray-500">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold">Event</th>
                                <th class="px-4 py-3 text-left font-semibold">Venue</th>
                                <th class="px-4 py-3 text-left font-semibold">Start</th>
                                <th class="px-4 py-3 text-left font-semibold">End</th>
                                <th class="px-4 py-3 text-center font-semibold">Crew</th>
                                <th class="px-4 py-3 text-center font-semibold">Status</th>
                                <th class="px-4 py-3 text-right font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var ev in _sortedEvents)
                            {
                                <tr class="hover:bg-gray-50/60">
                                    <td class="px-4 py-3 font-semibold text-gray-800">@ev.Title</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs">@ev.Venue</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@ev.StartAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@ev.EndAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                    <td class="px-4 py-3 text-center text-xs">
                                        <span class="bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full font-medium">
                                            @ev.AssignedCrew@(ev.MaxCrew > 0 ? $"/{ev.MaxCrew}" : "")
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(ev.Status)">@ev.Status</span>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="inline-flex gap-1.5">
                                            <button @onclick="() => OpenDetailPanel(ev)"
                                                    class="text-xs px-2.5 py-1 rounded-lg bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium">View</button>
                                            @if (ev.Status is not "Completed" and not "Cancelled")
                                            {
                                                <button @onclick="() => OpenEditModal(ev)"
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium">Edit</button>
                                            }
                                            @if (ev.Status == "Draft")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "publish")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-green-50 hover:bg-green-100 text-green-700 font-medium">Publish</button>
                                            }
                                            @if (ev.Status == "Published")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "start")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium">Start</button>
                                            }
                                            @if (ev.Status == "InProgress")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "complete")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-purple-50 hover:bg-purple-100 text-purple-700 font-medium">Complete</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (_totalPages > 1)
            {
                <div class="flex justify-center gap-2 pt-2">
                    <button @onclick="PrevPage" disabled="@(_page == 1)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">← Prev</button>
                    <span class="px-3 py-1.5 text-sm text-gray-500">Page @_page of @_totalPages</span>
                    <button @onclick="NextPage" disabled="@(_page >= _totalPages)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">Next →</button>
                </div>
            }
        }

        @* Toasts *@
        @if (_error is not null)
        {
            <div class="fixed bottom-5 right-5 bg-red-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ⚠️ @_error <button @onclick="() => _error = null" class="ml-3 font-bold">✕</button>
            </div>
        }
        @if (_success is not null)
        {
            <div class="fixed bottom-5 right-5 bg-green-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ✅ @_success <button @onclick="() => _success = null" class="ml-3 font-bold">✕</button>
            </div>
        }
    </div>

    <!-- ── Detail Side Panel ──────────────────────────────────────────────────── -->
    @if (_selectedEvent is not null)
    {
        <div class="fixed inset-0 bg-black/40 z-40 flex justify-end" @onclick="CloseDetailPanel">
            <div class="bg-white w-full max-w-lg h-full overflow-y-auto shadow-2xl p-6 space-y-5 relative"
                 @onclick:stopPropagation>
                <button @onclick="CloseDetailPanel"
                        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl">✕</button>

                <div>
                    <h3 class="text-lg font-bold text-gray-800">@_selectedEvent.Title</h3>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(_selectedEvent.Status)">
                        @_selectedEvent.Status
                    </span>
                </div>

                @if (_selectedEvent.Description is not null)
                {
                    <p class="text-sm text-gray-600">@_selectedEvent.Description</p>
                }

                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Venue</p>
                        <p class="font-medium text-gray-700">@_selectedEvent.Venue</p>
                        @if (_selectedEvent.Address is not null)
                        {
                            <p class="text-xs text-gray-400">@_selectedEvent.Address</p>
                        }
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Schedule</p>
                        <p class="font-medium text-gray-700 text-xs">@_selectedEvent.StartAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                        <p class="text-xs text-gray-400">→ @_selectedEvent.EndAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                    </div>
                    <div class="bg-indigo-50 rounded-xl p-3">
                        <p class="text-xs text-indigo-400 mb-1">Crew Assigned</p>
                        <p class="font-bold text-indigo-700">@_selectedEvent.AssignedCrew @((_selectedEvent.MaxCrew > 0) ? $"/ {_selectedEvent.MaxCrew}" : "")</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Created By</p>
                        <p class="font-medium text-gray-700 text-xs">@_selectedEvent.CreatedByName</p>
                    </div>
                </div>

                <!-- Assign Crew (Admin/Manager) — first per UX -->
                @if (!_isEventLocked)
                {
                <div class="space-y-3">
                    <h4 class="font-semibold text-gray-700 text-sm">Assign Crew Member</h4>

                    @* ── Mode toggle: Direct OR Via Vendor ── *@
                    <div class="grid grid-cols-3 gap-1 p-1 bg-gray-100 rounded-xl text-[11px] font-medium">
                        <button type="button"
                                @onclick='() => SetAssignMode("crew")'
                                class="@(_assignMode == "crew" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            👤 Crew only
                        </button>
                        <button type="button"
                                @onclick='() => SetAssignMode("vendor")'
                                class="@(_assignMode == "vendor" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            🏢 Vendor only
                        </button>
                        <button type="button"
                                @onclick='() => SetAssignMode("both")'
                                class="@(_assignMode == "both" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            🤝 Vendor + Crew
                        </button>
                    </div>

                    @if (_assignMode == "vendor" || _assignMode == "both")
                    {
                        @* ── Vendor picker ── *@
                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-500 mb-1">Vendor <span class="text-red-400">*</span></label>
                            @if (_assignSelectedVendor != null)
                            {
                                <div class="flex items-center justify-between px-3 py-2 rounded-xl border border-indigo-200 bg-indigo-50 text-xs">
                                    <div>
                                        <span class="font-semibold text-indigo-800">@_assignSelectedVendor.FullName</span>
                                        <span class="text-gray-400 ml-2">@_assignSelectedVendor.Mobile</span>
                                    </div>
                                    <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearAssignVendor">✕</button>
                                </div>
                            }
                            else
                            {
                                <input class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                       placeholder="Search vendor by name…"
                                       @value="_assignVendorSearch"
                                       @onfocus="() => _assignVendorDropOpen = true"
                                       @oninput="OnAssignVendorSearch" />
                                @if (_assignVendorDropOpen)
                                {
                                    @if (_assignVendorResults.Count > 0)
                                    {
                                        <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto">
                                            @foreach (var v in _assignVendorResults)
                                            {
                                                <button class="block w-full text-left px-3 py-2 text-xs hover:bg-indigo-50 border-b border-gray-50 last:border-0"
                                                        @onclick="() => SelectAssignVendor(v)">
                                                    <span class="font-semibold text-gray-800">@v.FullName</span>
                                                    <span class="text-gray-400 ml-2">@v.Mobile</span>
                                                    @if (!string.IsNullOrEmpty(v.BusinessName))
                                                    {
                                                        <span class="text-gray-400 ml-1">· @v.BusinessName</span>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    }
                                    else if (_assignVendorSearch.Length >= 1)
                                    {
                                        <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-sm px-3 py-2 text-xs text-gray-400 italic">
                                            No vendors found for "@_assignVendorSearch"
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }

                    @if (_assignMode == "crew" || _assignMode == "both")
                    {
                    @* ── Crew picker (filtered by vendor in vendor mode) ── *@
                    <div class="relative">
                        <label class="block text-xs font-medium text-gray-500 mb-1">Crew Member <span class="text-red-400">*</span></label>
                        @if (_assignSelectedCrew != null)
                        {
                            <div class="flex items-center justify-between px-3 py-2 rounded-xl border border-indigo-200 bg-indigo-50 text-xs">
                                <div>
                                    <span class="font-semibold text-indigo-800">@_assignSelectedCrew.FullName</span>
                                    <span class="text-gray-400 ml-2">@_assignSelectedCrew.Mobile</span>
                                </div>
                                <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearAssignCrew">✕</button>
                            </div>
                        }
                        else
                        {
                            <input class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                   placeholder="@(_assignMode == "vendor" && _assignSelectedVendor != null ? "Search crew under this vendor…" : "Search crew by name…")"
                                   @value="_assignCrewSearch"
                                   @onfocus="() => _assignCrewDropOpen = true"
                                   @oninput="OnAssignCrewSearch" />
                            @if (_assignCrewDropOpen)
                            {
                                @if (_assignCrewResults.Count > 0)
                                {
                                    <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto">
                                        @foreach (var cr in _assignCrewResults)
                                        {
                                            <button class="block w-full text-left px-3 py-2 text-xs hover:bg-indigo-50 border-b border-gray-50 last:border-0"
                                                    @onclick="() => SelectAssignCrew(cr)">
                                                <span class="font-semibold text-gray-800">@cr.FullName</span>
                                                <span class="text-gray-400 ml-2">@cr.Mobile</span>
                                                @if (!string.IsNullOrEmpty(cr.VendorName))
                                                {
                                                    <span class="text-gray-400 ml-1">· via @cr.VendorName</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                }
                                else if (_assignCrewSearch.Length >= 1)
                                {
                                    <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-sm px-3 py-2 text-xs text-gray-400 italic">
                                        No crew found for "@_assignCrewSearch"
                                    </div>
                                }
                            }
                        }
                    </div>
                    }

                    @* ── Mode hint ── *@
                    @if (_assignMode == "crew")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Direct crew assignment — skips the vendor step. Crew acceptance goes straight to your Approval Queue.
                        </p>
                    }
                    else if (_assignMode == "vendor")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Vendor-only — the vendor will assign their own crew to this event.
                        </p>
                    }
                    else if (_assignMode == "both")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Vendor + Crew — both are linked. Crew acceptance goes to the vendor for approval first.
                        </p>
                    }

                    @* ── Duplicate-assignment warning ── *@
                    @{
                        var dupWarn = DuplicateAssignWarning();
                    }
                    @if (dupWarn is not null)
                    {
                        <div class="p-2.5 bg-amber-50 border border-amber-200 rounded-lg text-[11px] text-amber-800 flex items-center gap-1.5">
                            <span>⚠️</span><span>@dupWarn</span>
                        </div>
                    }

                    @* ── Assign button ── *@
                    <button @onclick="AssignCrew"
                            disabled="@(!CanSubmitAssign() || _assigning)"
                            class="w-full py-2 text-xs rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed transition">
                        @(_assigning ? "Assigning…" : "✚ Assign to Event")
                    </button>

                    @if (_assignError is not null)
                    {
                        <p class="text-xs text-red-600">⚠️ @_assignError</p>
                    }
                </div>
                }
                else
                {
                    <div class="border border-gray-200 bg-gray-50 rounded-xl p-4 text-xs text-gray-500 italic">
                        🔒 This event is @_selectedEvent.Status.ToLower() — crew can no longer be assigned or edited.
                    </div>
                }

                @* ── Phase C step 5: Vendor allocations per shift ──────────
                   Admins/Managers grant per-vendor quotas on each shift.
                   Without at least one allocation on a shift, the quota
                   gate stays in legacy mode (capacity-only) — so this
                   section is the on-ramp to quota-managed staffing.
                   Hidden when event is locked (matches assign-crew form). *@
                @if (!_isEventLocked && _selectedEventShifts is not null && _selectedEventShifts.Count > 0)
                {
                    <div class="border-t border-gray-100 pt-4">
                        <div class="flex items-center justify-between mb-3">
                            <h4 class="font-semibold text-gray-700 text-sm">Vendor Quotas</h4>
                            <button type="button" @onclick="ToggleAllocSection"
                                    class="text-[11px] text-indigo-600 hover:underline">
                                @(_allocSectionOpen ? "Hide" : "Show")
                            </button>
                        </div>
                        @if (_allocSectionOpen)
                        {
                            @foreach (var sh in _selectedEventShifts)
                            {
                                var shiftId = sh.Id;
                                var rows    = _allocationsByShift.GetValueOrDefault(shiftId);
                                var totalQ  = rows?.Where(r => !r.IsArchived).Sum(r => r.Quota) ?? 0;
                                var headroom = sh.CrewCount - totalQ;
                                <div class="bg-gray-50 border border-gray-200 rounded-xl p-3 mb-2 space-y-2">
                                    <div class="min-w-0">
                                        <p class="text-xs font-semibold text-gray-700 truncate">@sh.ScopeName</p>
                                        <p class="text-[10px] text-gray-500">
                                            Capacity @sh.CrewCount · Allocated @totalQ · Free <b class="@(headroom > 0 ? "text-emerald-700" : "text-gray-400")">@headroom</b>
                                        </p>
                                    </div>
                                    @if (rows is null)
                                    {
                                        <p class="text-[11px] text-gray-400 italic">Loading…</p>
                                    }
                                    else if (rows.Where(r => !r.IsArchived).ToList() is var active && active.Count == 0)
                                    {
                                        <p class="text-[11px] text-gray-400 italic">No vendor allocations yet. Use the assign panel above to invite a vendor for this shift.</p>
                                    }
                                    else
                                    {
                                        <div class="space-y-1.5">
                                            @foreach (var r in active.OrderBy(x => x.VendorName))
                                            {
                                                @* Phase D step 18: surface placeholder invite status next
                                                   to the vendor name. Mapping: VendorAccepted → green
                                                   "Accepted"; Invited → amber "Pending Invite"; rejection
                                                   states → rose "Rejected"; null/unknown → no badge. *@
                                                var (vIsLbl, vIsClass) = r.InviteStatus switch
                                                {
                                                    "VendorAccepted"                  => ("Accepted",        "bg-emerald-50 text-emerald-700 border border-emerald-200"),
                                                    "Invited"                         => ("Pending Invite",  "bg-amber-50 text-amber-700 border border-amber-200"),
                                                    "RejectedByVendor"                => ("Rejected",        "bg-rose-50 text-rose-700 border border-rose-200"),
                                                    "Declined" or "RejectedByManager" => ("Rejected",        "bg-rose-50 text-rose-700 border border-rose-200"),
                                                    _                                 => ("",                ""),
                                                };
                                                <div class="flex items-center justify-between bg-white border border-gray-200 rounded-lg px-2.5 py-1.5">
                                                    <div class="min-w-0">
                                                        <div class="flex items-center gap-1.5">
                                                            <p class="text-[11px] font-semibold text-gray-800 truncate">@r.VendorName</p>
                                                            @if (!string.IsNullOrEmpty(vIsLbl))
                                                            {
                                                                <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full @vIsClass">@vIsLbl</span>
                                                            }
                                                        </div>
                                                        <p class="text-[10px] text-gray-500">@r.CurrentlyAssigned / @r.Quota assigned</p>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            @if (_allocError is not null)
                            {
                                <p class="text-xs text-red-600 mt-1">⚠️ @_allocError</p>
                            }
                        }
                    </div>
                }

                @* ── Allocation Create mini-modal ───────────────────────── *@
                @if (_allocCreateShiftId is not null)
                {
                    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4" @onclick="CloseAllocCreate">
                        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-5 space-y-3" @onclick:stopPropagation="true">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="font-bold text-gray-800 text-sm">Allocate vendor quota</h3>
                                    @{
                                        var allocShift = _selectedEventShifts?.FirstOrDefault(x => x.Id == _allocCreateShiftId);
                                    }
                                    @if (allocShift is not null)
                                    {
                                        <p class="text-[11px] text-gray-500 mt-0.5">
                                            for <b class="text-gray-700">@allocShift.ScopeName</b>
                                            · @allocShift.StartAt.ToLocalTime().ToString("MMM d, HH:mm")
                                            @if (allocShift.EndAt is { } e)
                                            {
                                                <span> – @e.ToLocalTime().ToString("HH:mm")</span>
                                            }
                                        </p>
                                    }
                                </div>
                                <button @onclick="CloseAllocCreate" class="text-gray-400 hover:text-gray-700 text-xl leading-none">×</button>
                            </div>
                            <div class="relative">
                                <label class="block text-[11px] font-medium text-gray-500 mb-1">Vendor</label>
                                @if (_allocCreateVendor is not null)
                                {
                                    <div class="flex items-center justify-between px-3 py-2 rounded-xl border border-indigo-200 bg-indigo-50 text-xs">
                                        <span class="font-semibold text-indigo-800">@_allocCreateVendor.FullName</span>
                                        <button class="text-gray-400 hover:text-red-500" @onclick="() => { _allocCreateVendor = null; }">✕</button>
                                    </div>
                                }
                                else
                                {
                                    <input class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                           placeholder="Search vendor by name…"
                                           @value="_allocVendorSearch"
                                           @oninput="OnAllocVendorSearch" />
                                    @if (_allocVendorResults.Count > 0)
                                    {
                                        <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg max-h-40 overflow-y-auto">
                                            @foreach (var v in _allocVendorResults)
                                            {
                                                <button class="block w-full text-left px-3 py-2 text-xs hover:bg-indigo-50 border-b border-gray-50 last:border-0"
                                                        @onclick="() => SelectAllocVendor(v)">
                                                    <span class="font-semibold text-gray-800">@v.FullName</span>
                                                    <span class="text-gray-400 ml-2">@v.Mobile</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                            <div>
                                <label class="block text-[11px] font-medium text-gray-500 mb-1">Quota</label>
                                <input type="number" min="1" max="@_allocCreateMaxQuota"
                                       @bind="_allocCreateQuota"
                                       class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                                <p class="text-[10px] text-gray-400 mt-1">Max for this shift right now: @_allocCreateMaxQuota</p>
                            </div>
                            @if (_allocCreateError is not null)
                            {
                                <p class="text-xs text-red-600">⚠️ @_allocCreateError</p>
                            }
                            <div class="flex justify-end gap-2 pt-1">
                                <button @onclick="CloseAllocCreate" class="text-xs px-3 py-1.5 rounded-lg text-gray-500 hover:bg-gray-100">Cancel</button>
                                <button @onclick="SubmitAllocCreate"
                                        disabled="@(_allocCreateVendor is null || _allocCreateSubmitting || _allocCreateQuota < 1)"
                                        class="text-xs px-3 py-1.5 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 disabled:opacity-50">
                                    @(_allocCreateSubmitting ? "Saving…" : "Grant Quota")
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @* ── Phase D step 4: Multi-shift assignment modal ──────────
                   Vendor-only with N shifts: distribute N seats across rows.
                   Crew-only / Vendor+Crew with N shifts: pick exactly ONE row
                   (a single crew member can't fan across shifts). *@
                @if (_multiShiftModalOpen)
                {
                    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-50 flex items-center justify-center p-4" @onclick="CloseMultiShiftModal">
                        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-5 space-y-3" @onclick:stopPropagation="true">
                            <div class="flex items-center justify-between">
                                <div>
                                    @if (_assignMode == "vendor" && _assignSelectedVendor is not null)
                                    {
                                        <h3 class="font-bold text-gray-800 text-sm">Assign Vendor <span class="text-indigo-700">@_assignSelectedVendor.FullName</span> to shifts</h3>
                                        <p class="text-[11px] text-gray-500 mt-0.5">Pick one or more shifts and how many crew the vendor brings to each.</p>
                                    }
                                    else if (_assignMode == "crew" && _assignSelectedCrew is not null)
                                    {
                                        <h3 class="font-bold text-gray-800 text-sm">Assign Crew <span class="text-indigo-700">@_assignSelectedCrew.FullName</span> to a shift</h3>
                                        <p class="text-[11px] text-gray-500 mt-0.5">Pick the shift this crew member will work.</p>
                                    }
                                    else
                                    {
                                        <h3 class="font-bold text-gray-800 text-sm">Assign Crew + Vendor to a shift</h3>
                                        <p class="text-[11px] text-gray-500 mt-0.5">Pick the shift this crew member will work under @_assignSelectedVendor?.FullName.</p>
                                    }
                                </div>
                                <button @onclick="CloseMultiShiftModal" class="text-gray-400 hover:text-gray-700 text-xl leading-none">×</button>
                            </div>

                            <div class="space-y-2 max-h-[55vh] overflow-y-auto pr-1">
                                @if (_selectedEventShifts is not null)
                                {
                                    @foreach (var sh in _selectedEventShifts)
                                    {
                                        // Phase D step 9: free seats must account for placeholder
                                        // invites too — not just real crew. Total reserved =
                                        // max(AssignedCrew, sum of active allocation quotas) since
                                        // every allocation row reserves N placeholder seats.
                                        var totalAlloc = _allocationsByShift.GetValueOrDefault(sh.Id)
                                            ?.Where(r => !r.IsArchived).Sum(r => r.Quota) ?? 0;
                                        var reserved = Math.Max(sh.AssignedCrew, totalAlloc);
                                        var free  = Math.Max(0, sh.CrewCount - reserved);
                                        var row   = _multiShiftRows.GetValueOrDefault(sh.Id) ?? new MultiShiftRow();
                                        _multiShiftRows[sh.Id] = row;  // make sure dict has it
                                        var isVendorMode = _assignMode == "vendor";
                                        <div class="bg-gray-50 border border-gray-200 rounded-xl p-3 flex items-center gap-3">
                                            @if (isVendorMode)
                                            {
                                                <input type="checkbox" @bind="row.Selected"
                                                       class="w-4 h-4 accent-indigo-600 shrink-0" />
                                            }
                                            else
                                            {
                                                <input type="radio" name="single-shift-pick"
                                                       checked="@(_multiShiftSingleChoice == sh.Id)"
                                                       @onchange="() => _multiShiftSingleChoice = sh.Id"
                                                       class="w-4 h-4 accent-indigo-600 shrink-0" />
                                            }
                                            <div class="min-w-0 flex-1">
                                                <p class="text-xs font-semibold text-gray-800 truncate">@sh.ScopeName</p>
                                                <p class="text-[10px] text-gray-500">
                                                    @sh.StartAt.ToLocalTime().ToString("MMM d, HH:mm")
                                                    @if (sh.EndAt is { } e)
                                                    {
                                                        <span> – @e.ToLocalTime().ToString("HH:mm")</span>
                                                    }
                                                    · <b class="@(free > 0 ? "text-emerald-700" : "text-gray-400")">@free free</b> of @sh.CrewCount
                                                </p>
                                            </div>
                                            @if (isVendorMode)
                                            {
                                                <input type="number" min="1" max="@(free > 0 ? free : 1)"
                                                       @bind="row.Count"
                                                       disabled="@(!row.Selected || free <= 0)"
                                                       class="w-16 px-2 py-1 text-xs rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400 disabled:bg-gray-100 disabled:text-gray-400" />
                                            }
                                        </div>
                                    }
                                }
                            </div>

                            @if (_multiShiftError is not null)
                            {
                                <p class="text-xs text-red-600">⚠️ @_multiShiftError</p>
                            }

                            <div class="flex justify-end gap-2 pt-1">
                                <button @onclick="CloseMultiShiftModal" class="text-xs px-3 py-1.5 rounded-lg text-gray-500 hover:bg-gray-100">Cancel</button>
                                <button @onclick="SubmitMultiShiftAssign"
                                        disabled="@_multiShiftSubmitting"
                                        class="text-xs px-3 py-1.5 rounded-lg bg-indigo-600 text-white font-semibold hover:bg-indigo-700 disabled:opacity-50">
                                    @(_multiShiftSubmitting ? "Assigning…" : "Assign")
                                </button>
                            </div>
                        </div>
                    </div>
                }

                <!-- Assignments (grouped by vendor) -->
                <div class="border-t border-gray-100 pt-4">
                    <h4 class="font-semibold text-gray-700 text-sm mb-3">Crew Assignments</h4>
                    @if (_loadingAssignments)
                    {
                        <div class="flex justify-center py-4">
                            <svg class="animate-spin h-5 w-5 text-indigo-400" viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                            </svg>
                        </div>
                    }
                    else if (!(_assignments?.Items.Any(a => a.CrewId.HasValue) ?? false))
                    {
                        <p class="text-xs text-gray-400 text-center py-4">No crew assigned yet.</p>
                    }
                    else
                    {
                        @* Group assignments by vendor. Vendor-less rows ("direct"
                           assignments — admin assigned the crew bypassing a vendor)
                           collapse into a synthetic "Direct (no vendor)" bucket
                           pinned at the bottom so it doesn't clutter the top. *@
                        <div class="space-y-2">
                            @* Phase D step 18: placeholder rows (vendor-acceptance
                               anchors with CrewId == null) are hidden from Crew
                               Assignments entirely — they belong in Vendor Quotas
                               above, where each vendor's row carries an "Accepted"
                               / "Pending Invite" badge and a "Used / Quota" count.
                               This list now contains ONLY real-crew assignments,
                               which matches what managers actually need to see. *@
                            @foreach (var group in GroupAssignmentsByVendor(_assignments!.Items.Where(a => a.CrewId.HasValue)))
                            {
                                var isOpen = _expandedVendorGroups.Contains(group.Key);
                                var headerLabel = group.VendorName ?? "Direct (no vendor)";
                                var headerSub   = group.VendorName is null
                                                  ? "Crew assigned directly by Admin/Manager"
                                                  : $"{group.Rows.Count} crew assignment{(group.Rows.Count == 1 ? "" : "s")}";

                                <div class="border border-gray-200 rounded-xl overflow-hidden">
                                    <button type="button"
                                            @onclick="() => ToggleVendorGroup(group.Key)"
                                            class="w-full flex items-center justify-between bg-gray-50 hover:bg-gray-100 px-4 py-2.5 text-left transition">
                                        <div class="flex items-center gap-2">
                                            <span class="text-gray-400 text-xs">@(isOpen ? "▼" : "▶")</span>
                                            <span class="text-sm font-semibold text-gray-800">@headerLabel</span>
                                        </div>
                                        <span class="text-[11px] text-gray-500">@headerSub</span>
                                    </button>

                                    @if (isOpen)
                                    {
                                        <div class="bg-white p-2 space-y-3">
                                            @* Phase D step 5: rows are grouped by shift inside each
                                               vendor. When every row in a shift bucket is an empty-crew
                                               "Invited" placeholder, the whole bucket collapses to a
                                               single summary line ("Box Office × 5 - Invited / Revoke
                                               Invite"). Mixed buckets render rows individually. *@
                                            @foreach (var bucket in BucketByShift(group.Rows))
                                            {
                                                var allPlaceholders = IsAllInvitedPlaceholders(bucket);
                                                var allRejected     = IsAllRejectedPlaceholders(bucket);
                                                var bucketBusy      = bucket.All.Any(x => _placeholderBusy == x.Id);

                                                <div class="border border-gray-100 rounded-xl overflow-hidden">
                                                    <div class="bg-indigo-50/40 px-3 py-1.5 flex items-center justify-between">
                                                        <span class="text-[11px] font-semibold text-indigo-900 uppercase tracking-wide">@bucket.ScopeLabel</span>
                                                        <span class="text-[10px] text-indigo-700/70">@bucket.All.Count seat@(bucket.All.Count == 1 ? "" : "s")</span>
                                                    </div>

                                                    @if (allPlaceholders)
                                                    {
                                                        <div class="bg-gray-50 px-4 py-2.5 flex items-center justify-between">
                                                            <div>
                                                                <p class="text-sm font-medium text-gray-800">@bucket.ScopeLabel — @bucket.All.Count slot@(bucket.All.Count == 1 ? "" : "s")</p>
                                                                <p class="text-xs text-gray-400 italic">Waiting for vendor to invite crew</p>
                                                            </div>
                                                            <div class="flex items-center gap-2">
                                                                <span class="text-xs px-2.5 py-1 rounded-full font-semibold bg-amber-100 text-amber-700">Invited</span>
                                                                @if (_canWrite && !_isEventLocked)
                                                                {
                                                                    <button @onclick="() => RevokeBucket(bucket)"
                                                                            disabled="@bucketBusy"
                                                                            class="px-3 py-1 rounded-lg border border-rose-200 text-rose-600 hover:bg-rose-50 text-[11px] font-semibold disabled:opacity-50 transition">
                                                                        @(bucketBusy ? "Revoking…" : "✕ Revoke Invite")
                                                                    </button>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    else if (allRejected)
                                                    {
                                                        @* Phase D step 10: collapsed "vendor rejected" row.
                                                           Surfaces the first row's RejectionReason (they're
                                                           all the same when the vendor rejected the bucket
                                                           in one click) and offers a single Re-invite All
                                                           that fans out per-row server-side. *@
                                                        var firstReason = bucket.All
                                                            .Select(x => x.RejectionReason)
                                                            .FirstOrDefault(r => !string.IsNullOrEmpty(r));
                                                        <div class="bg-rose-50/40 px-4 py-2.5 flex items-center justify-between">
                                                            @{
                                                                var rejectedLabel = string.IsNullOrEmpty(firstReason)
                                                                    ? "Rejected by vendor"
                                                                    : "Rejected by vendor — " + firstReason;
                                                            }
                                                            <div class="min-w-0">
                                                                <p class="text-sm font-medium text-gray-800">@bucket.ScopeLabel — @bucket.All.Count slot@(bucket.All.Count == 1 ? "" : "s")</p>
                                                                <p class="text-xs text-rose-500 italic truncate">@rejectedLabel</p>
                                                            </div>
                                                            <div class="flex items-center gap-2 shrink-0">
                                                                <span class="text-xs px-2.5 py-1 rounded-full font-semibold bg-rose-100 text-rose-700">RejectedByVendor</span>
                                                                @if (_canWrite && !_isEventLocked)
                                                                {
                                                                    <button @onclick="() => ReinviteBucket(bucket)"
                                                                            disabled="@bucketBusy"
                                                                            class="px-3 py-1 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-semibold disabled:opacity-50 transition">
                                                                        @(bucketBusy ? "Re-inviting…" : "↻ Re-invite")
                                                                    </button>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="p-2 space-y-2">
                                                            @foreach (var a in bucket.All)
                                                            {
                                                                var isPlaceholder    = string.IsNullOrEmpty(a.CrewName) && !string.IsNullOrEmpty(a.VendorName);
                                                                var canRevoke        = _canWrite && isPlaceholder && a.Status == "Invited" && !_isEventLocked;
                                                                var canReinvite      = _canWrite && isPlaceholder && a.Status == "RejectedByVendor" && !_isEventLocked;
                                                                var rowBusy          = _placeholderBusy == a.Id;

                                                <div class="bg-gray-50 rounded-xl px-4 py-2.5 space-y-2">
                                                    <div class="flex items-center justify-between">
                                                        <div>
                                                            <p class="text-sm font-medium text-gray-800">
                                                                @(string.IsNullOrEmpty(a.CrewName) ? "(Vendor to assign crew)" : a.CrewName)
                                                            </p>
                                                            <p class="text-xs text-gray-400">
                                                                @if (!string.IsNullOrEmpty(a.CrewMobile)) { <span>@a.CrewMobile</span> }
                                                                @if (string.IsNullOrEmpty(a.VendorName))
                                                                {
                                                                    <span class="italic text-amber-600">@(string.IsNullOrEmpty(a.CrewMobile) ? "" : " · ")direct</span>
                                                                }
                                                            </p>
                                                            @if (a.Status == "RejectedByVendor" && !string.IsNullOrEmpty(a.RejectionReason))
                                                            {
                                                                <p class="text-[11px] text-rose-500 mt-0.5 italic">"@a.RejectionReason"</p>
                                                            }
                                                        </div>
                                                        @{
                                                            var (lbl, badge, sub) = AssignmentStatusDisplay.For(a.Status, _selectedEvent.Status, a.AttendanceNote);
                                                            var canOverride = AssignmentStatusDisplay.CanAdminMarkAttended(a.Status, _selectedEvent.Status, _role == "Admin") && a.CrewId.HasValue;
                                                        }
                                                        <div class="flex flex-col items-end gap-0.5">
                                                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold @badge">@lbl</span>
                                                            @if (!string.IsNullOrEmpty(sub))
                                                            {
                                                                <span class="text-[10px] text-gray-400 italic">@sub</span>
                                                            }
                                                        </div>
                                                    </div>

                                                    @if (canOverride)
                                                    {
                                                        var ovBusy = _overrideBusy == a.Id;
                                                        <div class="flex justify-end pt-1">
                                                            <button @onclick="() => AdminMarkAttended(a)"
                                                                    disabled="@ovBusy"
                                                                    class="px-3 py-1 rounded-lg border border-emerald-200 text-emerald-700 hover:bg-emerald-50 text-[11px] font-semibold disabled:opacity-50 transition">
                                                                @(ovBusy ? "Marking…" : "✓ Mark Attended (Admin)")
                                                            </button>
                                                        </div>
                                                    }

                                                    @if (canRevoke || canReinvite)
                                                    {
                                                        <div class="flex justify-end gap-2 pt-1">
                                                            @if (canRevoke)
                                                            {
                                                                <button @onclick="() => RevokeVendorInvite(a)"
                                                                        disabled="@rowBusy"
                                                                        class="px-3 py-1 rounded-lg border border-rose-200 text-rose-600 hover:bg-rose-50 text-[11px] font-semibold disabled:opacity-50 transition">
                                                                    @(rowBusy ? "Revoking…" : "✕ Revoke Invite")
                                                                </button>
                                                            }
                                                            @if (canReinvite)
                                                            {
                                                                <button @onclick="() => ReinviteVendor(a)"
                                                                        disabled="@rowBusy"
                                                                        class="px-3 py-1 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-semibold disabled:opacity-50 transition">
                                                                    @(rowBusy ? "Re-inviting…" : "↻ Re-invite")
                                                                </button>
                                                            }
                                                        </div>
                                                    }
                                                            </div>
                                                        }
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    }

    <!-- ── Create / Edit Event Modal ─────────────────────────────────────────── -->
    @if (_showEventModal)
    {
        <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" @onclick="CloseModal">
            <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md flex flex-col max-h-[90vh]" @onclick:stopPropagation>
                @* Sticky header — pinned so users always see what dialog
                   they're in even when the body scrolls. *@
                <div class="flex items-center justify-between px-6 pt-6 pb-3 border-b border-gray-100 flex-shrink-0">
                    <h3 class="text-base font-bold text-gray-800">@(_editingEvent is null ? "Create Event" : "Edit Event")</h3>
                    <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 text-xl">✕</button>
                </div>

                @* Scrollable body — caps the modal at 90vh and lets content
                   inside scroll when there are several shifts. Without this
                   the panel grew off-screen and neither the panel nor the
                   page behind it could scroll. *@
                <div class="flex-1 overflow-y-auto px-6 py-4 space-y-5">

                <div class="space-y-3">
                    <input @bind="_form.Title" placeholder="Event title *"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <textarea @bind="_form.Description" placeholder="Description (optional)" rows="2"
                              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"></textarea>
                    <input @bind="_form.Venue" placeholder="Venue *"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <input @bind="_form.Address" placeholder="Address (optional)"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-xs text-gray-500 mb-1 block">Start *</label>
                            <input type="datetime-local" @bind="_form.StartAt"
                                   class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 mb-1 block">End *</label>
                            <input type="datetime-local" @bind="_form.EndAt"
                                   class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>
                    </div>
                    @* ─── Phase B: Scope of Work + Crew Count ───────────────────
                       Replaces the old MaxCrew field. v1 of the UI surfaces
                       ONE shift per event (scope + count + optional end time);
                       Phase C will let admins add more rows here. The API
                       already accepts a list, so the data path is forward-
                       compatible — only the UI is single-shift for now.

                       On Edit: we don't yet allow editing existing shifts
                       from this modal (read-only summary shown instead).
                       Editing shifts after creation is a dedicated Phase C
                       affordance — too much UX to retrofit safely here. *@
                    @* ── Phase C step 4: multi-shift editor (CREATE only) ──────
                       Repeating row list. Each row = one EventShift. Total
                       capacity (MaxCrew) is derived from SUM(CrewCount) and
                       is shown read-only at the bottom. Empty list disables
                       Save. We don't allow editing shifts after creation
                       from this modal — that's a Phase D affordance and
                       safer as a dedicated drawer than retrofitted here. *@
                    @if (_editingEvent is null)
                    {
                        <div class="border border-gray-200 rounded-xl p-3 space-y-3 bg-gray-50">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-semibold text-gray-700">🧰 Shifts</span>
                            </div>
                            @if (_scopeCatalog.Count == 0)
                            {
                                <p class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded-lg p-2">
                                    ⚠️ No scope-of-work categories yet. <a href="/admin/scope-of-work" class="underline">Create one</a> first.
                                </p>
                            }
                            else
                            {
                                @for (int i = 0; i < _form.Shifts.Count; i++)
                                {
                                    var ix  = i; // capture for lambdas
                                    var row = _form.Shifts[ix];
                                    <div class="bg-white border border-gray-200 rounded-xl p-3 space-y-2">
                                        <div class="flex items-center justify-between gap-2">
                                            <span class="text-[11px] font-semibold text-gray-600">Shift @(ix + 1)</span>
                                            @if (_form.Shifts.Count > 1)
                                            {
                                                <button type="button" @onclick="() => RemoveShiftRow(ix)"
                                                        class="text-[11px] text-gray-400 hover:text-red-500 transition">✕ Remove</button>
                                            }
                                        </div>
                                        <select @bind="row.ScopeOfWorkId"
                                                class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 bg-white">
                                            @foreach (var sc in _scopeCatalog)
                                            {
                                                <option value="@sc.Id">@sc.Name</option>
                                            }
                                        </select>
                                        <div class="grid grid-cols-3 gap-2">
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block">Crew needed *</label>
                                                <input type="number" min="1" @bind="row.CrewCount"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                                            </div>
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block" title="Defaults to event start. Set earlier for load-in crew.">Shift start</label>
                                                <input type="datetime-local" @bind="row.StartAt"
                                                       placeholder="(event start)"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                                            </div>
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block">Shift end (optional)</label>
                                                <input type="datetime-local" @bind="row.EndAt"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                                            </div>
                                        </div>
                                    </div>
                                }

                                <div class="flex items-center justify-between gap-2 pt-1">
                                    <button type="button" @onclick="AddShiftRow"
                                            class="text-xs font-semibold text-indigo-600 hover:text-indigo-800 transition">
                                        ➕ Add another shift
                                    </button>
                                    <span class="text-[11px] text-gray-500">
                                        Total crew: <b class="text-gray-700">@_form.Shifts.Sum(x => Math.Max(0, x.CrewCount))</b>
                                    </span>
                                </div>
                                <p class="text-[11px] text-gray-500 italic">
                                    Each shift is a separate staffing slot (different scope or different end-time). Leave shift end blank to run until the event wraps.
                                </p>
                            }
                        </div>
                    }
                    else
                    {
                        @* ── Phase D step 1: real shift editor ─────────────────
                           Replaces the legacy MaxCrew input. Each row in
                           _editShifts is one EventShift; add/edit/archive
                           each one independently. Total capacity is computed
                           from SUM(active CrewCount) and auto-synced on the
                           server side via Event.RecomputeCapacityFromShifts. *@
                        <div class="border border-gray-200 rounded-xl p-3 space-y-3 bg-gray-50">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-semibold text-gray-700">🧰 Shifts</span>
                                @if (_editShifts is not null)
                                {
                                    <span class="text-[11px] text-gray-500">
                                        Total crew: <b class="text-gray-700">@_editShifts.Sum(x => x.CrewCount)</b>
                                    </span>
                                }
                            </div>

                            @if (_editShiftError is not null)
                            {
                                <div class="text-[11px] text-red-600 bg-red-50 border border-red-100 rounded-lg p-2">⚠️ @_editShiftError</div>
                            }

                            @if (_editShiftsLoading)
                            {
                                <p class="text-[11px] text-gray-400 italic">Loading shifts…</p>
                            }
                            else if (_editShifts is null || _editShifts.Count == 0)
                            {
                                <p class="text-[11px] text-gray-500 italic">No shifts on this event yet.</p>
                            }
                            else
                            {
                                @foreach (var sh in _editShifts.ToList())
                                {
                                    var row = sh;
                                    var busy = _editShiftBusyId == row.Id;
                                    <div class="bg-white border border-gray-200 rounded-xl p-3 space-y-2">
                                        <div class="flex items-center justify-between gap-2">
                                            <span class="text-[11px] font-semibold text-gray-600">@row.ScopeName · @row.AssignedCrew/@row.CrewCount used</span>
                                            <button type="button" @onclick="() => ArchiveShiftRow(row)"
                                                    disabled="@busy"
                                                    title="@(row.AssignedCrew > 0 ? "Reject or unassign crew first" : "Remove shift")"
                                                    class="text-[11px] text-gray-400 hover:text-red-500 disabled:opacity-40 transition">✕ Remove</button>
                                        </div>
                                        <select value="@row.ScopeOfWorkId.ToString()"
                                                @onchange="e => OnShiftScopeChanged(row, e)"
                                                disabled="@busy"
                                                class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm bg-white">
                                            @foreach (var sc in _scopeCatalog)
                                            {
                                                <option value="@sc.Id">@sc.Name</option>
                                            }
                                        </select>
                                        <div class="grid grid-cols-3 gap-2">
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block">Crew (min @row.AssignedCrew)</label>
                                                <input type="number" min="@Math.Max(1, row.AssignedCrew)" value="@row.CrewCount"
                                                       @onchange="e => OnShiftCrewCountChanged(row, e)"
                                                       disabled="@busy"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                            </div>
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block">Shift start</label>
                                                <input type="datetime-local" value="@row.StartAt.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")"
                                                       @onchange="e => OnShiftStartChanged(row, e)"
                                                       disabled="@busy"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                            </div>
                                            <div>
                                                <label class="text-[11px] text-gray-500 mb-1 block">Shift end</label>
                                                <input type="datetime-local" value="@(row.EndAt?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm"))"
                                                       @onchange="e => OnShiftEndChanged(row, e)"
                                                       disabled="@busy"
                                                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            }

                            @* Inline add-shift row *@
                            @if (_scopeCatalog.Count > 0)
                            {
                                <div class="bg-white border border-dashed border-indigo-200 rounded-xl p-3 space-y-2">
                                    <span class="text-[11px] font-semibold text-indigo-700">➕ Add another shift</span>
                                    <select @bind="_addShiftDraft.ScopeOfWorkId"
                                            class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm bg-white">
                                        @foreach (var sc in _scopeCatalog)
                                        {
                                            <option value="@sc.Id">@sc.Name</option>
                                        }
                                    </select>
                                    <div class="grid grid-cols-3 gap-2">
                                        <input type="number" min="1" @bind="_addShiftDraft.CrewCount" placeholder="Crew needed"
                                               class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                        <input type="datetime-local" @bind="_addShiftDraft.StartAt"
                                               title="Defaults to event start"
                                               class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                        <input type="datetime-local" @bind="_addShiftDraft.EndAt"
                                               title="Optional end time"
                                               class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm" />
                                    </div>
                                    <button type="button" @onclick="AddShiftToExistingEvent"
                                            disabled="@_editShiftsLoading"
                                            class="w-full py-2 rounded-xl bg-indigo-600 text-white text-xs font-semibold hover:bg-indigo-700 disabled:opacity-50 transition">
                                        Add shift
                                    </button>
                                </div>
                            }

                            <p class="text-[11px] text-gray-500 italic">
                                Total capacity auto-syncs to SUM(crew needed). Removing a shift is blocked while crew are still approved or confirmed on it.
                            </p>
                        </div>
                    }
                </div>

                @if (_formError is not null)
                {
                    <p class="text-sm text-red-600">⚠️ @_formError</p>
                }

                </div>
                @* ── /scrollable body ── *@

                @* Sticky footer — Save / Cancel always visible no matter
                   how tall the body gets. *@
                <div class="flex gap-3 px-6 py-4 border-t border-gray-100 flex-shrink-0 bg-white rounded-b-2xl">
                    <button @onclick="CloseModal"
                            class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button @onclick="SaveEvent" disabled="@_saving"
                            class="flex-1 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition disabled:opacity-60">
                        @(_saving ? "Saving…" : (_editingEvent is null ? "Create" : "Save Changes"))
                    </button>
                </div>
            </div>
        </div>
    }
}
else
{
    <!-- ══════════════════════════════════════════════════════════════════════
         CREW / VENDOR — My Assignments View
         ════════════════════════════════════════════════════════════════════ -->
    <div class="space-y-5">
        <div>
            <h2 class="text-lg font-bold text-gray-800">@(_role == "Vendor" ? "My Crew Assignments" : "My Assignments")</h2>
            <p class="text-sm text-gray-500">
            @(_role == "Vendor" ? "Crew members from your roster assigned to events." : "Events you've been assigned to by your vendor.")
        </p>
        </div>

        @if (_loading)
        {
            <div class="flex justify-center py-16">
                <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
            </div>
        }
        else if (_myAssignments?.Items.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
                <p class="text-4xl mb-3">📋</p>
                @if (_role == "Vendor")
                {
                    <p class="text-gray-500 text-sm font-medium">No event assignments found.</p>
                    <p class="text-gray-400 text-xs mt-1">As a vendor, your crew members will appear here once assigned to events by an admin.</p>
                }
                else
                {
                    <p class="text-gray-500 text-sm font-medium">No assignments yet.</p>
                    <p class="text-gray-400 text-xs mt-1">You'll see your event assignments here once your vendor assigns you.</p>
                }
            </div>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var a in _myAssignments!.Items)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                        <div class="flex items-start justify-between gap-3 flex-wrap">
                            <div class="flex-1 min-w-0">
                                <p class="font-semibold text-gray-800">@a.EventTitle</p>
                                <p class="text-xs text-gray-500 mt-0.5">
                                    @if (_role == "Vendor")
                                    {
                                        <span>Crew: <span class="font-medium text-gray-700">@(a.CrewName ?? "(unassigned)")</span> @(string.IsNullOrEmpty(a.CrewMobile) ? "" : "· " + a.CrewMobile)</span>
                                    }
                                    else
                                    {
                                        <span>@(string.IsNullOrEmpty(a.VendorName) ? "(direct)" : "via " + a.VendorName)</span>
                                    }
                                </p>
                            </div>
                            <span class="shrink-0 text-xs font-semibold px-3 py-1.5 rounded-full @GetAssignmentStatusClass(a.Status)">
                                @a.Status
                            </span>
                        </div>

                        <div class="mt-3 flex flex-wrap gap-3 text-xs text-gray-500">
                            <span>📅 Assigned @a.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</span>
                            @if (a.ConfirmedAt.HasValue)
                            {
                                <span class="text-green-600">✓ Confirmed @a.ConfirmedAt.Value.ToLocalTime().ToString("MMM dd")</span>
                            }
                            @if (a.DeclinedAt.HasValue)
                            {
                                <span class="text-red-500">✗ Declined @a.DeclinedAt.Value.ToLocalTime().ToString("MMM dd")</span>
                            }
                        </div>

                        <!-- Crew: respond to pending assignment -->
                        @if (_role == "Crew" && a.Status == "Pending")
                        {
                            <div class="mt-4 flex gap-2">
                                <button @onclick='() => RespondToAssignment(a.Id, "confirm")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-green-600 text-white font-semibold hover:bg-green-700 transition">
                                    ✓ Accept
                                </button>
                                <button @onclick='() => RespondToAssignment(a.Id, "decline")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-red-50 text-red-600 font-semibold hover:bg-red-100 border border-red-200 transition">
                                    ✗ Decline
                                </button>
                            </div>
                        }

                        <!-- Crew: attendance check-in/out for confirmed + in-progress events -->
                        @if (_role == "Crew" && a.Status == "Confirmed")
                        {
                            <div class="mt-4 flex gap-2">
                                <button @onclick='() => RecordAttendance(a.Id, "checkin")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 transition">
                                    📍 Check In
                                </button>
                                <button @onclick='() => RecordAttendance(a.Id, "checkout")'
                                        class="flex-1 py-2 text-xs rounded-xl bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition">
                                    🚪 Check Out
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_totalMyPages > 1)
            {
                <div class="flex justify-center gap-2 pt-2">
                    <button @onclick="PrevMyPage" disabled="@(_myPage == 1)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">← Prev</button>
                    <span class="px-3 py-1.5 text-sm text-gray-500">Page @_myPage of @_totalMyPages</span>
                    <button @onclick="NextMyPage" disabled="@(_myPage >= _totalMyPages)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">Next →</button>
                </div>
            }
        }

        @* Toasts *@
        @if (_error is not null)
        {
            <div class="fixed bottom-5 right-5 bg-red-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ⚠️ @_error <button @onclick="() => _error = null" class="ml-3 font-bold">✕</button>
            </div>
        }
        @if (_success is not null)
        {
            <div class="fixed bottom-5 right-5 bg-green-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ✅ @_success <button @onclick="() => _success = null" class="ml-3 font-bold">✕</button>
            </div>
        }
    </div>
}

@code {
    private bool _accessDenied;
    private bool _canWrite;
    private Guid _placeholderBusy = Guid.Empty;
    private Guid _overrideBusy    = Guid.Empty;   // admin "Mark Attended" button busy-state
    // ── State ──────────────────────────────────────────────────────────────────
    private string _role = "";
    private bool   _loading = true;
    private bool   _loadingAssignments;
    private bool   _saving;
    private string? _search;
    private string? _statusFilter;
    private string  _sortKey   = "upcoming";   // sort dropdown (client-side over current page)
    private string  _viewMode  = "cards";       // "cards" | "list"

    private IEnumerable<EventListItemDto> SortEvents(IEnumerable<EventListItemDto> items) => _sortKey switch
    {
        "past"         => items.OrderByDescending(e => e.StartAt),
        "created_desc" => items.OrderByDescending(e => e.CreatedAt),
        "created_asc"  => items.OrderBy(e => e.CreatedAt),
        "title"        => items.OrderBy(e => e.Title, StringComparer.OrdinalIgnoreCase),
        "capacity"     => items.OrderBy(e => e.MaxCrew),
        // "upcoming" — future events first (closest first), then past (most recent first)
        _              => items.OrderBy(e => e.StartAt < DateTime.UtcNow ? 1 : 0)
                                .ThenBy(e => e.StartAt < DateTime.UtcNow ? -e.StartAt.Ticks : e.StartAt.Ticks)
    };
    private string? _error;
    private string? _success;

    // Admin/Manager paging
    private int _page = 1;
    private int _totalPages = 1;
    private PagedEventResult? _events;

    // Detail panel
    private EventDetailDto?          _selectedEvent;
    private PagedEventAssignmentResult? _assignments;
    private AttendanceSummaryDto?    _attendance;

    // Vendor-group accordion state (one entry per expanded vendor — keyed by
    // VendorId.ToString() for real vendors, or the sentinel "_direct" for the
    // synthetic "no-vendor" bucket). Reset on each drawer open in OpenDetailPanel.
    private readonly HashSet<string> _expandedVendorGroups = new();

    // ── Phase C step 5: Vendor allocation state ────────────────────────
    // _selectedEventShifts: cached shifts for the drawer's open event;
    //   reset to null on CloseDetailPanel and re-loaded in OpenDetailPanel.
    // _allocationsByShift: per-shift dictionary of every allocation row
    //   (active + archived). Markup filters archived in the view layer.
    // _allocSectionOpen: drawer-level toggle so the section starts
    //   collapsed for clean events; admins click "Show" to expose it.
    // _alloc*Edit*: in-row quota editor (single row at a time).
    // _allocCreate*: state for the "+ Allocate" mini-modal.
    private IReadOnlyList<EventShiftDto>? _selectedEventShifts;
    private readonly Dictionary<Guid, IReadOnlyList<VendorAllocationDto>> _allocationsByShift = new();
    private bool   _allocSectionOpen;
    private string? _allocError;

    // Per-row inline edit
    private Guid?  _allocEditingId;
    private int    _allocEditQuota;

    // "+ Allocate" modal state
    private Guid?  _allocCreateShiftId;
    private int    _allocCreateMaxQuota;
    private int    _allocCreateQuota = 1;
    private string _allocVendorSearch = string.Empty;
    private List<VendorListItemDto> _allocVendorResults = new();
    private VendorListItemDto? _allocCreateVendor;
    private bool   _allocCreateSubmitting;
    private string? _allocCreateError;
    private System.Threading.CancellationTokenSource? _allocSearchCts;


    // Computed: is the event in a terminal state where editing & assignment
    // are forbidden? Backend enforces this too (Event.Update throws), but the
    // UI hides the entry points so users don't bonk into a 400.
    private bool _isEventLocked =>
        _selectedEvent is not null
        && _selectedEvent.Status is "Completed" or "Cancelled";

    // Lightweight DTO + grouping helper. Lives here (not in a separate file)
    // because it's a view-model concern — the API returns a flat list and the
    // grouping is purely a presentation choice.
    private sealed record VendorGroup(string Key, string? VendorName, List<EventAssignmentDto> Rows);

    /// <summary>
    /// One shift's worth of assignments under a single vendor. The UI renders
    /// this as ONE collapsed row when every assignment is an empty-crew
    /// "Invited" placeholder ("Box Office × 5 — Invited / Revoke Invite").
    /// As soon as the vendor invites real named crew, those rows show
    /// individually alongside any remaining placeholders.
    /// </summary>
    private sealed record ShiftBucket(
        Guid?   ShiftId,
        string  ScopeLabel,
        List<EventAssignmentDto> All);

    /// <summary>
    /// Group a vendor's assignments by ShiftId. Buckets are ordered by scope
    /// label for stable rendering. Rows with no ShiftId (legacy data) land
    /// in a synthetic "Unassigned shift" bucket.
    /// </summary>
    private static IEnumerable<ShiftBucket> BucketByShift(IEnumerable<EventAssignmentDto> rows)
    {
        return rows
            .GroupBy(a => new { a.ShiftId, a.ShiftScopeName })
            .OrderBy(g => g.Key.ShiftScopeName ?? "~unassigned", StringComparer.OrdinalIgnoreCase)
            .Select(g => new ShiftBucket(
                ShiftId:    g.Key.ShiftId,
                ScopeLabel: g.Key.ShiftScopeName ?? "Unassigned shift",
                All:        g.ToList()));
    }

    /// <summary>
    /// Returns true when every row in the bucket is an empty-crew placeholder
    /// (vendor not yet filled the seat) AND all share the same Invited status.
    /// In that case the UI collapses the bucket into a single "× N" row.
    /// </summary>
    private static bool IsAllInvitedPlaceholders(ShiftBucket bucket)
    {
        if (bucket.All.Count == 0) return false;
        return bucket.All.All(a =>
            string.IsNullOrEmpty(a.CrewName) &&
            a.Status == "Invited");
    }

    /// <summary>
    /// Phase D step 10: counterpart to IsAllInvitedPlaceholders for the
    /// post-rejection state. When a vendor rejects an invite, every row
    /// in the shift bucket flips to RejectedByVendor but stays in the
    /// list (no auto-delete) so the admin can see the rejection reason
    /// and re-invite. Without this collapse, 6 rejected placeholders
    /// turn into 6 noisy rows. With it, they collapse into a single
    /// "× N — Rejected by vendor" summary with one Re-invite All button.
    /// </summary>
    private static bool IsAllRejectedPlaceholders(ShiftBucket bucket)
    {
        if (bucket.All.Count == 0) return false;
        return bucket.All.All(a =>
            string.IsNullOrEmpty(a.CrewName) &&
            a.Status == "RejectedByVendor");
    }

    private static IEnumerable<VendorGroup> GroupAssignmentsByVendor(IEnumerable<EventAssignmentDto> rows)
    {
        // Real-vendor groups first (alphabetised by name for stable order),
        // then the synthetic "Direct (no vendor)" bucket pinned last.
        var byVendor = rows
            .Where(a => a.VendorId.HasValue)
            .GroupBy(a => new { a.VendorId, a.VendorName })
            .OrderBy(g => g.Key.VendorName, StringComparer.OrdinalIgnoreCase)
            .Select(g => new VendorGroup(
                Key:        g.Key.VendorId!.Value.ToString(),
                VendorName: g.Key.VendorName,
                Rows:       g.ToList()));

        var direct = rows.Where(a => !a.VendorId.HasValue).ToList();

        foreach (var group in byVendor) yield return group;
        if (direct.Count > 0)
            yield return new VendorGroup("_direct", null, direct);
    }

    private void ToggleVendorGroup(string key)
    {
        if (!_expandedVendorGroups.Add(key))
            _expandedVendorGroups.Remove(key);
    }
