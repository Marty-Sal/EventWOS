@page "/events"
@attribute [Authorize]
@inject IEventApiService EventApi
@inject IVendorApiService VendorApi
@inject HttpClient Http
@inject AuthenticationStateProvider Auth
@inject NotificationHubService Hub
@implements IAsyncDisposable


    @if (_accessDenied)
    {
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
            <p class="text-gray-500 text-sm">You don't have permission to view this page.<br/>Contact your Admin to request access.</p>
        </div>
        return;
    }

<PageTitle>Events — EventWOS</PageTitle>

@if (_role is "Admin" or "Manager")
{
    <!-- ══════════════════════════════════════════════════════════════════════
         ADMIN / MANAGER — Full Event Management Board
         ════════════════════════════════════════════════════════════════════ -->
    <div class="space-y-5">
        <!-- Header -->
        <div class="flex items-center justify-between flex-wrap gap-3">
            <div>
                <h2 class="text-lg font-bold text-gray-800">Events</h2>
                <p class="text-sm text-gray-500">Manage workforce events end-to-end.</p>
            </div>
            @if (_canWrite)
            {
                <button @onclick="() => OpenCreateModal()"
                        class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow">
                    + Create Event
                </button>
            }
        </div>

        <!-- Filters -->
        <div class="flex flex-wrap gap-3 items-center">
            <div class="relative">
                <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
                       placeholder="Search events…"
                       class="w-64 pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
            </div>
            <select @bind:get="_statusFilter" @bind:set="OnStatusFilterChanged"
                    class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option value="">All Statuses</option>
                <option value="0">Draft</option>
                <option value="1">Published</option>
                <option value="2">In Progress</option>
                <option value="3">Completed</option>
                <option value="4">Cancelled</option>
            </select>

            <select @bind="_sortKey"
                    class="px-3 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                <option value="upcoming">Upcoming first</option>
                <option value="past">Most recent first</option>
                <option value="created_desc">Recently created</option>
                <option value="created_asc">Oldest created</option>
                <option value="title">Title A→Z</option>
                <option value="capacity">Capacity (low→high)</option>
            </select>

            <div class="ml-auto inline-flex rounded-xl border border-gray-200 bg-white p-0.5">
                <button @onclick='() => _viewMode = "cards"'
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "cards" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                    🔲 Cards
                </button>
                <button @onclick='() => _viewMode = "list"'
                        class="px-3 py-1.5 text-xs font-semibold rounded-lg transition @(_viewMode == "list" ? "bg-indigo-50 text-indigo-700" : "text-gray-500 hover:text-gray-700")">
                    ☰ List
                </button>
            </div>
        </div>

        <!-- Loading -->
        @if (_loading)
        {
            <div class="flex justify-center py-16">
                <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
            </div>
        }
        else if (_events?.Items.Count == 0)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
                <p class="text-4xl mb-3">📅</p>
                <p class="text-gray-500 text-sm">No events found. Create your first event!</p>
            </div>
        }
        else
        {
            var _sortedEvents = SortEvents(_events!.Items);

            @if (_viewMode == "cards")
            {
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
                @foreach (var ev in _sortedEvents)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow p-5 flex flex-col gap-3">
                        <div class="flex items-start justify-between gap-2">
                            <div>
                                <p class="font-semibold text-gray-800 text-sm leading-tight">@ev.Title</p>
                                <p class="text-xs text-gray-400 mt-0.5">📍 @ev.Venue</p>
                            </div>
                            <span class="shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(ev.Status)">
                                @ev.Status
                            </span>
                        </div>
                        <div class="text-xs text-gray-500 space-y-0.5">
                            <p>🕐 @ev.StartAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                            <p>🔚 @ev.EndAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</p>
                        </div>
                        <div class="flex items-center gap-2 text-xs">
                            <span class="bg-indigo-50 text-indigo-700 px-2.5 py-1 rounded-full font-medium">
                                👥 @ev.AssignedCrew @(ev.MaxCrew > 0 ? $"/ {ev.MaxCrew}" : "") Crew
                            </span>
                        </div>
                        <div class="flex gap-2 pt-1 border-t border-gray-50">
                            <button @onclick="() => OpenDetailPanel(ev)"
                                    class="flex-1 text-xs py-1.5 rounded-lg bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium transition">
                                View Details
                            </button>
                            <button @onclick="() => OpenEditModal(ev)"
                                    class="px-3 text-xs py-1.5 rounded-lg bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium transition">
                                Edit
                            </button>
                            @if (ev.Status == "Draft")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "publish")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-green-50 hover:bg-green-100 text-green-700 font-medium transition">
                                    Publish
                                </button>
                            }
                            @if (ev.Status == "Published")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "start")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium transition">
                                    Start
                                </button>
                            }
                            @if (ev.Status == "InProgress")
                            {
                                <button @onclick='() => ChangeStatus(ev.Id, "complete")'
                                        class="px-3 text-xs py-1.5 rounded-lg bg-purple-50 hover:bg-purple-100 text-purple-700 font-medium transition">
                                    Complete
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
            }
            else
            {
                <!-- List view -->
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="bg-gray-50 text-[11px] uppercase tracking-widest text-gray-500">
                            <tr>
                                <th class="px-4 py-3 text-left font-semibold">Event</th>
                                <th class="px-4 py-3 text-left font-semibold">Venue</th>
                                <th class="px-4 py-3 text-left font-semibold">Start</th>
                                <th class="px-4 py-3 text-left font-semibold">End</th>
                                <th class="px-4 py-3 text-center font-semibold">Crew</th>
                                <th class="px-4 py-3 text-center font-semibold">Status</th>
                                <th class="px-4 py-3 text-right font-semibold">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var ev in _sortedEvents)
                            {
                                <tr class="hover:bg-gray-50/60">
                                    <td class="px-4 py-3 font-semibold text-gray-800">@ev.Title</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs">@ev.Venue</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@ev.StartAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                    <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap">@ev.EndAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                    <td class="px-4 py-3 text-center text-xs">
                                        <span class="bg-indigo-50 text-indigo-700 px-2 py-0.5 rounded-full font-medium">
                                            @ev.AssignedCrew@(ev.MaxCrew > 0 ? $"/{ev.MaxCrew}" : "")
                                        </span>
                                    </td>
                                    <td class="px-4 py-3 text-center">
                                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(ev.Status)">@ev.Status</span>
                                    </td>
                                    <td class="px-4 py-3 text-right">
                                        <div class="inline-flex gap-1.5">
                                            <button @onclick="() => OpenDetailPanel(ev)"
                                                    class="text-xs px-2.5 py-1 rounded-lg bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium">View</button>
                                            <button @onclick="() => OpenEditModal(ev)"
                                                    class="text-xs px-2.5 py-1 rounded-lg bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium">Edit</button>
                                            @if (ev.Status == "Draft")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "publish")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-green-50 hover:bg-green-100 text-green-700 font-medium">Publish</button>
                                            }
                                            @if (ev.Status == "Published")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "start")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-blue-50 hover:bg-blue-100 text-blue-700 font-medium">Start</button>
                                            }
                                            @if (ev.Status == "InProgress")
                                            {
                                                <button @onclick='() => ChangeStatus(ev.Id, "complete")'
                                                        class="text-xs px-2.5 py-1 rounded-lg bg-purple-50 hover:bg-purple-100 text-purple-700 font-medium">Complete</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (_totalPages > 1)
            {
                <div class="flex justify-center gap-2 pt-2">
                    <button @onclick="PrevPage" disabled="@(_page == 1)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">← Prev</button>
                    <span class="px-3 py-1.5 text-sm text-gray-500">Page @_page of @_totalPages</span>
                    <button @onclick="NextPage" disabled="@(_page >= _totalPages)"
                            class="px-3 py-1.5 text-sm rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50">Next →</button>
                </div>
            }
        }

        @* Toasts *@
        @if (_error is not null)
        {
            <div class="fixed bottom-5 right-5 bg-red-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ⚠️ @_error <button @onclick="() => _error = null" class="ml-3 font-bold">✕</button>
            </div>
        }
        @if (_success is not null)
        {
            <div class="fixed bottom-5 right-5 bg-green-600 text-white text-sm px-5 py-3 rounded-xl shadow-lg z-50">
                ✅ @_success <button @onclick="() => _success = null" class="ml-3 font-bold">✕</button>
            </div>
        }
    </div>

    <!-- ── Detail Side Panel ──────────────────────────────────────────────────── -->
    @if (_selectedEvent is not null)
    {
        <div class="fixed inset-0 bg-black/40 z-40 flex justify-end" @onclick="CloseDetailPanel">
            <div class="bg-white w-full max-w-lg h-full overflow-y-auto shadow-2xl p-6 space-y-5 relative"
                 @onclick:stopPropagation>
                <button @onclick="CloseDetailPanel"
                        class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 text-xl">✕</button>

                <div>
                    <h3 class="text-lg font-bold text-gray-800">@_selectedEvent.Title</h3>
                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full @GetStatusClass(_selectedEvent.Status)">
                        @_selectedEvent.Status
                    </span>
                </div>

                @if (_selectedEvent.Description is not null)
                {
                    <p class="text-sm text-gray-600">@_selectedEvent.Description</p>
                }

                <div class="grid grid-cols-2 gap-3 text-sm">
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Venue</p>
                        <p class="font-medium text-gray-700">@_selectedEvent.Venue</p>
                        @if (_selectedEvent.Address is not null)
                        {
                            <p class="text-xs text-gray-400">@_selectedEvent.Address</p>
                        }
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Schedule</p>
                        <p class="font-medium text-gray-700 text-xs">@_selectedEvent.StartAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                        <p class="text-xs text-gray-400">→ @_selectedEvent.EndAt.ToLocalTime().ToString("MMM dd HH:mm")</p>
                    </div>
                    <div class="bg-indigo-50 rounded-xl p-3">
                        <p class="text-xs text-indigo-400 mb-1">Crew Assigned</p>
                        <p class="font-bold text-indigo-700">@_selectedEvent.AssignedCrew @((_selectedEvent.MaxCrew > 0) ? $"/ {_selectedEvent.MaxCrew}" : "")</p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-3">
                        <p class="text-xs text-gray-400 mb-1">Created By</p>
                        <p class="font-medium text-gray-700 text-xs">@_selectedEvent.CreatedByName</p>
                    </div>
                </div>

                <!-- Assignments -->
                <div>
                    <h4 class="font-semibold text-gray-700 text-sm mb-3">Crew Assignments</h4>
                    @if (_loadingAssignments)
                    {
                        <div class="flex justify-center py-4">
                            <svg class="animate-spin h-5 w-5 text-indigo-400" viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                            </svg>
                        </div>
                    }
                    else if (_assignments?.Items.Count == 0)
                    {
                        <p class="text-xs text-gray-400 text-center py-4">No crew assigned yet.</p>
                    }
                    else
                    {
                        <div class="space-y-2">
                            @foreach (var a in _assignments!.Items)
                            {
                                var isPlaceholder    = string.IsNullOrEmpty(a.CrewName) && !string.IsNullOrEmpty(a.VendorName);
                                var canRevoke        = _canWrite && isPlaceholder && a.Status == "Invited";
                                var canReinvite      = _canWrite && isPlaceholder && a.Status == "RejectedByVendor";
                                var rowBusy          = _placeholderBusy == a.Id;

                                <div class="bg-gray-50 rounded-xl px-4 py-2.5 space-y-2">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <p class="text-sm font-medium text-gray-800">
                                                @(string.IsNullOrEmpty(a.CrewName) ? "(Vendor to assign crew)" : a.CrewName)
                                            </p>
                                            <p class="text-xs text-gray-400">
                                                @if (!string.IsNullOrEmpty(a.CrewMobile)) { <span>@a.CrewMobile</span> }
                                                @if (!string.IsNullOrEmpty(a.VendorName))
                                                {
                                                    <span>@(string.IsNullOrEmpty(a.CrewMobile) ? "" : " · ")via @a.VendorName</span>
                                                }
                                                else
                                                {
                                                    <span class="italic text-amber-600">@(string.IsNullOrEmpty(a.CrewMobile) ? "" : " · ")direct</span>
                                                }
                                            </p>
                                            @if (a.Status == "RejectedByVendor" && !string.IsNullOrEmpty(a.RejectionReason))
                                            {
                                                <p class="text-[11px] text-rose-500 mt-0.5 italic">"@a.RejectionReason"</p>
                                            }
                                        </div>
                                        @{
                                            var (lbl, badge, sub) = AssignmentStatusDisplay.For(a.Status, _selectedEvent.Status, a.AttendanceNote);
                                            var canOverride = AssignmentStatusDisplay.CanAdminMarkAttended(a.Status, _selectedEvent.Status, _role == "Admin") && a.CrewId.HasValue;
                                        }
                                        <div class="flex flex-col items-end gap-0.5">
                                            <span class="text-xs px-2.5 py-1 rounded-full font-semibold @badge">@lbl</span>
                                            @if (!string.IsNullOrEmpty(sub))
                                            {
                                                <span class="text-[10px] text-gray-400 italic">@sub</span>
                                            }
                                        </div>
                                    </div>

                                    @if (canOverride)
                                    {
                                        var ovBusy = _overrideBusy == a.Id;
                                        <div class="flex justify-end pt-1">
                                            <button @onclick="() => AdminMarkAttended(a)"
                                                    disabled="@ovBusy"
                                                    class="px-3 py-1 rounded-lg border border-emerald-200 text-emerald-700 hover:bg-emerald-50 text-[11px] font-semibold disabled:opacity-50 transition">
                                                @(ovBusy ? "Marking…" : "✓ Mark Attended (Admin)")
                                            </button>
                                        </div>
                                    }

                                    @if (canRevoke || canReinvite)
                                    {
                                        <div class="flex justify-end gap-2 pt-1">
                                            @if (canRevoke)
                                            {
                                                <button @onclick="() => RevokeVendorInvite(a)"
                                                        disabled="@rowBusy"
                                                        class="px-3 py-1 rounded-lg border border-rose-200 text-rose-600 hover:bg-rose-50 text-[11px] font-semibold disabled:opacity-50 transition">
                                                    @(rowBusy ? "Revoking…" : "✕ Revoke Invite")
                                                </button>
                                            }
                                            @if (canReinvite)
                                            {
                                                <button @onclick="() => ReinviteVendor(a)"
                                                        disabled="@rowBusy"
                                                        class="px-3 py-1 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-semibold disabled:opacity-50 transition">
                                                    @(rowBusy ? "Re-inviting…" : "↻ Re-invite")
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Assign Crew (Admin/Manager) -->
                <div class="border-t border-gray-100 pt-4 space-y-3">
                    <h4 class="font-semibold text-gray-700 text-sm">Assign Crew Member</h4>

                    @* ── Mode toggle: Direct OR Via Vendor ── *@
                    <div class="grid grid-cols-3 gap-1 p-1 bg-gray-100 rounded-xl text-[11px] font-medium">
                        <button type="button"
                                @onclick='() => SetAssignMode("crew")'
                                class="@(_assignMode == "crew" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            👤 Crew only
                        </button>
                        <button type="button"
                                @onclick='() => SetAssignMode("vendor")'
                                class="@(_assignMode == "vendor" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            🏢 Vendor only
                        </button>
                        <button type="button"
                                @onclick='() => SetAssignMode("both")'
                                class="@(_assignMode == "both" ? "bg-white text-indigo-700 shadow-sm" : "text-gray-500 hover:text-gray-700") py-1.5 rounded-lg transition">
                            🤝 Vendor + Crew
                        </button>
                    </div>

                    @if (_assignMode == "vendor" || _assignMode == "both")
                    {
                        @* ── Vendor picker ── *@
                        <div class="relative">
                            <label class="block text-xs font-medium text-gray-500 mb-1">Vendor <span class="text-red-400">*</span></label>
                            @if (_assignSelectedVendor != null)
                            {
                                <div class="flex items-center justify-between px-3 py-2 rounded-xl border border-indigo-200 bg-indigo-50 text-xs">
                                    <div>
                                        <span class="font-semibold text-indigo-800">@_assignSelectedVendor.FullName</span>
                                        <span class="text-gray-400 ml-2">@_assignSelectedVendor.Mobile</span>
                                    </div>
                                    <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearAssignVendor">✕</button>
                                </div>
                            }
                            else
                            {
                                <input class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                       placeholder="Search vendor by name…"
                                       @value="_assignVendorSearch"
                                       @onfocus="() => _assignVendorDropOpen = true"
                                       @oninput="OnAssignVendorSearch" />
                                @if (_assignVendorDropOpen)
                                {
                                    @if (_assignVendorResults.Count > 0)
                                    {
                                        <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto">
                                            @foreach (var v in _assignVendorResults)
                                            {
                                                <button class="block w-full text-left px-3 py-2 text-xs hover:bg-indigo-50 border-b border-gray-50 last:border-0"
                                                        @onclick="() => SelectAssignVendor(v)">
                                                    <span class="font-semibold text-gray-800">@v.FullName</span>
                                                    <span class="text-gray-400 ml-2">@v.Mobile</span>
                                                    @if (!string.IsNullOrEmpty(v.BusinessName))
                                                    {
                                                        <span class="text-gray-400 ml-1">· @v.BusinessName</span>
                                                    }
                                                </button>
                                            }
                                        </div>
                                    }
                                    else if (_assignVendorSearch.Length >= 1)
                                    {
                                        <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-sm px-3 py-2 text-xs text-gray-400 italic">
                                            No vendors found for "@_assignVendorSearch"
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }

                    @if (_assignMode == "crew" || _assignMode == "both")
                    {
                    @* ── Crew picker (filtered by vendor in vendor mode) ── *@
                    <div class="relative">
                        <label class="block text-xs font-medium text-gray-500 mb-1">Crew Member <span class="text-red-400">*</span></label>
                        @if (_assignSelectedCrew != null)
                        {
                            <div class="flex items-center justify-between px-3 py-2 rounded-xl border border-indigo-200 bg-indigo-50 text-xs">
                                <div>
                                    <span class="font-semibold text-indigo-800">@_assignSelectedCrew.FullName</span>
                                    <span class="text-gray-400 ml-2">@_assignSelectedCrew.Mobile</span>
                                </div>
                                <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearAssignCrew">✕</button>
                            </div>
                        }
                        else
                        {
                            <input class="w-full px-3 py-2 text-xs rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-400"
                                   placeholder="@(_assignMode == "vendor" && _assignSelectedVendor != null ? "Search crew under this vendor…" : "Search crew by name…")"
                                   @value="_assignCrewSearch"
                                   @onfocus="() => _assignCrewDropOpen = true"
                                   @oninput="OnAssignCrewSearch" />
                            @if (_assignCrewDropOpen)
                            {
                                @if (_assignCrewResults.Count > 0)
                                {
                                    <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-lg max-h-48 overflow-y-auto">
                                        @foreach (var cr in _assignCrewResults)
                                        {
                                            <button class="block w-full text-left px-3 py-2 text-xs hover:bg-indigo-50 border-b border-gray-50 last:border-0"
                                                    @onclick="() => SelectAssignCrew(cr)">
                                                <span class="font-semibold text-gray-800">@cr.FullName</span>
                                                <span class="text-gray-400 ml-2">@cr.Mobile</span>
                                                @if (!string.IsNullOrEmpty(cr.VendorName))
                                                {
                                                    <span class="text-gray-400 ml-1">· via @cr.VendorName</span>
                                                }
                                            </button>
                                        }
                                    </div>
                                }
                                else if (_assignCrewSearch.Length >= 1)
                                {
                                    <div class="absolute left-0 right-0 top-full z-50 mt-1 bg-white border border-gray-200 rounded-xl shadow-sm px-3 py-2 text-xs text-gray-400 italic">
                                        No crew found for "@_assignCrewSearch"
                                    </div>
                                }
                            }
                        }
                    </div>
                    }

                    @* ── Mode hint ── *@
                    @if (_assignMode == "crew")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Direct crew assignment — skips the vendor step. Crew acceptance goes straight to your Approval Queue.
                        </p>
                    }
                    else if (_assignMode == "vendor")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Vendor-only — the vendor will assign their own crew to this event.
                        </p>
                    }
                    else if (_assignMode == "both")
                    {
                        <p class="text-[11px] text-gray-500 italic">
                            Vendor + Crew — both are linked. Crew acceptance goes to the vendor for approval first.
                        </p>
                    }

                    @* ── Duplicate-assignment warning ── *@
                    @{
                        var dupWarn = DuplicateAssignWarning();
                    }
                    @if (dupWarn is not null)
                    {
                        <div class="p-2.5 bg-amber-50 border border-amber-200 rounded-lg text-[11px] text-amber-800 flex items-center gap-1.5">
                            <span>⚠️</span><span>@dupWarn</span>
                        </div>
                    }

                    @* ── Assign button ── *@
                    <button @onclick="AssignCrew"
                            disabled="@(!CanSubmitAssign() || _assigning)"
                            class="w-full py-2 text-xs rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 disabled:opacity-50 disabled:cursor-not-allowed transition">
                        @(_assigning ? "Assigning…" : "✚ Assign to Event")
                    </button>

                    @if (_assignError is not null)
                    {
                        <p class="text-xs text-red-600">⚠️ @_assignError</p>
                    }
                </div>
            </div>
        </div>
    }

    <!-- ── Create / Edit Event Modal ─────────────────────────────────────────── -->
    @if (_showEventModal)
    {
        <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4" @onclick="CloseModal">
            <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-5" @onclick:stopPropagation>
                <div class="flex items-center justify-between">
                    <h3 class="text-base font-bold text-gray-800">@(_editingEvent is null ? "Create Event" : "Edit Event")</h3>
                    <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 text-xl">✕</button>
                </div>

                <div class="space-y-3">
                    <input @bind="_form.Title" placeholder="Event title *"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <textarea @bind="_form.Description" placeholder="Description (optional)" rows="2"
                              class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"></textarea>
                    <input @bind="_form.Venue" placeholder="Venue *"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <input @bind="_form.Address" placeholder="Address (optional)"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="text-xs text-gray-500 mb-1 block">Start *</label>
                            <input type="datetime-local" @bind="_form.StartAt"
                                   class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>
                        <div>
                            <label class="text-xs text-gray-500 mb-1 block">End *</label>
                            <input type="datetime-local" @bind="_form.EndAt"
                                   class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                        </div>
                    </div>
                    <input type="number" @bind="_form.MaxCrew" placeholder="Max crew (0 = unlimited)"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>

                @if (_formError is not null)
                {
                    <p class="text-sm text-red-600">⚠️ @_formError</p>
                }

                <div class="flex gap-3">
                    <button @onclick="CloseModal"
                            class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                        Cancel
                    </button>
                    <button @onclick="SaveEvent" disabled="@_saving"
                            class="flex-1 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition disabled:opacity-60">
                        @(_saving ? "Saving…" : (_editingEvent is null ? "Create" : "Save Changes"))
                    </button>
                </div>
            </div>
        </div>
    }
}
