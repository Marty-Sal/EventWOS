    // ── Crew search for assign section ───────────────────────────────────────
    private async Task OnAssignCrewSearch(ChangeEventArgs e)
    {
        _assignCrewSearch = e.Value?.ToString() ?? "";
        if (_assignCrewSearch.Length < 1) { _assignCrewResults.Clear(); _assignCrewDropOpen = false; return; }
        var vendorId = _assignSelectedVendor?.Id;
        var result   = await VendorApi.GetCrewAsync(search: _assignCrewSearch, vendorId: vendorId, page: 1);
        _assignCrewResults  = result?.Items?.Take(8).ToList() ?? new();
        _assignCrewDropOpen = true;
    }

    private void SelectAssignCrew(CrewMemberDto c)
    {
        _assignSelectedCrew = c;
        _assignCrewDropOpen = false;
        _assignCrewSearch   = "";
        _assignCrewResults.Clear();
    }

    private void ClearAssignCrew()
    {
        _assignSelectedCrew = null;
    }

    // ── Mode helpers ─────────────────────────────────────────────────────────
    private void SetAssignMode(string mode)
    {
        _assignMode  = mode;
        _assignError = null;
        // When switching modes, clear selections that don't apply
        if (mode == "crew")   { _assignSelectedVendor = null; _assignVendorSearch = ""; }
        if (mode == "vendor") { _assignSelectedCrew   = null; _assignCrewSearch   = ""; }
    }

    // Statuses that mean the row is still 'live' on the event — re-assigning would be a duplicate.
    private static readonly HashSet<string> ActiveAssignmentStatuses = new(StringComparer.OrdinalIgnoreCase)
    {
        "Invited", "VendorAccepted", "VendorApproved", "PendingManagerApproval",
        "ManagerApproved", "Confirmed", "Pending", "Attended"
    };

    /// <summary>
    /// Phase D step 9: per-shift free-seat math used everywhere capacity
    /// matters (multi-shift modal, headroom warnings).
    /// reserved = max(real crew on shift, sum of active allocation quotas)
    /// because every allocation row reserves a placeholder seat the vendor
    /// will fill later. Free = capacity - reserved (floored at 0).
    /// </summary>
    private int ShiftFreeSeats(EventShiftDto sh)
    {
        var totalAlloc = _allocationsByShift.GetValueOrDefault(sh.Id)
            ?.Where(r => !r.IsArchived).Sum(r => r.Quota) ?? 0;
        var reserved = Math.Max(sh.AssignedCrew, totalAlloc);
        return Math.Max(0, sh.CrewCount - reserved);
    }

    private string? DuplicateAssignWarning()
    {
        if (_assignments?.Items is null || _assignments.Items.Count == 0) return null;
        var rows = _assignments.Items.Where(a => ActiveAssignmentStatuses.Contains(a.Status)).ToList();
        if (rows.Count == 0) return null;

        if (_assignMode == "crew" && _assignSelectedCrew is not null)
        {
            // Direct crew: same crew already assigned (with or without a vendor).
            var dup = rows.FirstOrDefault(a => a.CrewId == _assignSelectedCrew.Id);
            if (dup is not null)
                return $"{_assignSelectedCrew.FullName} is already on this event ({dup.Status}).";
        }
        else if (_assignMode == "vendor" && _assignSelectedVendor is not null)
        {
            // Phase D step 8: vendor-mode is now per-shift. A vendor can legitimately
            // be invited to multiple shifts on the same event (e.g. Saly on both
            // Box Office and F&B), or have their existing shift quota grown. The
            // multi-shift modal handles the per-shift "free" count and disables
            // shifts that have no headroom — that's the real gate, not this one.
            //
            // Only block when there is literally nowhere to put new placeholders:
            // every active shift on this event is already at full capacity.
            // (Capacity here = sh.CrewCount; assignments = sh.AssignedCrew.)
            if (_selectedEventShifts is { Count: > 0 })
            {
                var anyHeadroom = _selectedEventShifts.Any(sh => ShiftFreeSeats(sh) > 0);
                if (!anyHeadroom)
                    return $"All shifts on this event are fully staffed — no seats left for {_assignSelectedVendor.FullName}.";
            }
        }
        else if (_assignMode == "both" && _assignSelectedCrew is not null && _assignSelectedVendor is not null)
        {
            var dup = rows.FirstOrDefault(a =>
                a.CrewId   == _assignSelectedCrew.Id &&
                a.VendorId == _assignSelectedVendor.Id);
            if (dup is not null)
                return $"{_assignSelectedCrew.FullName} is already assigned via {_assignSelectedVendor.FullName} ({dup.Status}).";

            // Same crew under a *different* vendor on the same event is also a duplicate.
            var dupCrew = rows.FirstOrDefault(a => a.CrewId == _assignSelectedCrew.Id);
            if (dupCrew is not null)
                return $"{_assignSelectedCrew.FullName} is already on this event via {dupCrew.VendorName ?? "another vendor"} ({dupCrew.Status}).";
        }
        return null;
    }

    private bool CanSubmitAssign()
    {
        var baseOk = _assignMode switch
        {
            "crew"   => _assignSelectedCrew   is not null,
            "vendor" => _assignSelectedVendor is not null,
            "both"   => _assignSelectedCrew is not null && _assignSelectedVendor is not null,
            _        => false
        };
        return baseOk && DuplicateAssignWarning() is null;
    }

    // ── Assign button handler ─────────────────────────────────────────────────
    private async Task AssignCrew()
    {
        _assignError = null;
        if (_selectedEvent is null) return;

        // Validate per mode
        if (_assignMode == "crew" && _assignSelectedCrew is null)
        {
            _assignError = "Please select a crew member.";
            return;
        }
        if (_assignMode == "vendor" && _assignSelectedVendor is null)
        {
            _assignError = "Please select a vendor.";
            return;
        }
        if (_assignMode == "both" && (_assignSelectedCrew is null || _assignSelectedVendor is null))
        {
            _assignError = "Please select both a vendor and a crew member.";
            return;
        }

        var dupNow = DuplicateAssignWarning();
        if (dupNow is not null)
        {
            _assignError = dupNow;
            return;
        }

        // Phase D step 4 (UX): multi-shift events open a dedicated modal that
        // lets the admin distribute the vendor across multiple shifts in one
        // pass — instead of an inline single-shift picker. Single-shift
        // events keep the original direct-assign call (resolver picks).
        var activeShiftsCount = _selectedEventShifts?.Count ?? 0;

        // Vendor-only flow on a multi-shift event → open the multi-shift modal.
        if (_assignMode == "vendor" && activeShiftsCount > 1)
        {
            OpenMultiShiftAssignModal();
            return;
        }

        // Crew-only or Vendor+Crew on multi-shift → still need to pick ONE
        // shift (you can't fan a single crew member across multiple shifts).
        // Use the same modal but in single-pick mode.
        if (_assignMode != "vendor" && activeShiftsCount > 1)
        {
            OpenMultiShiftAssignModal();
            return;
        }

        // Single-shift fast path: direct API call.
        _assigning = true;
        var (ok, _, err) = await EventApi.AssignCrewAsync(
            _selectedEvent.Id,
            _assignSelectedCrew?.Id,
            _assignSelectedVendor?.Id,
            shiftId: null);
        _assigning = false;

        if (ok)
        {
            var label = _assignMode switch
            {
                "crew"   => $"{_assignSelectedCrew!.FullName} assigned directly ✅",
                "vendor" => $"Vendor {_assignSelectedVendor!.FullName} assigned ✅",
                _        => $"{_assignSelectedCrew!.FullName} assigned via {_assignSelectedVendor!.FullName} ✅"
            };
            _success              = label;
            _assignSelectedVendor = null;
            _assignSelectedCrew   = null;
            _assignVendorSearch   = "";
            _assignCrewSearch     = "";
            _assignments          = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            _selectedEventShifts  = await EventApi.GetEventShiftsAsync(_selectedEvent.Id) ?? new List<EventShiftDto>();
        }
        else { _assignError = err; }
    }

    // ── Phase D step 4: Multi-shift assignment modal ───────────────────────────
    //
    // Opens when admin clicks "+ Assign to Event" on a multi-shift event.
    // - Vendor-only mode: checkbox + count per row → multiple AssignCrew calls.
    // - Crew-only / Both: single radio pick → one AssignCrew call with shiftId.
    private sealed class MultiShiftRow
    {
        public bool Selected { get; set; }
        public int  Count    { get; set; } = 1;
    }

    private bool                          _multiShiftModalOpen;
    private readonly Dictionary<Guid, MultiShiftRow> _multiShiftRows = new();
    private Guid?                         _multiShiftSingleChoice;
    private bool                          _multiShiftSubmitting;
    private string?                       _multiShiftError;

    private void OpenMultiShiftAssignModal()
    {
        _multiShiftRows.Clear();
        _multiShiftSingleChoice = null;
        _multiShiftError        = null;
        if (_selectedEventShifts is not null)
        {
            foreach (var sh in _selectedEventShifts)
            {
                var free = ShiftFreeSeats(sh);
                _multiShiftRows[sh.Id] = new MultiShiftRow
                {
                    Selected = false,
                    Count    = free > 0 ? 1 : 0,
                };
            }
        }
        _multiShiftModalOpen = true;
    }

    private void CloseMultiShiftModal()
    {
        _multiShiftModalOpen    = false;
        _multiShiftRows.Clear();
        _multiShiftSingleChoice = null;
        _multiShiftError        = null;
    }

    private async Task SubmitMultiShiftAssign()
    {
        if (_selectedEvent is null) return;
        _multiShiftError = null;

        // Branch on mode: vendor-only fans out, others are single-shift pick.
        if (_assignMode == "vendor")
        {
            if (_assignSelectedVendor is null)
            {
                _multiShiftError = "Vendor missing — close and try again.";
                return;
            }
            var picks = _multiShiftRows
                .Where(kv => kv.Value.Selected && kv.Value.Count > 0)
                .ToList();
            if (picks.Count == 0)
            {
                _multiShiftError = "Pick at least one shift.";
                return;
            }

            _multiShiftSubmitting = true;
            try
            {
                // Step 1: keep VendorShiftAllocations in sync with what the admin
                // is about to assign. Otherwise the "Vendor Quotas" panel reads
                // 0 even though there are 10 active EventAssignments — confusing.
                // For each picked shift:
                //   - if the vendor already has an active allocation row, bump
                //     its quota by the new count (UpdateAsync).
                //   - otherwise create a fresh one with that quota.
                var allocErrors = new List<string>();
                foreach (var (shiftId, row) in picks)
                {
                    // Ensure we have the latest allocation snapshot for this shift.
                    await ReloadShiftAllocations(shiftId);
                    var existing = _allocationsByShift.GetValueOrDefault(shiftId)
                                    ?.FirstOrDefault(r => !r.IsArchived && r.VendorId == _assignSelectedVendor.Id);
                    if (existing is null)
                    {
                        var (aOk, aErr, _) = await AllocApi.CreateAsync(shiftId, _assignSelectedVendor.Id, row.Count);
                        if (!aOk) allocErrors.Add(aErr ?? "alloc create failed");
                    }
                    else
                    {
                        var newQuota = existing.Quota + row.Count;
                        var (uOk, uErr, _) = await AllocApi.UpdateAsync(existing.Id, newQuota);
                        if (!uOk) allocErrors.Add(uErr ?? "alloc update failed");
                    }
                }

                // Step 2: actually create the EventAssignment seats (one per crew slot).
                int totalCreated = 0;
                var errors = new List<string>();
                foreach (var (shiftId, row) in picks)
                {
                    for (int i = 0; i < row.Count; i++)
                    {
                        var (ok, _, err) = await EventApi.AssignCrewAsync(
                            _selectedEvent.Id,
                            crewId:   null,
                            vendorId: _assignSelectedVendor.Id,
                            shiftId:  shiftId);
                        if (ok) totalCreated++;
                        else
                        {
                            errors.Add(err ?? "Unknown error");
                            break;  // stop trying this shift if one fails
                        }
                    }
                }
                if (totalCreated > 0)
                {
                    _success = $"Vendor {_assignSelectedVendor.FullName}: {totalCreated} seat(s) assigned across {picks.Count} shift(s) ✅";
                    _assignSelectedVendor = null;
                    _assignVendorSearch   = "";
                    _assignments          = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
                    _selectedEventShifts  = await EventApi.GetEventShiftsAsync(_selectedEvent.Id) ?? new List<EventShiftDto>();
                    // Refresh allocations for every picked shift so the panel reflects new quotas.
                    foreach (var (shiftId, _) in picks)
                        await ReloadShiftAllocations(shiftId);
                    CloseMultiShiftModal();
                }
                var allMsgs = errors.Concat(allocErrors).Distinct().ToList();
                if (allMsgs.Count > 0)
                {
                    _multiShiftError = $"Created {totalCreated} but hit: {string.Join("; ", allMsgs)}";
                }
            }
            finally { _multiShiftSubmitting = false; }
            return;
        }

        // Crew-only or Both — pick exactly ONE shift.
        if (_multiShiftSingleChoice is null)
        {
            _multiShiftError = "Pick a shift.";
            return;
        }
        _multiShiftSubmitting = true;
        try
        {
            var (ok, _, err) = await EventApi.AssignCrewAsync(
                _selectedEvent.Id,
                _assignSelectedCrew?.Id,
                _assignSelectedVendor?.Id,
                _multiShiftSingleChoice);
            if (!ok) { _multiShiftError = err; return; }
            var label = _assignMode switch
            {
                "crew" => $"{_assignSelectedCrew!.FullName} assigned directly ✅",
                _      => $"{_assignSelectedCrew!.FullName} assigned via {_assignSelectedVendor!.FullName} ✅"
            };
            _success              = label;
            _assignSelectedVendor = null;
            _assignSelectedCrew   = null;
            _assignVendorSearch   = "";
            _assignCrewSearch     = "";
            _assignments          = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            _selectedEventShifts  = await EventApi.GetEventShiftsAsync(_selectedEvent.Id) ?? new List<EventShiftDto>();
            CloseMultiShiftModal();
        }
        finally { _multiShiftSubmitting = false; }
    }

    // ── Crew / Vendor ──────────────────────────────────────────────────────────
    private async Task LoadMyAssignments()
    {
        _loading = true;
        _myAssignments = await EventApi.GetMyAssignmentsAsync(_myPage);
        if (_myAssignments is not null)
            _totalMyPages = (int)Math.Ceiling((double)_myAssignments.TotalCount / 20);
        _loading = false;
    }

    private async Task LoadVendorAssignments()
    {
        _loading = true;
        _myAssignments = await EventApi.GetVendorAssignmentsAsync(_myPage);
        if (_myAssignments is not null)
            _totalMyPages = (int)Math.Ceiling((double)_myAssignments.TotalCount / 20);
        _loading = false;
    }

    private async Task PrevMyPage()
    {
        if (_myPage > 1) { _myPage--;
            if (_role == "Vendor") await LoadVendorAssignments();
            else await LoadMyAssignments();
        }
    }
    private async Task NextMyPage()
    {
        if (_myPage < _totalMyPages) { _myPage++;
            if (_role == "Vendor") await LoadVendorAssignments();
            else await LoadMyAssignments();
        }
    }

    private async Task RespondToAssignment(Guid assignmentId, string response)
    {
        var (ok, err) = await EventApi.RespondAssignmentAsync(assignmentId, response);
        if (ok) { _success = response == "confirm" ? "Assignment accepted!" : "Assignment declined."; await LoadMyAssignments(); }
        else    { _error = err ?? "Failed to respond."; }
    }

    private async Task RecordAttendance(Guid assignmentId, string action)
    {
        var (ok, err) = await EventApi.RecordAttendanceAsync(assignmentId, action);
        if (ok) { _success = action == "checkin" ? "Checked in! 📍" : "Checked out! 🚪"; await LoadMyAssignments(); }
        else    { _error = err ?? "Failed to record attendance."; }
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    private static string GetStatusClass(string status) => status switch
    {
        "Draft"      => "bg-gray-100 text-gray-600",
        "Published"  => "bg-blue-100 text-blue-700",
        "InProgress" => "bg-yellow-100 text-yellow-700",
        "Completed"  => "bg-green-100 text-green-700",
        "Cancelled"  => "bg-red-100 text-red-700",
        _            => "bg-gray-100 text-gray-600"
    };

    private async Task RevokeVendorInvite(EventAssignmentDto a)
    {
        _placeholderBusy = a.Id; StateHasChanged();
        try
        {
            var resp = await Http.DeleteAsync($"api/v1/events/vendor-invitations/{a.Id}");
            if (resp.IsSuccessStatusCode)
            {
                _success = "Vendor invitation revoked.";
                if (_selectedEvent is not null) _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            }
            else
            {
                _error = "Couldn't revoke invitation: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    /// <summary>
    /// Phase D step 5: revoke an entire shift bucket of empty-crew vendor invites
    /// in one click. Iterates over each row, mirroring RevokeVendorInvite but
    /// batching the UI refresh to the end. Errors accumulate; partial success
    /// is reported.
    /// </summary>
    private async Task RevokeBucket(ShiftBucket bucket)
    {
        var ids = bucket.All.Select(x => x.Id).ToList();
        int revoked = 0;
        var errors = new List<string>();
        try
        {
            foreach (var id in ids)
            {
                _placeholderBusy = id; StateHasChanged();
                var resp = await Http.DeleteAsync($"api/v1/events/vendor-invitations/{id}");
                if (resp.IsSuccessStatusCode) revoked++;
                else errors.Add(await resp.Content.ReadAsStringAsync());
            }
            if (revoked > 0)
                _success = $"Revoked {revoked} of {ids.Count} invites for {bucket.ScopeLabel}.";
            if (errors.Count > 0)
                _error = "Some revokes failed: " + string.Join("; ", errors.Distinct().Take(3));
            if (_selectedEvent is not null)
                _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    /// <summary>
    /// Phase D step 10: batch counterpart to ReinviteVendor. When every
    /// placeholder in a bucket is RejectedByVendor (typical after a vendor
    /// taps "Reject" on a whole shift), the UI collapses to a single row
    /// with one Re-invite button. This loops the existing per-row
    /// re-invite endpoint so backend semantics + audit trail stay intact.
    /// </summary>
    private async Task ReinviteBucket(ShiftBucket bucket)
    {
        var ids = bucket.All
            .Where(x => x.Status == "RejectedByVendor")
            .Select(x => x.Id)
            .ToList();
        if (ids.Count == 0) return;

        int reinvited = 0;
        var errors = new List<string>();
        try
        {
            foreach (var id in ids)
            {
                _placeholderBusy = id; StateHasChanged();
                var resp = await Http.PatchAsJsonAsync(
                    $"api/v1/events/vendor-invitations/{id}/reinvite", new { });
                if (resp.IsSuccessStatusCode) reinvited++;
                else errors.Add(await resp.Content.ReadAsStringAsync());
            }
            if (reinvited > 0)
                _success = $"Re-invited {reinvited} of {ids.Count} placeholder{(ids.Count == 1 ? "" : "s")} for {bucket.ScopeLabel}.";
            if (errors.Count > 0)
                _error = "Some re-invites failed: " + string.Join("; ", errors.Distinct().Take(3));
            if (_selectedEvent is not null)
                _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    private async Task ReinviteVendor(EventAssignmentDto a)
    {
        _placeholderBusy = a.Id; StateHasChanged();
        try
        {
            var resp = await Http.PatchAsJsonAsync(
                $"api/v1/events/vendor-invitations/{a.Id}/reinvite", new { });
            if (resp.IsSuccessStatusCode)
            {
                _success = "Vendor re-invited.";
                if (_selectedEvent is not null) _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
            }
            else
            {
                _error = "Couldn't re-invite vendor: " + await resp.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _placeholderBusy = Guid.Empty; StateHasChanged(); }
    }

    /// <summary>
    /// Admin-only post-event correction: flips a No-Show / hanging row to
    /// Attended via the API. The response carries no body, so the page
    /// optimistically updates the row and refreshes the drawer's
    /// assignments + the event's attendance summary so KPIs stay honest.
    /// </summary>
    private async Task AdminMarkAttended(EventAssignmentDto a)
    {
        if (_selectedEvent is null) return;
        _overrideBusy = a.Id; StateHasChanged();
        try
        {
            var (ok, err) = await EventApi.AdminMarkAttendedAsync(a.Id);
            if (!ok)
            {
                _error = "Couldn't mark attended: " + (err ?? "unknown error");
            }
            else
            {
                // Re-pull the assignment list + attendance summary so the
                // new label, audit note, badge, and KPI counts all render
                // from the source of truth instead of optimistic guesses.
                _assignments = await EventApi.GetAssignmentsAsync(_selectedEvent.Id);
                if (_selectedEvent.Status is "InProgress" or "Completed")
                    _attendance = await EventApi.GetAttendanceSummaryAsync(_selectedEvent.Id);
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _overrideBusy = Guid.Empty; StateHasChanged(); }
    }

        private static string GetAssignmentStatusClass(string status) => status switch
    {
        "Pending"                 => "bg-yellow-100 text-yellow-700",
        "Confirmed"               => "bg-green-100 text-green-700",
        "Declined"                => "bg-red-100 text-red-600",
        "Completed"               => "bg-blue-100 text-blue-700",
        "Invited"                 => "bg-amber-100 text-amber-700",
        "VendorAccepted"          => "bg-emerald-100 text-emerald-700",
        "VendorApproved"          => "bg-emerald-100 text-emerald-700",
        "PendingManagerApproval"  => "bg-purple-100 text-purple-700",
        "ManagerApproved"         => "bg-green-100 text-green-700",
        "RejectedByVendor"        => "bg-rose-100 text-rose-700",
        "RejectedByManager"       => "bg-rose-100 text-rose-700",
        "Attended"                => "bg-teal-100 text-teal-700",
        "NoShow"                  => "bg-orange-100 text-orange-700",
        _                          => "bg-gray-100 text-gray-600"
    };

    // ── Form Model ─────────────────────────────────────────────────────────────
    private class EventForm
    {
        public string    Title       { get; set; } = "";
        public string?   Description { get; set; }
        public string    Venue       { get; set; } = "";
        public string?   Address     { get; set; }
        public DateTime  StartAt     { get; set; } = DateTime.Now.AddDays(1);
        public DateTime  EndAt       { get; set; } = DateTime.Now.AddDays(1).AddHours(4);
        public int       MaxCrew     { get; set; } = 1;

        // Phase C step 4 (create-mode only): list of shift drafts. Each
        // row maps 1:1 to a CreateEventShiftRequest on save. MaxCrew is
        // derived from SUM(Shifts.CrewCount) at submit-time. We don't
        // include a default row here — OpenCreateModal seeds it once
        // (after the catalog is loaded) so we know which scope to default to.
        public List<ShiftDraft> Shifts { get; set; } = new();
    }

    /// <summary>
    /// One row in the multi-shift editor. ScopeOfWorkId is required on
    /// save; EndAt is a sentinel DateTime (MinValue = "unset" → null on
    /// the wire). CrewCount has min=1 from the input element but the
    /// save-time guard also floors it to 1.
    /// </summary>
    public sealed class ShiftDraft
    {
        public Guid      ScopeOfWorkId { get; set; }
        public int       CrewCount     { get; set; } = 1;
        // Phase D step 2: optional per-shift start. Null = use event StartAt.
        // Stored as nullable local-time DateTime; converted to UTC at save.
        public DateTime? StartAt       { get; set; }
        public DateTime  EndAt         { get; set; } = default;
    }
}
