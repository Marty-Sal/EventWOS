    private void ToggleAllocSection() => _allocSectionOpen = !_allocSectionOpen;

    private void StartAllocEdit(VendorAllocationDto row)
    {
        _allocEditingId = row.Id;
        _allocEditQuota = row.Quota;
        _allocError     = null;
    }

    private void CancelAllocEdit()
    {
        _allocEditingId = null;
        _allocError = null;
    }

    private async Task SaveAllocEdit(VendorAllocationDto row)
    {
        if (_allocEditQuota < row.CurrentlyAssigned)
        {
            _allocError = $"Can't shrink below {row.CurrentlyAssigned} — that many crew are already assigned under this vendor.";
            return;
        }
        var (ok, err, updated) = await AllocApi.UpdateAsync(row.Id, _allocEditQuota);
        if (!ok) { _allocError = err; return; }
        await ReloadShiftAllocations(row.ShiftId);
        _allocEditingId = null;
        _allocError     = null;
    }

    private async Task ArchiveAlloc(VendorAllocationDto row)
    {
        if (row.CurrentlyAssigned > 0)
        {
            _allocError = $"Can't remove — {row.CurrentlyAssigned} crew are still assigned under this vendor on this shift.";
            return;
        }
        var (ok, err) = await AllocApi.ArchiveAsync(row.Id);
        if (!ok) { _allocError = err; return; }
        await ReloadShiftAllocations(row.ShiftId);
        _allocError = null;
    }

    private void OpenAllocCreate(Guid shiftId)
    {
        var sh = _selectedEventShifts?.FirstOrDefault(x => x.Id == shiftId);
        if (sh is null) return;
        var totalQ = _allocationsByShift.GetValueOrDefault(shiftId)
                        ?.Where(r => !r.IsArchived).Sum(r => r.Quota) ?? 0;
        _allocCreateShiftId  = shiftId;
        _allocCreateMaxQuota = Math.Max(1, sh.CrewCount - totalQ);
        _allocCreateQuota    = Math.Min(1, _allocCreateMaxQuota);
        if (_allocCreateQuota < 1) _allocCreateQuota = 1;
        _allocCreateVendor   = null;
        _allocVendorSearch   = string.Empty;
        _allocVendorResults  = new();
        _allocCreateError    = null;
    }

    private void CloseAllocCreate()
    {
        _allocCreateShiftId = null;
        _allocCreateVendor  = null;
        _allocCreateError   = null;
        _allocVendorResults = new();
        _allocVendorSearch  = string.Empty;
        _allocSearchCts?.Cancel();
        _allocSearchCts     = null;
    }

    private async Task OnAllocVendorSearch(ChangeEventArgs e)
    {
        _allocVendorSearch = e.Value?.ToString() ?? string.Empty;
        if (_allocVendorSearch.Length < 1)
        {
            _allocVendorResults = new();
            return;
        }
        // Cancel previous in-flight search so we don't race results.
        _allocSearchCts?.Cancel();
        _allocSearchCts = new System.Threading.CancellationTokenSource();
        var token = _allocSearchCts.Token;
        try
        {
            var page = await VendorApi.GetVendorsAsync(1, _allocVendorSearch, token);
            if (token.IsCancellationRequested) return;
            _allocVendorResults = page?.Items?.Take(8).ToList() ?? new();
        }
        catch (OperationCanceledException) { /* superseded; ignore */ }
    }

    private void SelectAllocVendor(VendorListItemDto v)
    {
        _allocCreateVendor  = v;
        _allocVendorResults = new();
        _allocVendorSearch  = string.Empty;
    }

    private async Task SubmitAllocCreate()
    {
        if (_allocCreateShiftId is null || _allocCreateVendor is null) return;
        if (_allocCreateQuota < 1) { _allocCreateError = "Quota must be at least 1."; return; }
        if (_allocCreateQuota > _allocCreateMaxQuota)
        {
            _allocCreateError = $"Only {_allocCreateMaxQuota} seats left on this shift.";
            return;
        }
        _allocCreateSubmitting = true;
        _allocCreateError      = null;
        try
        {
            var (ok, err, _) = await AllocApi.CreateAsync(
                _allocCreateShiftId.Value, _allocCreateVendor.Id, _allocCreateQuota);
            if (!ok) { _allocCreateError = err; return; }
            var shiftId = _allocCreateShiftId.Value;
            await ReloadShiftAllocations(shiftId);
            CloseAllocCreate();
        }
        finally
        {
            _allocCreateSubmitting = false;
        }
    }

    private async Task ReloadShiftAllocations(Guid shiftId)
    {
        var rows = await AllocApi.GetForShiftAsync(shiftId);
        _allocationsByShift[shiftId] = rows ?? Array.Empty<VendorAllocationDto>();
    }

    private async Task OpenCreateModal()
    {
        _editingEvent = null;
        _form = new EventForm { StartAt = DateTime.Now.AddDays(1), EndAt = DateTime.Now.AddDays(1).AddHours(4) };
        _formError = null;
        _showEventModal = true;
        await EnsureScopeCatalogLoaded();
        // Phase C step 4: seed exactly ONE default shift row pointing at the
        // first scope. If the catalog is empty the editor renders a helpful
        // "create one first" banner instead.
        if (_form.Shifts.Count == 0 && _scopeCatalog.Count > 0)
            _form.Shifts.Add(new ShiftDraft { ScopeOfWorkId = _scopeCatalog[0].Id, CrewCount = 1 });
    }

    /// <summary>Append a fresh shift row, defaulting to the first scope.</summary>
    private void AddShiftRow()
    {
        if (_scopeCatalog.Count == 0) return;
        _form.Shifts.Add(new ShiftDraft { ScopeOfWorkId = _scopeCatalog[0].Id, CrewCount = 1 });
    }

    /// <summary>Remove a shift row by index. Last-row delete is guarded in markup.</summary>
    private void RemoveShiftRow(int index)
    {
        if (index < 0 || index >= _form.Shifts.Count) return;
        if (_form.Shifts.Count <= 1) return;  // belt-and-braces; UI hides the button too
        _form.Shifts.RemoveAt(index);
    }

    /// <summary>
    /// Phase B: lazy-load the active scope-of-work catalog. We pull a big
    /// page (200) instead of paginating — the catalog is admin-curated and
    /// realistically &lt; 50 rows. If that ever stops being true, swap for
    /// a typeahead.
    /// </summary>
    private async Task EnsureScopeCatalogLoaded()
    {
        if (_scopeCatalog.Count > 0) return;
        try
        {
            var resp = await Http.GetFromJsonAsync<ScopeApiEnvelope>(
                "/api/v1/scope-of-work?page=1&pageSize=200&includeArchived=false");
            if (resp?.Data?.Items is not null)
                _scopeCatalog = resp.Data.Items
                    .Select(x => new ScopePickItem(x.Id, x.Name))
                    .OrderBy(x => x.Name)
                    .ToList();
        }
        catch
        {
            // Picker degrades gracefully — modal shows the "no scopes yet"
            // empty state and the user goes to /admin/scope-of-work.
            _scopeCatalog = new();
        }
    }

    private sealed record ScopeApiEnvelope(ScopeApiData? Data);
    private sealed record ScopeApiData(List<ScopePickItem> Items);

    // ── Phase D step 1: shift editor handlers ──────────────────────────
    // Each row mutates in-place via @onchange so the user can keep typing;
    // the actual API call fires on blur (we treat onchange as "commit").
    // This makes the editor feel responsive and avoids per-keystroke
    // network chatter.

    private async Task OnShiftScopeChanged(EventShiftDto row, ChangeEventArgs e)
    {
        if (!Guid.TryParse(e.Value?.ToString(), out var newScope) || newScope == row.ScopeOfWorkId) return;
        await SaveShiftEdit(row with { ScopeOfWorkId = newScope });
    }

    private async Task OnShiftCrewCountChanged(EventShiftDto row, ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var newCount) || newCount == row.CrewCount) return;
        await SaveShiftEdit(row with { CrewCount = newCount });
    }

    private async Task OnShiftEndChanged(EventShiftDto row, ChangeEventArgs e)
    {
        DateTime? newEnd = null;
        if (DateTime.TryParse(e.Value?.ToString(), out var parsed))
            newEnd = DateTime.SpecifyKind(parsed, DateTimeKind.Local).ToUniversalTime();
        if (newEnd == row.EndAt) return;
        await SaveShiftEdit(row with { EndAt = newEnd });
    }

    private async Task OnShiftStartChanged(EventShiftDto row, ChangeEventArgs e)
    {
        // Required field — empty means "no change" rather than "clear".
        if (!DateTime.TryParse(e.Value?.ToString(), out var parsed)) return;
        var newStartUtc = DateTime.SpecifyKind(parsed, DateTimeKind.Local).ToUniversalTime();
        if (newStartUtc == row.StartAt) return;
        await SaveShiftEdit(row with { StartAt = newStartUtc });
    }

    private async Task SaveShiftEdit(EventShiftDto next)
    {
        if (_editShifts is null) return;
        _editShiftError = null;
        _editShiftBusyId = next.Id;
        StateHasChanged();
        try
        {
            var (ok, updated, err) = await EventApi.UpdateEventShiftAsync(
                next.Id, next.ScopeOfWorkId, next.CrewCount, next.StartAt, next.EndAt);
            if (!ok)
            {
                _editShiftError = err ?? "Couldn't save shift.";
                return;
            }
            if (updated is not null)
            {
                var idx = _editShifts.FindIndex(x => x.Id == updated.Id);
                if (idx >= 0) _editShifts[idx] = updated;
                // Auto-sync the form's MaxCrew badge so the user sees the new total.
                _form.MaxCrew = _editShifts.Sum(x => x.CrewCount);
            }
        }
        finally
        {
            _editShiftBusyId = Guid.Empty;
            StateHasChanged();
        }
    }

    private async Task ArchiveShiftRow(EventShiftDto row)
    {
        if (_editShifts is null) return;
        if (row.AssignedCrew > 0)
        {
            _editShiftError = $"Reject or unassign the {row.AssignedCrew} crew on this shift before removing it.";
            return;
        }
        if (_editShifts.Count <= 1)
        {
            _editShiftError = "Can't remove the only shift — add another first, or cancel the event.";
            return;
        }
        _editShiftError = null;
        _editShiftBusyId = row.Id;
        StateHasChanged();
        try
        {
            var (ok, err) = await EventApi.ArchiveEventShiftAsync(row.Id);
            if (!ok)
            {
                _editShiftError = err ?? "Couldn't remove shift.";
                return;
            }
            _editShifts.RemoveAll(x => x.Id == row.Id);
            _form.MaxCrew = _editShifts.Sum(x => x.CrewCount);
        }
        finally
        {
            _editShiftBusyId = Guid.Empty;
            StateHasChanged();
        }
    }

    private async Task AddShiftToExistingEvent()
    {
        if (_editingEvent is null || _editShifts is null) return;
        if (_addShiftDraft.ScopeOfWorkId == Guid.Empty)
        {
            _editShiftError = "Pick a scope of work for the new shift.";
            return;
        }
        if (_addShiftDraft.CrewCount < 1)
        {
            _editShiftError = "Crew count must be at least 1.";
            return;
        }
        _editShiftError = null;
        DateTime? endUtc = _addShiftDraft.EndAt is { } e
            ? DateTime.SpecifyKind(e, DateTimeKind.Local).ToUniversalTime()
            : (DateTime?)null;
        // Default per-shift start to the event's StartAt when the user
        // doesn't enter one — same fallback as the create-mode form.
        DateTime startUtc = _addShiftDraft.StartAt is { } sa
            ? DateTime.SpecifyKind(sa, DateTimeKind.Local).ToUniversalTime()
            : _editingEvent.StartAt;   // already UTC
        var (ok, shift, err) = await EventApi.AddEventShiftAsync(
            _editingEvent.Id, _addShiftDraft.ScopeOfWorkId, _addShiftDraft.CrewCount,
            startUtc, endUtc);
        if (!ok)
        {
            _editShiftError = err ?? "Couldn't add shift.";
            return;
        }
        if (shift is not null)
        {
            _editShifts.Add(shift);
            _form.MaxCrew = _editShifts.Sum(x => x.CrewCount);
            _addShiftDraft = new() { ScopeOfWorkId = _scopeCatalog.FirstOrDefault()?.Id ?? Guid.Empty };
        }
        StateHasChanged();
    }

    private async Task OpenEditModal(EventListItemDto ev)
    {
        // Fix: the shift editor's scope <select> needs the catalog loaded
        // before render — otherwise the existing shift's ScopeOfWorkId
        // can't match any option and the dropdown shows blank.
        await EnsureScopeCatalogLoaded();

        _editingEvent = ev;
        _form = new EventForm
        {
            Title       = ev.Title,
            Venue       = ev.Venue,
            StartAt     = ev.StartAt.ToLocalTime(),
            EndAt       = ev.EndAt.ToLocalTime(),
            MaxCrew     = ev.MaxCrew,
        };
        _formError      = null;
        _editShiftError = null;
        _editShifts     = null;
        _addShiftDraft  = new() { ScopeOfWorkId = _scopeCatalog.FirstOrDefault()?.Id ?? Guid.Empty };
        _showEventModal = true;

        // Phase D: load shifts so the editor can render. We don't block the
        // modal on this — it shows a skeleton while loading.
        _editShiftsLoading = true;
        StateHasChanged();
        try
        {
            var shifts = await EventApi.GetEventShiftsAsync(ev.Id);
            _editShifts = shifts?.ToList() ?? new();
        }
        finally
        {
            _editShiftsLoading = false;
            StateHasChanged();
        }
    }

    private void CloseModal() => _showEventModal = false;

    private async Task SaveEvent()
    {
        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Venue))
        {
            _formError = "Title and Venue are required.";
            return;
        }
        if (_editingEvent is null)
        {
            if (_form.Shifts.Count == 0)
            {
                _formError = "Add at least one shift, or create a Scope of Work first.";
                return;
            }
            if (_form.Shifts.Any(x => x.ScopeOfWorkId == Guid.Empty))
            {
                _formError = "Every shift needs a Scope of Work.";
                return;
            }
            if (_form.Shifts.Any(x => x.CrewCount < 1))
            {
                _formError = "Every shift needs at least 1 crew.";
                return;
            }
        }
        _saving = true;
        _formError = null;
        // Phase C step 4: on Create, send the whole shift list. Each draft
        // row maps to one CreateEventShiftRequest; the API derives the
        // event's MaxCrew from SUM(CrewCount). On Edit, we still don't
        // touch shifts from this modal (dedicated editor is a future
        // affordance) — Shifts=null leaves them alone on the server.
        IReadOnlyList<CreateEventShiftRequest>? shifts = null;
        int derivedMaxCrew = _form.MaxCrew;
        if (_editingEvent is null)
        {
            shifts = _form.Shifts
                .Select(s => new CreateEventShiftRequest(
                    s.ScopeOfWorkId,
                    Math.Max(s.CrewCount, 1),
                    (s.StartAt ?? _form.StartAt).ToUniversalTime(),
                    s.EndAt == default ? null : s.EndAt.ToUniversalTime()))
                .ToArray();
            derivedMaxCrew = shifts.Sum(x => x.CrewCount);
        }

        var req = new CreateEventRequest(
            _form.Title, _form.Description, _form.Venue, _form.Address,
            _form.StartAt.ToUniversalTime(), _form.EndAt.ToUniversalTime(),
            derivedMaxCrew, shifts);

        if (_editingEvent is null)
        {
            var (ok, err, _) = await EventApi.CreateEventAsync(req);
            if (ok) { _success = "Event created!"; CloseModal(); await LoadEvents(); }
            else    { _formError = err; }
        }
        else
        {
            var (ok, err) = await EventApi.UpdateEventAsync(_editingEvent.Id, req);
            if (ok) { _success = "Event updated!"; CloseModal(); await LoadEvents(); }
            else    { _formError = err; }
        }
        _saving = false;
    }

    private async Task ChangeStatus(Guid id, string action)
    {
        var (ok, err) = await EventApi.ChangeEventStatusAsync(id, action);
        if (ok) { _success = "Status updated!"; await LoadEvents(); }
        else    { _error = err; }
    }

