@page "/vendors"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IVendorApiService VendorApi


    @if (_accessDenied)
    {
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
            <p class="text-gray-500 text-sm">You don't have permission to view this page.<br/>Contact your Admin to request access.</p>
        </div>
        return;
    }

<PageTitle>Vendors — EventWOS</PageTitle>

<div class="space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Vendors</h2>
            <p class="text-sm text-gray-500">Manage manpower suppliers.</p>
        </div>
        @if (_canWrite)
        {
            <button @onclick="() => _showCreate = true"
                    class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow">
                + Add Vendor
            </button>
        }
    </div>

    <!-- Search -->
    <div class="relative max-w-sm">
        <input @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp"
               placeholder="Search vendors…"
               class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">🔍</span>
    </div>

    <!-- Table -->
    @if (_loading)
    {
        <div class="flex justify-center py-16">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_vendors?.Items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <p class="text-4xl mb-3">🏢</p>
            <p class="text-gray-500 text-sm">No vendors found. Add your first vendor!</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="overflow-x-auto -mx-1 sm:mx-0">
            <table class="min-w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Vendor</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Mobile</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Referral</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Rating</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Crew</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var v in _vendors!.Items)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-3.5">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-xl bg-amber-100 flex items-center justify-center text-sm font-bold text-amber-700">
                                        @(v.FullName.FirstOrDefault())
                                    </div>
                                    <div>
                                        <p class="font-medium text-gray-800">@v.FullName</p>
                                        <p class="text-xs text-gray-400">@(v.BusinessName ?? "—")</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-5 py-3.5 text-gray-600 font-mono text-xs">@v.Mobile</td>
                            <td class="px-5 py-3.5">
                                <span class="font-mono text-xs bg-gray-100 px-2 py-0.5 rounded">@(v.ReferralCode ?? "—")</span>
                            </td>
                            <td class="px-5 py-3.5">
                                @if (v.Rating.HasValue)
                                {
                                    <span class="text-amber-500 font-semibold">★ @v.Rating.Value.ToString("F1")</span>
                                }
                                else { <span class="text-gray-400 text-xs">Unrated</span> }
                            </td>
                            <td class="px-5 py-3.5">
                                <span class="font-semibold text-indigo-600">@v.CrewCount</span>
                            </td>
                            <td class="px-5 py-3.5">
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium @StatusColor(v.Status)">@v.Status</span>
                            </td>
                            <td class="px-5 py-3.5 text-right">
                                <button @onclick="() => OpenRate(v)"
                                        class="text-xs text-indigo-600 hover:underline mr-3">Rate</button>
                                <button @onclick="() => ToggleStatus(v)"
                                        class="text-xs @(v.Status == "Active" ? "text-red-500" : "text-green-600") hover:underline">
                                    @(v.Status == "Active" ? "Suspend" : "Activate")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (_vendors!.TotalCount > 20)
        {
            <div class="flex items-center justify-between text-sm text-gray-500">
                <span>@_vendors.TotalCount total vendors</span>
                <div class="flex gap-2">
                    <button @onclick="PrevPage" disabled="@(_page == 1)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50 transition">← Prev</button>
                    <span class="px-3 py-1.5">Page @_page</span>
                    <button @onclick="NextPage" disabled="@(_vendors.TotalCount <= _page * 20)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-gray-50 transition">Next →</button>
                </div>
            </div>
        }
    }
</div>

<!-- Create Vendor Modal -->
@if (_showCreate)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-gray-800">Add Vendor</h3>
                <button @onclick="() => { _showCreate = false; _createError = null; }" class="text-gray-400 hover:text-gray-600">✕</button>
            </div>
            <div class="space-y-3">
                <input @bind="_newMobile" placeholder="Mobile (+91...)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_newName" placeholder="Full Name" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_newBusiness" placeholder="Business Name (optional)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_newEmail" type="email" placeholder="Email (optional)" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
            </div>
            @if (_createError is not null)
            {
                <p class="text-xs text-red-600 bg-red-50 rounded-lg px-3 py-2">⚠️ @_createError</p>
            }
            <div class="flex gap-3">
                <button @onclick="CreateVendor" disabled="@_creating"
                        class="flex-1 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 disabled:opacity-50 transition">
                    @(_creating ? "Creating…" : "Create Vendor")
                </button>
                <button @onclick="() => { _showCreate = false; _createError = null; }"
                        class="px-5 py-2.5 rounded-xl border border-gray-200 text-sm hover:bg-gray-50 transition">Cancel</button>
            </div>
        </div>
    </div>
}

<!-- Rate Vendor Modal -->
@if (_rateTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 space-y-4">
            <h3 class="font-bold text-gray-800">Rate @_rateTarget.FullName</h3>
            <div class="flex gap-2 items-center">
                <input @bind="_newRating" type="number" min="0" max="5" step="0.1"
                       class="flex-1 px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-amber-400" />
                <span class="text-amber-500 text-xl">★</span>
            </div>
            <div class="flex gap-3">
                <button @onclick="SubmitRating"
                        class="flex-1 py-2.5 rounded-xl bg-amber-500 text-white text-sm font-semibold hover:bg-amber-600 transition">
                    Submit Rating
                </button>
                <button @onclick="() => _rateTarget = null"
                        class="px-5 py-2.5 rounded-xl border border-gray-200 text-sm hover:bg-gray-50 transition">Cancel</button>
            </div>
        </div>
    </div>
}

@code {

    private bool _accessDenied;
    private bool _canWrite;
    private PagedVendorResult? _vendors;
    private bool _loading = true;
    private int  _page    = 1;
    private string? _search;
    private System.Timers.Timer? _debounce;

    private bool _showCreate;
    private bool _creating;
    private string? _createError;
    private string _newMobile   = string.Empty;
    private string _newName     = string.Empty;
    private string? _newBusiness;
    private string? _newEmail;

    private VendorListItemDto? _rateTarget;
    private decimal _newRating = 5.0m;

    protected override async Task OnInitializedAsync()
    {
        // ── Permission gate ──────────────────────────────────────────────────────
        _accessDenied = !await PermGuard.CanAsync("vendors:read");
        if (_accessDenied) { StateHasChanged(); return; }
        _canWrite = await PermGuard.CanAsync("vendors:write");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _vendors = await VendorApi.GetVendorsAsync(_page, _search);
        _loading = false;
    }

    private void OnSearchKeyUp(KeyboardEventArgs _)
    {
        _debounce?.Dispose();
        _debounce = new System.Timers.Timer(400);
        _debounce.Elapsed += async (_, _) =>
        {
            _page = 1;
            await InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
            _debounce?.Dispose();
        };
        _debounce.AutoReset = false;
        _debounce.Start();
    }

    private async Task PrevPage() { _page--; await LoadAsync(); }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private async Task CreateVendor()
    {
        if (string.IsNullOrWhiteSpace(_newMobile) || string.IsNullOrWhiteSpace(_newName)) return;
        _creating = true; _createError = null;
        var (ok, err) = await VendorApi.CreateVendorAsync(_newMobile, _newName, _newBusiness, _newEmail);
        if (ok)
        {
            _showCreate = false; _newMobile = _newName = string.Empty; _newBusiness = _newEmail = null;
            await LoadAsync();
        }
        else { _createError = err; }
        _creating = false;
    }

    private void OpenRate(VendorListItemDto v) { _rateTarget = v; _newRating = v.Rating ?? 5.0m; }

    private async Task SubmitRating()
    {
        if (_rateTarget is null) return;
        await VendorApi.RateVendorAsync(_rateTarget.Id, _newRating);
        _rateTarget = null;
        await LoadAsync();
    }

    private async Task ToggleStatus(VendorListItemDto v)
    {
        var newStatus = v.Status == "Active" ? "suspended" : "active";
        await VendorApi.ChangeVendorStatusAsync(v.Id, newStatus);
        await LoadAsync();
    }

    private static string StatusColor(string status) => status switch
    {
        "Active"      => "bg-green-50 text-green-700 border border-green-100",
        "Suspended"   => "bg-amber-50 text-amber-700 border border-amber-100",
        "Deactivated" => "bg-red-50 text-red-600 border border-red-100",
        _             => "bg-gray-100 text-gray-500"
    };
}
