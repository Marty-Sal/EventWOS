@page "/admin/roles"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject HttpClient Http

<PageTitle>Roles — EventWOS</PageTitle>

@if (_accessDenied)
{
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
        <div class="text-5xl mb-4">🔒</div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
        <p class="text-gray-500 text-sm">You need <strong>roles:read</strong> permission.</p>
    </div>
    return;
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Roles</h2>
            <p class="text-sm text-gray-500 mt-0.5">System roles and their default permissions.</p>
        </div>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z" />
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">@_error</div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @foreach (var role in _roles)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 space-y-4">
                    <div class="flex items-center gap-3">
                        <span class="text-2xl">@RoleIcon(role.Name)</span>
                        <div>
                            <h3 class="font-bold text-gray-800">@role.Name</h3>
                            <p class="text-xs text-gray-400">@role.Description</p>
                        </div>
                        <span class="ml-auto px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100">
                            @role.UserCount users
                        </span>
                    </div>

                    @if (role.Permissions.Count > 0)
                    {
                        <div>
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Permissions (@role.Permissions.Count)</p>
                            <div class="flex flex-wrap gap-1.5">
                                @foreach (var perm in role.Permissions.OrderBy(p => p))
                                {
                                    <span class="px-2 py-0.5 rounded-full bg-gray-50 border border-gray-200 text-xs font-mono text-gray-600">@perm</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-xs text-gray-400 italic">No permissions assigned yet.</p>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private bool _loading     = true;
    private bool _accessDenied;
    private string? _error;

    private List<RoleView> _roles = new();

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var me = await Http.GetFromJsonAsync<ApiResult<UserProfileDto>>("api/v1/users/me", JsonOpts);
            _accessDenied = !(me?.Data?.Permissions.Contains("roles:read") ?? false);
            if (_accessDenied) { _loading = false; StateHasChanged(); return; }

            // Load all permissions to group by role from role-permission mappings
            var permsResp = await Http.GetFromJsonAsync<ApiResult<List<PermissionDef>>>(
                "api/v1/managers/permissions/all", JsonOpts);
            var allPerms = permsResp?.Data ?? new();

            // Build role views from static knowledge + live permissions
            _roles = new List<RoleView>
            {
                new("Admin",   "Full unrestricted system access",   allPerms.Select(p => p.Name).ToList(), 0),
                new("Manager", "Dynamic permission-based access",   new(), 0),
                new("Vendor",  "Manage own crew and invitations",   new() {"profile:read","profile:write","crew:read","crew:write","crew:invite"}, 0),
                new("Crew",    "Self-service field access",         new() {"profile:read","profile:write"}, 0),
            };

            // Get user counts per role
            var usersResp = await Http.GetFromJsonAsync<ApiResult<PagedUsers>>(
                "api/v1/users?pageSize=500", JsonOpts);
            if (usersResp?.Data?.Items is not null)
            {
                var grouped = usersResp.Data.Items.GroupBy(u => u.Role)
                    .ToDictionary(g => g.Key, g => g.Count());
                foreach (var r in _roles)
                {
                    r.UserCount = grouped.TryGetValue(r.Name, out var cnt) ? cnt : 0;
                }
            }
        }
        catch (Exception ex)
        {
            _error = "Could not load roles: " + ex.Message;
        }
        finally
        {
            _loading = false; StateHasChanged();
        }
    }

    private static string RoleIcon(string role) => role switch
    {
        "Admin"   => "🛡️",
        "Manager" => "👔",
        "Vendor"  => "🏢",
        "Crew"    => "👷",
        _         => "👤"
    };

    private sealed class RoleView
    {
        public string Name { get; }
        public string Description { get; }
        public List<string> Permissions { get; }
        public int UserCount { get; set; }

        public RoleView(string name, string desc, List<string> perms, int userCount)
        {
            Name = name; Description = desc; Permissions = perms; UserCount = userCount;
        }
    }

    private sealed record PermissionDef(Guid Id, string Name, string Resource, string Action, string? Description);
    private sealed record UserDto(Guid Id, string FullName, string Mobile, string Role, string Status);
    private sealed record PagedUsers(List<UserDto> Items, int TotalCount);
    private sealed record UserProfileDto(Guid Id, string FullName, IReadOnlyList<string> Permissions);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
