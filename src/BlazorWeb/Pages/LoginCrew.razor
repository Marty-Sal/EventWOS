@page "/login/crew"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout

<PageTitle>Crew sign in — EventWOS</PageTitle>

@*
    Thin wrapper around <PasswordLoginCard /> with the portal pre-selected.
    ReturnUrl comes from the [SupplyParameterFromQuery] attribute on the
    component parameter so the post-login redirect still honours it.
*@

<PasswordLoginCard Portal="Crew" ReturnUrl="@ReturnUrl" />

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
}
