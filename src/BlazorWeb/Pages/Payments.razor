    .dropdown-item  { display:block;width:100%;text-align:left;padding:.5rem .85rem;font-size:.83rem;color:#111827;cursor:pointer;border-bottom:1px solid #f3f4f6; }
    .dropdown-item:hover { background:#f5f3ff; }
    .dropdown-item:last-child { border-bottom:none; }
    .chip           { padding:.3rem .75rem;border-radius:9999px;font-size:.74rem;font-weight:600;border:1px solid #e5e7eb;background:white;color:#4b5563;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:.25rem; }
    .chip:hover     { background:#f9fafb; }
    .chip-active        { background:#eef2ff;color:#4338ca;border-color:#c7d2fe; }
    .chip-active-amber  { background:#fffbeb;color:#b45309;border-color:#fde68a; }
    .chip-active-green  { background:#f0fdf4;color:#15803d;border-color:#bbf7d0; }
    .chip-active-slate  { background:#f1f5f9;color:#475569;border-color:#cbd5e1; }
</style>

@code {

    private bool _accessDenied;
    private bool _canWrite;
    private enum Tab { Payments, Payroll }
    private Tab _tab = Tab.Payments;

    // ── Data ──────────────────────────────────────────────────────────────────
    private PagedPaymentResult? _payments;
    private PagedPayrollResult? _payroll;
    private bool    _loading;
    private bool    _saving;
    private string? _error;
    private string? _success;
    private string  _filterStatus = "";
    private int     _page = 1;

    // ── Crew-ack quick-filter chips (client-side) ─────────────────────────────
    private enum AckFilter { All, ReportedPending, AwaitingAck, Received }
    private AckFilter _ackFilter = AckFilter.All;
    private int _ackReportedCount;          // count on the current page — drives the badge
    private void SetAckFilter(AckFilter f)  { _ackFilter = f; }

    // ── Mark Paid modal ───────────────────────────────────────────────────────
    private CrewPaymentDto? _markPaidPayment;
    private decimal         _paidAmount;
    private string          _paidMethod    = "";
    private string?         _transactionRef;

    // ══════════════════════════════════════════════════════════════════════════
    // CREATE PAYMENT STATE
    // ══════════════════════════════════════════════════════════════════════════
    private bool _showCreatePayment;

    // Event picker
    private string                 _pmtEventSearch    = "";
    private bool                   _pmtEventDropOpen;
    private List<EventListItemDto> _pmtEventResults   = new();
    private EventListItemDto?      _pmtSelectedEvent;

    // Vendor picker
    private string             _pmtVendorSearch   = "";
    private bool               _pmtVendorDropOpen;
    private List<VendorListItemDto> _pmtVendorResults = new();
    private VendorListItemDto? _pmtSelectedVendor;

    // Crew picker
    private string            _pmtCrewSearch   = "";
    private bool              _pmtCrewDropOpen;
    private List<CrewMemberDto> _pmtCrewResults = new();
    private CrewMemberDto?    _pmtSelectedCrew;

    // Assignment auto-resolve
    private bool   _pmtAssignmentLoading;
    private Guid?  _pmtResolvedAssignmentId;
    private string _pmtManualAssignmentId = "";

    // Form fields
    private decimal _pmtAmount;
    private string? _pmtNotes;

    // ══════════════════════════════════════════════════════════════════════════
    // CREATE BATCH STATE (event-centric)
    // ══════════════════════════════════════════════════════════════════════════
    private bool _showCreateBatch;

    // Event picker
    private string                 _batchEventSearch  = "";
    private bool                   _batchEventDropOpen;
    private List<EventListItemDto> _batchEventResults = new();
    private EventListItemDto?      _batchSelectedEvent;

    // Roster + per-line amounts
    private bool                       _rosterLoading;
    private EventPayableRosterDto?     _roster;
    private Dictionary<string, decimal> _lineAmounts = new();
    private string?                    _batchNotes;

    // ══════════════════════════════════════════════════════════════════════════
    // LIFECYCLE
    // ══════════════════════════════════════════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        // ── Permission gate ──────────────────────────────────────────────────────
        _accessDenied = !await PermGuard.CanAsync("payments:read");
        if (_accessDenied) { StateHasChanged(); return; }
        _canWrite = await PermGuard.CanAsync("payments:write");

        // Live: refresh master payments list on any payment / payroll state change.
        Hub.PaymentChangedReceived += OnPaymentMoved;
        Hub.PayrollChangedReceived += OnPaymentMoved;
        try { await Hub.StartAsync(); } catch { }

        await LoadData();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.PaymentChangedReceived -= OnPaymentMoved;
        Hub.PayrollChangedReceived -= OnPaymentMoved;
        await ValueTask.CompletedTask;
    }

    private void OnPaymentMoved(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadData(); StateHasChanged(); });
    }

    private async Task SwitchTab(Tab tab)
    {
        _tab = tab; _page = 1; _filterStatus = "";
        await LoadData();
    }

    private async Task ReloadFromPage1() { _page = 1; await LoadData(); }

    private async Task LoadData()
    {
        _loading = true; _error = null; StateHasChanged();
        var status = string.IsNullOrEmpty(_filterStatus) ? null : _filterStatus;
        if (_tab == Tab.Payments)
        {
            _payments = await PaymentApi.GetPaymentsAsync(status: status, page: _page);
            _ackReportedCount = _payments?.Items.Count(x => x.CrewAcknowledgment == "Pending") ?? 0;
        }
        else
            _payroll = await PaymentApi.GetPayrollBatchesAsync(status: status, page: _page);
        _loading = false;
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadData(); } }
    private async Task NextPage() { _page++; await LoadData(); }

    // ══════════════════════════════════════════════════════════════════════════
    // EVENT SEARCH — Payment modal
    // ══════════════════════════════════════════════════════════════════════════
    private async Task OnPmtEventSearch(ChangeEventArgs e)
    {
        _pmtEventSearch = e.Value?.ToString() ?? "";
        if (_pmtEventSearch.Length < 2) { _pmtEventResults.Clear(); return; }
        var result = await EventApi.GetEventsAsync(search: _pmtEventSearch, page: 1);
        _pmtEventResults = result?.Items?.Take(8).ToList() ?? new();
        _pmtEventDropOpen = true;
    }

    private void SelectPmtEvent(EventListItemDto ev)
    {
        _pmtSelectedEvent  = ev;
        _pmtEventDropOpen  = false;
        _pmtEventSearch    = "";
        _pmtEventResults.Clear();
        _ = TryResolveAssignment();
    }

    private void ClearPmtEvent()
    {
        _pmtSelectedEvent            = null;
        _pmtResolvedAssignmentId     = null;
        _pmtManualAssignmentId       = "";
    }

    // ══════════════════════════════════════════════════════════════════════════
    // VENDOR SEARCH — Payment modal
    // ══════════════════════════════════════════════════════════════════════════
    private async Task OnPmtVendorSearch(ChangeEventArgs e)
    {
        _pmtVendorSearch = e.Value?.ToString() ?? "";
        if (_pmtVendorSearch.Length < 1) { _pmtVendorResults.Clear(); _pmtVendorDropOpen = false; return; }
        var result = await VendorApi.GetVendorsAsync(search: _pmtVendorSearch, page: 1);
        _pmtVendorResults = result?.Items?.Take(8).ToList() ?? new();
        _pmtVendorDropOpen = true;
    }

    private void SelectPmtVendor(VendorListItemDto v)
    {
        _pmtSelectedVendor = v;
        _pmtVendorDropOpen = false;
        _pmtVendorSearch   = "";
        _pmtVendorResults.Clear();
        // Reset crew selection when vendor changes
        _pmtSelectedCrew          = null;
        _pmtCrewResults.Clear();
        _pmtResolvedAssignmentId  = null;
        _ = TryResolveAssignment();
    }

    private void ClearPmtVendor()
    {
        _pmtSelectedVendor           = null;
        _pmtSelectedCrew             = null;
        _pmtResolvedAssignmentId     = null;
        _pmtManualAssignmentId       = "";
    }

    // ══════════════════════════════════════════════════════════════════════════
    // CREW SEARCH — Payment modal
    // ══════════════════════════════════════════════════════════════════════════
    private async Task OnPmtCrewSearch(ChangeEventArgs e)
    {
        _pmtCrewSearch = e.Value?.ToString() ?? "";
        if (_pmtCrewSearch.Length < 1) { _pmtCrewResults.Clear(); _pmtCrewDropOpen = false; return; }
        var vendorId = _pmtSelectedVendor?.Id;
        var result   = await VendorApi.GetCrewAsync(search: _pmtCrewSearch, vendorId: vendorId, page: 1);
        _pmtCrewResults  = result?.Items?.Take(8).ToList() ?? new();
        _pmtCrewDropOpen = true;
    }

    private void SelectPmtCrew(CrewMemberDto c)
    {
        _pmtSelectedCrew = c;
        _pmtCrewDropOpen = false;
        _pmtCrewSearch   = "";
        _pmtCrewResults.Clear();
        _ = TryResolveAssignment();
    }

    private void ClearPmtCrew()
    {
        _pmtSelectedCrew             = null;
        _pmtResolvedAssignmentId     = null;
        _pmtManualAssignmentId       = "";
    }

    // ── Auto-resolve assignment when all 3 pickers are set ───────────────────
    // If no existing assignment is found, auto-create one (Invited status).
    private async Task TryResolveAssignment()
    {
        if (_pmtSelectedEvent == null || _pmtSelectedCrew == null || _pmtSelectedVendor == null) return;

        _pmtAssignmentLoading    = true;
        _pmtResolvedAssignmentId = null;
        StateHasChanged();

        try
        {
            // First: look for an existing assignment (any non-declined status)
            var assignments = await EventApi.GetAssignmentsAsync(_pmtSelectedEvent.Id, page: 1);
            var match = assignments?.Items?.FirstOrDefault(a =>
                a.CrewId   == _pmtSelectedCrew.Id &&
                a.VendorId == _pmtSelectedVendor.Id &&
                a.Status   != "Declined");

            if (match != null)
            {
                _pmtResolvedAssignmentId = match.Id;
            }
            else
            {
                // Auto-create the assignment so payment can proceed
                var (ok, assignmentId, err) = await EventApi.AssignCrewAsync(
                    _pmtSelectedEvent.Id, _pmtSelectedCrew.Id, _pmtSelectedVendor.Id);

                if (ok && assignmentId.HasValue)
                {
                    _pmtResolvedAssignmentId  = assignmentId.Value;
                }
            }
        }
        catch { }

        _pmtAssignmentLoading = false;
        StateHasChanged();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // EVENT SEARCH — Batch modal
    // ══════════════════════════════════════════════════════════════════════════
    private async Task OnBatchEventSearch(ChangeEventArgs e)
    {
        _batchEventSearch = e.Value?.ToString() ?? "";
        if (_batchEventSearch.Length < 2) { _batchEventResults.Clear(); return; }
        var result = await EventApi.GetEventsAsync(search: _batchEventSearch, page: 1);
        _batchEventResults  = result?.Items?.Take(8).ToList() ?? new();
        _batchEventDropOpen = true;
    }

    private async Task SelectBatchEvent(EventListItemDto ev)
    {
        _batchSelectedEvent = ev;
        _batchEventDropOpen = false;
        _batchEventSearch   = "";
        _batchEventResults.Clear();
        if (ev.Status == "Completed")
            await LoadRosterAsync();
    }

    private void ClearBatchEvent()
    {
        _batchSelectedEvent = null;
        _roster             = null;
        _lineAmounts.Clear();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // OPEN MODALS
    // ══════════════════════════════════════════════════════════════════════════
    private void OpenCreatePayment()
    {
        _pmtSelectedEvent        = null; _pmtEventSearch    = ""; _pmtEventResults.Clear();
        _pmtSelectedVendor       = null; _pmtVendorSearch   = ""; _pmtVendorResults.Clear();
        _pmtSelectedCrew         = null; _pmtCrewSearch     = ""; _pmtCrewResults.Clear();
        _pmtResolvedAssignmentId = null; _pmtManualAssignmentId = "";
        _pmtAmount = 0; _pmtNotes = null;
        _showCreatePayment = true;
    }

    private void OpenCreateBatch()
    {
        _batchSelectedEvent = null;
        _batchEventSearch   = "";
        _batchEventResults.Clear();
        _roster             = null;
        _lineAmounts.Clear();
        _batchNotes         = null;
        _rosterLoading      = false;
        _showCreateBatch    = true;
    }

    // ── Roster helpers ────────────────────────────────────────────────────────
    private static string LineKey(PayableLineDto l) => $"{l.Kind}:{l.PartyId}";

    private decimal GetLineAmount(PayableLineDto l)
        => _lineAmounts.TryGetValue(LineKey(l), out var v) ? v : 0m;

    private void SetLineAmount(PayableLineDto l, object? raw)
    {
        if (raw is null || !decimal.TryParse(raw.ToString(), out var amt) || amt < 0)
        {
            _lineAmounts.Remove(LineKey(l));
            return;
        }
        _lineAmounts[LineKey(l)] = amt;
    }

    private decimal RosterTotal()
    {
        // Phase D step 23: total is sum of (per-crew × attended count).
        // Direct-crew lines have count = 1, so per-crew == line total — same
        // result as before for that flow. Vendor lines now reflect the real
        // amount the manager will hand over (per-crew × every crew).
        if (_roster is null) return 0m;
        decimal sum = 0m;
        foreach (var l in _roster.VendorLines.Concat(_roster.DirectCrewLines))
        {
            if (l.AlreadyHasPayment) continue;
            if (!_lineAmounts.TryGetValue(LineKey(l), out var perCrew)) continue;
            var count = l.AttendedCrewCount > 0 ? l.AttendedCrewCount : 1;
            sum += perCrew * count;
        }
        return sum;
    }

    private async Task LoadRosterAsync()
    {
        _roster = null;
        _lineAmounts.Clear();
        if (_batchSelectedEvent is null) return;
        _rosterLoading = true;
        var (r, _) = await PaymentApi.GetEventPayableRosterAsync(_batchSelectedEvent.Id);
        _roster        = r;
        _rosterLoading = false;
        StateHasChanged();
    }

    // ══════════════════════════════════════════════════════════════════════════
    // ACTIONS
    // ══════════════════════════════════════════════════════════════════════════
    private async Task CreatePayment()
    {
        if (_pmtSelectedEvent == null)  { _error = "Please select an event.";   return; }
        if (_pmtSelectedVendor == null) { _error = "Please select a vendor.";   return; }
        if (_pmtSelectedCrew == null)   { _error = "Please select a crew member."; return; }
        if (_pmtAmount <= 0)            { _error = "Enter a valid amount.";      return; }

        Guid assignmentId;
        if (_pmtResolvedAssignmentId.HasValue)
            assignmentId = _pmtResolvedAssignmentId.Value;
        else if (Guid.TryParse(_pmtManualAssignmentId, out var manualId))
            assignmentId = manualId;
        else { _error = "No assignment found. Please enter the Assignment ID manually."; return; }

        _saving = true;
        var (ok, err) = await PaymentApi.CreatePaymentAsync(new NewPaymentForm
        {
            EventId      = _pmtSelectedEvent.Id,
            AssignmentId = assignmentId,
            CrewId       = _pmtSelectedCrew.Id,
            VendorId     = _pmtSelectedVendor.Id,
            AgreedAmount = _pmtAmount,
            Notes        = _pmtNotes
        });
        _saving = false;

        if (ok) { _success = "Payment created ✅"; _showCreatePayment = false; await LoadData(); }
        else _error = err;
    }

    private async Task CreatePayrollBatch()
    {
        if (_batchSelectedEvent == null) { _error = "Please select an event."; return; }
        if (_batchSelectedEvent.Status != "Completed")
        {
            _error = "Payroll can only be created once the event is Completed.";
            return;
        }
        if (_roster is null) { _error = "Roster not loaded yet."; return; }

        var lines = new List<EventBatchLineForm>();
        foreach (var l in _roster.VendorLines.Concat(_roster.DirectCrewLines))
        {
            if (l.AlreadyHasPayment) continue;
            if (!_lineAmounts.TryGetValue(LineKey(l), out var amt) || amt <= 0) continue;
            lines.Add(new EventBatchLineForm { Kind = l.Kind, PartyId = l.PartyId, Amount = amt });
        }
        if (lines.Count == 0) { _error = "Enter an amount for at least one row before creating the batch."; return; }

        _saving = true;
        var (ok, err) = await PaymentApi.CreateEventPayrollBatchAsync(
            _batchSelectedEvent.Id, lines, _batchNotes);
        _saving = false;

        if (ok) { _success = $"Payroll batch created ✅ ({lines.Count} line(s))"; _showCreateBatch = false; await LoadData(); }
        else _error = err;
    }

    private async Task QuickAction(Guid id, string action)
    {
        var (ok, err) = await PaymentApi.UpdatePaymentStatusAsync(id, action);
        if (ok) { _success = $"Payment {action}d."; await LoadData(); }
        else _error = err;
    }

    private Task ApprovePayment(Guid id) => QuickAction(id, "approve");
    private Task RejectPayment(Guid id)  => QuickAction(id, "reject");
    private Task HoldPayment(Guid id)    => QuickAction(id, "hold");

    private void OpenMarkPaid(CrewPaymentDto p)
    {
        _markPaidPayment = p;
        _paidAmount      = p.AgreedAmount;
        _paidMethod      = "";
        _transactionRef  = null;
    }

    private async Task ConfirmMarkPaid()
    {
        if (_markPaidPayment is null) return;
        if (string.IsNullOrEmpty(_paidMethod)) { _error = "Select a payment method."; return; }
        _saving = true;
        var (ok, err) = await PaymentApi.UpdatePaymentStatusAsync(
            _markPaidPayment.Id, "pay", _paidAmount, _paidMethod, _transactionRef);
        _saving = false;
        if (ok) { _success = "Marked as paid ✅"; _markPaidPayment = null; await LoadData(); }
        else _error = err;
    }

    private async Task BatchAction(Guid id, string action)
    {
        var (ok, err) = await PaymentApi.UpdatePayrollBatchStatusAsync(id, action);
        if (ok) { _success = $"Batch {action}d."; await LoadData(); }
        else _error = err;
    }

    private Task SubmitBatch(Guid id)   => BatchAction(id, "submit");
    private Task ApproveBatch(Guid id)  => BatchAction(id, "approve");
    private Task RejectBatch(Guid id)   => BatchAction(id, "reject");
    private Task DisburseBatch(Guid id) => BatchAction(id, "disburse");

    // ── Helpers ───────────────────────────────────────────────────────────────
    private static string PayBadge(string status) => status switch
    {
        "Pending"  => "bg-amber-100 text-amber-800",
        "Approved" => "bg-blue-100 text-blue-800",
        "Paid"     => "bg-green-100 text-green-800",
        "Rejected" => "bg-red-100 text-red-800",
        "OnHold"   => "bg-orange-100 text-orange-800",
        _          => "bg-gray-100 text-gray-700"
    };

    private static string BatchBadge(string status) => status switch
    {
        "Draft"     => "bg-gray-100 text-gray-700",
        "Submitted" => "bg-blue-100 text-blue-800",
        "Approved"  => "bg-indigo-100 text-indigo-800",
        "Disbursed" => "bg-green-100 text-green-800",
        "Rejected"  => "bg-red-100 text-red-800",
        _           => "bg-gray-100 text-gray-700"
    };
}
