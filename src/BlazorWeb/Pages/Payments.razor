    .modal-bg       { position:fixed;inset:0;background:rgba(0,0,0,.4);backdrop-filter:blur(4px);z-index:50;display:flex;align-items:center;justify-content:center;padding:1rem; }
    .modal          { background:white;border-radius:1.25rem;padding:1.75rem;width:100%;max-width:560px;box-shadow:0 20px 60px rgba(0,0,0,.2);max-height:90vh;overflow-y:auto; }
    .lbl            { display:block;font-size:.78rem;font-weight:600;color:#374151;margin-bottom:.35rem; }
    .inp            { width:100%;border:1px solid #e5e7eb;border-radius:.75rem;padding:.55rem .85rem;font-size:.85rem;outline:none;color:#111827; }
    .inp:focus      { border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.12); }
    .btn-primary    { background:#4f46e5;color:white;font-weight:700;padding:.55rem 1.25rem;border-radius:.75rem;font-size:.85rem;cursor:pointer;transition:background .15s; }
    .btn-primary:hover    { background:#4338ca; }
