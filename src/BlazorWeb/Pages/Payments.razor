@page "/payments"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IPaymentApiService PaymentApi
@inject IEventApiService   EventApi
@inject IVendorApiService  VendorApi
@inject NotificationHubService Hub
@implements IAsyncDisposable


    @if (_accessDenied)
    {
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
            <p class="text-gray-500 text-sm">You don't have permission to view this page.<br/>Contact your Admin to request access.</p>
        </div>
        return;
    }

<PageTitle>Payments & Payroll — EventWOS</PageTitle>

<div class="space-y-6">

    @* ── Header ──────────────────────────────────────────────────────────── *@
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-xl font-bold text-gray-900">Payments & Payroll</h1>
            <p class="text-sm text-gray-400 mt-0.5">Manage crew payments and vendor payroll batches</p>
        </div>
        @if (_tab == Tab.Payments)
        {
            @if (_canWrite) { <button class="btn-primary" @onclick="OpenCreatePayment">+ New Payment</button> }
        }
        else
        {
            <button class="btn-primary" @onclick="OpenCreateBatch">+ New Payroll Batch</button>
        }
    </div>

    @* ── Tabs ─────────────────────────────────────────────────────────────── *@
    <div class="flex gap-1 bg-gray-100 p-1 rounded-xl w-fit">
        <button class="tab-btn @(_tab == Tab.Payments ? "tab-active" : "")"
                @onclick="() => SwitchTab(Tab.Payments)">💰 Crew Payments</button>
        <button class="tab-btn @(_tab == Tab.Payroll ? "tab-active" : "")"
                @onclick="() => SwitchTab(Tab.Payroll)">📦 Payroll Batches</button>
    </div>

    @* ── Filters ──────────────────────────────────────────────────────────── *@
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 flex flex-wrap gap-3 items-center">
        <select class="filter-select" @bind="_filterStatus" @bind:after="ReloadFromPage1">
            <option value="">All Statuses</option>
            @if (_tab == Tab.Payments)
            {
                <option>Pending</option><option>Approved</option>
                <option>Paid</option><option>Rejected</option><option>OnHold</option>
            }
            else
            {
                <option>Draft</option><option>Submitted</option>
                <option>Approved</option><option>Disbursed</option><option>Rejected</option>
            }
        </select>
    </div>

    @* ── Alerts ───────────────────────────────────────────────────────────── *@
    @if (_error != null)
    {
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700 flex items-center gap-2">
            ⚠️ @_error
            <button class="ml-auto text-red-400 hover:text-red-600" @onclick="() => _error = null">✕</button>
        </div>
    }
    @if (_success != null)
    {
        <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-sm text-green-700 flex items-center gap-2">
            ✅ @_success
            <button class="ml-auto text-green-400 hover:text-green-600" @onclick="() => _success = null">✕</button>
        </div>
    }

    @* ════════════════════════ PAYMENTS TABLE ════════════════════════════════ *@
    @if (_tab == Tab.Payments)
    {
        @if (_loading) { <div class="text-center py-12 text-gray-400">Loading payments…</div> }
        else if (_payments?.Items.Count == 0) { <div class="text-center py-12 text-gray-400">No payments found.</div> }
        else if (_payments != null)
        {
            @* Quick-filter chips for crew acknowledgment states (client-side) *@
            <div class="flex flex-wrap items-center gap-2 mb-3">
                <span class="text-xs text-gray-500 mr-1">Quick filter:</span>
                <button class="chip @(_ackFilter == AckFilter.All ? "chip-active" : "")"
                        @onclick="() => SetAckFilter(AckFilter.All)">All</button>
                <button class="chip @(_ackFilter == AckFilter.ReportedPending ? "chip-active-amber" : "")"
                        @onclick="() => SetAckFilter(AckFilter.ReportedPending)">
                    ⚠ Reported Pending
                    @if (_ackReportedCount > 0) { <span class="ml-1 text-[10px] font-bold">@_ackReportedCount</span> }
                </button>
                <button class="chip @(_ackFilter == AckFilter.AwaitingAck ? "chip-active-slate" : "")"
                        @onclick="() => SetAckFilter(AckFilter.AwaitingAck)">Awaiting Ack</button>
                <button class="chip @(_ackFilter == AckFilter.Received ? "chip-active-green" : "")"
                        @onclick="() => SetAckFilter(AckFilter.Received)">✓ Received</button>
            </div>

            var _filtered = _ackFilter switch
            {
                AckFilter.ReportedPending => _payments.Items.Where(p => p.CrewAcknowledgment == "Pending").ToList(),
                AckFilter.Received        => _payments.Items.Where(p => p.CrewAcknowledgment == "Received").ToList(),
                AckFilter.AwaitingAck     => _payments.Items.Where(p => p.Status == "Paid" && p.CrewAcknowledgment == "None").ToList(),
                _                         => _payments.Items.ToList()
            };

            @if (_filtered.Count == 0)
            {
                <div class="text-center py-10 text-gray-400 bg-white rounded-2xl border border-gray-100">
                    No rows match this filter on the current page.
                </div>
            }
            else
            {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="th-cell">Crew</th>
                            <th class="th-cell">Event</th>
                            <th class="th-cell">Vendor</th>
                            <th class="th-cell">Agreed</th>
                            <th class="th-cell">Paid</th>
                            <th class="th-cell">Status</th>
                            <th class="th-cell">Crew Ack</th>
                            <th class="th-cell">Method</th>
                            <th class="th-cell">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var p in _filtered)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="td-cell">
                                    <div class="font-semibold text-gray-900 text-sm">@p.CrewName</div>
                                    <div class="text-xs text-gray-400">@p.CrewMobile</div>
                                </td>
                                <td class="td-cell text-sm text-gray-700">
                                    <div>@p.EventTitle</div>
                                    @* Phase D step 28: shift sub-line. Tells two sibling rows
                                       apart when a crew is paid for multiple shifts at one event. *@
                                    @if (!string.IsNullOrEmpty(p.ShiftScopeName) || p.ShiftStartAt.HasValue)
                                    {
                                        <div class="text-[11px] text-indigo-600 mt-0.5">
                                            @if (!string.IsNullOrEmpty(p.ShiftScopeName)) { <span class="font-medium">@p.ShiftScopeName</span> }
                                            @if (p.ShiftStartAt.HasValue)
                                            {
                                                <span class="text-indigo-400 font-normal"> · @p.ShiftStartAt.Value.ToLocalTime().ToString("dd MMM HH:mm")</span>
                                            }
                                        </div>
                                    }
                                </td>
                                <td class="td-cell text-sm text-gray-700">@(string.IsNullOrEmpty(p.VendorName) ? "Direct" : p.VendorName)</td>
                                <td class="td-cell text-sm font-semibold text-gray-900">@(p.AgreedAmount == 0 ? "—" : "₹" + p.AgreedAmount.ToString("N0"))</td>
                                <td class="td-cell text-sm text-gray-600">@(p.PaidAmount.HasValue ? "₹" + p.PaidAmount.Value.ToString("N0") : "—")</td>
                                <td class="td-cell"><span class="badge @PayBadge(p.Status)">@p.Status</span></td>
                                <td class="td-cell text-xs">
                                    @if (p.CrewAcknowledgment == "Received")
                                    {
                                        <span class="text-emerald-600 font-semibold" title="@(p.AcknowledgedAt?.ToLocalTime().ToString("dd MMM yyyy"))">✓ Received</span>
                                    }
                                    else if (p.CrewAcknowledgment == "Pending")
                                    {
                                        <span class="text-amber-600 font-semibold" title="@p.AcknowledgmentNote">⚠ Reported Pending</span>
                                    }
                                    else if (p.Status == "Paid")
                                    {
                                        <span class="text-gray-400 italic">Awaiting</span>
                                    }
                                    else
                                    {
                                        <span class="text-gray-300">—</span>
                                    }
                                </td>
                                <td class="td-cell text-xs text-gray-500">@(p.Method ?? "—")</td>
                                <td class="td-cell">
                                    <div class="flex flex-wrap gap-1">
                                        @if (p.Status == "Pending" || p.Status == "OnHold")
                                        {
                                            <button class="act-btn green" @onclick="() => ApprovePayment(p.Id)">Approve</button>
                                            <button class="act-btn red"   @onclick="() => RejectPayment(p.Id)">Reject</button>
                                        }
                                        @if (p.Status == "Pending")
                                        {
                                            <button class="act-btn amber" @onclick="() => HoldPayment(p.Id)">Hold</button>
                                        }
                                        @if (p.Status == "Approved" && p.VendorId == null)
                                        {
                                            @* Direct-crew payments are marked Paid by the manager.
                                               Vendor-mediated payments are marked Paid by the vendor. *@
                                            <button class="act-btn blue"   @onclick="() => OpenMarkPaid(p)">Mark Paid</button>
                                        }
                                        else if (p.Status == "Approved" && p.VendorId != null)
                                        {
                                            <span class="text-[11px] text-slate-500 italic">Vendor will mark paid</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            <div class="flex items-center justify-between text-sm text-gray-500 mt-2">
                <span>Total: @_payments.TotalCount</span>
                <div class="flex gap-2">
                    <button class="page-btn" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
                    <span class="px-2 py-1">Page @_page</span>
                    <button class="page-btn" @onclick="NextPage"
                            disabled="@(_payments.Items.Count < 20)">Next →</button>
                </div>
            </div>
        }
    }

    @* ════════════════════════ PAYROLL TABLE ═════════════════════════════════ *@
    else
    {
        @if (_loading) { <div class="text-center py-12 text-gray-400">Loading batches…</div> }
        else if (_payroll?.Items.Count == 0) { <div class="text-center py-12 text-gray-400">No payroll batches found.</div> }
        else if (_payroll != null)
        {
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-x-auto">
                <table class="min-w-full">
                    <thead class="bg-gray-50 border-b border-gray-100">
                        <tr>
                            <th class="th-cell">Batch Ref</th>
                            <th class="th-cell">Vendor</th>
                            <th class="th-cell">Event</th>
                            <th class="th-cell">Total</th>
                            <th class="th-cell">Payments</th>
                            <th class="th-cell">Status</th>
                            <th class="th-cell">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @foreach (var b in _payroll.Items)
                        {
                            <tr class="hover:bg-gray-50/50 transition-colors">
                                <td class="td-cell">
                                    <div class="font-mono text-xs text-indigo-700 font-semibold">@b.BatchRef</div>
                                    <div class="text-xs text-gray-400">@b.CreatedDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td class="td-cell text-sm text-gray-700">@b.VendorName</td>
                                <td class="td-cell text-sm text-gray-700">@b.EventTitle</td>
                                <td class="td-cell text-sm font-semibold text-gray-900">₹@b.TotalAmount.ToString("N0")</td>
                                <td class="td-cell text-sm text-gray-600">@b.PaymentCount items</td>
                                <td class="td-cell"><span class="badge @BatchBadge(b.Status)">@b.Status</span></td>
                                <td class="td-cell">
                                    <div class="flex flex-wrap gap-1">
                                        @if (b.Status == "Draft")
                                        {
                                            <button class="act-btn blue" @onclick="() => SubmitBatch(b.Id)">Submit</button>
                                        }
                                        @if (b.Status == "Submitted")
                                        {
                                            <button class="act-btn green"  @onclick="() => ApproveBatch(b.Id)">Approve</button>
                                            <button class="act-btn red"    @onclick="() => RejectBatch(b.Id)">Reject</button>
                                        }
                                        @if (b.Status == "Approved")
                                        {
                                            <button class="act-btn purple" @onclick="() => DisburseBatch(b.Id)">Disburse</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between text-sm text-gray-500 mt-2">
                <span>Total: @_payroll.TotalCount</span>
                <div class="flex gap-2">
                    <button class="page-btn" @onclick="PrevPage" disabled="@(_page == 1)">← Prev</button>
                    <span class="px-2 py-1">Page @_page</span>
                    <button class="page-btn" @onclick="NextPage"
                            disabled="@(_payroll.Items.Count < 20)">Next →</button>
                </div>
            </div>
        }
    }
</div>

@* ══════════════════ MODAL: New Crew Payment ═════════════════════════════════ *@
@if (_showCreatePayment)
{
    <div class="modal-bg" @onclick="() => _showCreatePayment = false">
        <div class="modal" @onclick:stopPropagation="true">
            <h3 class="text-lg font-bold text-gray-900 mb-5">New Crew Payment</h3>
            <div class="space-y-4">

                @* ── Event search ─────────────────────────────────────────────── *@
                <div class="relative">
                    <label class="lbl">Event <span class="text-red-400">*</span></label>
                    @if (_pmtSelectedEvent != null)
                    {
                        <div class="inp flex items-center justify-between bg-indigo-50 border-indigo-200">
                            <div>
                                <span class="font-semibold text-indigo-800 text-sm">@_pmtSelectedEvent.Title</span>
                                <span class="text-xs text-gray-500 ml-2">@_pmtSelectedEvent.Venue</span>
                                <span class="badge bg-gray-100 text-gray-700 ml-2">@_pmtSelectedEvent.Status</span>
                            </div>
                            <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearPmtEvent">✕</button>
                        </div>
                        @if (_pmtSelectedEvent.Status != "Completed")
                        {
                            <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-700 mt-2">
                                ⚠ Payments can only be created once the event is <strong>Completed</strong>.
                                This event is currently <strong>@_pmtSelectedEvent.Status</strong>.
                            </div>
                        }
                    }
                    else
                    {
                        <input class="inp" placeholder="Search event by name…"
                               @value="_pmtEventSearch"
                               @onfocus="() => _pmtEventDropOpen = true"
                               @oninput="OnPmtEventSearch" />
                        @if (_pmtEventDropOpen && _pmtEventResults.Count > 0)
                        {
                            <div class="dropdown-list">
                                @foreach (var e in _pmtEventResults)
                                {
                                    <button class="dropdown-item" @onclick="() => SelectPmtEvent(e)">
                                        <span class="font-semibold">@e.Title</span>
                                        <span class="text-xs text-gray-400 ml-2">@e.Venue · @e.Status</span>
                                    </button>
                                }
                            </div>
                        }
                    }
                </div>

                @* ── Vendor search ────────────────────────────────────────────── *@
                <div class="relative">
                    <label class="lbl">Vendor <span class="text-red-400">*</span></label>
                    @if (_pmtSelectedVendor != null)
                    {
                        <div class="inp flex items-center justify-between bg-indigo-50 border-indigo-200">
                            <div>
                                <span class="font-semibold text-indigo-800 text-sm">@_pmtSelectedVendor.FullName</span>
                                <span class="text-xs text-gray-500 ml-2">@_pmtSelectedVendor.Mobile</span>
                            </div>
                            <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearPmtVendor">✕</button>
                        </div>
                    }
                    else
                    {
                        <input class="inp" placeholder="Search vendor by name…"
                               @value="_pmtVendorSearch"
                               @onfocus="() => _pmtVendorDropOpen = true"
                               @oninput="OnPmtVendorSearch" />
                        @if (_pmtVendorDropOpen)
                        {
                            @if (_pmtVendorResults.Count > 0)
                            {
                                <div class="dropdown-list">
                                    @foreach (var v in _pmtVendorResults)
                                    {
                                        <button class="dropdown-item" @onclick="() => SelectPmtVendor(v)">
                                            <span class="font-semibold">@v.FullName</span>
                                            <span class="text-xs text-gray-400 ml-2">@v.Mobile</span>
                                        </button>
                                    }
                                </div>
                            }
                            else if (_pmtVendorSearch.Length >= 1)
                            {
                                <div class="dropdown-list px-3 py-2 text-xs text-gray-400 italic">No vendors found for "@_pmtVendorSearch"</div>
                            }
                        }
                    }
                </div>

                @* ── Crew search (filtered by vendor if selected) ─────────────── *@
                <div class="relative">
                    <label class="lbl">Crew Member <span class="text-red-400">*</span></label>
                    @if (_pmtSelectedCrew != null)
                    {
                        <div class="inp flex items-center justify-between bg-indigo-50 border-indigo-200">
                            <div>
                                <span class="font-semibold text-indigo-800 text-sm">@_pmtSelectedCrew.FullName</span>
                                <span class="text-xs text-gray-500 ml-2">@_pmtSelectedCrew.Mobile</span>
                            </div>
                            <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearPmtCrew">✕</button>
                        </div>
                    }
                    else
                    {
                        <input class="inp" placeholder="@(_pmtSelectedVendor != null ? "Search crew under this vendor…" : "Search crew by name…")"
                               @value="_pmtCrewSearch"
                               @onfocus="() => _pmtCrewDropOpen = true"
                               @oninput="OnPmtCrewSearch" />
                        @if (_pmtCrewDropOpen)
                        {
                            @if (_pmtCrewResults.Count > 0)
                            {
                                <div class="dropdown-list">
                                    @foreach (var c in _pmtCrewResults)
                                    {
                                        <button class="dropdown-item" @onclick="() => SelectPmtCrew(c)">
                                            <span class="font-semibold">@c.FullName</span>
                                            <span class="text-xs text-gray-400 ml-2">@c.Mobile</span>
                                        </button>
                                    }
                                </div>
                            }
                            else if (_pmtCrewSearch.Length >= 1)
                            {
                                <div class="dropdown-list px-3 py-2 text-xs text-gray-400 italic">No crew members found for "@_pmtCrewSearch"</div>
                            }
                        }
                    }
                </div>

                @* ── Assignment ID (auto-resolved or manual fallback) ──────────── *@
                @if (_pmtSelectedEvent != null && _pmtSelectedCrew != null && _pmtSelectedVendor != null)
                {
                    @if (_pmtAssignmentLoading)
                    {
                        <div class="text-xs text-gray-400 italic">Resolving assignment…</div>
                    }
                    else if (_pmtResolvedAssignmentId.HasValue)
                    {
                        <div class="bg-green-50 border border-green-200 rounded-xl p-3 text-xs text-green-800">
                            ✅ Assignment found: <span class="font-mono">@_pmtResolvedAssignmentId.Value.ToString()[..8]…</span>
                        </div>
                    }
                    else
                    {
                        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-800">
                            ⚠️ No confirmed assignment found for this crew + event. Enter Assignment ID manually:
                        </div>
                        <div>
                            <label class="lbl">Assignment ID (manual)</label>
                            <input class="inp font-mono text-xs" placeholder="Paste Assignment GUID…"
                                   @bind="_pmtManualAssignmentId" />
                        </div>
                    }
                }

                @* ── Amount & notes ───────────────────────────────────────────── *@
                <div>
                    <label class="lbl">Agreed Amount (₹) <span class="text-red-400">*</span></label>
                    <input class="inp" type="number" min="1" step="1" @bind="_pmtAmount" />
                </div>
                <div>
                    <label class="lbl">Notes</label>
                    <textarea class="inp resize-none h-20" @bind="_pmtNotes"></textarea>
                </div>
            </div>
            <div class="flex justify-end gap-3 mt-6">
                <button class="btn-sec" @onclick="() => _showCreatePayment = false">Cancel</button>
                <button class="btn-primary" @onclick="CreatePayment"
                        disabled="@(_saving || _pmtSelectedEvent is null || _pmtSelectedEvent.Status != "Completed")">
                    @(_saving ? "Creating…" : "Create Payment")
                </button>
            </div>
        </div>
    </div>
}

@* ══════════════════ MODAL: Mark Paid ════════════════════════════════════════ *@
@if (_markPaidPayment != null)
{
    <div class="modal-bg" @onclick="() => _markPaidPayment = null">
        <div class="modal" @onclick:stopPropagation="true">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Mark as Paid</h3>
            <p class="text-sm text-gray-500 mb-5">
                Crew: <strong>@_markPaidPayment.CrewName</strong> · Agreed: ₹@_markPaidPayment.AgreedAmount.ToString("N0")
            </p>
            <div class="space-y-4">
                <div>
                    <label class="lbl">Paid Amount (₹)</label>
                    @* Phase D step 23: when there's an AgreedAmount on file, the
                       paid amount is locked to it — the server enforces this
                       too, so even if a user fiddles with DevTools the payment
                       lands at AgreedAmount. Show it as read-only with a hint. *@
                    @if (_markPaidPayment is not null && _markPaidPayment.AgreedAmount > 0m)
                    {
                        <input class="inp bg-gray-50" type="number" value="@_markPaidPayment.AgreedAmount" disabled />
                        <p class="text-[11px] text-gray-500 mt-1">Paid amount matches the agreed amount.</p>
                    }
                    else
                    {
                        <input class="inp" type="number" min="1" @bind="_paidAmount" />
                    }
                </div>
                <div>
                    <label class="lbl">Payment Method</label>
                    <select class="inp" @bind="_paidMethod">
                        <option value="">Select method…</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="UPI">UPI</option>
                        <option value="Cash">Cash</option>
                        <option value="Cheque">Cheque</option>
                    </select>
                </div>
                <div>
                    <label class="lbl">Transaction Reference (optional)</label>
                    <input class="inp" placeholder="UTR / Transaction ID" @bind="_transactionRef" />
                </div>
            </div>
            <div class="flex justify-end gap-3 mt-6">
                <button class="btn-sec" @onclick="() => _markPaidPayment = null">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmMarkPaid" disabled="@_saving">
                    @(_saving ? "Saving…" : "Confirm Payment")
                </button>
            </div>
        </div>
    </div>
}

@* ══════════════════ MODAL: New Payroll Batch (event-centric) ══════════════ *@
@if (_showCreateBatch)
{
    <div class="modal-bg" @onclick="() => _showCreateBatch = false">
        <div class="modal max-w-3xl" @onclick:stopPropagation="true">
            <h3 class="text-lg font-bold text-gray-900 mb-1">New Payroll Batch</h3>
            <p class="text-xs text-gray-500 mb-5">Pick a completed event, then enter the <b>per-crew rate</b> for each vendor and direct crew member. The total billed is automatically <code class="bg-gray-100 px-1 rounded">per-crew × attended</code>.</p>

            <div class="space-y-4">

                @* ── Event picker ─────────────────────────────────────────────── *@
                <div class="relative">
                    <label class="lbl">Event <span class="text-red-400">*</span></label>
                    @if (_batchSelectedEvent != null)
                    {
                        <div class="inp flex items-center justify-between bg-indigo-50 border-indigo-200">
                            <div>
                                <span class="font-semibold text-indigo-800 text-sm">@_batchSelectedEvent.Title</span>
                                <span class="text-xs text-gray-500 ml-2">@_batchSelectedEvent.Venue · @_batchSelectedEvent.Status</span>
                            </div>
                            <button class="text-gray-400 hover:text-red-500 ml-2" @onclick="ClearBatchEvent">✕</button>
                        </div>
                    }
                    else
                    {
                        <input class="inp" placeholder="Search event by name…"
                               @value="_batchEventSearch"
                               @onfocus="() => _batchEventDropOpen = true"
                               @oninput="OnBatchEventSearch" />
                        @if (_batchEventDropOpen && _batchEventResults.Count > 0)
                        {
                            <div class="dropdown-list">
                                @foreach (var e in _batchEventResults)
                                {
                                    <button class="dropdown-item" @onclick="() => SelectBatchEvent(e)">
                                        <span class="font-semibold">@e.Title</span>
                                        <span class="text-xs text-gray-400 ml-2">@e.Venue · @e.Status</span>
                                    </button>
                                }
                            </div>
                        }
                    }
                </div>

                @* ── Event status guard ──────────────────────────────────────── *@
                @if (_batchSelectedEvent != null && _batchSelectedEvent.Status != "Completed")
                {
                    <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-700">
                        ⚠ Payroll can only be created after the event is <strong>Completed</strong>. This event is currently <strong>@_batchSelectedEvent.Status</strong>.
                    </div>
                }

                @* ── Roster table ────────────────────────────────────────────── *@
                @if (_batchSelectedEvent != null && _batchSelectedEvent.Status == "Completed")
                {
                    @if (_rosterLoading)
                    {
                        <div class="text-xs text-gray-400 italic">Loading payable roster…</div>
                    }
                    else if (_roster is null)
                    {
                        <div class="text-xs text-red-500 italic">Could not load roster — check the event and try again.</div>
                    }
                    else if (_roster.VendorLines.Count == 0 && _roster.DirectCrewLines.Count == 0)
                    {
                        <div class="bg-amber-50 border border-amber-200 rounded-xl p-3 text-xs text-amber-700">
                            No attended crew were found for this event. Make sure crew checked in before creating a payroll batch.
                        </div>
                    }
                    else
                    {
                        <div class="border border-gray-200 rounded-xl overflow-hidden">
                            <table class="w-full text-sm">
                                <thead class="bg-gray-50 text-gray-600 text-xs uppercase tracking-wide">
                                    <tr>
                                        <th class="px-3 py-2 text-left">Type</th>
                                        <th class="px-3 py-2 text-left">Party</th>
                                        <th class="px-3 py-2 text-center">Attended</th>
                                        <th class="px-3 py-2 text-right">Per Crew (₹)</th>
                                        <th class="px-3 py-2 text-right">Line Total (₹)</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    @foreach (var l in _roster.VendorLines)
                                    {
                                        <tr class="@(l.AlreadyHasPayment ? "bg-gray-50 opacity-60" : "")">
                                            <td class="px-3 py-2"><span class="badge bg-indigo-100 text-indigo-800 text-[10px]">Vendor</span></td>
                                            <td class="px-3 py-2">
                                                <div class="font-medium text-gray-800">@l.PartyName</div>
                                                <div class="text-[11px] text-gray-400">@l.PartyMobile</div>
                                            </td>
                                            <td class="px-3 py-2 text-center text-gray-700">@l.AttendedCrewCount</td>
                                            <td class="px-3 py-2 text-right">
                                                @if (l.AlreadyHasPayment)
                                                {
                                                    <span class="text-[11px] text-gray-400 italic">Already paid out</span>
                                                }
                                                else
                                                {
                                                    <input type="number" min="0" step="1" class="inp w-32 text-right inline-block"
                                                           value="@GetLineAmount(l)"
                                                           @oninput="e => SetLineAmount(l, e.Value)" />
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-right">
                                                @if (l.AlreadyHasPayment)
                                                {
                                                    <span class="text-[11px] text-gray-400">—</span>
                                                }
                                                else
                                                {
                                                    var perCrew = GetLineAmount(l);
                                                    var lineTot = perCrew * l.AttendedCrewCount;
                                                    <span class="font-semibold text-gray-800">@(lineTot > 0 ? $"₹{lineTot:N0}" : "—")</span>
                                                    @if (perCrew > 0 && l.AttendedCrewCount > 1)
                                                    {
                                                        <div class="text-[10px] text-gray-400">@l.AttendedCrewCount × ₹@perCrew.ToString("N0")</div>
                                                    }
                                                }
                                            </td>
                                        </tr>
                                    }
                                    @foreach (var l in _roster.DirectCrewLines)
                                    {
                                        <tr class="@(l.AlreadyHasPayment ? "bg-gray-50 opacity-60" : "")">
                                            <td class="px-3 py-2"><span class="badge bg-purple-100 text-purple-800 text-[10px]">Direct Crew</span></td>
                                            <td class="px-3 py-2">
                                                <div class="font-medium text-gray-800">@l.PartyName</div>
                                                <div class="text-[11px] text-gray-400">@l.PartyMobile</div>
                                            </td>
                                            <td class="px-3 py-2 text-center text-gray-700">1</td>
                                            <td class="px-3 py-2 text-right">
                                                @if (l.AlreadyHasPayment)
                                                {
                                                    <span class="text-[11px] text-gray-400 italic">Already paid out</span>
                                                }
                                                else
                                                {
                                                    <input type="number" min="0" step="1" class="inp w-32 text-right inline-block"
                                                           value="@GetLineAmount(l)"
                                                           @oninput="e => SetLineAmount(l, e.Value)" />
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-right">
                                                @if (l.AlreadyHasPayment)
                                                {
                                                    <span class="text-[11px] text-gray-400">—</span>
                                                }
                                                else
                                                {
                                                    var perCrew = GetLineAmount(l);
                                                    <span class="font-semibold text-gray-800">@(perCrew > 0 ? $"₹{perCrew:N0}" : "—")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="bg-indigo-50 text-indigo-900 text-sm font-semibold">
                                    <tr>
                                        <td colspan="4" class="px-3 py-2 text-right">Total</td>
                                        <td class="px-3 py-2 text-right">₹@RosterTotal().ToString("N0")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        <div class="text-[11px] text-gray-500 italic">
                            Enter the <b>per-crew rate</b>. The Line Total (per-crew × attended) is what the manager owes the vendor (or pays the direct crew). Each crew payment row will be created with this exact agreed amount.
                        </div>
                    }
                }

                <div>
                    <label class="lbl">Notes</label>
                    <textarea class="inp resize-none h-16" @bind="_batchNotes" placeholder="Optional notes for this payroll batch"></textarea>
                </div>
            </div>

            <div class="flex justify-end gap-3 mt-6">
                <button class="btn-sec" @onclick="() => _showCreateBatch = false">Cancel</button>
                <button class="btn-primary" @onclick="CreatePayrollBatch"
                        disabled="@(_saving || _batchSelectedEvent is null
                                    || _batchSelectedEvent.Status != "Completed"
                                    || RosterTotal() <= 0)">
                    @(_saving ? "Creating…" : $"Create Batch (₹{RosterTotal():N0})")
                </button>
            </div>
        </div>
    </div>
}



<style>
    .tab-btn        { padding:.4rem 1rem;border-radius:.75rem;font-size:.85rem;font-weight:600;color:#6b7280;cursor:pointer;transition:all .15s; }
