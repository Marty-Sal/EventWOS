@page "/users"
@attribute [Authorize(Roles = "Admin,Manager")]
@inject IUserApiService UserApi


    @if (_accessDenied)
    {
        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div class="text-5xl mb-4">🔒</div>
            <h2 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h2>
            <p class="text-gray-500 text-sm">You don't have permission to view this page.<br/>Contact your Admin to request access.</p>
        </div>
        return;
    }

<PageTitle>Users — EventWOS</PageTitle>

<div class="space-y-5">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
        <h2 class="text-lg font-bold text-gray-800">User Management</h2>
        <div class="flex items-center gap-3 flex-wrap">
            <div class="relative">
                <input value="@_search" @oninput="OnSearchChanged"
                       type="search" placeholder="Search users…"
                       class="pl-9 pr-4 py-2 text-sm rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-indigo-500 w-64" />
                <span class="absolute left-3 top-2.5 text-gray-400 text-sm">🔍</span>
            </div>
            <AuthorizeView Roles="Admin">
                @if (_canWrite) { <button @onclick="() => _showCreate = true"
                        class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition shadow whitespace-nowrap">
                    + Add User
                </button> }
            </AuthorizeView>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        @if (_loading)
        {
            <div class="flex items-center justify-center py-16 text-gray-400">
                <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                </svg>
            </div>
        }
        else if (_users?.Items.Any() != true)
        {
            <div class="text-center py-16 text-gray-400">
                <p class="text-4xl mb-3">👥</p>
                <p class="text-sm">No users found.</p>
            </div>
        }
        else
        {
            <table class="min-w-full divide-y divide-gray-100">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">User</th>
                        <th class="px-6 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Role</th>
                        <th class="px-6 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Status</th>
                        <th class="px-6 py-3.5 text-left text-xs font-semibold uppercase tracking-wider text-gray-500">Joined</th>
                        <AuthorizeView Roles="Admin">
                            <th class="px-6 py-3.5 text-right text-xs font-semibold uppercase tracking-wider text-gray-500">Actions</th>
                        </AuthorizeView>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-50">
                    @foreach (var user in _users.Items)
                    {
                        var currentUser = user;
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-indigo-100 text-indigo-700 flex items-center justify-center text-sm font-bold flex-shrink-0">
                                        @currentUser.FullName.FirstOrDefault()
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-gray-800">@currentUser.FullName</p>
                                        <p class="text-xs text-gray-400">@currentUser.Mobile</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium @GetRoleBadgeClass(currentUser.Role)">
                                    @currentUser.Role
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-1.5 text-xs font-medium @GetStatusClass(currentUser.Status)">
                                    <span class="w-1.5 h-1.5 rounded-full @GetStatusDotClass(currentUser.Status)"></span>
                                    @currentUser.Status
                                </span>
                            </td>
                            <td class="px-6 py-4 text-xs text-gray-400">
                                @currentUser.CreatedAt.ToString("dd MMM yyyy")
                            </td>
                            <AuthorizeView Roles="Admin">
                                <td class="px-6 py-4 text-right">
                                    @if (currentUser.Status == "Active")
                                    {
                                        <button @onclick="@(() => ChangeStatusAsync(currentUser.Id, StatusSuspended))"
                                                class="text-xs text-red-600 hover:underline font-medium">Suspend</button>
                                    }
                                    else if (currentUser.Status == "Suspended")
                                    {
                                        <button @onclick="@(() => ChangeStatusAsync(currentUser.Id, StatusActive))"
                                                class="text-xs text-green-600 hover:underline font-medium">Activate</button>
                                    }
                                </td>
                            </AuthorizeView>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- Pagination -->
            @if (_users.TotalPages > 1)
            {
                <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100 bg-gray-50">
                    <p class="text-xs text-gray-500">
                        Showing @((_page - 1) * _pageSize + 1)–@(Math.Min(_page * _pageSize, _users.TotalCount)) of @_users.TotalCount
                    </p>
                    <div class="flex gap-2">
                        <button @onclick="PrevPage" disabled="@(_page <= 1)"
                                class="px-3 py-1.5 text-xs rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-indigo-50 transition-colors">
                            ← Prev
                        </button>
                        <button @onclick="NextPage" disabled="@(_page >= _users.TotalPages)"
                                class="px-3 py-1.5 text-xs rounded-lg border border-gray-200 disabled:opacity-40 hover:bg-indigo-50 transition-colors">
                            Next →
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (_showCreate)
{
    <div class="fixed inset-0 bg-black/40 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-6 space-y-4">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-gray-800">Add New User</h3>
                <button @onclick="CloseCreate" class="text-gray-400 hover:text-gray-600 text-xl leading-none">✕</button>
            </div>

            <!-- Role selector -->
            <div class="flex gap-2">
                <button @onclick='() => _createRole = "Vendor"'
                        class="flex-1 py-2.5 rounded-xl border text-sm font-medium transition @(_createRole == "Vendor" ? "bg-indigo-600 text-white border-indigo-600" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    🏢 Vendor
                </button>
                <button @onclick='() => _createRole = "Crew"'
                        class="flex-1 py-2.5 rounded-xl border text-sm font-medium transition @(_createRole == "Crew" ? "bg-indigo-600 text-white border-indigo-600" : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                    👷 Crew
                </button>
            </div>

            <div class="space-y-3">
                <input @bind="_createMobile" placeholder="Mobile (+91...)"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_createName" placeholder="Full Name"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <input @bind="_createEmail" type="email" placeholder="Email (optional)"
                       class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                @if (_createRole == "Vendor")
                {
                    <input @bind="_createBusiness" placeholder="Business Name (optional)"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                }
                @if (_createRole == "Crew")
                {
                    <input @bind="_createReferral" placeholder="Vendor Referral Code (optional)"
                           class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 uppercase" />
                }
            </div>

            @if (_createError is not null)
            {
                <p class="text-xs text-red-600 bg-red-50 rounded-lg px-3 py-2">⚠️ @_createError</p>
            }

            <div class="flex gap-3">
                <button @onclick="SubmitCreate" disabled="@(_creating || string.IsNullOrWhiteSpace(_createMobile) || string.IsNullOrWhiteSpace(_createName))"
                        class="flex-1 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 disabled:opacity-50 transition">
                    @(_creating ? "Creating…" : $"Create {_createRole}")
                </button>
                <button @onclick="CloseCreate"
                        class="px-5 py-2.5 rounded-xl border border-gray-200 text-sm hover:bg-gray-50 transition">Cancel</button>
            </div>
        </div>
    </div>
}


@code {

    private bool _accessDenied;
    private bool _canWrite;
    private const string StatusActive    = "Active";
    private const string StatusSuspended = "Suspended";

    private PagedResult<UserListItemDto>? _users;
    private bool _loading = true;
    private string _search = string.Empty;
    private int _page = 1;
    private const int _pageSize = 20;
    private System.Timers.Timer? _debounce;

    // Create user modal
    private bool _showCreate;
    private bool _creating;
    private string? _createError;
    private string _createRole   = "Vendor";
    private string _createMobile = string.Empty;
    private string _createName   = string.Empty;
    private string? _createEmail;
    private string? _createBusiness;
    private string? _createReferral;

    protected override async Task OnInitializedAsync()
    {
        // ── Permission gate ──────────────────────────────────────────────────────
        _accessDenied = !await PermGuard.CanAsync("users:read");
        if (_accessDenied) { StateHasChanged(); return; }
        _canWrite = await PermGuard.CanAsync("users:write");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _users = await UserApi.GetUsersAsync(_page, _pageSize, _search);
        _loading = false;
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        _debounce?.Stop();
        _debounce = new System.Timers.Timer(350);
        _debounce.Elapsed += async (_, _) =>
        {
            _page = 1;
            await InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
            _debounce.Stop();
        };
        _debounce.Start();
    }

    private async Task ChangeStatusAsync(Guid userId, string status)
    {
        await UserApi.ChangeStatusAsync(userId, status);
        await LoadAsync();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_users != null && _page < _users.TotalPages) { _page++; await LoadAsync(); } }

    private static string GetRoleBadgeClass(string role) => role switch
    {
        "Admin"   => "bg-purple-100 text-purple-700",
        "Manager" => "bg-blue-100 text-blue-700",
        "Vendor"  => "bg-amber-100 text-amber-700",
        _         => "bg-gray-100 text-gray-700"
    };

    private static string GetStatusClass(string status) => status switch
    {
        "Active"      => "text-green-700",
        "Suspended"   => "text-red-600",
        "Deactivated" => "text-gray-400",
        _             => "text-gray-500"
    };

    private static string GetStatusDotClass(string status) => status switch
    {
        "Active"    => "bg-green-500",
        "Suspended" => "bg-red-500",
        _           => "bg-gray-400"
    };
    private void CloseCreate()
    {
        _showCreate = false; _createError = null;
        _createMobile = _createName = string.Empty;
        _createEmail = _createBusiness = _createReferral = null;
    }

    private async Task SubmitCreate()
    {
        if (string.IsNullOrWhiteSpace(_createMobile) || string.IsNullOrWhiteSpace(_createName)) return;
        _creating = true; _createError = null;

        (bool ok, string? err) = _createRole == "Vendor"
            ? await UserApi.CreateVendorAsync(_createMobile, _createName, _createBusiness, _createEmail)
            : await UserApi.CreateCrewAsync(_createMobile, _createName, _createEmail, _createReferral);

        if (ok)
        {
            CloseCreate();
            await LoadAsync();
        }
        else { _createError = err; }
        _creating = false;
    }

}
