@page "/my-events"
@attribute [Authorize(Roles = "Crew,Vendor")]
@inject HttpClient Http
@inject AuthenticationStateProvider Auth
@inject IEventApiService EventApi
@inject IVendorApiService VendorApi
@inject ICrewGroupApiService GroupsApi
@inject NotificationHubService Hub
@implements IAsyncDisposable

<PageTitle>My Events — EventWOS</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">My Events</h2>
        <p class="text-sm text-gray-500 mt-0.5">@(_userRole == "Vendor" ? "Events you've been assigned to. Add crew to staff them." : "Events you have been assigned to.")</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">⚠️ @_error</div>
    }
    else if (_items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-5xl mb-4">📅</p>
            <p class="text-gray-700 font-semibold">No events yet</p>
            <p class="text-gray-400 text-sm mt-1">@(_userRole == "Vendor" ? "Events will appear when a Manager assigns you." : "You'll see events here once a vendor assigns you to one.")</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @foreach (var ev in _items)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex items-center gap-1.5 flex-wrap">
                            <h3 class="font-bold text-gray-800 leading-snug">@ev.Title</h3>
                            @if (_userRole == "Vendor" && _inviteBucketsByEventId.ContainsKey(ev.Id))
                            {
                                <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-100 text-amber-800 border border-amber-200 animate-pulse">
                                    ✉ Awaiting Response
                                </span>
                            }
                        </div>
                        <span class="shrink-0 px-2.5 py-0.5 rounded-full text-xs font-semibold @StatusColor(ev.Status)">
                            @ev.Status
                        </span>
                    </div>

                    <div class="flex items-center gap-1.5 text-sm text-gray-500">
                        <span>📍</span>
                        <span>@ev.Venue</span>
                    </div>

                    <div class="flex items-center gap-4 text-xs text-gray-400">
                        <span>🗓 @ev.StartAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                        <span>→ @ev.EndAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>

                    <div class="flex items-center justify-between text-xs text-gray-400 border-t border-gray-50 pt-3">
                        <span>👥 @ev.AssignedCrew / @ev.MaxCrew crew</span>
                        @if (_userRole != "Vendor"
                             && _myShiftRowsByEventId.TryGetValue(ev.Id, out var myRows)
                             && myRows.Any(r => r.ShiftId is not null))
                        {
                            @* Phase D step 12: one chip per shift the crew is on.
                               Falls through to legacy single-pill below if no shift
                               metadata exists (pre-multi-shift assignments). *@
                        }
                        else if (_myStatuses.TryGetValue(ev.Id, out var myStatus))
                        {
                            <span class="px-2 py-0.5 rounded-full font-medium @AssignmentStatusColor(myStatus)">
                                My status: @myStatus
                            </span>
                        }
                    </div>

                    @* Phase D step 12: per-shift chip row. Renders only when
                       crew has shift-attached assignments on this event. Each
                       chip shows scope · status · hours. *@
                    @if (_userRole != "Vendor"
                         && _myShiftRowsByEventId.TryGetValue(ev.Id, out var crewShiftRows)
                         && crewShiftRows.Any(r => r.ShiftId is not null))
                    {
                        <div class="flex flex-wrap gap-1.5 -mt-1">
                            @foreach (var r in crewShiftRows.Where(x => x.ShiftId is not null))
                            {
                                var chipLabel = CrewShiftChipLabel(r);
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold border @CrewShiftChipColor(r.Status)">
                                    🎯 @chipLabel
                                </span>
                            }
                        </div>
                    }

                    @* Vendor action: invite response → then assign crew *@
                    @if (_userRole == "Vendor" && ev.Status != "Completed" && ev.Status != "Cancelled")
                    {
                        // Phase D step 7: Accept and Assign coexist. A vendor
                        // can have BOTH:
                        //   (a) pending shift buckets they haven't decided on yet
                        //       (admin just added F&B after Saly already accepted Box Office)
                        //   (b) an accepted shift where they can now staff crew
                        // Render both side-by-side instead of either/or.
                        if (HasAcceptedInvite(ev.Id))
                        {
                            <button @onclick="() => OpenAssignPanel(ev)"
                                    class="mt-2 w-full px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold transition flex items-center justify-center gap-2">
                                <span>👥</span> Assign My Crew
                            </button>
                        }
                        if (_inviteBucketsByEventId.TryGetValue(ev.Id, out var pendingBuckets) && pendingBuckets.Count > 0)
                        {
                            var open = _expandedInviteEventId == ev.Id;
                            var totalSeats = pendingBuckets.Sum(b => b.Seats);
                            <div class="mt-2 relative">
                                <button @onclick="() => ToggleInvitePopover(ev.Id)"
                                        class="w-full px-4 py-2 rounded-xl bg-amber-100 hover:bg-amber-200 text-amber-900 text-sm font-semibold transition flex items-center justify-center gap-2 border border-amber-200">
                                    <span>✉️</span> Invited — Respond <span class="text-[11px] opacity-70">(@pendingBuckets.Count shift@(pendingBuckets.Count == 1 ? "" : "s"))</span>
                                </button>

                                @if (open)
                                {
                                    <div class="mt-2 bg-white rounded-xl border border-amber-200 shadow-sm p-3 space-y-3">
                                        <p class="text-xs text-gray-600">
                                            @if (pendingBuckets.Count == 1)
                                            {
                                                <span>The Manager has invited you to staff this event. Accept the shift to start adding your crew.</span>
                                            }
                                            else
                                            {
                                                <span>You've been invited for <b>@pendingBuckets.Count shifts</b>. Decide each one — Accept the ones you can staff, Reject the rest.</span>
                                            }
                                        </p>
                                        @foreach (var bucket in pendingBuckets)
                                        {
                                            var busy = _inviteBusyBucketKey == bucket.Key;
                                            <div class="bg-amber-50/60 border border-amber-100 rounded-lg p-2.5">
                                                <div class="flex items-center justify-between mb-1.5">
                                                    <p class="text-xs font-semibold text-amber-900">@bucket.ScopeLabel</p>
                                                    <span class="text-[10px] text-amber-800/70">@bucket.Seats seat@(bucket.Seats == 1 ? "" : "s")</span>
                                                </div>
                                                <div class="flex gap-2">
                                                    <button @onclick="() => AcceptInviteBucket(bucket)"
                                                            disabled="@busy"
                                                            class="flex-1 px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold disabled:opacity-50 transition">
                                                        @(busy ? "Accepting…" : "✓ Accept")
                                                    </button>
                                                    <button @onclick="() => OpenRejectInviteBucket(bucket)"
                                                            disabled="@busy"
                                                            class="flex-1 px-3 py-1.5 rounded-lg border border-rose-200 text-rose-600 hover:bg-rose-50 text-xs font-semibold disabled:opacity-50 transition">
                                                        ✕ Reject
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>

        @if (_total > _pageSize)
        {
            <div class="flex items-center justify-between text-sm text-gray-500">
                <span>Showing @_items.Count of @_total events</span>
                <div class="flex gap-2">
                    <button @onclick="PrevPage" disabled="@(_page <= 1)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">← Prev</button>
                    <span class="px-3 py-1.5 text-gray-700 font-medium">Page @_page</span>
                    <button @onclick="NextPage" disabled="@(_items.Count < _pageSize)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">Next →</button>
                </div>
            </div>
        }
    }
</div>

@* ─── Assign-Crew Modal ────────────────────────────────────────────────── *@
@if (_assignTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 flex items-center justify-center p-4" @onclick="CloseAssignPanel">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md max-h-[85vh] overflow-hidden flex flex-col" @onclick:stopPropagation="true">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <div>
                    <h3 class="font-bold text-gray-800">Assign Crew</h3>
                    <p class="text-xs text-gray-500 mt-0.5">@_assignTarget.Title</p>
                </div>
                <button @onclick="CloseAssignPanel" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">×</button>
            </div>

            <div class="p-5 flex-1 overflow-y-auto">
                @if (_assignError is not null)
                {
                    <div class="mb-3 p-3 bg-red-50 border border-red-100 rounded-lg text-red-600 text-xs">⚠️ @_assignError</div>
                }

                @* ── Phase C step 6: Shift picker ──────────────────────────
                   Hidden for single-shift events (the only option is the
                   default). For multi-shift events the vendor picks which
                   shift each invite/group lands on; the quota label updates
                   as they switch. If the vendor has NO allocations on ANY
                   shift the picker is empty — we surface a friendly
                   "ask your manager" banner instead of a broken control. *@
                @if (_shiftPickerOptions.Count == 0 && _assignTarget is not null)
                {
                    <div class="mb-4 p-3 bg-amber-50 border border-amber-200 rounded-xl text-xs text-amber-800">
                        ⚠️ You don't have a quota on any shift of this event yet.
                        Ask the event manager to allocate you a slot before inviting crew.
                    </div>
                }
                else
                {
                    @* Phase D step 11: per-shift summary cards. Each card shows
                       counts (invited / accepted / approved / final), free seats,
                       and a "Publish — Invite Active Crew" button that fills
                       remaining seats with this vendor's roster. For multi-shift
                       events the dropdown lets the vendor pick which shift each
                       INDIVIDUAL invite/group lands on; the Publish button
                       always targets ITS OWN card so the vendor can publish
                       shift-by-shift without re-picking. *@
                    @if (_shiftPickerOptions.Count > 1)
                    {
                        <div class="mb-3 p-3 rounded-xl border border-indigo-100 bg-white space-y-1.5">
                            <label class="block text-[11px] font-semibold text-gray-600 uppercase tracking-wide">
                                Default shift for new invites
                            </label>
                            <select @bind="_selectedShiftId"
                                    class="w-full px-3 py-2 rounded-lg border border-gray-200 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
                                @foreach (var opt in _shiftPickerOptions)
                                {
                                    <option value="@opt.ShiftId">@opt.Label</option>
                                }
                            </select>
                            <p class="text-[11px] text-gray-500 italic">
                                Individual "Invite" buttons below use this shift. Per-shift "Publish" buttons always use their own card.
                            </p>
                        </div>
                    }

                    <div class="mb-4 space-y-2">
                        @foreach (var opt in _shiftPickerOptions)
                        {
                            var sum   = opt.Summary;
                            var busy  = _publishingShiftId == opt.ShiftId;
                            var free  = sum.SeatsFree;
                            var canPublish = free > 0 && (_roster?.Count ?? 0) > 0 && !_invitingGroup;
                            <div class="rounded-xl border border-gray-200 bg-white p-3 space-y-2">
                                <div class="flex items-center justify-between gap-2">
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-800 truncate">@sum.ScopeName</p>
                                        <p class="text-[11px] text-gray-500">
                                            @sum.StartAt.ToLocalTime().ToString("MMM d HH:mm")
                                            @if (sum.EndAt is { } e) { <span> – @e.ToLocalTime().ToString("HH:mm")</span> }
                                            @if (sum.Enforced)
                                            {
                                                <span> · <b class="@(free > 0 ? "text-emerald-700" : "text-rose-600")">@free</b> of @sum.Quota free</span>
                                            }
                                            else
                                            {
                                                <span> · <b class="@(free > 0 ? "text-emerald-700" : "text-rose-600")">@free</b> of @sum.ShiftCapacity free (shared)</span>
                                            }
                                        </p>
                                    </div>
                                    @if (canPublish)
                                    {
                                        <button @onclick="() => PublishShift(opt)"
                                                disabled="@busy"
                                                class="shrink-0 px-3 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-semibold disabled:opacity-50 transition">
                                            @(busy ? "Publishing…" : "📣 Publish")
                                        </button>
                                    }
                                </div>

                                @{
                                    var placeholders = sum.Placeholders;
                                    var invited      = sum.Invited;
                                    var accepted     = sum.Accepted;
                                    var approved     = sum.Approved;
                                    var final        = sum.Final;
                                    var declined     = sum.Declined + sum.NoShow;
                                }
                                @if (placeholders + invited + accepted + approved + final + declined > 0)
                                {
                                    <div class="flex flex-wrap gap-1.5 text-[10px]">
                                        @if (placeholders > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 font-semibold">@placeholders placeholder@(placeholders == 1 ? "" : "s")</span>
                                        }
                                        @if (invited > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-semibold">@invited invited</span>
                                        }
                                        @if (accepted > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-semibold">@accepted accepted</span>
                                        }
                                        @if (approved > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-teal-100 text-teal-700 font-semibold">@approved awaiting manager</span>
                                        }
                                        @if (final > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700 font-semibold">@final confirmed</span>
                                        }
                                        @if (declined > 0)
                                        {
                                            <span class="px-2 py-0.5 rounded-full bg-rose-100 text-rose-700 font-semibold">@declined declined/no-show</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-[11px] text-gray-400 italic">No invites sent on this shift yet.</p>
                                }
                            </div>
                        }
                    </div>
                }
                @* ─── Invite a saved group ─────────────────────────────────────── *@
                @if (_groupsForPicker is not null && _groupsForPicker.Count > 0)
                {
                    <div class="mb-4 p-3 rounded-xl border border-indigo-100 bg-indigo-50/40 space-y-2">
                        <div class="flex items-center justify-between gap-2">
                            <div class="min-w-0">
                                <p class="text-xs font-bold text-indigo-700 uppercase tracking-wide">Invite a Group</p>
                                <p class="text-[11px] text-gray-500">Send invites to a whole saved team at once.</p>
                            </div>
                            <a href="/my-crew-groups" class="text-[11px] text-indigo-600 hover:underline shrink-0">Manage</a>
                        </div>

                        <div class="flex gap-2">
                            <select @bind="_selectedGroupId"
                                    class="flex-1 px-3 py-2 rounded-lg border border-indigo-200 bg-white text-sm focus:outline-none focus:border-indigo-400">
                                <option value="">Choose a group…</option>
                                @foreach (var g in _groupsForPicker)
                                {
                                    <option value="@g.Id">@g.Name (@g.MemberCount)</option>
                                }
                            </select>
                            <button @onclick="InviteGroup"
                                    disabled="@(_invitingGroup || string.IsNullOrEmpty(_selectedGroupId))"
                                    class="px-4 py-2 rounded-lg bg-indigo-600 text-white text-xs font-semibold hover:bg-indigo-700 disabled:opacity-50 transition">
                                @(_invitingGroup ? "Inviting…" : "Invite All")
                            </button>
                        </div>

                        @if (_groupInviteSummary is not null)
                        {
                            <div class="text-xs text-gray-700 bg-white border border-indigo-100 rounded-lg p-2.5 space-y-1">
                                <p>
                                    <span class="font-semibold text-green-700">Invited @_groupInviteSummary.Invited</span>
                                    @if (_groupInviteSummary.SkippedAlreadyOnEvent > 0)
                                    {
                                        <span class="text-gray-500"> · Skipped @_groupInviteSummary.SkippedAlreadyOnEvent (already on event)</span>
                                    }
                                    @if (_groupInviteSummary.Failed > 0)
                                    {
                                        <span class="text-red-600"> · Failed @_groupInviteSummary.Failed</span>
                                    }
                                </p>
                                @if (_groupInviteSummary.InvitedNames.Count > 0)
                                {
                                    <p class="text-[11px] text-gray-500">✓ @string.Join(", ", _groupInviteSummary.InvitedNames)</p>
                                }
                                @if (_groupInviteSummary.Failures.Count > 0)
                                {
                                    @foreach (var f in _groupInviteSummary.Failures)
                                    {
                                        <p class="text-[11px] text-red-600">⚠️ @f.FullName — @f.Reason</p>
                                    }
                                }
                            </div>
                        }
                    </div>

                    <div class="flex items-center gap-3 mb-3">
                        <div class="flex-1 h-px bg-gray-200"></div>
                        <span class="text-[10px] uppercase tracking-wider text-gray-400 font-semibold">or pick individually</span>
                        <div class="flex-1 h-px bg-gray-200"></div>
                    </div>
                }

                <input type="text" placeholder="Search your crew…"
                       @bind="_crewSearch" @bind:event="oninput"
                       class="w-full px-4 py-2 mb-3 rounded-xl border border-gray-200 focus:border-indigo-400 focus:outline-none text-sm" />

                @if (_roster is null)
                {
                    <p class="text-center text-gray-400 text-sm py-8">Loading roster…</p>
                }
                else if (FilteredRoster.Count == 0)
                {
                    <div class="text-center py-8">
                        <p class="text-3xl mb-2">🧑‍🤝‍🧑</p>
                        <p class="text-gray-700 text-sm font-medium">No crew in your roster yet</p>
                        <p class="text-gray-400 text-xs mt-1">Add crew first from the <a href="/crew" class="text-indigo-600 underline">My Crew</a> page.</p>
                    </div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var c in FilteredRoster)
                        {
                            var busy           = _assigningId == c.Id;
                            var existingStatus = _existingByCrewId.TryGetValue(c.Id, out var st) ? st : null;
                            var blocksReinvite = existingStatus is
                                "Invited" or "VendorApproved" or "PendingManagerApproval" or
                                "ManagerApproved" or "Confirmed" or "Attended";
                            var canReinvite    = existingStatus is "Declined" or "RejectedByVendor" or "RejectedByManager" or "NoShow";

                            <div class="flex items-center justify-between p-3 rounded-xl border border-gray-100 hover:border-indigo-200 hover:bg-indigo-50/30 transition">
                                <div>
                                    <p class="text-sm font-medium text-gray-800">@c.FullName</p>
                                    <p class="text-xs text-gray-400">@c.Mobile</p>
                                </div>

                                <div class="flex items-center gap-2">

                                @if (_justActedId == c.Id && _justActedLabel is not null)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded-md bg-green-50 text-green-700 text-[11px] font-semibold animate-pulse"
                                          title="@_justActedLabel">
                                        ✓ @_justActedLabel
                                    </span>
                                }

                                @if (blocksReinvite)
                                {
                                    <div class="flex items-center gap-2">
                                        <span class="px-3 py-1.5 rounded-lg text-xs font-semibold @AssignBadgeClass(existingStatus!)">
                                            @AssignBadgeLabel(existingStatus!)
                                        </span>
                                        @if (existingStatus == "Invited")
                                        {
                                            <button @onclick="() => RevokeCrewInvite(c)"
                                                    disabled="@(busy || _assigningId != Guid.Empty)"
                                                    class="px-2.5 py-1.5 rounded-lg text-xs font-semibold text-red-600 hover:bg-red-50 border border-red-200 disabled:opacity-50 transition"
                                                    title="Revoke this pending invitation">
                                                @(busy ? "…" : "✕ Revoke")
                                            </button>
                                        }
                                    </div>
                                }
                                else if (canReinvite)
                                {
                                    <button @onclick="() => AssignCrewMember(c)"
                                            disabled="@(busy || _assigningId != Guid.Empty)"
                                            class="px-3 py-1.5 rounded-lg bg-amber-500 hover:bg-amber-600 text-white text-xs font-semibold disabled:opacity-50 transition"
                                            title="Previously @existingStatus — invite again">
                                        @(busy ? "Assigning…" : "↻ Re-invite")
                                    </button>
                                }
                                else
                                {
                                    <button @onclick="() => AssignCrewMember(c)"
                                            disabled="@(busy || _assigningId != Guid.Empty)"
                                            class="px-3 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold disabled:opacity-50 transition">
                                        @(busy ? "Assigning…" : "Invite")
                                    </button>
                                }

                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-right">
                <button @onclick="CloseAssignPanel"
                        class="px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">Done</button>
            </div>
        </div>
    </div>
}

@* ─── Reject-Invitation Modal ──────────────────────────────────────────── *@
@if (_rejectInviteTargetBucket is not null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 flex items-center justify-center p-4" @onclick="CancelRejectInvite">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden" @onclick:stopPropagation="true">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-800">Reject Shift</h3>
                <p class="text-xs text-gray-500 mt-0.5">@_rejectInviteTargetBucket.ScopeLabel · @_rejectInviteTargetBucket.Seats seat@(_rejectInviteTargetBucket.Seats == 1 ? "" : "s")</p>
            </div>
            <div class="p-5 space-y-3">
                <label class="block text-xs font-medium text-gray-600">Why are you rejecting this shift?</label>
                <textarea @bind="_rejectInviteReason" rows="3" placeholder="e.g. Can't staff Box Office on that date"
                          class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:border-rose-400 focus:outline-none text-sm"></textarea>
                @if (_rejectInviteError is not null)
                {
                    <p class="text-xs text-rose-600">⚠️ @_rejectInviteError</p>
                }
                <p class="text-[11px] text-gray-500 italic">Rejecting this shift only — other shifts on this event stay pending until you decide on them.</p>
            </div>
            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex justify-end gap-2">
                <button @onclick="CancelRejectInvite"
                        class="px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">Cancel</button>
                <button @onclick="ConfirmRejectInvite"
                        disabled="@(_inviteBusyBucketKey != Guid.Empty)"
                        class="px-4 py-1.5 rounded-lg bg-rose-600 hover:bg-rose-700 text-white text-sm font-semibold disabled:opacity-50 transition">
                    @(_inviteBusyBucketKey == _rejectInviteTargetBucket.Key ? "Rejecting…" : "Reject Shift")
                </button>
            </div>
        </div>
    </div>
}

@code {
