    private IReadOnlyList<CrewLite> FilteredRoster
    {
        get
        {
            if (_roster is null) return Array.Empty<CrewLite>();
            if (string.IsNullOrWhiteSpace(_crewSearch)) return _roster;
            var s = _crewSearch.Trim().ToLowerInvariant();
            return _roster.Where(c => c.FullName.ToLower().Contains(s) || c.Mobile.Contains(s)).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                 ?? authState.User.FindFirst("role")?.Value;
        var sub = authState.User.FindFirst("sub")?.Value
               ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(sub, out var uid)) _userId = uid;

        // Per-event "X / Y assigned" counters change whenever any assignment moves.
        Hub.AssignmentInviteReceived  += OnAnyAssignmentChange;
        Hub.CrewAcceptedReceived      += OnAnyAssignmentChange;
        Hub.CrewDeclinedReceived      += OnAnyAssignmentChange;
        Hub.VendorApprovedReceived    += OnAnyAssignmentChange;
        Hub.VendorRejectedReceived    += OnAnyAssignmentChange;
        Hub.ManagerApprovedReceived   += OnAnyAssignmentChange;
        Hub.ManagerRejectedReceived   += OnAnyAssignmentChange;
        try { await Hub.StartAsync(); } catch { }

        await LoadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.AssignmentInviteReceived  -= OnAnyAssignmentChange;
        Hub.CrewAcceptedReceived      -= OnAnyAssignmentChange;
        Hub.CrewDeclinedReceived      -= OnAnyAssignmentChange;
        Hub.VendorApprovedReceived    -= OnAnyAssignmentChange;
        Hub.VendorRejectedReceived    -= OnAnyAssignmentChange;
        Hub.ManagerApprovedReceived   -= OnAnyAssignmentChange;
        Hub.ManagerRejectedReceived   -= OnAnyAssignmentChange;
        await ValueTask.CompletedTask;
    }

    private void OnAnyAssignmentChange(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            var evResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventListItemDto>>>(
                $"api/v1/events/my-events?page={_page}&pageSize={_pageSize}", JsonOpts);
            _items = evResult?.Data?.Items?.ToList() ?? new();
            _total = evResult?.Data?.TotalCount ?? 0;

            var assignmentEndpoint = _userRole == "Vendor"
                ? $"api/v1/events/vendor-assignments?page=1&pageSize=200"
                : $"api/v1/events/my-assignments?page=1&pageSize=200";

            var asgResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventAssignmentDto>>>(
                assignmentEndpoint, JsonOpts);
            var allRows = asgResult?.Data?.Items ?? new List<EventAssignmentDto>();
            _myStatuses = allRows
                .GroupBy(a => a.EventId)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(a => StatusRank(a.Status)).First().Status);

            // Phase D step 12: stash per-event rows for the crew-side card.
            // For vendors this dict is also built (cheap) but unused — the
            // vendor card already has its own pending/accepted breakdown.
            _myShiftRowsByEventId = allRows
                .Where(a => a.CrewId is not null)   // exclude vendor placeholder rows
                .GroupBy(a => a.EventId)
                .ToDictionary(g => g.Key, g => g.OrderBy(r => r.ShiftStartAt ?? DateTime.MaxValue)
                                                .ThenBy(r => r.ShiftScopeName ?? "")
                                                .ToList());

            if (_userRole == "Vendor")
            {
                // Placeholder rows where the Manager invited the vendor and they
