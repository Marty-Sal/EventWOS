                _inviteBucketsByEventId = _pendingInvites
                    .GroupBy(a => a.EventId)
                    .ToDictionary(
                        g => g.Key,
                        g => g.GroupBy(r => new { r.ShiftId, r.ShiftScopeName })
                              .OrderBy(b => b.Key.ShiftScopeName ?? "~unassigned",
                                       StringComparer.OrdinalIgnoreCase)
                              .Select(b => new InviteShiftBucket(
