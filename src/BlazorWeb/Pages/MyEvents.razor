        if (assignments?.Items is { Count: > 0 })
        {
            _existingByCrewId = assignments.Items
                .Where(a => a.CrewId.HasValue && a.VendorId == _userId)
                .GroupBy(a => a.CrewId!.Value)
                .ToDictionary(g => g.Key, g => g.OrderByDescending(a => a.CreatedAt).First().Status);
        }
        StateHasChanged();
    }

    private void CloseAssignPanel()
    {
        _assignTarget     = null;
        _roster           = null;
        _assignError      = null;
        _assignSuccess    = null;
        _existingByCrewId = new();
        _groupsForPicker  = null;
        _selectedGroupId  = "";
        _groupInviteSummary = null;
        _invitingGroup    = false;
    }

    private async Task AssignCrewMember(CrewLite c)
    {
        if (_assignTarget is null) return;
        _assignError = null;
        _assignSuccess = null;
        _assigningId = c.Id;
        StateHasChanged();

        var (ok, _, err) = await EventApi.VendorAssignCrewAsync(_assignTarget.Id, c.Id);
        _assigningId = Guid.Empty;
        if (ok)
        {
            // Status map flip → row renders the 'Invited' badge + ✕ Revoke
            // pair on the next StateHasChanged. Crew stays in _roster.
            _existingByCrewId[c.Id] = "Invited";
            // Brief inline ✓ pill on this row in place of the old top banner.
            _ = FlashJustActed(c.Id, "Invited");
            // Refresh event list to bump AssignedCrew count
            _ = LoadAsync();
            // Phase D step 11: refresh per-shift summary so chips/SeatsFree stay live.
            _ = RefreshShiftSummary();
        }
        else
        {
            _assignError = err ?? "Couldn't assign that crew member.";
        }
        StateHasChanged();
    }

    private async Task RevokeCrewInvite(CrewLite c)
    {
        if (_assignTarget is null) return;
        _assignError   = null;
        _assignSuccess = null;
        _assigningId   = c.Id;
        StateHasChanged();

        var (ok, err) = await EventApi.VendorRevokeCrewInviteAsync(_assignTarget.Id, c.Id);
        _assigningId = Guid.Empty;
        if (ok)
        {
            // Drop from the existing-status map so the row flips back to
            // a fresh 'Invite' button next render. Crew stays in _roster.
            _existingByCrewId.Remove(c.Id);
            // Brief inline ✓ pill confirming the revoke happened.
            _ = FlashJustActed(c.Id, "Revoked");
            // Refresh event list so AssignedCrew count drops by 1
            _ = LoadAsync();
            // Phase D step 11: refresh per-shift summary so chips/SeatsFree stay live.
            _ = RefreshShiftSummary();
        }
        else
        {
            _assignError = err ?? "Couldn't revoke that invitation.";
        }
        StateHasChanged();
    }

    private async Task InviteGroup()
    {
        if (_assignTarget is null) return;
        if (!Guid.TryParse(_selectedGroupId, out var gid)) return;

        _invitingGroup       = true;
        _assignError         = null;
        _assignSuccess       = null;
        _groupInviteSummary  = null;
        StateHasChanged();

        var (ok, result, err) = await GroupsApi.InviteGroupToEventAsync(_assignTarget.Id, gid, _selectedShiftId);
        _invitingGroup = false;

        if (!ok || result is null)
        {
            _assignError = err ?? "Couldn't invite that group.";
            StateHasChanged();
            return;
        }

        _groupInviteSummary = result;

        // Mark newly-invited crew so each row flips to the 'Invited'
        // badge + Revoke button. We keep the crew in _roster (parallel
        // to the per-crew Invite path) so the vendor sees consistent
        // state across the whole list — every row is always visible,
        // only its right-hand control changes.
        if (result.InvitedNames.Count > 0 && _roster is not null)
        {
            var invitedSet = result.InvitedNames.ToHashSet();
            foreach (var c in _roster)
            {
                if (invitedSet.Contains(c.FullName))
                    _existingByCrewId[c.Id] = "Invited";
            }
        }

        if (result.Invited > 0)
        {
            _ = LoadAsync();   // bump AssignedCrew count on event cards
            // Phase D step 11: refresh per-shift summary so chips/SeatsFree stay live.
            _ = RefreshShiftSummary();
        }

        StateHasChanged();
    }

    /// <summary>
    /// Phase D step 11: re-fetch the per-shift summary after any invite/
    /// revoke/publish so the count chips and SeatsFree headroom stay live.
    /// Cheap (one indexed query) and idempotent — safe to fire-and-forget
    /// after every mutation. Preserves the currently-selected shift.
    /// </summary>
    private async Task RefreshShiftSummary()
    {
        if (_assignTarget is null) return;
        var fresh = await EventApi.GetMyShiftSummaryAsync(_assignTarget.Id);
        if (_assignTarget is null) return;   // closed while awaiting
        var keep = _selectedShiftId;
        _shiftPickerOptions = (fresh ?? Array.Empty<VendorShiftSummaryDto>())
            .Select(x =>
            {
                var time = x.StartAt.ToLocalTime().ToString("MMM d HH:mm");
                var label = x.Enforced
                    ? $"{x.ScopeName} · {time} · {x.SeatsFree}/{x.Quota} free"
                    : $"{x.ScopeName} · {time} · {x.SeatsFree}/{x.ShiftCapacity} free (shared)";
                return new ShiftPickerOption(x.ShiftId, label, x);
            })
            .ToList();
        if (keep is not null && _shiftPickerOptions.Any(o => o.ShiftId == keep.Value))
            _selectedShiftId = keep;
        else
            _selectedShiftId = _shiftPickerOptions.FirstOrDefault()?.ShiftId;
        StateHasChanged();
    }

    /// <summary>
    /// Phase D step 11: "Publish" — fill the remaining seats on ONE shift
    /// by inviting every active crew member in the vendor's roster, up to
    /// the shift's free-seat count. Skips crew already on this event
    /// (placeholder/invited/accepted/approved/final all count). Stops at
    /// SeatsFree to never breach quota. Returns counts as an inline banner.
    ///
    /// Per-row endpoint reuse means audit, allocation-consumption, and
    /// notification side-effects all stay correct — we just batch the
    /// HTTP calls client-side. Server-side mass-invite is a future
    /// optimization if rosters get into the hundreds.
    /// </summary>
    private async Task PublishShift(ShiftPickerOption opt)
    {
        if (_assignTarget is null || _roster is null) return;
        if (_publishingShiftId is not null)  return;   // re-entrancy guard

        var free = opt.Summary.SeatsFree;
        if (free <= 0)
        {
            _assignError = $"No free seats on {opt.Summary.ScopeName} right now.";
            StateHasChanged();
            return;
        }

        // Skip crew already on this event in ANY active state. Declined /
        // rejected / no-show crew are eligible to be re-invited.
        var blockedStates = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        { "Invited", "VendorAccepted", "VendorApproved", "PendingManagerApproval",
          "ManagerApproved", "Confirmed", "Attended" };

        var eligible = _roster
            .Where(c => !_existingByCrewId.TryGetValue(c.Id, out var st) || !blockedStates.Contains(st))
            .Take(free)
            .ToList();

        if (eligible.Count == 0)
        {
            _assignError = $"No eligible crew to publish for {opt.Summary.ScopeName} — everyone in your roster is already on this event.";
            StateHasChanged();
            return;
        }

        _publishingShiftId = opt.ShiftId;
        _assignError       = null;
        _assignSuccess     = null;
        StateHasChanged();

        int invited = 0, failed = 0;
        string? firstError = null;
        foreach (var c in eligible)
        {
            var (ok, _, err) = await EventApi.VendorAssignCrewAsync(_assignTarget!.Id, c.Id, opt.ShiftId);
            if (ok)
            {
                _existingByCrewId[c.Id] = "Invited";
                invited++;
            }
            else
            {
                failed++;
                firstError ??= err;
            }
        }

        _publishingShiftId = null;

        if (invited > 0)
        {
            _assignSuccess = failed == 0
                ? $"📣 Published {invited} to {opt.Summary.ScopeName}."
                : $"📣 Published {invited} to {opt.Summary.ScopeName} ({failed} failed — {firstError}).";
            _ = LoadAsync();                  // bump event-card "Assigned X / Y"
            await RefreshShiftSummary();      // refresh count chips + SeatsFree
        }
        else
        {
            _assignError = $"Couldn't publish to {opt.Summary.ScopeName} — {firstError ?? "all invites failed"}.";
            StateHasChanged();
        }
    }

    /// <summary>
    /// Phase D step 12: build a compact chip label for ONE crew assignment
    /// shown on the Crew "My Events" cards. Format: "Box Office · Invited · 5h".
    /// </summary>
    private static string CrewShiftChipLabel(EventAssignmentDto a)
    {
        var parts = new List<string>();
        parts.Add(string.IsNullOrWhiteSpace(a.ShiftScopeName) ? "Shift" : a.ShiftScopeName!);
        parts.Add(ShortStatus(a.Status));
        if (a.ShiftStartAt is { } st && a.ShiftEndAt is { } et)
        {
            var hrs = (et.ToLocalTime() - st.ToLocalTime()).TotalHours;
            if (hrs > 0) parts.Add($"{hrs:0.#}h");
        }
        return string.Join(" · ", parts);
    }

    /// <summary>Phase D step 12: colour the chip by status — same palette as the
    /// global AssignmentStatusColor map, just borders + lighter bg for chips.</summary>
    private static string CrewShiftChipColor(string status) => status switch
