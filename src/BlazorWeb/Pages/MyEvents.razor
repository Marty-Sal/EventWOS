@page "/my-events"
@attribute [Authorize(Roles = "Crew,Vendor")]
@inject HttpClient Http
@inject AuthenticationStateProvider Auth

<PageTitle>My Events — EventWOS</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">My Events</h2>
        <p class="text-sm text-gray-500 mt-0.5">@(_userRole == "Vendor" ? "Events where your crew is assigned." : "Events you have been assigned to.")</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">⚠️ @_error</div>
    }
    else if (_items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-5xl mb-4">📅</p>
            <p class="text-gray-700 font-semibold">No events yet</p>
            <p class="text-gray-400 text-sm mt-1">@(_userRole == "Vendor" ? "Events will appear once you assign crew to them." : "You'll see events here once a vendor assigns you to one.")</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @foreach (var ev in _items)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between gap-2">
                        <h3 class="font-bold text-gray-800 leading-snug">@ev.Title</h3>
                        <span class="shrink-0 px-2.5 py-0.5 rounded-full text-xs font-semibold @StatusColor(ev.Status)">
                            @ev.Status
                        </span>
                    </div>

                    <div class="flex items-center gap-1.5 text-sm text-gray-500">
                        <span>📍</span>
                        <span>@ev.Venue</span>
                    </div>

                    <div class="flex items-center gap-4 text-xs text-gray-400">
                        <span>🗓 @ev.StartAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                        <span>→ @ev.EndAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>

                    <div class="flex items-center justify-between text-xs text-gray-400 border-t border-gray-50 pt-3">
                        <span>👥 @ev.AssignedCrew / @ev.MaxCrew crew</span>
                        @if (_myStatuses.TryGetValue(ev.Id, out var myStatus))
                        {
                            <span class="px-2 py-0.5 rounded-full font-medium @AssignmentStatusColor(myStatus)">
                                My status: @myStatus
                            </span>
                        }
                    </div>
                </div>
            }
        </div>

        @if (_total > _pageSize)
        {
            <div class="flex items-center justify-between text-sm text-gray-500">
                <span>Showing @_items.Count of @_total events</span>
                <div class="flex gap-2">
                    <button @onclick="PrevPage" disabled="@(_page <= 1)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">← Prev</button>
                    <span class="px-3 py-1.5 text-gray-700 font-medium">Page @_page</span>
                    <button @onclick="NextPage" disabled="@(_items.Count < _pageSize)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">Next →</button>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<EventListItemDto> _items = new();
    private Dictionary<Guid, string> _myStatuses = new();
    private bool _loading = true;
    private string? _error;
    private int _page = 1;
    private const int _pageSize = 20;
    private int _total;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    private string? _userRole;

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                 ?? authState.User.FindFirst("role")?.Value;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            // Load my events (backend now handles Vendor vs Crew via role)
            var evResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventListItemDto>>>(
                $"api/v1/events/my-events?page={_page}&pageSize={_pageSize}", JsonOpts);
            _items = evResult?.Data?.Items?.ToList() ?? new();
            _total = evResult?.Data?.TotalCount ?? 0;

            // Load assignment statuses — use role-appropriate endpoint
            var assignmentEndpoint = _userRole == "Vendor"
                ? $"api/v1/events/vendor-assignments?page=1&pageSize=200"
                : $"api/v1/events/my-assignments?page=1&pageSize=200";

            var asgResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventAssignmentDto>>>(
                assignmentEndpoint, JsonOpts);
            // For Vendor, multiple crew per event → same EventId repeated → GroupBy to deduplicate
            _myStatuses = (asgResult?.Data?.Items ?? new List<EventAssignmentDto>())
                .GroupBy(a => a.EventId)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(a => StatusRank(a.Status)).First().Status);
        }
        catch (Exception ex) { _error = "Could not load your events: " + ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    // Higher = more advanced in the workflow → shown as event badge
    private static int StatusRank(string s) => s switch
    {
        "ManagerApproved"          => 6,
        "PendingManagerApproval"   => 5,
        "VendorApproved"           => 4,
        "Invited"                  => 3,
        "Attended"                 => 7,
        "Declined"                 => 1,
        "RejectedByVendor"         => 1,
        "RejectedByManager"        => 1,
        _                          => 2
    };

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private static string StatusColor(string status) => status switch
    {
        "InProgress" => "bg-amber-100 text-amber-700",
        "Published"  => "bg-blue-100 text-blue-700",
        "Completed"  => "bg-green-100 text-green-700",
        "Cancelled"  => "bg-red-100 text-red-600",
        _            => "bg-gray-100 text-gray-600"
    };

    private static string AssignmentStatusColor(string status) => status switch
    {
        "Confirmed" => "bg-green-50 text-green-700 border border-green-100",
        "Invited"   => "bg-indigo-50 text-indigo-700 border border-indigo-100",
        "Declined"  => "bg-red-50 text-red-600 border border-red-100",
        "Attended"  => "bg-teal-50 text-teal-700 border border-teal-100",
        _           => "bg-gray-50 text-gray-600"
    };

    private sealed record EventListItemDto(Guid Id, string Title, string Venue,
        DateTime StartAt, DateTime EndAt, string Status, int MaxCrew, int AssignedCrew, DateTime CreatedAt);
    private sealed record EventAssignmentDto(Guid Id, Guid EventId, string EventTitle,
        Guid CrewId, string CrewName, string CrewMobile, Guid VendorId, string VendorName,
        string Status, DateTime? ConfirmedAt, DateTime? DeclinedAt, DateTime CreatedAt);
    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
