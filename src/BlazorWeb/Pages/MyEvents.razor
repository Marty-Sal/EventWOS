    // ─── Vendor: assign-crew panel ──────────────────────────────────────
    private async Task OpenAssignPanel(EventListItemDto ev)
    {
        _assignTarget   = ev;
        _assignError    = null;
        _assignSuccess  = null;
        _assigningId    = Guid.Empty;
        _crewSearch     = "";
        _roster         = null;
