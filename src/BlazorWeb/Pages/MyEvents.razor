    private Guid    _justActedId    = Guid.Empty;
    private string? _justActedLabel;
    private int     _justActedToken; // bumped on every flash so a late timer never wipes a newer flash

    private async Task FlashJustActed(Guid crewId, string label)
    {
        var myToken = ++_justActedToken;
        _justActedId    = crewId;
        _justActedLabel = label;
        StateHasChanged();

        try { await Task.Delay(2000); }
        catch { /* navigated away */ }

        // Only clear if no newer flash has started in the meantime
        if (_justActedToken == myToken)
