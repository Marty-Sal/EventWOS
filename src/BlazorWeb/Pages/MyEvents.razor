        foreach (var inv in bucket.Rows)
        {
            var (ok, err) = await EventApi.VendorRespondToInviteAsync(inv.Id, "accept", null);
            if (ok) accepted++;
            else    errors.Add(err ?? "unknown error");
        }
        _inviteBusyBucketKey = Guid.Empty;
        if (accepted > 0)
        {
            _expandedInviteEventId = Guid.Empty;
            await LoadAsync();
        }
        if (errors.Count > 0)
        {
            _error = $"Accepted {accepted} of {bucket.Rows.Count}. Issues: " +
                     string.Join("; ", errors.Distinct().Take(3));
