@page "/my-events"
@attribute [Authorize(Roles = "Crew,Vendor")]
@inject HttpClient Http
@inject AuthenticationStateProvider Auth
@inject IEventApiService EventApi
@inject IVendorApiService VendorApi
@inject NotificationHubService Hub
@implements IAsyncDisposable

<PageTitle>My Events — EventWOS</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">My Events</h2>
        <p class="text-sm text-gray-500 mt-0.5">@(_userRole == "Vendor" ? "Events you've been assigned to. Add crew to staff them." : "Events you have been assigned to.")</p>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">⚠️ @_error</div>
    }
    else if (_items.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-5xl mb-4">📅</p>
            <p class="text-gray-700 font-semibold">No events yet</p>
            <p class="text-gray-400 text-sm mt-1">@(_userRole == "Vendor" ? "Events will appear when a Manager assigns you." : "You'll see events here once a vendor assigns you to one.")</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            @foreach (var ev in _items)
            {
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex items-center gap-1.5 flex-wrap">
                            <h3 class="font-bold text-gray-800 leading-snug">@ev.Title</h3>
                            @if (_userRole == "Vendor" && _inviteByEventId.ContainsKey(ev.Id))
                            {
                                <span class="shrink-0 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-100 text-amber-800 border border-amber-200 animate-pulse">
                                    ✉ Awaiting Response
                                </span>
                            }
                        </div>
                        <span class="shrink-0 px-2.5 py-0.5 rounded-full text-xs font-semibold @StatusColor(ev.Status)">
                            @ev.Status
                        </span>
                    </div>

                    <div class="flex items-center gap-1.5 text-sm text-gray-500">
                        <span>📍</span>
                        <span>@ev.Venue</span>
                    </div>

                    <div class="flex items-center gap-4 text-xs text-gray-400">
                        <span>🗓 @ev.StartAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</span>
                        <span>→ @ev.EndAt.ToLocalTime().ToString("HH:mm")</span>
                    </div>

                    <div class="flex items-center justify-between text-xs text-gray-400 border-t border-gray-50 pt-3">
                        <span>👥 @ev.AssignedCrew / @ev.MaxCrew crew</span>
                        @if (_myStatuses.TryGetValue(ev.Id, out var myStatus))
                        {
                            <span class="px-2 py-0.5 rounded-full font-medium @AssignmentStatusColor(myStatus)">
                                My status: @myStatus
                            </span>
                        }
                    </div>

                    @* Vendor action: invite response → then assign crew *@
                    @if (_userRole == "Vendor" && ev.Status != "Completed" && ev.Status != "Cancelled")
                    {
                        if (HasAcceptedInvite(ev.Id))
                        {
                            <button @onclick="() => OpenAssignPanel(ev)"
                                    class="mt-2 w-full px-4 py-2 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold transition flex items-center justify-center gap-2">
                                <span>👥</span> Assign My Crew
                            </button>
                        }
                        else if (_inviteByEventId.TryGetValue(ev.Id, out var pendingInvite))
                        {
                            var inv = pendingInvite;
                            var open = _expandedInviteEventId == ev.Id;
                            <div class="mt-2 relative">
                                <button @onclick="() => ToggleInvitePopover(ev.Id)"
                                        class="w-full px-4 py-2 rounded-xl bg-amber-100 hover:bg-amber-200 text-amber-900 text-sm font-semibold transition flex items-center justify-center gap-2 border border-amber-200">
                                    <span>✉️</span> Invited — Respond
                                </button>

                                @if (open)
                                {
                                    <div class="mt-2 bg-white rounded-xl border border-amber-200 shadow-sm p-3 space-y-2">
                                        <p class="text-xs text-gray-600">The Manager has invited you to staff this event. Accept to start adding your crew.</p>
                                        <div class="flex gap-2">
                                            <button @onclick="() => AcceptInvite(inv)"
                                                    disabled="@(_inviteBusyId == inv.Id)"
                                                    class="flex-1 px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold disabled:opacity-50 transition">
                                                @(_inviteBusyId == inv.Id ? "Accepting…" : "✓ Accept")
                                            </button>
                                            <button @onclick="() => OpenRejectInvite(inv)"
                                                    disabled="@(_inviteBusyId == inv.Id)"
                                                    class="flex-1 px-3 py-1.5 rounded-lg border border-rose-200 text-rose-600 hover:bg-rose-50 text-xs font-semibold disabled:opacity-50 transition">
                                                ✕ Reject
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </div>

        @if (_total > _pageSize)
        {
            <div class="flex items-center justify-between text-sm text-gray-500">
                <span>Showing @_items.Count of @_total events</span>
                <div class="flex gap-2">
                    <button @onclick="PrevPage" disabled="@(_page <= 1)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">← Prev</button>
                    <span class="px-3 py-1.5 text-gray-700 font-medium">Page @_page</span>
                    <button @onclick="NextPage" disabled="@(_items.Count < _pageSize)"
                            class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 disabled:opacity-40 transition">Next →</button>
                </div>
            </div>
        }
    }
</div>

@* ─── Assign-Crew Modal ────────────────────────────────────────────────── *@
@if (_assignTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 flex items-center justify-center p-4" @onclick="CloseAssignPanel">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md max-h-[85vh] overflow-hidden flex flex-col" @onclick:stopPropagation="true">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <div>
                    <h3 class="font-bold text-gray-800">Assign Crew</h3>
                    <p class="text-xs text-gray-500 mt-0.5">@_assignTarget.Title</p>
                </div>
                <button @onclick="CloseAssignPanel" class="text-gray-400 hover:text-gray-700 text-2xl leading-none">×</button>
            </div>

            <div class="p-5 flex-1 overflow-y-auto">
                @if (_assignError is not null)
                {
                    <div class="mb-3 p-3 bg-red-50 border border-red-100 rounded-lg text-red-600 text-xs">⚠️ @_assignError</div>
                }
                @if (_assignSuccess is not null)
                {
                    <div class="mb-3 p-3 bg-green-50 border border-green-100 rounded-lg text-green-700 text-xs">✓ @_assignSuccess</div>
                }

                <input type="text" placeholder="Search your crew…"
                       @bind="_crewSearch" @bind:event="oninput"
                       class="w-full px-4 py-2 mb-3 rounded-xl border border-gray-200 focus:border-indigo-400 focus:outline-none text-sm" />

                @if (_roster is null)
                {
                    <p class="text-center text-gray-400 text-sm py-8">Loading roster…</p>
                }
                else if (FilteredRoster.Count == 0)
                {
                    <div class="text-center py-8">
                        <p class="text-3xl mb-2">🧑‍🤝‍🧑</p>
                        <p class="text-gray-700 text-sm font-medium">No crew in your roster yet</p>
                        <p class="text-gray-400 text-xs mt-1">Add crew first from the <a href="/crew" class="text-indigo-600 underline">My Crew</a> page.</p>
                    </div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var c in FilteredRoster)
                        {
                            var busy = _assigningId == c.Id;
                            <div class="flex items-center justify-between p-3 rounded-xl border border-gray-100 hover:border-indigo-200 hover:bg-indigo-50/30 transition">
                                <div>
                                    <p class="text-sm font-medium text-gray-800">@c.FullName</p>
                                    <p class="text-xs text-gray-400">@c.Mobile</p>
                                </div>
                                <button @onclick="() => AssignCrewMember(c)"
                                        disabled="@(busy || _assigningId != Guid.Empty)"
                                        class="px-3 py-1.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold disabled:opacity-50 transition">
                                    @(busy ? "Assigning…" : "Invite")
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-right">
                <button @onclick="CloseAssignPanel"
                        class="px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">Done</button>
            </div>
        </div>
    </div>
}

@* ─── Reject-Invitation Modal ──────────────────────────────────────────── *@
@if (_rejectInviteTarget is not null)
{
    <div class="fixed inset-0 bg-black/40 backdrop-blur-sm z-40 flex items-center justify-center p-4" @onclick="CancelRejectInvite">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm overflow-hidden" @onclick:stopPropagation="true">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-bold text-gray-800">Reject Invitation</h3>
                <p class="text-xs text-gray-500 mt-0.5">@_rejectInviteTarget.EventTitle</p>
            </div>
            <div class="p-5 space-y-3">
                <label class="block text-xs font-medium text-gray-600">Why are you rejecting this event?</label>
                <textarea @bind="_rejectInviteReason" rows="3" placeholder="e.g. Date conflict with another event"
                          class="w-full px-3 py-2 rounded-lg border border-gray-200 focus:border-rose-400 focus:outline-none text-sm"></textarea>
                @if (_rejectInviteError is not null)
                {
                    <p class="text-xs text-rose-600">⚠️ @_rejectInviteError</p>
                }
            </div>
            <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 flex justify-end gap-2">
                <button @onclick="CancelRejectInvite"
                        class="px-4 py-1.5 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">Cancel</button>
                <button @onclick="ConfirmRejectInvite"
                        disabled="@(_inviteBusyId != Guid.Empty)"
                        class="px-4 py-1.5 rounded-lg bg-rose-600 hover:bg-rose-700 text-white text-sm font-semibold disabled:opacity-50 transition">
                    @(_inviteBusyId == _rejectInviteTarget.Id ? "Rejecting…" : "Reject")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<EventListItemDto> _items = new();
    private Dictionary<Guid, string> _myStatuses = new();
    private bool _loading = true;
    private string? _error;
    private int _page = 1;
    private const int _pageSize = 20;
    private int _total;

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new() { PropertyNameCaseInsensitive = true };

    private string? _userRole;
    private Guid? _userId;

    // Vendor invitation state
    private List<EventAssignmentDto>            _pendingInvites    = new();
    private Dictionary<Guid, EventAssignmentDto> _inviteByEventId  = new();
    private HashSet<Guid>                        _acceptedEventIds = new();
    private Guid                                 _inviteBusyId     = Guid.Empty;
    private Guid                                 _expandedInviteEventId = Guid.Empty;
    private EventAssignmentDto?                  _rejectInviteTarget;
    private string                               _rejectInviteReason = "";
    private string?                              _rejectInviteError;

    // Assign panel state
    private EventListItemDto? _assignTarget;
    private List<CrewLite>? _roster;
    private string _crewSearch = "";
    private string? _assignError;
    private string? _assignSuccess;
    private Guid _assigningId = Guid.Empty;

    private IReadOnlyList<CrewLite> FilteredRoster
    {
        get
        {
            if (_roster is null) return Array.Empty<CrewLite>();
            if (string.IsNullOrWhiteSpace(_crewSearch)) return _roster;
            var s = _crewSearch.Trim().ToLowerInvariant();
            return _roster.Where(c => c.FullName.ToLower().Contains(s) || c.Mobile.Contains(s)).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await Auth.GetAuthenticationStateAsync();
        _userRole = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                 ?? authState.User.FindFirst("role")?.Value;
        var sub = authState.User.FindFirst("sub")?.Value
               ?? authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(sub, out var uid)) _userId = uid;

        // Per-event "X / Y assigned" counters change whenever any assignment moves.
        Hub.AssignmentInviteReceived  += OnAnyAssignmentChange;
        Hub.CrewAcceptedReceived      += OnAnyAssignmentChange;
        Hub.CrewDeclinedReceived      += OnAnyAssignmentChange;
        Hub.VendorApprovedReceived    += OnAnyAssignmentChange;
        Hub.VendorRejectedReceived    += OnAnyAssignmentChange;
        Hub.ManagerApprovedReceived   += OnAnyAssignmentChange;
        Hub.ManagerRejectedReceived   += OnAnyAssignmentChange;
        try { await Hub.StartAsync(); } catch { }

        await LoadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.AssignmentInviteReceived  -= OnAnyAssignmentChange;
        Hub.CrewAcceptedReceived      -= OnAnyAssignmentChange;
        Hub.CrewDeclinedReceived      -= OnAnyAssignmentChange;
        Hub.VendorApprovedReceived    -= OnAnyAssignmentChange;
        Hub.VendorRejectedReceived    -= OnAnyAssignmentChange;
        Hub.ManagerApprovedReceived   -= OnAnyAssignmentChange;
        Hub.ManagerRejectedReceived   -= OnAnyAssignmentChange;
        await ValueTask.CompletedTask;
    }

    private void OnAnyAssignmentChange(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null; StateHasChanged();
        try
        {
            var evResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventListItemDto>>>(
                $"api/v1/events/my-events?page={_page}&pageSize={_pageSize}", JsonOpts);
            _items = evResult?.Data?.Items?.ToList() ?? new();
            _total = evResult?.Data?.TotalCount ?? 0;

            var assignmentEndpoint = _userRole == "Vendor"
                ? $"api/v1/events/vendor-assignments?page=1&pageSize=200"
                : $"api/v1/events/my-assignments?page=1&pageSize=200";

            var asgResult = await Http.GetFromJsonAsync<ApiResult<PagedResult<EventAssignmentDto>>>(
                assignmentEndpoint, JsonOpts);
            var allRows = asgResult?.Data?.Items ?? new List<EventAssignmentDto>();
            _myStatuses = allRows
                .GroupBy(a => a.EventId)
                .ToDictionary(
                    g => g.Key,
                    g => g.OrderByDescending(a => StatusRank(a.Status)).First().Status);

            if (_userRole == "Vendor")
            {
                // Placeholder rows where the Manager invited the vendor and they
                // haven't responded yet. CrewId is null + Status is Invited.
                _pendingInvites = allRows
                    .Where(a => a.CrewId is null && a.Status == "Invited")
                    .ToList();

                // Keyed lookup so each event card can find its own pending invite.
                _inviteByEventId = _pendingInvites
                    .GroupBy(a => a.EventId)
                    .ToDictionary(g => g.Key, g => g.First());

                // Track which events have at least one vendor row past the
                // invitation stage — that's what gates "Assign My Crew".
                _acceptedEventIds = allRows
                    .Where(a => a.Status != "Invited"
                             && a.Status != "Declined"
                             && a.Status != "RejectedByVendor"
                             && a.Status != "RejectedByManager")
                    .Select(a => a.EventId)
                    .ToHashSet();
            }
        }
        catch (Exception ex) { _error = "Could not load your events: " + ex.Message; }
        finally { _loading = false; StateHasChanged(); }
    }

    // ─── Vendor: pending invitations ─────────────────────────────────────
    private bool HasAcceptedInvite(Guid eventId) => _acceptedEventIds.Contains(eventId);

    private void ToggleInvitePopover(Guid eventId)
    {
        _expandedInviteEventId = _expandedInviteEventId == eventId ? Guid.Empty : eventId;
    }

    private async Task AcceptInvite(EventAssignmentDto inv)
    {
        _inviteBusyId = inv.Id; StateHasChanged();
        var (ok, err) = await EventApi.VendorRespondToInviteAsync(inv.Id, "accept", null);
        _inviteBusyId = Guid.Empty;
        if (ok)
        {
            _expandedInviteEventId = Guid.Empty;
            await LoadAsync();
        }
        else    { _error = err ?? "Couldn't accept that invitation."; }
        StateHasChanged();
    }

    private void OpenRejectInvite(EventAssignmentDto inv)
    {
        _rejectInviteTarget = inv;
        _rejectInviteReason = "";
        _rejectInviteError = null;
        StateHasChanged();
    }

    private void CancelRejectInvite()
    {
        _rejectInviteTarget = null;
        _rejectInviteError = null;
    }

    private async Task ConfirmRejectInvite()
    {
        if (_rejectInviteTarget is null) return;
        if (string.IsNullOrWhiteSpace(_rejectInviteReason))
        {
            _rejectInviteError = "Please give a brief reason.";
            StateHasChanged();
            return;
        }
        _inviteBusyId = _rejectInviteTarget.Id;
        StateHasChanged();

        var (ok, err) = await EventApi.VendorRespondToInviteAsync(
            _rejectInviteTarget.Id, "reject", _rejectInviteReason.Trim());

        _inviteBusyId = Guid.Empty;
        if (ok)
        {
            _rejectInviteTarget = null;
            _rejectInviteReason = "";
            await LoadAsync();
        }
        else { _rejectInviteError = err ?? "Couldn't reject that invitation."; }
        StateHasChanged();
    }

    // ─── Vendor: assign-crew panel ──────────────────────────────────────
    private async Task OpenAssignPanel(EventListItemDto ev)
    {
        _assignTarget   = ev;
        _assignError    = null;
        _assignSuccess  = null;
        _assigningId    = Guid.Empty;
        _crewSearch     = "";
        _roster         = null;
        StateHasChanged();

        if (_userId is null) { _assignError = "Couldn't identify your account."; return; }

        var page = await VendorApi.GetCrewAsync(page: 1, vendorId: _userId);
        _roster = page?.Items?.Select(c => new CrewLite(c.Id, c.FullName, c.Mobile)).ToList() ?? new();
        StateHasChanged();
    }

    private void CloseAssignPanel()
    {
        _assignTarget = null;
        _roster       = null;
        _assignError  = null;
        _assignSuccess = null;
    }

    private async Task AssignCrewMember(CrewLite c)
    {
        if (_assignTarget is null) return;
        _assignError = null;
        _assignSuccess = null;
        _assigningId = c.Id;
        StateHasChanged();

        var (ok, _, err) = await EventApi.VendorAssignCrewAsync(_assignTarget.Id, c.Id);
        _assigningId = Guid.Empty;
        if (ok)
        {
            _assignSuccess = $"Invited {c.FullName}.";
            // Remove from roster list so vendor can't double-add
            _roster = _roster?.Where(x => x.Id != c.Id).ToList();
            // Refresh event list to bump AssignedCrew count
            _ = LoadAsync();
        }
        else
        {
            _assignError = err ?? "Couldn't assign that crew member.";
        }
        StateHasChanged();
    }

    // Higher = more advanced in the workflow → shown as event badge
    private static int StatusRank(string s) => s switch
    {
        "ManagerApproved"          => 6,
        "PendingManagerApproval"   => 5,
        "VendorApproved"           => 4,
        "Invited"                  => 3,
        "Attended"                 => 7,
        "Declined"                 => 1,
        "RejectedByVendor"         => 1,
        "RejectedByManager"        => 1,
        _                          => 2
    };

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { _page++; await LoadAsync(); }

    private static string StatusColor(string status) => status switch
    {
        "InProgress" => "bg-amber-100 text-amber-700",
        "Published"  => "bg-blue-100 text-blue-700",
        "Completed"  => "bg-green-100 text-green-700",
        "Cancelled"  => "bg-red-100 text-red-600",
        _            => "bg-gray-100 text-gray-600"
    };

    private static string AssignmentStatusColor(string status) => status switch
    {
        "Confirmed" => "bg-green-50 text-green-700 border border-green-100",
        "Invited"   => "bg-indigo-50 text-indigo-700 border border-indigo-100",
        "Declined"  => "bg-red-50 text-red-600 border border-red-100",
        "Attended"  => "bg-teal-50 text-teal-700 border border-teal-100",
        _           => "bg-gray-50 text-gray-600"
    };

    private sealed record EventListItemDto(Guid Id, string Title, string Venue,
        DateTime StartAt, DateTime EndAt, string Status, int MaxCrew, int AssignedCrew, DateTime CreatedAt);
    private sealed record EventAssignmentDto(Guid Id, Guid EventId, string EventTitle,
        Guid? CrewId, string? CrewName, string? CrewMobile, Guid? VendorId, string? VendorName,
        string Status, DateTime? ConfirmedAt, DateTime? DeclinedAt, DateTime CreatedAt);
    private sealed record PagedResult<T>(IReadOnlyList<T> Items, int TotalCount, int Page, int PageSize);
    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
    private sealed record CrewLite(Guid Id, string FullName, string Mobile);
}
