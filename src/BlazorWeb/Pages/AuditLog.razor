@page "/admin/audit"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject IUserApiService UserApi

<PageTitle>Audit Log — EventWOS</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between flex-wrap gap-3">
        <div>
            <h2 class="text-lg font-bold text-gray-800">Audit Log</h2>
            <p class="text-sm text-gray-500 mt-0.5">Immutable record of all system actions.</p>
        </div>
        <button @onclick="LoadAsync" disabled="@_loading"
                class="px-4 py-2 rounded-xl bg-indigo-600 text-white text-sm font-medium hover:bg-indigo-700 transition disabled:opacity-50">
            🔄 Refresh
        </button>
    </div>

    @if (_loading)
    {
        <div class="flex items-center justify-center py-16">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">
            ⚠️ @_error
        </div>
    }
    else if (_logs.Count == 0)
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-12 text-center">
            <p class="text-4xl mb-3">📋</p>
            <p class="text-gray-500 text-sm">No audit entries yet.</p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Time</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Action</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Entity</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actor</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">IP</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var log in _logs)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-5 py-3.5 text-gray-500 whitespace-nowrap text-xs">
                                @log.CreatedAt.ToLocalTime().ToString("dd MMM HH:mm:ss")
                            </td>
                            <td class="px-5 py-3.5">
                                <span class="px-2 py-0.5 rounded-full text-xs font-medium @GetActionColor(log.Action)">
                                    @log.Action
                                </span>
                            </td>
                            <td class="px-5 py-3.5 text-gray-700 font-mono text-xs">@log.EntityName</td>
                            <td class="px-5 py-3.5 text-gray-600 text-xs">@log.ActorMobile</td>
                            <td class="px-5 py-3.5 text-gray-400 text-xs font-mono">@(log.IpAddress ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<AuditLogDto> _logs = new();
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true; _error = null;
        try
        {
            var result = await Http.GetFromJsonAsync<ApiResult<List<AuditLogDto>>>(
                "api/v1/audit?page=1&pageSize=50",
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            _logs = result?.Data ?? new();
        }
        catch (Exception ex)
        {
            // If audit endpoint doesn't exist yet, show empty state gracefully
            _logs = new();
            if (!ex.Message.Contains("404"))
                _error = "Could not load audit logs: " + ex.Message;
        }
        finally { _loading = false; }
    }

    private static string GetActionColor(string action) => action switch
    {
        "Login"         => "bg-green-50 text-green-700 border border-green-100",
        "Logout"        => "bg-gray-100 text-gray-600",
        "StatusChanged" => "bg-amber-50 text-amber-700 border border-amber-100",
        "Deleted"       => "bg-red-50 text-red-600 border border-red-100",
        _               => "bg-indigo-50 text-indigo-700 border border-indigo-100"
    };

    private sealed record AuditLogDto(
        Guid Id, string Action, string EntityName, string ActorMobile,
        string? IpAddress, DateTime CreatedAt);

    private sealed record ApiResult<T>(bool Success, T? Data, string? Message);
}
