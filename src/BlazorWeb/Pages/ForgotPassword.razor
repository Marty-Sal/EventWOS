@page "/forgot-password"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav

<PageTitle>Forgot password — EventWOS</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-2xl p-8">
        <h1 class="text-xl font-bold text-gray-900 text-center">Forgot password?</h1>
        <p class="text-sm text-gray-500 text-center mt-1 mb-6">Enter your username, email, or mobile.</p>

        <div class="space-y-4">
            <input @bind="_input" @bind:event="oninput" type="text"
                   placeholder="alex / alex@x.com / +91 98…"
                   class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm" />

            @if (_error is not null)
            {
                <div class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-sm">@_error</div>
            }
            @if (_success is not null)
            {
                <div class="px-3 py-2 rounded-lg bg-emerald-50 text-emerald-800 text-sm space-y-1">
                    <div>@_success</div>
                    <a class="text-emerald-700 underline" href="@_resetLink">Continue →</a>
                </div>
            }

            <button type="button" @onclick="RequestAsync" disabled="@_loading"
                    class="w-full py-2.5 rounded-xl bg-indigo-600 text-white font-medium shadow-md hover:bg-indigo-700 disabled:opacity-50">
                @(_loading ? "Sending…" : "Send reset code")
            </button>

            <p class="text-center text-xs text-gray-500">
                <a href="/login" class="text-indigo-600 hover:underline">Back to sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private string _input = "";
    private string? _error, _success, _resetLink;
    private bool _loading;

    private async Task RequestAsync()
    {
        if (string.IsNullOrWhiteSpace(_input)) { _error = "Please enter something."; return; }
        _loading = true; _error = null;
        try
        {
            var result = await AuthApi.RequestPasswordResetAsync(_input.Trim());
            // Endpoint always returns success (no account enumeration).
            // If OtpRequestId is non-null an OTP went out; if it's null the
            // account didn't exist but we tell the user the same thing.
            var masked = result.Data?.MaskedDestination ?? "your registered contact";
            _success = $"If an account matches, a 6-digit code was sent to {masked}. It expires in 10 minutes.";
            // If we have an OtpRequestId, we can deep-link the next page.
            // (Otherwise we still show the link so non-existent accounts don't leak.)
            // The reset page asks for OtpRequestId + Mobile + Otp + new password.
            // For UX: pass the OtpRequestId + Mobile via the URL when available;
            // otherwise the reset page lets the user type them.
            if (result.Data?.OtpRequestId is Guid id)
                _resetLink = $"/reset-password?otpId={id}";
            else
                _resetLink = "/reset-password";
        }
        catch { _error = "Network error. Please try again."; }
        finally { _loading = false; }
    }
}
