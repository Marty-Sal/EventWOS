@page "/vendor-payments"
@attribute [Authorize(Roles = "Vendor")]
@inject IPaymentApiService PaymentApi
@inject NotificationHubService Hub
@implements IAsyncDisposable

<PageTitle>My Crew Payments — EventWOS</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-lg font-bold text-gray-800">My Crew Payments</h2>
        <p class="text-sm text-gray-500 mt-0.5">Track what your crew has earned across events.</p>
    </div>

    @* Summary cards.
       Phase D step 24: removed "Paid to Crew" / "Yet to Pay Out" totals
       from the vendor view — those numbers expose the per-crew breakdown
       which is the vendor's private business. Vendors now see what the
       organiser owes them and how many records, plus a count of how many
       payouts are still pending action on their side. *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
            <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">From Organiser</p>
            <p class="mt-1 text-xl font-bold text-gray-800">₹@FormatMoney(_totalAgreed)</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
            <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">Pending Payouts</p>
            <p class="mt-1 text-xl font-bold text-amber-600">@_pendingPayoutCount</p>
        </div>
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
            <p class="text-[11px] font-semibold uppercase tracking-widest text-gray-400">Records</p>
            <p class="mt-1 text-xl font-bold text-indigo-600">@_total</p>
        </div>
    </div>

    @* Status filter pills *@
    <div class="flex gap-2 flex-wrap">
        @foreach (var f in _filters)
        {
            <button @onclick="() => SetFilter(f.Key)"
                    class="px-4 py-1.5 rounded-full text-xs font-semibold transition
                           @(_status == f.Key ? "bg-indigo-600 text-white shadow" : "bg-white text-gray-500 border border-gray-200 hover:border-indigo-300")">
                @f.Label
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="flex justify-center py-20">
            <svg class="animate-spin h-8 w-8 text-indigo-500" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
            </svg>
        </div>
    }
    else if (_error is not null)
    {
        <div class="bg-red-50 border border-red-100 rounded-2xl p-5 text-red-600 text-sm">⚠️ @_error</div>
    }
    else if (!_items.Any())
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-16 text-center">
            <p class="text-5xl mb-3">💸</p>
            <p class="font-semibold text-gray-700 text-sm">No payment records yet</p>
            <p class="text-xs text-gray-400 mt-1">
                Manager creates these once crew is confirmed for an event.
            </p>
        </div>
    }
    else
    {
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-[11px] uppercase tracking-widest text-gray-500">
                    <tr>
                        <th class="text-left px-4 py-3 font-semibold">Crew</th>
                        <th class="text-left px-4 py-3 font-semibold">Event</th>
                        <th class="text-right px-4 py-3 font-semibold">From Organiser</th>
                        <th class="text-center px-4 py-3 font-semibold">Status</th>
                        <th class="text-left px-4 py-3 font-semibold">Paid On</th>
                        <th class="text-center px-4 py-3 font-semibold">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @foreach (var p in _items)
                    {
                        <tr class="hover:bg-gray-50/60">
                            <td class="px-4 py-3">
                                <p class="font-semibold text-gray-800">@p.CrewName</p>
                                <p class="text-[11px] text-gray-400">@p.CrewMobile</p>
                            </td>
                            <td class="px-4 py-3 text-gray-700">@p.EventTitle</td>
                            <td class="px-4 py-3 text-right font-mono text-gray-800">
                                @if (p.BatchTotal.HasValue && p.BatchTotal.Value > 0) {
                                    <span class="text-slate-700">₹@FormatMoney(p.BatchTotal.Value)</span>
                                } else {
                                    <span class="text-gray-300">—</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="@StatusPillClass(p.Status)">@p.Status</span>
                            </td>
                            <td class="px-4 py-3 text-[11px] text-gray-500">
                                @(p.PaidAt?.ToLocalTime().ToString("dd MMM yyyy") ?? "—")
                            </td>
                            <td class="px-4 py-3 text-center">
@{
                                    // Two flavours of Approved rows reach this cell:
                                    //   1. Batch-driven  — created as part of a PayrollBatch.
                                    //      The vendor can only mark paid AFTER the organiser
                                    //      disburses the batch (BatchStatus == "Disbursed").
                                    //   2. Direct        — created ad-hoc by a manager from
                                    //      the /payments "+ New Payment" form. No batch is
                                    //      involved; the vendor can mark paid immediately.
                                    //
                                    // BEFORE THE FIX: the cell only looked at BatchStatus and
                                    // hid the button for direct rows too — vendors saw
                                    // "Awaiting organiser disbursement" forever even though
                                    // there was nothing to disburse. Spotted via Sam Martin.
                                    var isBatchRow             = p.PayrollBatchId.HasValue;
                                    var batchDisbursed         = p.BatchStatus == "Disbursed";
                                    var canVendorMarkPaid      = p.Status == "Approved" && (!isBatchRow || batchDisbursed);
                                    var awaitingDisbursement   = p.Status == "Approved" && isBatchRow && !batchDisbursed;
                                }
                                @if (awaitingDisbursement)
                                {
                                    <span class="text-[11px] text-slate-500 italic">Awaiting organiser disbursement</span>
                                }
                                else if (canVendorMarkPaid)
                                {
                                    <button class="px-3 py-1 rounded-lg text-xs font-semibold bg-emerald-600 hover:bg-emerald-700 text-white"
                                            @onclick="() => OpenMarkPaid(p)">
                                        Mark Paid
                                    </button>
                                }
                                else if (p.Status == "Paid")
                                {
                                    @if (p.CrewAcknowledgment == "Received")
                                    {
                                        <span class="text-[11px] text-emerald-600 font-semibold">Crew ✓ Received</span>
                                    }
                                    else if (p.CrewAcknowledgment == "Pending")
                                    {
                                        <span class="text-[11px] text-amber-600 font-semibold" title="@p.AcknowledgmentNote">Crew reported Pending</span>
                                    }
                                    else
                                    {
                                        <span class="text-[11px] text-gray-400 italic">Awaiting crew ack</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-gray-300">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_total > _pageSize)
        {
            <div class="flex justify-center gap-2 pt-2">
                <button @onclick="PrevPage" disabled="@(_page <= 1)"
                        class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-white border border-gray-200 hover:border-indigo-300 disabled:opacity-40">
                    ← Prev
                </button>
                <span class="px-3 py-1.5 text-xs text-gray-500">Page @_page of @_pages</span>
                <button @onclick="NextPage" disabled="@(_page >= _pages)"
                        class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-white border border-gray-200 hover:border-indigo-300 disabled:opacity-40">
                    Next →
                </button>
            </div>
        }
    }
</div>



@* ── Confirm Disbursement modal ──────────────────────────────────────────────
   Phase D step 24: stripped-down modal. The vendor confirms they've paid
   the crew member; the amount is whatever was already agreed and is
   intentionally NOT shown — keeping the vendor's per-crew payout opaque
   to the manager view (the manager only sees that disbursement happened).

   The server stamps PaidAmount = AgreedAmount automatically (the locked-payout
   rule from step 23), so this just gathers the method + optional reference
   for the vendor's own records and the crew acknowledgement message.
   ────────────────────────────────────────────────────────────────────────── *@
@if (_markPaid is not null)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50" @onclick="() => _markPaid = null">
        <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md" @onclick:stopPropagation="true">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Confirm Payment to Crew</h3>
            <p class="text-xs text-gray-500 mb-4">@_markPaid.CrewName · @_markPaid.EventTitle</p>

            <div class="bg-indigo-50 border border-indigo-100 rounded-lg p-3 mb-4">
                <p class="text-[12px] text-indigo-800 leading-relaxed">
                    Confirming will notify @_markPaid.CrewName that you've paid them.
                    They'll be asked to acknowledge receipt on their end.
                </p>
            </div>

            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1">How did you pay?</label>
                    <select class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" @bind="_paidMethod">
                        <option value="">Select…</option>
                        <option value="UPI">UPI</option>
                        <option value="BankTransfer">Bank Transfer</option>
                        <option value="Cash">Cash</option>
                        <option value="Cheque">Cheque</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 mb-1">Reference number <span class="text-gray-400 font-normal">(optional, for your records)</span></label>
                    <input type="text" class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm" placeholder="UTR / txn id" @bind="_paidRef" />
                </div>
            </div>

            @if (_payError is not null)
            {
                <p class="text-xs text-red-500 mt-3">@_payError</p>
            }

            <div class="flex justify-end gap-2 mt-5">
                <button class="px-4 py-2 rounded-lg text-sm bg-gray-100 hover:bg-gray-200 text-gray-700" @onclick="() => _markPaid = null">Cancel</button>
                <button class="px-4 py-2 rounded-lg text-sm bg-emerald-600 hover:bg-emerald-700 text-white font-semibold disabled:opacity-50"
                        disabled="@_paySaving" @onclick="ConfirmMarkPaid">
                    @(_paySaving ? "Sending…" : "✓ Confirm & Notify Crew")
                </button>
            </div>
        </div>
    </div>
}

@code {

    // ── Confirm Disbursement modal state ─────────────────────────────────────
    // Phase D step 24: the modal no longer asks for or sends an amount. The
    // server locks PaidAmount to AgreedAmount (step-23 rule), so the vendor
    // just picks a method + an optional reference and confirms.
    private CrewPaymentDto? _markPaid;
    private string?         _paidMethod;
    private string?         _paidRef;
    private bool            _paySaving;
    private string?         _payError;

    private void OpenMarkPaid(CrewPaymentDto p)
    {
        _markPaid    = p;
        _paidMethod  = null;
        _paidRef     = null;
        _payError    = null;
    }

    private async Task ConfirmMarkPaid()
    {
        if (_markPaid is null) return;
        if (string.IsNullOrWhiteSpace(_paidMethod)) { _payError = "Select a payment method."; return; }

        _paySaving = true; _payError = null;
        // Send AgreedAmount as the paid amount; server will lock it anyway
        // when AgreedAmount > 0. For any legacy zero-amount rows we'd
        // otherwise need a separate UI flow — see admin /payments.
        var (ok, err) = await PaymentApi.UpdatePaymentStatusAsync(
            _markPaid.Id, "pay", _markPaid.AgreedAmount, _paidMethod, _paidRef);
        _paySaving = false;

        if (ok) { _markPaid = null; await LoadAsync(); }
        else _payError = err ?? "Failed to confirm.";
    }

    private List<CrewPaymentDto>     _items   = new();
    private bool                     _loading = true;
    private string?                  _error;
    private int                      _page = 1;
    private const int                _pageSize = 20;
    private int                      _total;
    private int                      _pages => Math.Max(1, (int)Math.Ceiling(_total / (double)_pageSize));
    private string?                  _status; // null = all

    private decimal _totalAgreed;
    // Phase D step 24: replaces _totalPaid/_totalPending — vendors don't see
    // per-crew amount totals, just how many payouts still need their action.
    private int     _pendingPayoutCount;

    private readonly List<(string? Key, string Label)> _filters = new()
    {
        (null,       "All"),
        ("pending",  "Pending"),
        ("approved", "Approved"),
        ("paid",     "Paid"),
        ("hold",     "On Hold"),
        ("rejected", "Rejected"),
    };

    protected override async Task OnInitializedAsync()
    {
        Hub.PaymentChangedReceived += OnPaymentMoved;
        try { await Hub.StartAsync(); } catch { }
        await LoadAsync();
    }

    public async ValueTask DisposeAsync()
    {
        Hub.PaymentChangedReceived -= OnPaymentMoved;
        await ValueTask.CompletedTask;
    }

    private void OnPaymentMoved(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error   = null;
        StateHasChanged();
        try
        {
            var result = await PaymentApi.GetPaymentsAsync(
                status: _status, page: _page, pageSize: _pageSize);

            if (result is null) { _error = "Couldn't load payments."; _items = new(); _total = 0; }
            else
            {
                _items = result.Items.ToList();
                _total = result.TotalCount;

                // Roll-up totals — when filtered, totals reflect the filter.
                // From Organiser is the sum of:
                //   • DISTINCT batch totals (one batch has many crew rows, count it once), PLUS
                //   • each direct (batch-less) row's AgreedAmount — the organiser owes the
                //     vendor that amount even though no batch was cut.
                var batchTotal  = _items.Where(p => p.PayrollBatchId.HasValue && p.BatchTotal.HasValue)
                                        .GroupBy(p => p.PayrollBatchId!.Value)
                                        .Sum(g => g.First().BatchTotal ?? 0m);
                var directTotal = _items.Where(p => !p.PayrollBatchId.HasValue)
                                        .Sum(p => p.AgreedAmount);
                _totalAgreed = batchTotal + directTotal;
                // Pending payouts = Approved rows the vendor can act on right now.
                // We mirror the "can mark paid" logic from the row:
                //   • Approved status
                //   • either direct (no batch) OR batch already Disbursed
                _pendingPayoutCount = _items.Count(p =>
                    p.Status.Equals("approved", StringComparison.OrdinalIgnoreCase)
                    && (!p.PayrollBatchId.HasValue || p.BatchStatus == "Disbursed"));
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        _loading = false;
        StateHasChanged();
    }

    private async Task SetFilter(string? key)
    {
        if (_status == key) return;
        _status = key;
        _page   = 1;
        await LoadAsync();
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await LoadAsync(); } }
    private async Task NextPage() { if (_page < _pages) { _page++; await LoadAsync(); } }

    private static string FormatMoney(decimal v) => v.ToString("N0", System.Globalization.CultureInfo.InvariantCulture);

    private static string StatusPillClass(string status) => status.ToLowerInvariant() switch
    {
        "paid"     => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200",
        "approved" => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-blue-50 text-blue-700 border border-blue-200",
        "pending"  => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-amber-50 text-amber-700 border border-amber-200",
        "hold"     => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-orange-50 text-orange-700 border border-orange-200",
        "rejected" => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-red-50 text-red-700 border border-red-200",
        _          => "px-2 py-0.5 rounded-full text-[11px] font-semibold bg-gray-100 text-gray-600 border border-gray-200",
    };
}
