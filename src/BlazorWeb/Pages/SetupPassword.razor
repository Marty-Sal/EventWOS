@page "/setup-password"
@layout EventWOS.BlazorWeb.Layout.EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Nav

<PageTitle>Set up your account — EventWOS</PageTitle>

@*
    Grandfathered first-login flow. The user logged in with the
    backfilled username (= their mobile) — they're forced through here
    to pick a real username + password. We send the OTP automatically
    on page load so the experience feels seamless.
*@

<div class="min-h-screen bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900 flex items-center justify-center p-4">
    <div class="w-full max-w-sm bg-white rounded-2xl shadow-2xl p-8 space-y-4">
        <h1 class="text-xl font-bold text-gray-900 text-center">Welcome back!</h1>
        <p class="text-sm text-gray-500 text-center">
            We're moving to password sign-in. Please set up your account — it takes 30 seconds.
        </p>

        @if (_otpInfo is not null)
        {
            <div class="px-3 py-2 rounded-lg bg-indigo-50 text-indigo-800 text-xs space-y-1">
                <div>Code sent to @_otpInfo</div>
                @if (_devOtp is not null)
                {
                    <div class="font-mono text-base bg-white border border-dashed border-indigo-300 rounded px-2 py-1 text-center text-indigo-900">
                        🛠 DEV OTP: <strong>@_devOtp</strong>
                    </div>
                    <div class="text-[10px] text-indigo-600">Dev mode — shown until SMS is production-ready.</div>
                }
            </div>
        }

        <Field Label="OTP code (from SMS)" Required="true">
            <input @bind="_otp" maxlength="6" class="@Css tracking-widest text-center" placeholder="••••••" />
        </Field>
        <Field Label="Choose a username" Required="true" Hint="3–50 chars · letters, numbers, . _ -">
            <input @bind="_newUsername" class="@Css" placeholder="alex.roy" autocomplete="username" />
        </Field>
        <Field Label="Choose a password" Required="true" Hint="Min 8 chars · 1 letter · 1 number">
            <input @bind="_password" type="password" class="@Css" placeholder="••••••••" autocomplete="new-password" />
        </Field>

        @if (_error is not null)
        {
            <div class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-sm">@_error</div>
        }

        <button type="button" @onclick="SubmitAsync" disabled="@_loading"
                class="w-full py-2.5 rounded-xl bg-indigo-600 text-white font-medium shadow-md hover:bg-indigo-700 disabled:opacity-50">
            @(_loading ? "Setting up…" : "Set up account")
        </button>

        <button type="button" @onclick="ResendAsync" disabled="@_loading"
                class="w-full text-center text-xs text-indigo-600 hover:underline">
            Didn't get a code? Resend
        </button>
    </div>
</div>

@code {
    private const string Css = "w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 text-sm";

    /// <summary>Mobile is passed from the login page after RequiresPasswordSetup=true.</summary>
    [SupplyParameterFromQuery(Name = "mobile")] public string? Mobile { get; set; }

    private string _otp = "", _newUsername = "", _password = "";
    private string? _otpInfo, _error, _devOtp;
    private Guid _otpRequestId;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Mobile))
        {
            _error = "Missing mobile number — please start again from the login page.";
            return;
        }
        await SendOtpAsync();
    }

    private async Task SendOtpAsync()
    {
        try
        {
            // We reuse the forgot-password OTP endpoint — same delivery channel,
            // same OtpRequest table, no need for a separate flow.
            var result = await AuthApi.RequestPasswordResetAsync(Mobile!);
            if (result.Data?.OtpRequestId is Guid id)
            {
                _otpRequestId = id;
                _otpInfo = result.Data.MaskedDestination;
                _devOtp  = result.Data.DevOtp;
            }
            else
            {
                _error = "We couldn't send a code to that number.";
            }
        }
        catch { _error = "Network error sending OTP."; }
    }

    private async Task ResendAsync()
    {
        _error = null;
        await SendOtpAsync();
    }

    private async Task SubmitAsync()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(Mobile) || _otpRequestId == Guid.Empty)
        { _error = "Please request a code first."; return; }
        if (string.IsNullOrWhiteSpace(_otp) || string.IsNullOrWhiteSpace(_newUsername) || string.IsNullOrWhiteSpace(_password))
        { _error = "Please fill in all fields."; return; }

        _loading = true;
        try
        {
            var req = new SetupPasswordRequest(_otpRequestId, Mobile!, _otp.Trim(), _newUsername.Trim(), _password);
            var result = await AuthApi.SetupPasswordAsync(req);
            if (!result.Success)
            {
                _error = result.Errors?.FirstOrDefault() ?? result.Message ?? "Setup failed.";
                return;
            }
            Nav.NavigateTo("/login?reason=password-updated", forceLoad: true);
        }
        catch { _error = "Network error."; }
        finally { _loading = false; }
    }
}
