@inherits LayoutComponentBase
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject AppAuthStateProvider AuthState
@inject IAuthApiService AuthApi
@inject NotificationHubService Hub
@inject IEventApiService EventApi
@inject HttpClient Http
@inject IJSRuntime JS

<div class="flex h-screen bg-gray-50 overflow-hidden">

    <!-- Mobile backdrop (only visible when the drawer is open on <md) -->
    @if (_sidebarOpen)
    {
        <div class="fixed inset-0 z-30 bg-black/50 md:hidden"
             @onclick="() => _sidebarOpen = false"></div>
    }

    <!--
        Sidebar
        On <md: fixed off-canvas drawer, slides in from the left when
                _sidebarOpen is true. z-40 to sit above the backdrop.
        On md+: normal in-flow flex sidebar (unchanged behaviour).
        The `transform` transition applies only on mobile — desktop
        rules override with `md:relative md:translate-x-0`.
    -->
    <aside class="@(_sidebarOpen ? "translate-x-0" : "-translate-x-full") md:translate-x-0
                  fixed inset-y-0 left-0 z-40 flex md:flex md:flex-shrink-0
                  md:relative md:inset-auto transition-transform duration-200 ease-in-out">
        <div class="flex flex-col w-64 bg-gray-900 text-white">
            <!-- Logo -->
            <div class="flex items-center h-16 px-6 border-b border-gray-700">
                <span class="text-xl font-bold tracking-tight text-white">⚡ EventWOS</span>
            </div>

            <!-- Nav Items -->
            <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto" @onclick="() => _sidebarOpen = false">

                @* Dashboard — everyone *@
                <NavItem Href="/dashboard" Icon="🏠" Label="Dashboard" />

                @* Events — permission-gated for Manager; always for Admin *@
                <AuthorizeView Roles="Admin">
                    <NavItem Href="/events" Icon="📅" Label="Events" />
                </AuthorizeView>
                <AuthorizeView Roles="Manager">
                    @if (_perms.Contains("events:read"))
                    {
                        <NavItem Href="/events" Icon="📅" Label="Events" />
                    }
                </AuthorizeView>
                <AuthorizeView Roles="Crew">
                    <NavItem Href="/my-events" Icon="📅" Label="My Events" />
                </AuthorizeView>
                <AuthorizeView Roles="Vendor">
                    <NavItem Href="/my-events" Icon="📅" Label="My Events" />
                </AuthorizeView>

                @* Admin always sees all nav *@
                <AuthorizeView Roles="Admin">
                    <NavItem Href="/users"    Icon="👥" Label="Users" />
                    <NavItem Href="/managers" Icon="👔" Label="Managers" />
                    <NavItem Href="/vendors"  Icon="🏢" Label="Vendors" />
                    <NavItem Href="/crew"     Icon="👷" Label="Crew" />
                    <NavItem Href="/attendance" Icon="📍" Label="Attendance" />
                    <NavItem Href="/payments" Icon="💰" Label="Payments" />
                    <NavItem Href="/sessions" Icon="🔌" Label="Sessions" />
                </AuthorizeView>

                @* Manager sees only links matching their permissions *@
                <AuthorizeView Roles="Manager">
                    @if (_perms.Contains("users:read"))    { <NavItem Href="/users"    Icon="👥" Label="Users" /> }
                    @if (_perms.Contains("vendors:read"))  { <NavItem Href="/vendors"  Icon="🏢" Label="Vendors" /> }
                    @if (_perms.Contains("crew:read"))     { <NavItem Href="/crew"     Icon="👷" Label="Crew" /> }
                    @if (_perms.Contains("attendance:read")) { <NavItem Href="/attendance" Icon="📍" Label="Attendance" /> }
                    @if (_perms.Contains("payments:read")) { <NavItem Href="/payments" Icon="💰" Label="Payments" /> }
                    @if (_perms.Contains("sessions:read")) { <NavItem Href="/sessions" Icon="🔌" Label="Sessions" /> }
                    @if (_perms.Contains("audit:read"))
                    {
                        <div class="pt-4 mt-4 border-t border-gray-700 space-y-1">
                            <NavItem Href="/admin/audit" Icon="📋" Label="Audit Log" />
                        </div>
                    }
                </AuthorizeView>

                @* Crew — My Assignments with pending badge + My Attendance *@
                <AuthorizeView Roles="Crew">
                    <div class="relative">
                        <NavItem Href="/my-assignments" Icon="📬" Label="My Assignments" />
                        @if (_pendingInvites > 0)
                        {
                            <span class="absolute top-1 right-2 w-4 h-4 rounded-full bg-red-500 text-white
                                         text-[9px] font-bold flex items-center justify-center pointer-events-none">
                                @_pendingInvites
                            </span>
                        }
                    </div>
                    <NavItem Href="/my-attendance" Icon="📍" Label="My Attendance" />
                    <NavItem Href="/my-payments"    Icon="💸" Label="My Payments" />
                </AuthorizeView>

                @* Vendor — My Crew + Crew Assignments + Attendance + Approvals + Payments + Report *@
                <AuthorizeView Roles="Vendor">
                    <NavItem Href="/crew"               Icon="👷" Label="My Crew" />
                    <NavItem Href="/my-crew-groups"     Icon="🧑‍🤝‍🧑" Label="Crew Groups" />
                    @* Attendance = Scan Check-In tab is the vendor's main
                       job on this page. Also gives them access to Logs
                       and per-event Summary for the crews they verified. *@
                    <NavItem Href="/attendance"          Icon="📍" Label="Attendance" />
                    <NavItem Href="/vendor-payments"     Icon="💸" Label="My Payments" />
                    <NavItem Href="/vendor-report"       Icon="📊" Label="My Report" />
                </AuthorizeView>

                @* Approval queue — every action role gets one entry.
                   Route is /approvals; the dispatcher page forwards to
                   the role-specific events page, then the tab header
                   lets the user switch to People. *@
                <AuthorizeView Roles="Admin,Manager,Vendor">
                    <div class="relative">
                        <NavItem Href="/approvals" Icon="✅" Label="Approval Queue" />
                        @if (_approvalCount > 0)
                        {
                            <span class="absolute top-1 right-2 px-1.5 py-0.5 rounded-full bg-red-500 text-white text-[10px] font-bold pointer-events-none">
                                @_approvalCount
                            </span>
                        }
                    </div>
                </AuthorizeView>

                @* Everyone *@
                <NavItem Href="/profile" Icon="👤" Label="My Profile" />

                @* Admin-only section *@
                <AuthorizeView Roles="Admin">
                    <div class="pt-4 mt-4 border-t border-gray-700 space-y-1">
                        <p class="px-2 text-xs font-semibold uppercase tracking-widest text-gray-500">Admin</p>
                        <NavItem Href="/admin/roles"          Icon="🛡️" Label="Roles" />
                        <NavItem Href="/admin/permissions"    Icon="🔑" Label="Permissions" />
                        <NavItem Href="/admin/scope-of-work"   Icon="🧰" Label="Scope of Work" />
                        <NavItem Href="/admin/audit"          Icon="📋" Label="Audit Log" />
                    </div>
                </AuthorizeView>

            </nav>

            <!-- User block -->
            <div class="p-4 border-t border-gray-700">
                <AuthorizeView>
                    <Authorized>
                        @{
                            var sbUsername = context.User.FindFirst("username")?.Value;
                            var sbMobile   = context.User.FindFirst("mobile")?.Value;
                            var sbRole     = context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                          ?? context.User.FindFirst("role")?.Value;
                            var sbInitialSource = !string.IsNullOrEmpty(sbUsername) ? sbUsername : (sbMobile ?? "?");
                        }
                        <div class="flex items-center gap-3">
                            <div class="w-9 h-9 rounded-full bg-indigo-600 flex items-center justify-center text-sm font-bold uppercase">
                                @sbInitialSource[0]
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="text-sm font-medium text-white truncate">
                                    @@@(sbUsername ?? sbMobile)
                                </p>
                                <p class="text-xs text-gray-400 truncate">
                                    @sbRole · @sbMobile
                                </p>
                            </div>
                            <button @onclick="LogoutAsync"
                                    class="text-gray-400 hover:text-white transition-colors" title="Logout">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5"
                                     viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd"
                                          d="M3 3a1 1 0 00-1 1v12a1 1 0 001 1h7a1 1 0 000-2H4V5h6a1 1 0 000-2H3zm11.707 4.293a1 1 0 010 1.414L13.414 10l1.293 1.293a1 1 0 01-1.414 1.414l-2-2a1 1 0 010-1.414l2-2a1 1 0 011.414 0z"
                                          clip-rule="evenodd" />
                                    <path d="M13 10a1 1 0 011-1h3a1 1 0 110 2h-3a1 1 0 01-1-1z" />
                                </svg>
                            </button>
                        </div>
                    </Authorized>
                </AuthorizeView>
            </div>

            <!-- Build version chip — reads /version.json emitted by the
                 Dockerfile. Tiny, unobtrusive, but decisive when
                 triaging cache/deploy questions ("is the user on the
                 fix?"). Shows short SHA + relative build time; the
                 title tooltip carries the full ISO timestamp. -->
            @if (!string.IsNullOrWhiteSpace(_buildSha))
            {
                <div class="px-4 pb-3 -mt-1">
                    <div class="text-[10px] text-gray-500 font-mono tracking-wide"
                         title="@($"Build {_buildSha} @ {_buildAt:u}")">
                        build @_buildSha · @_buildAgo
                    </div>
                </div>
            }
        </div>
    </aside>

    <!-- Main content -->
    <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
        <header class="flex items-center justify-between h-16 px-4 md:px-6 bg-white border-b border-gray-200 shadow-sm">
            <div class="flex items-center gap-3 min-w-0">
                <!-- Mobile hamburger — hidden on md+ where the sidebar is always visible -->
                <button type="button" @onclick="() => _sidebarOpen = !_sidebarOpen"
                        class="md:hidden -ml-1 p-2 rounded-md text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                        aria-label="Toggle navigation">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6"
                         fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="@(_sidebarOpen ? "M6 18L18 6M6 6l12 12" : "M4 6h16M4 12h16M4 18h16")" />
                    </svg>
                </button>
                <h1 class="text-lg font-semibold text-gray-800 truncate">@PageTitle</h1>
            </div>
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full @(Hub.IsConnected ? "bg-green-400" : "bg-red-400")"
                     title="@(Hub.IsConnected ? "Live" : "Reconnecting…")"></div>
                <span class="text-xs text-gray-400">@(Hub.IsConnected ? "Live" : "Reconnecting…")</span>
            </div>
        </header>
        <main class="flex-1 overflow-y-auto overflow-x-hidden p-4 md:p-6">@Body</main>
    </div>
</div>

<NotificationToast />
<PwaInstallBanner />

@code {
    private string PageTitle
    {
        get
        {
            if (Nav.Uri.Contains("/approvals", StringComparison.OrdinalIgnoreCase))
                return "Approval Queue";
            return Nav.Uri.Split('/').Last() switch
            {
        "dashboard"   => "Dashboard",
        "users"       => "Users",
        "managers"    => "Managers",
        "events"      => "Events",
        "vendors"     => "Vendors",
        "crew"        => "Crew",
        "payments"    => "Payments & Payroll",
        "sessions"    => "Sessions",
        "profile"     => "My Profile",
        "roles"       => "Roles",
        "permissions" => "Permissions",
        "audit"       => "Audit Log",
        "manager-approvals" => "Approval Queue",
        "approval-queue"    => "Registrations",
        "my-payments"       => "My Payments",
        "vendor-report"     => "My Performance Report",
                _             => "EventWOS"
            };
        }
    }

    // Mobile drawer visibility. Ignored on md+ where the sidebar is
    // permanently visible (Tailwind's md:translate-x-0 short-circuits us).
    private bool _sidebarOpen;

    // Current Manager's effective permissions (loaded from JWT claims)
    private HashSet<string> _perms = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        // Load permissions from JWT claims (already in auth state)
        var state = await AuthState.GetAuthenticationStateAsync();
        _perms = state.User
                      .FindAll(PermissionClaimTypes.Permission)
                      .Select(c => c.Value)
                      .ToHashSet(StringComparer.OrdinalIgnoreCase);

        await LoadPendingInvites();
        await LoadApprovalCountAsync();
        try { await Hub.StartAsync(); }
        catch { }
        Hub.ConnectionStateChanged += () => InvokeAsync(StateHasChanged);

        // Fire-and-forget the build-stamp fetch — never blocks layout render.
        _ = LoadBuildStampAsync();

        // ── Role-based permission priming ─────────────────────────
        // Fire OS-level prompts right after login (calm moment) instead
        // of mid-scan / mid-check-in (busy moment). One-shot per session
        // using sessionStorage so users aren't re-prompted on every page
        // load; browsers will silently return the cached answer anyway,
        // but this saves the async JS round-trip.
        //
        // Who needs what, post-crew-location refactor:
        //   * Vendors / Admins / Managers with attendance:verify
        //       → CAMERA only. They scan crew QR codes but no longer
        //         contribute location to the AttendanceRecord — the
        //         crew's own device is the source of truth now.
        //   * Crew
        //       → LOCATION only. Required for Check-In (server rejects
        //         missing coords) and Check-Out (same enforcement).
        //   * Everyone else (approvers, etc.) → nothing.
        _ = InvokeAsync(async () =>
        {
            try
            {
                var alreadyPrimed = await JS.InvokeAsync<string?>(
                    "sessionStorage.getItem", "eventwos_perms_primed");
                if (!string.IsNullOrEmpty(alreadyPrimed)) return;

                var role = state.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                           ?? state.User.FindFirst("role")?.Value;

                var wantsScan = role is "Vendor" or "Admin"
                                || (role is "Manager" && _perms.Contains("attendance:verify"));
                var wantsGeo  = role is "Crew";

                if (!wantsScan && !wantsGeo) return;

                await JS.InvokeVoidAsync(
                    "eventwosCheckin.primePermissions",
                    new { location = wantsGeo, camera = wantsScan });

                await JS.InvokeVoidAsync(
                    "sessionStorage.setItem", "eventwos_perms_primed", "1");
            }
            catch
            {
                // Prerender / JS not available / user closed the prompt.
                // Never a blocker — every downstream flow tolerates
                // missing permissions.
            }
        });

        // Keep sidebar counters live so the badge bumps without a refresh.
        Hub.AssignmentInviteReceived     += OnInviteCountChanged; // crew: new invite
        Hub.VendorApprovedReceived       += OnInviteCountChanged; // crew: state moved
        Hub.VendorRejectedReceived       += OnInviteCountChanged;
        Hub.ManagerApprovedReceived      += OnInviteCountChanged;
        Hub.ManagerRejectedReceived      += OnInviteCountChanged;
        Hub.PendingManagerApprovalReceived += OnApprovalCountChanged; // manager: queue grew
    }

    private void OnInviteCountChanged(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadPendingInvites(); StateHasChanged(); });
    }

    private void OnApprovalCountChanged(NotificationPayload payload)
    {
        _ = InvokeAsync(async () => { await LoadApprovalCountAsync(); StateHasChanged(); });
    }

    // ── Build version chip state ─────────────────────────────────────
    // Populated once at layout init from /version.json (produced by
    // the Dockerfile). Silent-fail on 404 or malformed JSON — the
    // chip just doesn't render, no user-visible error.
    private string  _buildSha = "";
    private DateTime _buildAt;
    private string  _buildAgo = "";

    private async Task LoadBuildStampAsync()
    {
        try
        {
            using var http = new HttpClient
            {
                BaseAddress = new Uri(Nav.BaseUri)
            };
            // Cache-bust so we always see the CURRENT deploy's version,
            // never a stale one the browser cached from a previous visit.
            var url = $"version.json?_cb={DateTimeOffset.UtcNow.ToUnixTimeSeconds()}";
            var v = await http.GetFromJsonAsync<VersionStamp>(url);
            if (v is not null && !string.IsNullOrWhiteSpace(v.Sha))
            {
                _buildSha = v.Sha;
                _buildAt  = v.BuiltAt;
                _buildAgo = FormatAgo(v.BuiltAt);
                StateHasChanged();
            }
        }
        catch
        {
            // No version.json (local dev, or Dockerfile skipped) — no chip.
        }
    }

    private static string FormatAgo(DateTime when)
    {
        var delta = DateTime.UtcNow - when.ToUniversalTime();
        if (delta.TotalSeconds < 60)    return "just now";
        if (delta.TotalMinutes < 60)    return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24)      return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 30)       return $"{(int)delta.TotalDays}d ago";
        return when.ToString("yyyy-MM-dd");
    }

    private sealed record VersionStamp(string Sha, DateTime BuiltAt);

    private async Task LogoutAsync()
    {
        var refresh = await AuthState.GetRefreshTokenAsync();
        await AuthApi.LogoutAsync(refresh ?? string.Empty);
        await Hub.StopAsync();
        Nav.NavigateTo("/login");
    }

    private static string GetInitials(string mobile) =>
        mobile.Length >= 2 ? mobile[^2..] : mobile;

    // ── Pending invite badge (Crew role) ──────────────────────────────────────
    private int _pendingInvites;
    private int _approvalCount;

    private async Task LoadPendingInvites()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var role      = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                         ?? authState.User.FindFirst("role")?.Value;
            if (role != "Crew") return;

            var data = await EventApi.GetMyAssignmentsAsync(page: 1);
            _pendingInvites = data?.Items.Count(a => a.Status == "Invited") ?? 0;
            StateHasChanged();
        }
        catch { }
    }

    // ── Sidebar approval-queue badge ─────────────────────────────────────────
    // Sums BOTH tabs of the unified /approvals page:
    //   • Events tab — Admin/Manager: assignments from vendors awaiting review
    //                  Vendor      : crew responses awaiting vendor review
    //   • People tab — Admin/Manager: pending vendor registrations
    //                  Vendor      : pending crew registrations under their code
    private async Task LoadApprovalCountAsync()
    {
        try
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var role      = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                         ?? authState.User.FindFirst("role")?.Value;
            if (role is not ("Admin" or "Manager" or "Vendor")) return;

            var jsonOpts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            int events = 0, people = 0;

            // ── Events tab count ──
            try
            {
                if (role is "Admin" or "Manager")
                {
                    var r = await Http.GetFromJsonAsync<ApprovalQueueResult>(
                        "api/v1/events/assignments/manager-queue?page=1&pageSize=1", jsonOpts);
                    events = r?.Data?.TotalCount ?? 0;
                }
                // Vendor events count is harder to fetch generically; the
                // VendorAssignments page sets _awaitingCount locally — for
                // the sidebar we just show People count when on Vendor.
            }
            catch { /* best-effort */ }

            // ── People tab count (role-scoped on backend) ──
            try
            {
                var r = await Http.GetFromJsonAsync<PeopleQueueResult>(
                    "api/v1/approval-queue", jsonOpts);
                people = (r?.Data?.VendorCount ?? 0) + (r?.Data?.CrewCount ?? 0);
            }
            catch { /* best-effort */ }

            _approvalCount = events + people;
            StateHasChanged();
        }
        catch { }
    }

    private sealed record ApprovalQueueResult(bool Success, ApprovalQueueData? Data);
    private sealed record ApprovalQueueData(int TotalCount);
    private sealed record PeopleQueueResult(bool Success, PeopleQueueData? Data);
    private sealed record PeopleQueueData(int VendorCount, int CrewCount);
}
