@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @* Distinguish between unauthenticated (redirect to login) and
                       authenticated-but-wrong-role (show 403 page). We check the
                       Identity directly to avoid a nested AuthorizeView context clash. *@
                    @if (context.User?.Identity?.IsAuthenticated == true)
                    {
                        <div class="flex h-screen flex-col items-center justify-center bg-gray-50 text-gray-500">
                            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-10 text-center max-w-sm">
                                <p class="text-5xl mb-4">🚫</p>
                                <h1 class="text-xl font-bold text-gray-800 mb-2">Access Denied</h1>
                                <p class="text-sm text-gray-500 mb-6">You don't have permission to view this page.</p>
                                <a href="/dashboard" class="px-5 py-2.5 rounded-xl bg-indigo-600 text-white text-sm font-semibold hover:bg-indigo-700 transition">
                                    ← Back to Dashboard
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <RedirectToLogin />
                    }
                </NotAuthorized>
                <Authorizing>
                    <div class="flex h-screen items-center justify-center">
                        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
                    </div>
                </Authorizing>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not Found — EventWOS</PageTitle>
            <div class="flex h-screen flex-col items-center justify-center text-gray-500">
                <h1 class="text-6xl font-bold text-gray-200">404</h1>
                <p class="mt-4 text-lg">Page not found.</p>
                <a href="/" class="mt-6 text-indigo-600 hover:underline">Go home</a>
            </div>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
