@*
    Shared password-login card used by /login/admin, /login/vendor, /login/crew.
    The parent page provides the Portal ("Admin" | "Vendor" | "Crew") and we
    drive everything from there — gradient color, "Sign up" link, etc.
*@
@inject IAuthApiService AuthApi
@inject NavigationManager Nav
@inject TokenRefreshService RefreshSvc

<div class="min-h-screen flex items-center justify-center p-4 @BackgroundClass">
    <div class="w-full max-w-sm">
        <div class="bg-white rounded-2xl shadow-2xl p-8">
            <!-- Logo -->
            <div class="text-center mb-6">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl @LogoClass text-2xl mb-3 shadow-lg">
                    @LogoEmoji
                </div>
                <h1 class="text-xl font-bold text-gray-900">EventWOS</h1>
                <p class="text-xs text-gray-500 mt-1">@Portal portal</p>
            </div>

            @if (_sessionMessage is not null)
            {
                <div class="mb-5 px-4 py-3 rounded-xl bg-amber-50 border border-amber-200 text-amber-800 text-xs flex items-start gap-2">
                    <span class="text-base leading-none">⚠️</span>
                    <span>@_sessionMessage</span>
                </div>
            }

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Username or Email</label>
                    <input @bind="_user" @bind:event="oninput"
                           @onkeydown="OnKey"
                           type="text"
                           autocomplete="username"
                           placeholder="yourname or you@example.com"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1.5">Password</label>
                    <input @bind="_password" @bind:event="oninput"
                           @onkeydown="OnKey"
                           type="password"
                           autocomplete="current-password"
                           placeholder="••••••••"
                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                </div>

                @if (_error is not null)
                {
                    <div class="px-3 py-2 rounded-lg bg-red-50 text-red-700 text-xs">@_error</div>
                }

                <button type="button" @onclick="LoginAsync" disabled="@_loading"
                        class="w-full py-3 rounded-xl text-white font-medium shadow-md transition disabled:opacity-50 @ButtonClass">
                    @if (_loading) { <span>Signing in…</span> } else { <span>Sign in</span> }
                </button>

                <div class="flex items-center justify-between text-xs pt-1">
                    <a href="/forgot-password" class="text-indigo-600 hover:underline">Forgot password?</a>
                    @if (Portal != "Admin")
                    {
                        <a href="@RegisterUrl" class="text-indigo-600 hover:underline">Sign up</a>
                    }
                </div>

                <div class="text-center pt-2">
                    <a href="/login/otp" class="text-xs text-gray-500 hover:text-indigo-600 hover:underline">
                        📱 Sign in with OTP instead
                    </a>
                </div>

                <p class="text-center text-xs text-gray-400 pt-3 border-t mt-3">
                    Wrong portal? <a href="/login" class="text-indigo-600 hover:underline">Choose another</a>
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Portal { get; set; } = "Admin";
    [Parameter] public string? ReturnUrl { get; set; }

    private string _user = string.Empty;
    private string _password = string.Empty;
    private string? _error;
    private string? _sessionMessage;
    private bool _loading;

    private string BackgroundClass => Portal switch
    {
        "Vendor" => "bg-gradient-to-br from-gray-900 via-emerald-950 to-gray-900",
        "Crew"   => "bg-gradient-to-br from-gray-900 via-orange-950 to-gray-900",
        _        => "bg-gradient-to-br from-gray-900 via-indigo-950 to-gray-900"
    };
    private string LogoClass => Portal switch
    {
        "Vendor" => "bg-emerald-600 text-white",
        "Crew"   => "bg-orange-600 text-white",
        _        => "bg-indigo-600 text-white"
    };
    private string ButtonClass => Portal switch
    {
        "Vendor" => "bg-emerald-600 hover:bg-emerald-700",
        "Crew"   => "bg-orange-600 hover:bg-orange-700",
        _        => "bg-indigo-600 hover:bg-indigo-700"
    };
    private string LogoEmoji => Portal switch
    {
        "Vendor" => "🏢",
        "Crew"   => "🧑‍🔧",
        _        => "⚡"
    };
    private string RegisterUrl => Portal == "Vendor" ? "/register/vendor" : "/register/crew";

    protected override void OnInitialized()
    {
        // Pick up ?reason= (carried over from the JWT 401 redirect handler).
        var uri = new Uri(Nav.Uri);
        if (string.IsNullOrEmpty(uri.Query)) return;
        string? reason = null;
        foreach (var part in uri.Query.TrimStart('?').Split('&'))
        {
            var eq = part.IndexOf('=');
            if (eq <= 0) continue;
            if (Uri.UnescapeDataString(part[..eq]).Equals("reason", StringComparison.OrdinalIgnoreCase))
            { reason = Uri.UnescapeDataString(part[(eq + 1)..]); break; }
        }
        _sessionMessage = reason?.ToLowerInvariant() switch
        {
            "revoked" or "session_revoked" => "Your session was ended by an administrator. Please sign in again.",
            "inactive"                     => "Your account is no longer active. Please contact your administrator.",
            "expired" or "session_expired" => "Your session has expired. Please sign in again.",
            "registered"                   => "Registration submitted. You'll be notified by email once an administrator approves your account.",
            "password-updated"             => "Password updated. Please sign in with your new password.",
            _                              => null
        };
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginAsync();
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_user) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please enter both your username (or email) and password.";
            return;
        }

        _loading = true; _error = null;
        try
        {
            var deviceId = Guid.NewGuid().ToString("N")[..16];
            var result = await AuthApi.LoginAsync(_user, _password, Portal, deviceId, "Web Browser");

            if (!result.Success)
            {
                _error = result.Errors?.FirstOrDefault() ?? result.Message ?? "Sign-in failed.";
                return;
            }

            // Setup-required short-circuit: grandfathered user, no token issued.
            if (result.Data?.RequiresPasswordSetup == true && !string.IsNullOrEmpty(result.Data.Mobile))
            {
                Nav.NavigateTo($"/setup-password?mobile={Uri.EscapeDataString(result.Data.Mobile)}");
                return;
            }

            // Successful login. Force-load so AppAuthStateProvider re-reads localStorage.
            RefreshSvc.Start();
            var raw = ReturnUrl is not null ? Uri.UnescapeDataString(ReturnUrl) : "/dashboard";
            var isLoopback = raw.Contains("/login", StringComparison.OrdinalIgnoreCase)
                          || raw == "/" || string.IsNullOrWhiteSpace(raw);
            var target = isLoopback ? "/dashboard" : raw;
            Nav.NavigateTo(target, forceLoad: true);
        }
        catch
        {
            _error = "Network error. Please try again.";
        }
        finally { _loading = false; }
    }
}
