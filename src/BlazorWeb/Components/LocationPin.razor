@*
    LocationPin — renders the split AttendanceRecord location fields
    (LocationAddress + LocationCoords) as a compact "📍 Address" link
    that opens the exact coordinates on Google Maps.

    Contract (from the two API endpoints that write the row):

      Address          Coords              Render
      ───────────────  ──────────────────  ──────────────────────────────
      "Airoli, ..."    "19.157020,73.02"   📍 Airoli, ... → maps?q=coords
      null             "19.157020,73.02"   📍 View on map → maps?q=coords
      "Airoli, ..."    null                📍 Airoli, ... (no link)
      null             null                — (em-dash)

    The middle two states occur when Nominatim was slow/rate-limited
    (address null; coords present) or, in rare cases, when a legacy
    row was hand-edited (address present; coords absent). Both must
    render sensibly.
*@

@if (string.IsNullOrWhiteSpace(Address) && string.IsNullOrWhiteSpace(Coords))
{
    <span class="text-gray-400">—</span>
}
else if (!string.IsNullOrWhiteSpace(Coords))
{
    var label = string.IsNullOrWhiteSpace(Address) ? "View on map" : Address;
    var mapsUrl = $"https://www.google.com/maps?q={Coords}";
    <a href="@mapsUrl" target="_blank" rel="noopener"
       class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 hover:underline"
       title="@Coords">
        <span>📍</span>
        <span>@label</span>
    </a>
}
else
{
    @* Coords absent — no map link, just the address text with the pin. *@
    <span class="inline-flex items-center gap-1 text-gray-600" title="No coordinates recorded">
        <span>📍</span>
        <span>@Address</span>
    </span>
}

@code {
    [Parameter] public string? Address { get; set; }
    [Parameter] public string? Coords  { get; set; }
}
