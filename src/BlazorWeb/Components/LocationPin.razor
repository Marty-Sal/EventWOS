@*
    LocationPin — renders an AttendanceRecord.Location value as a
    tiny pin link that opens Google Maps in a new tab, plus the
    reverse-geocoded label (if any).

    Storage format (produced by wwwroot/js/checkin.js getPosition):
      • "lat,lng|Short Address"   → pin link + label
      • "lat,lng"                 → pin link, no label (legacy rows)
      • "unavailable:<code>"      → em-dash (permission denied etc.)
      • null / empty              → em-dash

    Keeping the parsing entirely on the client means we never touched
    the schema — Location stays a plain string column, and any old
    "lat,lng" rows written before this commit still render a working
    pin.
*@

@if (string.IsNullOrWhiteSpace(Value) || Value.StartsWith("unavailable"))
{
    <span class="text-gray-400">—</span>
}
else
{
    var parts    = Value.Split(''|'', 2);
    var coords   = parts[0];
    var label    = parts.Length > 1 ? parts[1] : null;
    var mapsUrl  = $"https://www.google.com/maps?q={coords}";

    <a href="@mapsUrl" target="_blank" rel="noopener"
       class="inline-flex items-center gap-1 text-indigo-600 hover:text-indigo-800 hover:underline"
       title="@coords">
        <span>📍</span>
        <span>@(label ?? "View on map")</span>
    </a>
}

@code {
    [Parameter] public string? Value { get; set; }
}
